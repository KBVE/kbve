#!/usr/bin/env sh
# Git LFS upload — uploads any LFS-tracked blobs (currently the Unity
# native plugins under apps/rareicon/unity-rareicon/Assets/Plugins/**)
# to the configured endpoint at .lfsconfig (Forgejo KBVE/rareicon).
#
# No-op for repos / refs that don't have any LFS-tracked content,
# so contributors who only touch non-Unity code see zero overhead.
command -v git-lfs >/dev/null 2>&1 || { echo >&2 "\nThis repository is configured for Git LFS but 'git-lfs' was not found on your path. If you no longer wish to use Git LFS, remove this hook by deleting the 'pre-push' file in the hooks directory (set by 'core.hookspath'; usually '.git/hooks').\n"; exit 2; }
git lfs pre-push "$@"
