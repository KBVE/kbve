{
	"name": "axum-rareicon",
	"$schema": "../../../node_modules/nx/schemas/project-schema.json",
	"projectType": "application",
	"sourceRoot": "apps/rareicon/axum-rareicon/src",
	"tags": [],
	"targets": {
		"build": {
			"executor": "nx:run-commands",
			"options": {
				"commands": ["cargo build --release -p axum-rareicon"],
				"cwd": "{workspaceRoot}"
			}
		},
		"test": {
			"executor": "nx:run-commands",
			"options": {
				"commands": ["cargo test -p axum-rareicon"],
				"cwd": "{workspaceRoot}"
			},
			"cache": true
		},
		"lint": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"cargo clippy -p axum-rareicon --all-targets -- -D warnings"
				],
				"cwd": "{workspaceRoot}"
			},
			"cache": true
		},
		"container": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"docker buildx build --platform linux/amd64 -f apps/rareicon/axum-rareicon/Dockerfile -t kbve/rareicon:latest --load ."
				],
				"cwd": "{workspaceRoot}"
			}
		}
	}
}
