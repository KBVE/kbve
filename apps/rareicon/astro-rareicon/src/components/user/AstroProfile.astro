---
import ReactProfileCard from './ReactProfileCard';
---

<div class="ri-profile">
	<ReactProfileCard client:load />
</div>

<style is:global>
	.ri-profile {
		max-width: 600px;
		margin: 2rem auto;
		padding: 2rem;
		min-height: 200px;
		border: 1px solid var(--sl-color-hairline-light);
		border-radius: 4px;
		background: var(--sl-color-gray-6);
	}

	.ri-profile-guest {
		text-align: center;
		padding: 3rem 1rem;
		color: var(--sl-color-gray-2);
	}

	.ri-profile-guest p {
		margin-bottom: 1.5rem;
		font-size: 1.1rem;
	}

	.ri-profile-signin-btn {
		display: inline-flex;
		align-items: center;
		padding: 0.625rem 1.5rem;
		border: 1px solid var(--ri-accent-hover);
		border-radius: 4px;
		font-family: var(--sl-font);
		font-size: 0.875rem;
		font-weight: 600;
		letter-spacing: 0.05em;
		color: var(--ri-bg-app);
		background: var(--ri-text-primary);
		text-decoration: none;
		transition: all 0.2s;
	}

	.ri-profile-signin-btn:hover {
		background: var(--ri-accent);
		color: var(--ri-bg-app);
	}

	.ri-profile__header {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		margin-bottom: 2rem;
	}

	.ri-profile__avatar {
		width: 80px;
		height: 80px;
		border-radius: 50%;
		border: 2px solid var(--ri-accent-hover);
	}

	.ri-profile__info {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.ri-profile__name {
		font-family: var(--sl-font);
		color: var(--ri-text-primary);
		font-size: 1.5rem;
		margin: 0;
	}

	.ri-profile__provider {
		font-size: 0.8rem;
		color: var(--ri-accent);
		text-transform: capitalize;
		letter-spacing: 0.1em;
	}

	.ri-profile__email {
		font-size: 0.875rem;
		color: var(--sl-color-gray-3);
	}

	.ri-profile__actions {
		padding-top: 1.5rem;
		border-top: 1px solid var(--sl-color-hairline);
	}

	.ri-profile-signout-btn {
		display: inline-flex;
		align-items: center;
		padding: 0.5rem 1.25rem;
		border: 1px solid var(--ri-accent-hover);
		border-radius: 4px;
		font-family: var(--sl-font);
		font-size: 0.8rem;
		letter-spacing: 0.05em;
		color: var(--ri-accent);
		background: transparent;
		text-decoration: none;
		transition: all 0.2s;
	}

	.ri-profile-signout-btn:hover {
		background: rgba(212, 164, 76, 0.15);
		border-color: var(--ri-accent);
		color: var(--ri-accent);
	}
</style>
