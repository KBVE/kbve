---
import { getCollection } from 'astro:content';
import { collectTermSummaries, collectFacet } from '@/lib/icons/terms';
import IconsBrowserReact from './IconsBrowser';
import synonymsJson from '../../../../icons-codegen/dedup-keys.json';

interface Props {
	basePath?: string;
}

const { basePath = '/icons' } = Astro.props;

const docs = await getCollection('docs');
const terms = collectTermSummaries(docs);
const categories = collectFacet(terms, (t) =>
	t.primary_category ? [t.primary_category] : [],
);
const styles = collectFacet(terms, (t) => t.styles);
const themes = collectFacet(terms, (t) => t.themes);
const sources = collectFacet(terms, (t) => t.sourcePacks);

/**
 * Extract synonyms from the dedup ledger so the in-memory search can
 * expand a query like "blade" → ["sword", "dagger"]. The ledger may
 * carry a `synonyms` top-level key (curated by hand) and each
 * per-concept entry's pack-source slugs (auto-tracked by merger).
 * Form one map: `{ baseRef: [searchAlias, ...] }`.
 */
function buildSynonymMap(): Record<string, string[]> {
	const ledger = synonymsJson as Record<string, unknown>;
	const out: Record<string, string[]> = {};
	const explicit = ledger['synonyms'] as Record<string, string[]> | undefined;
	if (explicit) {
		for (const [baseRef, aliases] of Object.entries(explicit)) {
			if (!Array.isArray(aliases)) continue;
			out[baseRef] = (out[baseRef] ?? []).concat(aliases);
		}
	}
	for (const [baseRef, value] of Object.entries(ledger)) {
		if (baseRef === 'synonyms' || typeof value !== 'object' || !value)
			continue;
		const inner = value as Record<string, string>;
		const aliases = Object.values(inner).filter(
			(v) => typeof v === 'string' && v !== baseRef,
		);
		if (aliases.length > 0) {
			out[baseRef] = (out[baseRef] ?? []).concat(aliases);
		}
	}
	return out;
}

const synonyms = buildSynonymMap();
---

<IconsBrowserReact
	client:load
	terms={terms}
	categories={categories}
	styles={styles}
	themes={themes}
	sources={sources}
	synonyms={synonyms}
	basePath={basePath}
/>

<style is:global>
	.ri-icons-browser {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		margin: 1.5rem 0;
	}

	.ri-icons-browser__controls {
		display: flex;
		align-items: center;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.ri-icons-browser__search {
		flex: 1 1 20rem;
		padding: 0.65rem 1rem;
		font: inherit;
		color: var(--ri-text-primary);
		background: var(--ri-bg-panel);
		border: 1px solid var(--ri-border);
		border-radius: 8px;
		transition:
			border-color 0.15s,
			box-shadow 0.15s;
	}

	.ri-icons-browser__search:focus {
		outline: none;
		border-color: var(--ri-accent);
		box-shadow: 0 0 0 4px rgba(58, 174, 216, 0.2);
	}

	.ri-icons-browser__count {
		font-size: 0.8125rem;
		color: var(--ri-text-disabled);
		font-family: monospace;
	}

	.ri-icons-browser__chip-row {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.35rem;
	}

	.ri-icons-browser__chip-label {
		font-size: 0.6875rem;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--ri-text-disabled);
		margin-right: 0.25rem;
	}

	.ri-icons-browser__chip {
		font: inherit;
		font-size: 0.75rem;
		padding: 0.25rem 0.65rem;
		border-radius: 999px;
		background: var(--ri-bg-panel);
		color: var(--ri-text-secondary);
		border: 1px solid var(--ri-border);
		cursor: pointer;
		transition: all 0.15s;
		text-decoration: none !important;
		display: inline-block;
	}

	.ri-icons-browser__chip:hover {
		border-color: var(--ri-accent);
		color: var(--ri-accent);
	}

	.ri-icons-browser__chip[data-active='true'] {
		background: var(--ri-ocean-deep);
		border-color: var(--ri-accent);
		color: var(--ri-accent);
	}

	.ri-icons-browser__grid {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
		gap: 0.75rem;
	}

	.ri-icons-browser__featured {
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
		padding: 1rem;
		border-radius: 12px;
		background: color-mix(in srgb, var(--ri-accent) 6%, transparent);
		border: 1px solid color-mix(in srgb, var(--ri-accent) 25%, transparent);
	}

	.ri-icons-browser__featured-header {
		display: flex;
		align-items: baseline;
		gap: 0.65rem;
		flex-wrap: wrap;
	}

	.ri-icons-browser__featured-label {
		font-size: 0.6875rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		font-weight: 700;
		color: var(--ri-accent);
	}

	.ri-icons-browser__featured-hint {
		font-size: 0.75rem;
		color: var(--ri-text-disabled);
	}

	.ri-icons-browser__item {
		margin: 0;
	}

	.ri-icons-browser__card {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding: 0.75rem;
		border-radius: 8px;
		background: var(--ri-bg-panel);
		border: 1px solid var(--ri-border);
		text-decoration: none !important;
		color: var(--ri-text-primary);
		transition:
			border-color 0.15s,
			box-shadow 0.15s,
			transform 0.15s;
	}

	.ri-icons-browser__card:hover {
		border-color: var(--ri-accent);
		box-shadow: 0 0 24px rgba(58, 174, 216, 0.15);
		transform: translateY(-2px);
	}

	.ri-icons-browser__thumb {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 1rem;
		background: var(--ri-bg-panel-elevated);
		border-radius: 6px;
		color: var(--ri-accent);
		min-height: 80px;
	}

	.ri-icons-browser__thumb svg {
		width: 48px;
		height: 48px;
	}

	.ri-icons-browser__meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.35rem;
	}

	.ri-icons-browser__name {
		font-weight: 600;
		flex: 1 1 auto;
	}

	.ri-icons-browser__chip {
		/* overridden selector for inline category marker inside card meta */
	}

	.ri-icons-browser__count-pill {
		font-size: 0.6875rem;
		padding: 0.125rem 0.45rem;
		border-radius: 999px;
		background: var(--ri-bg-app);
		border: 1px solid var(--ri-border);
		color: var(--ri-text-disabled);
	}

	.ri-icons-browser__empty {
		padding: 2rem;
		text-align: center;
		color: var(--ri-text-disabled);
		border: 1px dashed var(--ri-border);
		border-radius: 8px;
	}
</style>
