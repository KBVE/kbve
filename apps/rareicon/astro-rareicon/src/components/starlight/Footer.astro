					</path>
				</svg>
			</a>
			<a
				href="https://kbve.com/discord/"
				class="ri-footer__badge"
				target="_blank"
				rel="noopener noreferrer"
				aria-label="Discord">
				<svg
					viewBox="0 0 24 24"
					width="18"
					height="18"
					fill="currentColor"
					aria-hidden="true">
					<path
