			<a
				href="https://kbve.com/twitter/"
				class="ri-footer__badge"
				target="_blank"
				rel="noopener noreferrer"
				aria-label="Twitter / X">
				<svg
					viewBox="0 0 24 24"
					width="18"
					height="18"
					fill="currentColor"
					aria-hidden="true">
