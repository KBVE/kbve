---
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/Footer.astro';
import SocialBar from '@/components/social/SocialBar.astro';

const currentYear = new Date().getFullYear();
---

<Default {...Astro.props}><slot /></Default>

<div class="ri-footer not-content">
	<div class="ri-footer__divider" aria-hidden="true">
		<div class="ri-footer__divider-line"></div>
	</div>

	<div class="ri-footer__main">
		<div class="ri-footer__brand">
			<a href="/" class="ri-footer__brand-link" data-astro-prefetch>
				<span class="ri-footer__logo-text">RareIcon</span>
			</a>
			<p class="ri-footer__brand-desc">
				Open world multiplayer RPG powered by Unreal Engine and OWS.
				<br />
				Explore vast lands, forge alliances, and conquer the unknown.
			</p>
		</div>

		<nav class="ri-footer__col">
			<h3 class="ri-footer__title">Adventure</h3>
			<a href="/guides/getting-started/">Getting Started</a>
			<a href="/game/">Game</a>
			<a href="/steam/">Steam</a>
			<a href="/press/">Press Kit</a>
		</nav>

		<nav class="ri-footer__col">
			<h3 class="ri-footer__title">Kingdom</h3>
			<a
				href="https://kbve.com"
				title="KBVE -- Open-source software, game development, and cloud infrastructure">
				KBVE.com
			</a>
			<a
				href="https://cryptothrone.com/"
				title="CryptoThrone -- A 2D tile-based RPG">
				CryptoThrone
			</a>
			<a href="https://kbve.com/github/">GitHub</a>
			<a href="https://kbve.com/discord/">Discord</a>
			<a href="https://kbve.com/youtube/">YouTube</a>
			<a href="https://kbve.com/twitch/">Twitch</a>
			<a href="https://kbve.com/twitter/">Twitter / X</a>
			<a href="https://kbve.com/bluesky/">Bluesky</a>
			<a href="https://kbve.com/tiktok/">TikTok</a>
			<a href="https://kbve.com/itch/">itch.io</a>
		</nav>

		<nav class="ri-footer__col">
			<h3 class="ri-footer__title">Scrolls</h3>
			<a href="https://kbve.com/legal/tos/">Terms of Use</a>
			<a href="https://kbve.com/legal/privacy/">Privacy Policy</a>
			<a href="https://kbve.com/legal/">Cookie Policy</a>
		</nav>
	</div>

	<div class="ri-footer__bottom">
		<span>
			&copy; {currentYear}
			<a href="/">RareIcon</a> &mdash; forged by <a
				href="https://kbve.com">
				KBVE
			</a>
		</span>
		<SocialBar variant="badges" utmCampaign="footer" />
	</div>
</div>

<style>
	.ri-footer {
		margin-top: 0;
		padding: 0 1.5rem;
		border-top: 1px solid rgba(255, 255, 255, 0.06);
		background: var(--ri-bg-app, #1a1a1f);
	}

	.ri-footer__divider {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 1.25rem 0 0;
	}

	.ri-footer__divider-line {
		width: 3rem;
		height: 1px;
		background: linear-gradient(
			90deg,
			transparent,
			var(--ri-accent),
			transparent
		);
		opacity: 0.4;
	}

	.ri-footer__main {
		display: grid;
		grid-template-columns: 1.5fr repeat(3, 1fr);
		gap: 2.5rem;
		max-width: 72rem;
		margin: 0 auto;
		padding: 1.5rem 0 2rem;
	}

	.ri-footer__brand-link {
		text-decoration: none;
	}

	.ri-footer__logo-text {
		font-family: var(--sl-font);
		font-size: 1.1rem;
		font-weight: 600;
		letter-spacing: 0.05em;
		color: var(--ri-text-primary, #e8dcc8);
	}

	.ri-footer__brand-desc {
		margin-top: 0.75rem;
		font-size: 0.8125rem;
		line-height: 1.6;
		color: var(--sl-color-gray-2, #9e9480);
	}

	.ri-footer__col {
		display: flex;
		flex-direction: column;
		gap: 0.625rem;
	}

	.ri-footer__title {
		font-family: var(--sl-font);
		font-size: 0.65rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: var(--ri-accent);
		margin-bottom: 0.25rem;
	}

	.ri-footer__col a {
		font-size: 0.8125rem;
		color: var(--sl-color-gray-2, #9e9480);
		text-decoration: none;
		transition: color 150ms ease;
	}

	.ri-footer__col a:hover {
		color: var(--ri-accent);
	}

	.ri-footer__bottom {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 72rem;
		margin: 0 auto;
		padding: 1.25rem 0;
		border-top: 1px solid
			color-mix(in srgb, var(--ri-accent) 10%, transparent);
	}

	.ri-footer__bottom span {
		font-size: 0.8125rem;
		color: var(--sl-color-gray-3, #6b6356);
	}

	.ri-footer__bottom a {
		color: var(--sl-color-gray-2, #9e9480);
		text-decoration: none;
		font-weight: 500;
		transition: color 150ms ease;
	}

	.ri-footer__bottom a:hover {
		color: var(--ri-accent);
	}

	@media (max-width: 768px) {
		.ri-footer__main {
			grid-template-columns: 1fr 1fr;
			gap: 2rem;
		}

		.ri-footer__brand {
			grid-column: 1 / -1;
		}
	}

	@media (max-width: 480px) {
		.ri-footer__main {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.ri-footer__bottom {
			flex-direction: column;
			gap: 1rem;
			text-align: center;
		}
	}
</style>
