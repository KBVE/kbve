						d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z">
					</path>
				</svg>
			</a>
		</div>
	</div>
</div>

<style>
	.ri-footer {
		margin-top: 0;
		padding: 0 1.5rem;
		border-top: 1px solid rgba(255, 255, 255, 0.06);
		background: var(--ri-bg-app, #1a1a1f);
	}

	.ri-footer__divider {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 1.25rem 0 0;
	}

	.ri-footer__divider-line {
		width: 3rem;
		height: 1px;
		background: linear-gradient(
			90deg,
			transparent,
			var(--ri-accent),
			transparent
		);
		opacity: 0.4;
	}

	.ri-footer__main {
		display: grid;
		grid-template-columns: 1.5fr repeat(3, 1fr);
		gap: 2.5rem;
		max-width: 72rem;
		margin: 0 auto;
		padding: 1.5rem 0 2rem;
	}

	.ri-footer__brand-link {
		text-decoration: none;
	}

	.ri-footer__logo-text {
		font-family: var(--sl-font);
		font-size: 1.1rem;
		font-weight: 600;
		letter-spacing: 0.05em;
		color: var(--ri-text-primary, #e8dcc8);
	}

	.ri-footer__brand-desc {
		margin-top: 0.75rem;
		font-size: 0.8125rem;
		line-height: 1.6;
		color: var(--sl-color-gray-2, #9e9480);
	}

	.ri-footer__col {
		display: flex;
		flex-direction: column;
		gap: 0.625rem;
	}

	.ri-footer__title {
		font-family: var(--sl-font);
		font-size: 0.65rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: var(--ri-accent);
		margin-bottom: 0.25rem;
	}

	.ri-footer__col a {
		font-size: 0.8125rem;
		color: var(--sl-color-gray-2, #9e9480);
		text-decoration: none;
		transition: color 150ms ease;
	}

	.ri-footer__col a:hover {
		color: var(--ri-accent);
	}

	.ri-footer__bottom {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 72rem;
		margin: 0 auto;
		padding: 1.25rem 0;
		border-top: 1px solid
			color-mix(in srgb, var(--ri-accent) 10%, transparent);
	}

	.ri-footer__bottom span {
		font-size: 0.8125rem;
		color: var(--sl-color-gray-3, #6b6356);
	}

	.ri-footer__bottom a {
		color: var(--sl-color-gray-2, #9e9480);
		text-decoration: none;
		font-weight: 500;
		transition: color 150ms ease;
	}

	.ri-footer__bottom a:hover {
		color: var(--ri-accent);
	}

	.ri-footer__badges {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.ri-footer__badge {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		border-radius: 0.5rem;
		color: var(--sl-color-gray-2, #9e9480);
		background: color-mix(in srgb, var(--ri-accent) 8%, transparent);
		border: 1px solid color-mix(in srgb, var(--ri-accent) 15%, transparent);
		transition: all 200ms ease;
	}

	.ri-footer__badge:hover {
		color: var(--ri-accent);
		border-color: color-mix(in srgb, var(--ri-accent) 40%, transparent);
		background: color-mix(in srgb, var(--ri-accent) 15%, transparent);
		transform: translateY(-2px);
	}

	@media (max-width: 768px) {
		.ri-footer__main {
			grid-template-columns: 1fr 1fr;
			gap: 2rem;
		}

		.ri-footer__brand {
			grid-column: 1 / -1;
		}
	}

	@media (max-width: 480px) {
		.ri-footer__main {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.ri-footer__bottom {
			flex-direction: column;
			gap: 1rem;
			text-align: center;
		}
	}
</style>
