---
import { SOCIALS, type Social } from '@/data/socials';

interface Props {
	/** Filter by platform slugs (e.g. ['steam', 'discord']). Empty = all. */
	include?: string[];
	/** Filter out platform slugs. Applied after `include`. */
	exclude?: string[];
	/** Visual variant — `badges` is the icon-only square row used in footers,
	 *  `cards` is the larger labeled grid used on press / steam splashes. */
	variant?: 'badges' | 'cards';
	/** Optional aria-label override for the wrapping nav element. */
	ariaLabel?: string;
}

const {
	include,
	exclude,
	variant = 'badges',
	ariaLabel = 'RareIcon social links',
} = Astro.props;

const items: Social[] = SOCIALS.filter((s) => {
	if (include && include.length > 0 && !include.includes(s.platform))
		return false;
	if (exclude && exclude.includes(s.platform)) return false;
	return true;
});
---

<nav
	class:list={['ri-socialbar', `ri-socialbar--${variant}`]}
	aria-label={ariaLabel}>
	{
		items.map((s) => {
			const isInternal = s.href.startsWith('/');
			const target = s.target ?? (isInternal ? '_self' : '_blank');
			const rel = target === '_blank' ? 'noopener noreferrer' : undefined;
			return (
				<a
					href={s.href}
					class="ri-socialbar__item"
					target={target}
					rel={rel}
					aria-label={s.label}
					style={`--ri-social-color: ${s.color};`}
					data-platform={s.platform}>
					<span class="ri-socialbar__icon" aria-hidden="true">
						{s.platform === 'steam' && (
							<svg
								viewBox="0 0 24 24"
								fill="currentColor"
