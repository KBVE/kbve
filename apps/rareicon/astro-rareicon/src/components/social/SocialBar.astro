							<svg
								viewBox="0 0 24 24"
								fill="currentColor"
								aria-hidden="true">
								<path d="M3.13 1.338C2.08 1.96.02 4.328 0 4.95v1.03c0 1.303 1.22 2.45 2.325 2.45 1.33 0 2.436-1.102 2.436-2.41 0 1.308 1.07 2.41 2.4 2.41 1.328 0 2.362-1.102 2.362-2.41 0 1.308 1.137 2.41 2.466 2.41h.024c1.33 0 2.466-1.102 2.466-2.41 0 1.308 1.034 2.41 2.363 2.41 1.33 0 2.4-1.102 2.4-2.41 0 1.308 1.106 2.41 2.435 2.41C22.78 8.43 24 7.282 24 5.98V4.95c-.02-.62-2.082-2.99-3.13-3.612-3.253-.114-5.508-.134-8.87-.133-3.362 0-7.945.053-8.87.133zm6.376 6.477a2.74 2.74 0 0 1-.466.6 2.747 2.747 0 0 1-3.892 0 2.74 2.74 0 0 1-.467-.6 2.747 2.747 0 0 1-.467.6c-.512.51-1.18.79-1.918.79-.083 0-.167-.005-.247-.014-.36 2.825-.503 5.567-.554 7.57v.002c-.003.987-.006 1.78.06 2.69.137 1.84.32 2.798 1.41 3.103 1.555.434 4.598.621 7.965.62 3.367 0 6.41-.187 7.964-.62 1.09-.305 1.273-1.262 1.41-3.102.067-.91.064-1.704.06-2.69v-.003c-.05-2.003-.193-4.745-.554-7.57-.08.01-.164.014-.247.014a2.71 2.71 0 0 1-1.918-.79 2.74 2.74 0 0 1-.466-.6 2.747 2.747 0 0 1-.467.6c-.512.51-1.21.79-1.948.79a2.71 2.71 0 0 1-1.92-.79 2.748 2.748 0 0 1-.495-.633 2.748 2.748 0 0 1-.494.633 2.71 2.71 0 0 1-1.92.79 2.71 2.71 0 0 1-1.917-.79zm-.585 4.143v.002c.79.003 1.49 0 2.355-.943.684.715 1.64.943 2.724.943 1.084 0 2.04-.228 2.724-.943.865.943 1.565.946 2.355.943h.002c.375 0 1.157 0 1.997.802.654.625-.156 5.967-.66 6.482-.838.853-3.567.59-4.5.486-.745-.083-1.81-.33-2.422-.93-.21.157-.34.293-.512.405-.41.27-.945.512-1.484.512s-1.075-.244-1.484-.51c-.17-.113-.302-.25-.51-.408-.615.6-1.68.847-2.424.93-.933.105-3.662.367-4.5-.485-.504-.515-1.314-5.857-.66-6.482.84-.802 1.622-.802 1.997-.802h.002zm3.08 2.582c-.376 0-1.197.94-1.464.94-.348 0-.43-.207-.624-.207a.6.6 0 0 0-.31.094.65.65 0 0 0-.13.13c-.084.114-.122.244-.085.387.048.18.235.32.42.376.187.057.397.065.594.057h.002c.495-.022 1.002-.197 1.36-.55.355.354.864.528 1.36.55h.002c.197.008.407 0 .594-.057.185-.057.372-.196.42-.376.037-.143-.001-.273-.085-.387a.65.65 0 0 0-.13-.13.6.6 0 0 0-.31-.094c-.193 0-.276.207-.624.207-.267 0-1.087-.94-1.46-.94z" />
							</svg>
						)}
					</span>
					{variant === 'cards' && (
						<span class="ri-socialbar__label">{s.label}</span>
					)}
				</a>
			);
		})
	}
</nav>

<style>
	.ri-socialbar {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.6rem;
	}
	.ri-socialbar--cards {
		gap: 0.75rem;
	}
	.ri-socialbar__item {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		color: var(--sl-color-gray-2, #9e9480);
		text-decoration: none;
		border-radius: 0.5rem;
		border: 1px solid
			color-mix(in srgb, var(--ri-social-color) 25%, transparent);
		background: color-mix(in srgb, var(--ri-social-color) 10%, transparent);
		transition:
			color 200ms ease,
			border-color 200ms ease,
			background 200ms ease,
			transform 200ms ease;
	}
	.ri-socialbar--badges .ri-socialbar__item {
		width: 2rem;
		height: 2rem;
	}
	.ri-socialbar--cards .ri-socialbar__item {
		padding: 0.55rem 0.95rem;
		font-size: 0.875rem;
		font-weight: 600;
	}
	.ri-socialbar__item:hover {
		color: var(--ri-social-color);
		border-color: color-mix(
			in srgb,
			var(--ri-social-color) 60%,
			transparent
		);
		background: color-mix(in srgb, var(--ri-social-color) 18%, transparent);
		transform: translateY(-2px);
	}
	.ri-socialbar__icon svg {
		width: 18px;
		height: 18px;
	}
	.ri-socialbar--cards .ri-socialbar__icon svg {
		width: 16px;
		height: 16px;
	}
</style>
