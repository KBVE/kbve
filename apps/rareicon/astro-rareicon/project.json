{
	"name": "astro-rareicon",
	"$schema": "../../../node_modules/nx/schemas/project-schema.json",
	"projectType": "application",
	"sourceRoot": "apps/rareicon/astro-rareicon/src",
	"tags": [],
	"targets": {
		"proto": {
			"executor": "nx:run-commands",
			"inputs": ["{workspaceRoot}/packages/data/proto/rareicon/*.proto"],
			"outputs": ["{projectRoot}/src/generated/proto"],
			"options": {
				"command": "buf generate packages/data/proto --template apps/rareicon/astro-rareicon/buf.gen.yaml",
				"cwd": "{workspaceRoot}"
			},
			"cache": true
		},
		"dev": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "apps/rareicon/astro-rareicon",
				"commands": [
					"rm -rf .astro",
					"nx exec -- astro sync",
					"UV_THREADPOOL_SIZE=4 NODE_OPTIONS=\"--max-old-space-size=8192\" nx exec -- astro dev"
				],
				"parallel": false
			}
		},
		"build": {
			"dependsOn": ["proto"],
			"executor": "nx:run-commands",
			"outputs": ["{workspaceRoot}/dist/apps/astro-rareicon"],
			"options": {
				"cwd": "apps/rareicon/astro-rareicon",
				"commands": [
					"rm -rf .astro",
					"nx exec -- astro sync",
					"UV_THREADPOOL_SIZE=4 NODE_OPTIONS=\"--max-old-space-size=8192\" nx exec -- astro build"
				],
				"parallel": false
			},
			"cache": true
		},
		"preview": {
			"dependsOn": [
				{
					"target": "build",
					"projects": "self"
				}
			],
			"executor": "nx:run-commands",
			"options": {
				"cwd": "apps/rareicon/astro-rareicon",
				"commands": ["nx exec -- astro preview"],
				"parallel": false
			}
		},
		"check": {
			"dependsOn": ["proto"],
			"executor": "nx:run-commands",
			"options": {
				"cwd": "apps/rareicon/astro-rareicon",
				"commands": ["nx exec -- astro check"],
				"parallel": false
			},
			"cache": true
		},
		"sync": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "apps/rareicon/astro-rareicon",
				"commands": ["nx exec -- astro sync"],
				"parallel": false
			}
		},
		"gen:icons-install": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "apps/rareicon/icons-codegen",
				"commands": ["pnpm install --ignore-workspace"],
				"parallel": false
			}
		},
		"gen:icons-clean": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "apps/rareicon/icons-codegen",
				"commands": ["pnpm clean:deps"],
				"parallel": false
			}
		},
		"gen:icons": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "apps/rareicon/icons-codegen",
				"commands": ["pnpm gen:lucide"],
				"parallel": false
			}
		},
		"gen:brand-icons": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "apps/rareicon/icons-codegen",
				"commands": ["pnpm gen:simple"],
				"parallel": false
			}
		},
		"gen:tabler-icons": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "apps/rareicon/icons-codegen",
				"commands": ["pnpm gen:tabler"],
				"parallel": false
			}
		},
		"gen:phosphor-icons": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "apps/rareicon/icons-codegen",
				"commands": ["pnpm gen:phosphor"],
				"parallel": false
			}
		},
		"gen:game-icons": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "apps/rareicon/icons-codegen",
				"commands": ["pnpm gen:gameicons"],
				"parallel": false
			}
		},
		"gen:iconify-icons": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "apps/rareicon/icons-codegen",
				"commands": ["pnpm gen:iconify"],
				"parallel": false
			}
		},
		"gen:merge-variants": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "apps/rareicon/icons-codegen",
				"commands": ["pnpm gen:merge"],
				"parallel": false
			}
		},
		"gen:all-icons": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "apps/rareicon/icons-codegen",
				"commands": ["pnpm gen:all"],
				"parallel": false
			}
		},
		"audit:links": {
			"executor": "nx:run-commands",
			"dependsOn": [
				{
					"target": "build",
					"projects": "self"
				}
			],
			"options": {
				"cwd": "apps/rareicon/icons-codegen",
				"commands": ["pnpm audit:links"],
				"parallel": false
			}
		},
		"proto:lint": {
			"executor": "nx:run-commands",
			"options": {
				"command": "buf lint packages/data/proto",
				"cwd": "{workspaceRoot}"
			}
		},
		"proto:clean": {
			"executor": "nx:run-commands",
			"options": {
				"command": "rm -rf apps/rareicon/astro-rareicon/src/generated/proto && mkdir -p apps/rareicon/astro-rareicon/src/generated/proto",
				"cwd": "{workspaceRoot}"
			}
		}
	}
}
