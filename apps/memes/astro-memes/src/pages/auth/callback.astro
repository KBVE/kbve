---
// OAuth callback — delegates to React for safe lifecycle management
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>Authenticating...</title>
		<style>
			body {
				margin: 0;
				padding: 0;
				font-family:
					system-ui,
					-apple-system,
					sans-serif;
				background: var(--sl-color-bg, #0a0a0a);
			}
		</style>
	</head>
	<body>
		<div id="callback-root">
			<!-- React hydrates here -->
			<div
				style="display:flex;align-items:center;justify-content:center;min-height:100vh;color:#94a3b8;">
				<p>Loading...</p>
			</div>
		</div>

		<script>
			import { createElement } from 'react';
			import { createRoot } from 'react-dom/client';
			import CallbackHandler from '../../components/auth/CallbackHandler';

			const root = document.getElementById('callback-root');
			if (root) {
				createRoot(root).render(createElement(CallbackHandler));
			}
		</script>
	</body>
</html>
