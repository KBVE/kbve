---
// AskamaMemeProvider — Renders the meme detail page shell.
//
// Askama variables (filled by axum at request time):
//   Core:   {{ meme_id }}, {{ title }}, {{ description }}, {{ canonical_url }}
//   Media:  {{ asset_url }}, {{ og_image }}, {{ format_label }},
//           {{ width }}, {{ height }}
//   Social: {{ author }}, {{ tags }}, {{ site_name }}, {{ og_type }},
//           {{ og_width }}, {{ og_height }}, {{ locale }}, {{ robots }},
//           {{ twitter_card }}, {{ twitter_site }}, {{ twitter_creator }},
//           {{ image_alt }}, {{ theme_color }}
//
// Social meta tags are rendered by AskamaSocialMeta — no need to
// duplicate OG/Twitter tags in MDX frontmatter.

import AskamaSocialMeta from './AskamaSocialMeta.astro';

interface Props {
	class?: string;
}

const { class: className = '' } = Astro.props;

// Askama template variables — output as literal strings in the built HTML.
// Axum's askama engine fills these at runtime.
const memeId = `{{ meme_id }}`;
const memeTitle = `{{ title }}`;
const assetUrl = `{{ asset_url }}`;
const formatLabel = `{{ format_label }}`;
const authorName = `{{ author }}`;

// Media block — conditionally renders video or image based on format_label
const mediaBlock = `{% if format_label == "video" %}
<video
	src="{{ asset_url }}"
	controls
	playsinline
	preload="metadata"
	class="meme-detail__media"
	{% if width > 0 %}width="{{ width }}"{% endif %}
	{% if height > 0 %}height="{{ height }}"{% endif %}
></video>
{% else %}
<img
	src="{{ asset_url }}"
	alt="{{ title }}"
	loading="eager"
	class="meme-detail__media"
	{% if width > 0 %}width="{{ width }}"{% endif %}
	{% if height > 0 %}height="{{ height }}"{% endif %}
/>
{% endif %}`;

// Author block
const authorBlock = `{% if !author.is_empty() %}
<p class="meme-detail__author">
	<span class="meme-detail__author-label">by</span>
	<span class="meme-detail__author-name">{{ author }}</span>
</p>
{% endif %}`;

// Tags block
const tagsBlock = `{% if !tags.is_empty() %}
<div class="meme-detail__tags">
	{% for tag in tags %}
	<span class="meme-detail__tag">{{ tag }}</span>
	{% endfor %}
</div>
{% endif %}`;
---

<AskamaSocialMeta />

<article class={`meme-detail ${className}`} data-meme-id={memeId}>
	<div class="meme-detail__container">
		<div class="meme-detail__media-wrap">
			<Fragment set:html={mediaBlock} />
		</div>

		<div class="meme-detail__info">
			<h1 class="meme-detail__title" set:html={memeTitle} />
			<Fragment set:html={authorBlock} />
			<Fragment set:html={tagsBlock} />
		</div>

		<!-- React island hydrates here for reactions, comments, etc. -->
		<div id="meme-island" data-meme-id={memeId}></div>
	</div>
</article>

<style>
	.meme-detail {
		width: 100%;
		min-height: 100dvh;
		display: flex;
		justify-content: center;
		padding: 2rem 1rem;
	}

	.meme-detail__container {
		max-width: 48rem;
		width: 100%;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.meme-detail__media-wrap {
		width: 100%;
		display: flex;
		justify-content: center;
		border-radius: 0.75rem;
		overflow: hidden;
		background-color: #161618;
	}

	:global(.meme-detail__media) {
		max-width: 100%;
		max-height: 75vh;
		object-fit: contain;
		display: block;
	}

	.meme-detail__info {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.meme-detail__title {
		font-size: 1.25rem;
		font-weight: 600;
		line-height: 1.3;
		color: #e2e2e6;
		margin: 0;
	}

	.meme-detail__author {
		font-size: 0.8125rem;
		color: #71717a;
		margin: 0;
	}

	.meme-detail__author-name {
		color: #a1a1aa;
		font-weight: 500;
	}

	.meme-detail__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
	}

	.meme-detail__tag {
		font-size: 0.6875rem;
		padding: 0.125rem 0.5rem;
		border-radius: 0.25rem;
		background-color: rgba(255, 255, 255, 0.06);
		color: #71717a;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	@media (prefers-color-scheme: light) {
		.meme-detail__media-wrap {
			background-color: #f0f0f2;
		}
		.meme-detail__title {
			color: #1a1a1e;
		}
		.meme-detail__author {
			color: #6b7280;
		}
		.meme-detail__author-name {
			color: #374151;
		}
		.meme-detail__tag {
			background-color: rgba(0, 0, 0, 0.06);
			color: #6b7280;
		}
	}
</style>
