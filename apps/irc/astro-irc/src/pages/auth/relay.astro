---
import AuthShell from '../../components/auth/AuthShell.astro';
---

<AuthShell title="Signing in…">
	<div class="kbve-auth-page__spinner"></div>
	<h1 class="kbve-auth-page__title" data-message>Signing in…</h1>
	<p class="kbve-auth-page__sub" data-sub>Please wait</p>
</AuthShell>

<script>
	import { setSharedToken } from '@kbve/astro';

	(async () => {
		const setMsg = (msg: string, sub?: string) => {
			const m = document.querySelector('[data-message]');
			const s = document.querySelector('[data-sub]');
			if (m) m.textContent = msg;
			if (s && sub) s.textContent = sub;
		};

		try {
			const params = new URLSearchParams(window.location.search);
			const token = params.get('token');

			if (!token) {
				throw new Error('No token provided');
			}

			const parts = token.split('.');
			if (parts.length !== 3) {
				throw new Error('Invalid token format');
			}

			setSharedToken(token);

			window.history.replaceState({}, '', '/auth/relay');

			await new Promise((resolve) => setTimeout(resolve, 300));
			window.location.href = '/chat';
		} catch (error: any) {
			console.error('[relay] Error:', error);
			setMsg('Sign-in failed', error.message || 'Redirecting…');
			setTimeout(() => {
				window.location.href = '/auth';
			}, 2000);
		}
	})();
</script>
