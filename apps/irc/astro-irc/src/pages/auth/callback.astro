---
import AuthShell from '../../components/auth/AuthShell.astro';
---

<AuthShell title="Authenticating…">
	<div class="kbve-auth-page__spinner"></div>
	<h1 class="kbve-auth-page__title" data-message>Completing sign-in…</h1>
	<p class="kbve-auth-page__sub" data-sub>Please wait</p>
</AuthShell>

<script>
	import { authBridge, initSupa, getSupa } from '../../lib/supa';

	(async () => {
		const setMsg = (msg: string, sub?: string) => {
			const m = document.querySelector('[data-message]');
			const s = document.querySelector('[data-sub]');
			if (m) m.textContent = msg;
			if (s && sub) s.textContent = sub;
		};

		try {
			const session = await authBridge.handleCallback();

			if (session) {
				await initSupa();
				const supa = getSupa();
				await supa.getSession();
				await new Promise((resolve) => setTimeout(resolve, 500));
				window.location.href = '/chat';
			} else {
				setMsg('Authentication failed', 'Redirecting…');
				setTimeout(() => {
					window.location.href = '/auth';
				}, 2000);
			}
		} catch (error) {
			console.error('Auth callback error:', error);
			setMsg('Authentication failed', 'Redirecting…');
			setTimeout(() => {
				window.location.href = '/auth';
			}, 2000);
		}
	})();
</script>
