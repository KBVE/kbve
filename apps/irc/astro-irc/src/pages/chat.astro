---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import ChatRoom from '../components/chat/ChatRoom.astro';
---

<StarlightPage
	frontmatter={{ title: 'Chat', template: 'splash', pagefind: false }}
	hasSidebar={false}>
	<div class="chat-page-wrapper">
		<ChatRoom wsUrl="wss://chat.kbve.com/ws" />
	</div>
</StarlightPage>

<style is:global>
	.content-panel:has(.chat-page-wrapper) {
		max-width: 100%;
		padding-inline: 0.5rem;
	}
	.sl-container:has(.chat-page-wrapper) {
		max-width: 100%;
	}
</style>
