---
import '../../styles/global.css';
import NavBar from '../navigation/NavBar.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="color-scheme" content="dark light" />
		<meta name="robots" content="noindex" />
		<title>{title}</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	</head>
	<body class="kbve-auth-page">
		<header class="kbve-auth-page__nav">
			<a href="/" class="kbve-auth-page__brand">
				<span class="kbve-auth-page__brand-dot">K</span>
				<span>KBVE Chat</span>
			</a>
			<NavBar />
		</header>
		<main class="kbve-auth-page__main">
			<div class="kbve-auth-page__card">
				<slot />
			</div>
		</main>
	</body>
</html>

<style is:global>
	body.kbve-auth-page {
		margin: 0;
		padding: 0;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		font-family:
			'Inter',
			-apple-system,
			BlinkMacSystemFont,
			system-ui,
			sans-serif;
		background:
			radial-gradient(
				ellipse at top left,
				color-mix(in srgb, var(--sl-color-accent) 12%, transparent) 0%,
				transparent 60%
			),
			radial-gradient(
				ellipse at bottom right,
				color-mix(in srgb, var(--sl-color-text-accent) 8%, transparent)
					0%,
				transparent 60%
			),
			var(--sl-color-bg);
		color: var(--sl-color-text);
	}

	.kbve-auth-page__nav {
		flex: 0 0 auto;
		display: flex;
		align-items: center;
		gap: 16px;
		height: 52px;
		padding: 0 16px;
		border-bottom: 1px solid var(--sl-color-border);
		background: color-mix(
			in srgb,
			var(--sl-color-bg-accent) 12%,
			var(--sl-color-bg)
		);
		backdrop-filter: blur(8px);
		z-index: 10;
	}

	.kbve-auth-page__brand {
		display: flex;
		align-items: center;
		gap: 10px;
		font-weight: 700;
		font-size: 15px;
		letter-spacing: -0.01em;
		color: var(--sl-color-text);
		text-decoration: none;
		flex-shrink: 0;
	}

	.kbve-auth-page__brand-dot {
		width: 28px;
		height: 28px;
		border-radius: 8px;
		background: linear-gradient(
			135deg,
			var(--sl-color-accent) 0%,
			var(--sl-color-text-accent) 100%
		);
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 13px;
		font-weight: 800;
		color: var(--sl-color-white);
		box-shadow: 0 4px 12px
			color-mix(in srgb, var(--sl-color-accent) 40%, transparent);
	}

	.kbve-auth-page__main {
		flex: 1 1 auto;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 24px;
	}

	.kbve-auth-page__card {
		max-width: 420px;
		width: 100%;
		padding: 36px 32px;
		border-radius: 16px;
		background: color-mix(
			in srgb,
			var(--sl-color-bg-accent) 14%,
			var(--sl-color-bg)
		);
		border: 1px solid var(--sl-color-border);
		box-shadow: 0 24px 64px -16px
			color-mix(in srgb, var(--sl-color-black) 50%, transparent);
		text-align: center;
	}

	.kbve-auth-page__title {
		font-size: 22px;
		font-weight: 700;
		margin: 0 0 8px;
		color: var(--sl-color-text);
	}

	.kbve-auth-page__sub {
		font-size: 14px;
		color: var(--sl-color-gray-3);
		margin: 0 0 24px;
		line-height: 1.5;
	}

	.kbve-auth-page__spinner {
		width: 44px;
		height: 44px;
		margin: 0 auto 20px;
		border: 3px solid var(--sl-color-border);
		border-top-color: var(--sl-color-accent);
		border-radius: 50%;
		animation: kbve-auth-spin 0.8s linear infinite;
	}

	@keyframes kbve-auth-spin {
		to {
			transform: rotate(360deg);
		}
	}

	.kbve-auth-page__btn {
		display: block;
		width: 100%;
		padding: 12px 16px;
		margin-bottom: 10px;
		border: 1px solid var(--sl-color-border);
		border-radius: 10px;
		font-size: 14px;
		font-weight: 600;
		cursor: pointer;
		font-family: inherit;
		background: color-mix(
			in srgb,
			var(--sl-color-bg-accent) 24%,
			var(--sl-color-bg)
		);
		color: var(--sl-color-text);
		transition: all 0.15s ease;
	}

	.kbve-auth-page__btn:hover {
		background: color-mix(
			in srgb,
			var(--sl-color-bg-accent) 38%,
			var(--sl-color-bg)
		);
		border-color: var(--sl-color-gray-5);
	}

	.kbve-auth-page__btn:disabled {
		opacity: 0.5;
		cursor: not-allowed;
	}

	.kbve-auth-page__btn--primary {
		background: linear-gradient(
			135deg,
			var(--sl-color-accent) 0%,
			var(--sl-color-text-accent) 100%
		);
		border-color: var(--sl-color-accent);
		color: var(--sl-color-white);
		box-shadow: 0 4px 12px
			color-mix(in srgb, var(--sl-color-accent) 35%, transparent);
	}

	.kbve-auth-page__back {
		display: inline-block;
		margin-top: 12px;
		color: var(--sl-color-gray-3);
		font-size: 13px;
		text-decoration: none;
	}

	.kbve-auth-page__back:hover {
		color: var(--sl-color-text);
	}
</style>
