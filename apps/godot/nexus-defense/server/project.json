{
	"name": "nd-server",
	"$schema": "../../../../node_modules/nx/schemas/project-schema.json",
	"projectType": "application",
	"sourceRoot": "apps/godot/nexus-defense/server/src",
	"tags": ["rust", "game-server", "nexus-defense"],
	"targets": {
		"build": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cargo build -p nd-server"
			},
			"outputs": ["{workspaceRoot}/dist/target/debug/nd-server"]
		},
		"build-release": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cargo build --release -p nd-server"
			},
			"outputs": ["{workspaceRoot}/dist/target/release/nd-server"]
		},
		"run": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cargo run -p nd-server"
			}
		},
		"test": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cargo test -p nd-server"
			}
		},
		"lint": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cargo clippy -p nd-server --all-targets -- -D warnings"
			}
		},
		"container": {
			"executor": "@nx-tools/nx-container:build",
			"defaultConfiguration": "local",
			"options": {
				"engine": "docker",
				"context": ".",
				"file": "apps/godot/nexus-defense/server/Dockerfile",
				"metadata": {
					"images": ["kbve/nd-server"],
					"load": true,
					"tags": ["latest"]
				}
			},
			"configurations": {
				"local": {
					"tags": ["latest"],
					"push": false
				},
				"production": {
					"tags": ["latest"],
					"push": true,
					"customBuildOptions": "--push",
					"cache-from": [
						"type=registry,ref=ghcr.io/kbve/nd-server:buildcache"
					],
					"cache-to": [
						"type=registry,ref=ghcr.io/kbve/nd-server:buildcache,mode=max"
					]
				}
			}
		}
	}
}
