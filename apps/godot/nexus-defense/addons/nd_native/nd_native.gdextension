[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.4
reloadable = true

[libraries]
linux.debug.x86_64 =     "res://addons/nd_native/bin/debug/libnd_native.so"
linux.release.x86_64 =   "res://addons/nd_native/bin/release/libnd_native.so"
windows.debug.x86_64 =   "res://addons/nd_native/bin/debug/nd_native.dll"
windows.release.x86_64 = "res://addons/nd_native/bin/release/nd_native.dll"
macos.debug =            "res://addons/nd_native/bin/debug/libnd_native.dylib"
macos.release =          "res://addons/nd_native/bin/release/libnd_native.dylib"
macos.debug.arm64 =      "res://addons/nd_native/bin/debug/libnd_native.dylib"
macos.release.arm64 =    "res://addons/nd_native/bin/release/libnd_native.dylib"
web.debug.wasm32 =       "res://addons/nd_native/bin/debug/nd_native.wasm"
web.release.wasm32 =     "res://addons/nd_native/bin/release/nd_native.wasm"
