{
	"name": "axum-rentearth",
	"$schema": "../../../node_modules/nx/schemas/project-schema.json",
	"projectType": "application",
	"sourceRoot": "apps/rentearth/axum-rentearth/src",
	"tags": [],
	"targets": {
		"web-build": {
			"executor": "nx:run-commands",
			"outputs": ["{projectRoot}/web/dist"],
			"options": {
				"commands": ["npm run build"],
				"cwd": "apps/rentearth/axum-rentearth/web",
				"parallel": false
			}
		},
		"web-dev": {
			"executor": "nx:run-commands",
			"cache": false,
			"options": {
				"commands": ["npm run dev"],
				"cwd": "apps/rentearth/axum-rentearth/web",
				"parallel": false
			}
		},
		"build": {
			"executor": "nx:run-commands",
			"options": {
				"commands": ["cargo build --release -p axum-rentearth"],
				"cwd": "{workspaceRoot}"
			}
		},
		"serve-static": {
			"executor": "nx:run-commands",
			"cache": false,
			"options": {
				"commands": [
					"STATIC_DIR=apps/rentearth/axum-rentearth/web/dist cargo run -p axum-rentearth"
				],
				"cwd": "{workspaceRoot}",
				"parallel": false
			}
		},
		"container": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"docker buildx build --platform linux/amd64 -f apps/rentearth/axum-rentearth/Dockerfile -t kbve/axum-rentearth:latest --load ."
				],
				"cwd": "{workspaceRoot}"
			}
		}
	}
}
