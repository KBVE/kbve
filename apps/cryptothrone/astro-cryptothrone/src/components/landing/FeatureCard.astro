---
interface Props {
	title: string;
	description: string;
	icon: string;
}

const { title, description, icon } = Astro.props;
---

<div class="ct-card">
	<div class="ct-card__icon">{icon}</div>
	<h3 class="ct-card__title">{title}</h3>
	<p class="ct-card__desc">{description}</p>
</div>

<style>
	.ct-card {
		background: color-mix(
			in srgb,
			var(--sl-color-gray-6, #27272a) 60%,
			transparent
		);
		border: 1px solid color-mix(in srgb, var(--ct-accent) 15%, transparent);
		border-radius: 0.75rem;
		padding: 1.5rem;
		transition: all 0.3s ease;
	}

	.ct-card:hover {
		border-color: color-mix(in srgb, var(--ct-accent) 40%, transparent);
		transform: translateY(-4px);
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
	}

	.ct-card__icon {
		font-size: 2rem;
		margin-bottom: 0.75rem;
	}

	.ct-card__title {
		font-size: 1.125rem;
		font-weight: 700;
		color: var(--ct-accent);
		margin: 0 0 0.5rem;
	}

	.ct-card__desc {
		font-size: 0.875rem;
		color: var(--sl-color-gray-3, #9ca3af);
		line-height: 1.6;
		margin: 0;
	}
</style>
