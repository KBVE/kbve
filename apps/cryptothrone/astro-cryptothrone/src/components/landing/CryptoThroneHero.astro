---
interface Props {
	title?: string;
	tagline?: string;
	playLink?: string;
	guidesLink?: string;
}

const {
	title = 'CryptoThrone',
	tagline = 'Explore cloud cities, battle bird monsters, and claim the throne.',
	playLink = '/game/play/',
	guidesLink = '/guides/getting-started/',
} = Astro.props;
---

<section class="ct-hero">
	<div class="ct-hero__bg">
		<div class="ct-hero__overlay"></div>
	</div>

	<div class="ct-hero__content">
		<p class="ct-hero__label">Browser-Based RPG</p>
		<h1 class="ct-hero__title">
			Claim the<br />
			<span class="ct-hero__title--accent">Throne</span>
		</h1>
		<p class="ct-hero__tagline">{tagline}</p>
		<div class="ct-hero__actions">
			<a href={playLink} class="ct-btn ct-btn--primary">
				<span class="ct-btn__fill"></span>
				<span class="ct-btn__text">Play Now</span>
			</a>
			<a href={guidesLink} class="ct-btn ct-btn--ghost">View Guides</a>
		</div>
	</div>

	<div class="ct-hero__scroll" aria-hidden="true">
		<span class="ct-hero__scroll-label">Scroll</span>
		<div class="ct-hero__scroll-line"></div>
	</div>
</section>

<style>
	.ct-hero {
		position: relative;
		width: 100%;
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
	}

	.ct-hero__bg {
		position: absolute;
		inset: 0;
		z-index: 0;
		background: url('/assets/background/chip-background.webp') center /
			cover no-repeat;
	}

	.ct-hero__overlay {
		position: absolute;
		inset: 0;
		background: rgba(0, 0, 0, 0.45);
		z-index: 1;
	}

	.ct-hero__content {
		position: relative;
		z-index: 2;
		text-align: center;
		padding: 2rem;
		max-width: 54rem;
		margin: 0 auto;
	}

	.ct-hero__label {
		color: var(--ct-accent);
		font-size: 0.7rem;
		letter-spacing: 0.3em;
		text-transform: uppercase;
		margin: 0 0 1.5rem;
	}

	.ct-hero__title {
		font-size: clamp(3rem, 8vw, 7rem);
		font-weight: 300;
		color: white;
		margin: 0 0 1.5rem;
		line-height: 1.05;
		letter-spacing: -0.02em;
	}

	.ct-hero__title--accent {
		font-style: italic;
		color: var(--ct-accent);
	}

	.ct-hero__tagline {
		font-size: clamp(0.9rem, 1.8vw, 1.1rem);
		color: rgba(255, 255, 255, 0.55);
		font-weight: 300;
		margin: 0 0 2.5rem;
		line-height: 1.7;
		max-width: 28rem;
		margin-inline: auto;
	}

	.ct-hero__actions {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	/* ── Buttons ── */
	.ct-btn {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.9rem 2.5rem;
		font-size: 0.75rem;
		font-weight: 500;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		text-decoration: none;
		transition: all 0.3s ease;
		overflow: hidden;
	}

	.ct-btn--primary {
		background: white;
		color: black;
	}

	.ct-btn--primary:hover {
		background: white;
	}

	.ct-btn__fill {
		position: absolute;
		bottom: 0;
		left: 0;
		width: 150%;
		height: 150%;
		background: var(--ct-accent);
		transform: translate(-110%, 60%) rotate(45deg);
		transition: transform 0.5s ease;
	}

	.ct-btn--primary:hover .ct-btn__fill {
		transform: translate(-10%, -10%) rotate(45deg);
	}

	.ct-btn__text {
		position: relative;
		z-index: 1;
		transition: color 0.3s ease;
	}

	.ct-btn--primary:hover .ct-btn__text {
		color: white;
	}

	.ct-btn--ghost {
		border: 1px solid var(--ct-accent);
		color: var(--ct-accent);
		background: transparent;
	}

	.ct-btn--ghost:hover {
		background: var(--ct-accent);
		color: black;
	}

	/* ── Scroll indicator ── */
	.ct-hero__scroll {
		position: absolute;
		bottom: 2.5rem;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		flex-direction: column;
		align-items: center;
		opacity: 0.6;
		animation: fade-bounce 3s infinite;
	}

	.ct-hero__scroll-label {
		font-size: 0.55rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.5);
		margin-bottom: 0.5rem;
	}

	.ct-hero__scroll-line {
		width: 1px;
		height: 3rem;
		background: linear-gradient(to bottom, var(--ct-accent), transparent);
	}

	@keyframes fade-bounce {
		0%,
		100% {
			opacity: 0.6;
			transform: translateX(-50%) translateY(0);
		}
		50% {
			opacity: 0.3;
			transform: translateX(-50%) translateY(6px);
		}
	}
</style>
