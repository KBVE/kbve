{
	"name": "arc-runner",
	"$schema": "../../../node_modules/nx/schemas/project-schema.json",
	"projectType": "library",
	"sourceRoot": "apps/vm/arc-runner",
	"targets": {
		"container": {
			"executor": "nx:run-commands",
			"defaultConfiguration": "local",
			"options": {
				"parallel": false
			},
			"configurations": {
				"local": {
					"commands": [
						"./kbve.sh -nx arc-runner:containerx",
						"VERSION=$(grep '^version' apps/vm/arc-runner/version.toml | sed 's/version = \"\\(.*\\)\"/\\1/') && docker tag kbve/arc-runner:latest kbve/arc-runner:$VERSION && echo \"Tagged kbve/arc-runner:$VERSION\""
					]
				},
				"production": {
					"commands": [
						"./kbve.sh -nx arc-runner:containerx --configuration=production",
						"VERSION=$(grep '^version' apps/vm/arc-runner/version.toml | sed 's/version = \"\\(.*\\)\"/\\1/') && docker tag kbve/arc-runner:latest kbve/arc-runner:$VERSION && docker tag kbve/arc-runner:latest ghcr.io/kbve/arc-runner:latest && docker tag kbve/arc-runner:latest ghcr.io/kbve/arc-runner:$VERSION && echo \"Tagged ghcr.io/kbve/arc-runner:$VERSION\""
					]
				}
			}
		},
		"containerx": {
			"executor": "@nx-tools/nx-container:build",
			"defaultConfiguration": "local",
			"options": {
				"engine": "docker",
				"context": ".",
				"file": "apps/vm/arc-runner/Dockerfile",
				"load": true
			},
			"configurations": {
				"local": {
					"load": true,
					"push": false,
					"tags": ["kbve/arc-runner:latest"]
				},
				"production": {
					"load": true,
					"push": false,
					"metadata": {
						"images": [
							"ghcr.io/kbve/arc-runner",
							"kbve/arc-runner"
						],
						"tags": ["latest"]
					},
					"cache-from": [
						"type=registry,ref=ghcr.io/kbve/arc-runner:buildcache"
					],
					"cache-to": [
						"type=registry,ref=ghcr.io/kbve/arc-runner:buildcache,mode=max"
					]
				}
			}
		}
	},
	"tags": ["scope:vm", "arc-runner", "infrastructure", "github-actions"]
}
