{
	"name": "aria2-proxy",
	"$schema": "../../../node_modules/nx/schemas/project-schema.json",
	"projectType": "library",
	"sourceRoot": "apps/vm/aria2-proxy",
	"targets": {
		"container": {
			"executor": "nx:run-commands",
			"defaultConfiguration": "local",
			"options": {
				"parallel": false
			},
			"configurations": {
				"local": {
					"commands": [
						"./kbve.sh -nx aria2-proxy:containerx",
						"VERSION=$(grep '^version' apps/vm/aria2-proxy/version.toml | sed 's/version = \"\\(.*\\)\"/\\1/') && docker tag kbve/aria2-proxy:latest kbve/aria2-proxy:$VERSION && echo \"Tagged kbve/aria2-proxy:$VERSION\""
					]
				},
				"production": {
					"commands": [
						"./kbve.sh -nx aria2-proxy:containerx --configuration=production",
						"VERSION=$(grep '^version' apps/vm/aria2-proxy/version.toml | sed 's/version = \"\\(.*\\)\"/\\1/') && docker tag kbve/aria2-proxy:latest kbve/aria2-proxy:$VERSION && docker tag kbve/aria2-proxy:latest ghcr.io/kbve/aria2-proxy:latest && docker tag kbve/aria2-proxy:latest ghcr.io/kbve/aria2-proxy:$VERSION && echo \"Tagged ghcr.io/kbve/aria2-proxy:$VERSION\""
					]
				}
			}
		},
		"containerx": {
			"executor": "@nx-tools/nx-container:build",
			"defaultConfiguration": "local",
			"options": {
				"engine": "docker",
				"context": ".",
				"file": "apps/vm/aria2-proxy/Dockerfile",
				"load": true
			},
			"configurations": {
				"local": {
					"load": true,
					"push": false,
					"tags": ["kbve/aria2-proxy:latest"]
				},
				"production": {
					"load": true,
					"push": false,
					"metadata": {
						"images": [
							"ghcr.io/kbve/aria2-proxy",
							"kbve/aria2-proxy"
						],
						"tags": ["latest"]
					},
					"cache-from": [
						"type=registry,ref=ghcr.io/kbve/aria2-proxy:buildcache"
					],
					"cache-to": [
						"type=registry,ref=ghcr.io/kbve/aria2-proxy:buildcache,mode=max"
					]
				}
			}
		}
	},
	"tags": ["scope:vm", "aria2-proxy", "infrastructure", "kubevirt"]
}
