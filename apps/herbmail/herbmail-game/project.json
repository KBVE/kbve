{
	"name": "herbmail-game",
	"$schema": "../../../node_modules/nx/schemas/project-schema.json",
	"sourceRoot": "apps/herbmail/herbmail-game/src",
	"projectType": "application",
	"tags": ["scope:herbmail", "type:app", "game"],
	"targets": {
		"dev": {
			"executor": "@nx/vite:dev-server",
			"options": {
				"buildTarget": "herbmail-game:build"
			}
		},
		"serve": {
			"executor": "@nx/vite:dev-server",
			"options": {
				"buildTarget": "herbmail-game:build"
			}
		},
		"build": {
			"executor": "@nx/vite:build",
			"outputs": ["{options.outputPath}"],
			"options": {
				"outputPath": "dist/apps/herbmail/herbmail-game"
			}
		},
		"preview": {
			"executor": "@nx/vite:preview-server",
			"options": {
				"buildTarget": "herbmail-game:build"
			}
		},
		"lint": {
			"executor": "@nx/eslint:lint"
		}
	}
}
