{
	"extends": ["plugin:@nx/react", "../../../.eslintrc.base.json"],
	"ignorePatterns": [
		"!**/*",
		"**/vite.config.*.timestamp*",
		"**/vitest.config.*.timestamp*"
	],
	"overrides": [
		{
			"files": ["*.ts", "*.tsx", "*.js", "*.jsx"],
			"rules": {}
		},
		{
			"files": ["*.ts", "*.tsx"],
			"rules": {
				"react-hooks/immutability": "off"
			}
		},
		{
			"files": ["*.js", "*.jsx"],
			"rules": {}
		}
	]
}
