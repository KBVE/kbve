{
	"extends": "../../../tsconfig.base.json",
	"compilerOptions": {
		"jsx": "react-jsx",
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"types": ["vite/client"],
		"resolveJsonModule": true,
		"baseUrl": ".",
		"paths": {
			"@kbve/laser": ["../../../packages/npm/laser/src/index.ts"],
			"@kbve/laser/ecs": ["../../../packages/npm/laser/src/ecs.ts"],
			"@kbve/laser/mecs": ["../../../packages/npm/laser/src/mecs.ts"],
			"@kbve/itemdb-data": [
				"../../../packages/data/codegen/generated/itemdb.json"
			],
			"@kbve/itemdb-schema": [
				"../../../packages/data/codegen/generated/itemdb-schema.ts"
			]
		},
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"ignoreDeprecations": "6.0"
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"exclude": ["node_modules", "dist"]
}
