					},
					"cache-from": [
						"type=gha",
						"type=registry,ref=ghcr.io/kbve/ows-instancemanagement:buildcache"
					],
					"cache-to": [
						"type=registry,ref=ghcr.io/kbve/ows-instancemanagement:buildcache,mode=max"
					]
				}
			}
		},
