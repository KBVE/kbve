{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Death Slayer Launcher",
	"version": "0.1.0",
	"identifier": "com.kbve.deathslayer.launcher",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:1423",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "Death Slayer Launcher",
				"width": 1000,
				"height": 650,
				"minWidth": 800,
				"minHeight": 500,
				"resizable": true,
				"visible": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"plugins": {
		"deep-link": {
			"desktop": {
				"schemes": ["deathslayer-launcher"]
			}
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"macOS": {
			"entitlements": null,
			"exceptionDomain": "",
			"frameworks": [],
			"providerShortName": null,
			"signingIdentity": null
		}
	}
}
