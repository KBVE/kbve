---
import Layout from '../layouts/Layout.astro';
import AstroServerGrid from '../components/servers/AstroServerGrid.astro';

const BOT_INVITE = '/discord';

const stats = [
	{ value: '2.5k+', label: 'servers listed' },
	{ value: '180k+', label: 'members reached' },
	{ value: '24/7', label: 'bot uptime' },
];

const commands = [
	{
		cmd: '/dungeon',
		args: 'start --class rogue',
		title: 'Dungeon Crawler',
		body: 'Raid The Glass Catacombs with your party. Classes, gear, crits, boss enrages — a full RPG living inside Discord.',
		tag: 'game',
	},
	{
		cmd: '/github',
		args: 'issues --repo kbve/kbve',
		title: 'GitHub Ops',
		body: 'Issues, PRs and repo intel piped straight into chat. Ship without alt-tabbing.',
		tag: 'tools',
	},
	{
		cmd: '/vote',
		args: 'cast --server pixel-legends',
		title: 'Topsite Directory',
		body: 'List your server, climb the vote board, get discovered. The directory is the front page of Discord.',
		tag: 'topsite',
	},
];
---

<Layout title="Discord.sh — Discord Bot & Server Directory">
	<main class="dsh-main">
		{/* ── HERO ─────────────────────────────────────────── */}
		<section class="hero">
			<div class="hero-copy">
				<span class="hero-eyebrow">
					<span class="blink">▊</span> rust · discord · topsite
				</span>
				<h1 class="hero-title">
					<span class="line">the discord bot,</span>
					<span class="line">forged in <em>rust</em>.</span>
				</h1>
				<p class="hero-sub">
					discord.sh is a blazing-fast Discord bot written in Rust —
					games, tools and a server directory shipped in one binary.
					Add it to your guild, or list your community and climb the
					board.
				</p>
				<div class="hero-cta">
					<a class="btn btn-primary" href={BOT_INVITE}>
						<span class="btn-prompt">$</span> add the bot
					</a>
					<a class="btn btn-ghost" href="#directory">
						<span class="btn-prompt">&gt;</span> browse servers
					</a>
				</div>
				<ul class="hero-stats">
					{
						stats.map((s) => (
							<li>
								<span class="stat-value">{s.value}</span>
								<span class="stat-label">{s.label}</span>
							</li>
						))
					}
				</ul>
			</div>

			{/* Terminal window */}
			<div class="term" aria-hidden="true">
				<div class="term-bar">
					<span class="dot dot-r"></span>
					<span class="dot dot-y"></span>
					<span class="dot dot-g"></span>
					<span class="term-title">discord.sh — zsh</span>
				</div>
				<div class="term-body">
					<p class="t-line t1">
						<span class="t-prompt">➜</span>
						<span class="t-path">~</span> cargo run --release -p discordsh
					</p>
					<p class="t-line t2">
						<span class="rust">Compiling</span> discordsh
						<span class="dim">(poise + serenity + axum)</span>
					</p>
					<p class="t-line t3">
						<span class="ok">✔</span> gateway connected
						<span class="dim">— shards [3/3]</span>
					</p>
					<p class="t-line t4">
						<span class="ok">✔</span> directory synced
						<span class="dim">— 2,500+ servers</span>
					</p>
					<p class="t-line t5">
						<span class="t-prompt">➜</span>
						<span class="t-path">~</span> /dungeon start
					</p>
					<p class="t-line t6">
						<span class="accent">⚔</span> party formed. entering room
						1…<span class="blink">▊</span>
					</p>
				</div>
				<div class="term-glow"></div>
			</div>
		</section>

		{/* ── COMMANDS ─────────────────────────────────────── */}
		<section class="commands">
			<header class="section-head">
				<h2><span class="hash">#</span> what it does</h2>
			</header>
			<div class="command-grid">
				{
					commands.map((c) => (
						<article class="cmd-card">
							<div class="cmd-top">
								<code class="cmd-code">
									<span class="cmd-name">{c.cmd}</span>{' '}
									<span class="cmd-args">{c.args}</span>
								</code>
								<span class={`cmd-tag tag-${c.tag}`}>
									{c.tag}
								</span>
							</div>
							<h3 class="cmd-title">{c.title}</h3>
							<p class="cmd-body">{c.body}</p>
						</article>
					))
				}
			</div>
		</section>

		{/* ── DIRECTORY ────────────────────────────────────── */}
		<section id="directory" class="directory">
			<header class="section-head">
				<h2><span class="hash">#</span> server directory</h2>
				<p>
					browse live communities — vote for your favorites or&nbsp;<a
						href="/servers/submit"
						class="inline-link">
						list your own
					</a>.
				</p>
			</header>
			<AstroServerGrid />
		</section>
	</main>
</Layout>

<style>
	.dsh-main {
		max-width: 76rem;
		margin: 0 auto;
		padding: 0 1.25rem 5rem;
		color: var(--sl-color-white, #f4f4f5);
	}

	/* ── Hero ─────────────────────────────────────────────── */
	.hero {
		display: grid;
		grid-template-columns: 1.1fr 1fr;
		gap: 3rem;
		align-items: center;
		padding: 5.5rem 0 5rem;
		position: relative;
	}
	@media (max-width: 56rem) {
		.hero {
			grid-template-columns: 1fr;
			padding-top: 3.5rem;
			text-align: center;
		}
	}

	.hero-eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-family: var(--dsh-font-mono);
		font-size: var(--dsh-text-sm);
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--sl-color-accent-high, #c4b5fd);
		border: 1px solid
			color-mix(in srgb, var(--sl-color-accent) 35%, transparent);
		background: color-mix(in srgb, var(--sl-color-accent) 8%, transparent);
		border-radius: 999px;
		padding: 0.35rem 0.9rem;
		margin-bottom: 1.75rem;
	}

	.hero-title {
		font-size: clamp(2.6rem, 6.5vw, 4.5rem);
		line-height: 1.02;
		font-weight: 850;
		letter-spacing: -0.03em;
		margin: 0 0 1.4rem;
	}
	.hero-title .line {
		display: block;
	}
	.hero-title em {
		font-style: normal;
		background: linear-gradient(
			100deg,
			var(--sl-color-accent, #8b5cf6),
			#22d3ee
		);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}

	.hero-sub {
		font-size: clamp(1rem, 2vw, 1.15rem);
		color: var(--sl-color-gray-2, #a1a1aa);
		max-width: 44ch;
		margin: 0 0 2.25rem;
		line-height: 1.6;
	}
	@media (max-width: 56rem) {
		.hero-sub {
			margin-inline: auto;
		}
	}

	.hero-cta {
		display: flex;
		gap: 0.85rem;
		flex-wrap: wrap;
	}
	@media (max-width: 56rem) {
		.hero-cta {
			justify-content: center;
		}
	}

	.btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-family: var(--dsh-font-mono);
		font-size: var(--dsh-text-base);
		font-weight: 600;
		padding: 0.8rem 1.6rem;
		border-radius: var(--dsh-radius-md);
		text-decoration: none;
		transition:
			transform 160ms ease,
			box-shadow 220ms ease,
			border-color 160ms ease,
			background-color 160ms ease;
	}
	.btn:hover {
		transform: translateY(-2px);
	}
	.btn:active {
		transform: translateY(0);
	}
	.btn-prompt {
		opacity: 0.7;
	}
	.btn-primary {
		background: linear-gradient(
			120deg,
			var(--sl-color-accent, #8b5cf6),
			#7c3aed 60%
		);
		color: #fff;
		box-shadow:
			0 0 0 1px
				color-mix(in srgb, var(--sl-color-accent) 60%, transparent),
			0 10px 30px
				color-mix(in srgb, var(--sl-color-accent) 40%, transparent);
	}
	.btn-primary:hover {
		box-shadow:
			0 0 0 1px var(--sl-color-accent),
			0 14px 40px
				color-mix(in srgb, var(--sl-color-accent) 55%, transparent);
	}
	.btn-ghost {
		background: color-mix(in srgb, #fff 4%, transparent);
		color: var(--sl-color-white, #f4f4f5);
		border: 1px solid var(--sl-color-gray-5, #3f3f46);
		backdrop-filter: blur(6px);
	}
	.btn-ghost:hover {
		border-color: #22d3ee;
		box-shadow: 0 10px 30px color-mix(in srgb, #22d3ee 20%, transparent);
	}

	.hero-stats {
		list-style: none;
		display: flex;
		gap: 2.75rem;
		margin: 2.75rem 0 0;
		padding: 0;
		flex-wrap: wrap;
	}
	@media (max-width: 56rem) {
		.hero-stats {
			justify-content: center;
		}
	}
	.stat-value {
		display: block;
		font-family: var(--dsh-font-mono);
		font-size: 1.6rem;
		font-weight: 800;
		background: linear-gradient(120deg, #fff, #a5b4fc);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}
	.stat-label {
		font-size: var(--dsh-text-sm);
		letter-spacing: 0.08em;
		color: var(--sl-color-gray-2, #a1a1aa);
	}

	/* ── Terminal ─────────────────────────────────────────── */
	.term {
		position: relative;
		border-radius: var(--dsh-radius-lg);
		background: color-mix(in srgb, #0d0d14 92%, var(--sl-color-accent));
		border: 1px solid
			color-mix(in srgb, var(--sl-color-accent) 30%, #27272a);
		box-shadow:
			0 30px 80px rgba(0, 0, 0, 0.55),
			0 0 60px color-mix(in srgb, var(--sl-color-accent) 12%, transparent);
		overflow: hidden;
		transform: perspective(1200px) rotateY(-4deg) rotateX(2deg);
		transition: transform 400ms ease;
	}
	.term:hover {
		transform: perspective(1200px) rotateY(0deg) rotateX(0deg);
	}
	.term-bar {
		display: flex;
		align-items: center;
		gap: 0.45rem;
		padding: 0.7rem 1rem;
		background: rgba(255, 255, 255, 0.04);
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
	}
	.dot {
		width: 0.7rem;
		height: 0.7rem;
		border-radius: 50%;
	}
	.dot-r {
		background: #ff5f57;
	}
	.dot-y {
		background: #febc2e;
	}
	.dot-g {
		background: #28c840;
	}
	.term-title {
		margin-left: 0.6rem;
		font-family: var(--dsh-font-mono);
		font-size: 0.72rem;
		color: var(--sl-color-gray-2, #a1a1aa);
	}
	.term-body {
		padding: var(--dsh-space-md) 1.4rem 1.6rem;
		font-family: var(--dsh-font-mono);
		font-size: var(--dsh-text-sm);
		line-height: 1.9;
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
	}
	@media (max-width: 26rem) {
		.term-body {
			font-size: 0.72rem;
			padding: var(--dsh-space-sm) var(--dsh-space-md);
		}
	}
	.t-line {
		margin: 0;
		white-space: nowrap;
		overflow: hidden;
		opacity: 0;
		animation: t-reveal 300ms ease forwards;
	}
	.t1 {
		animation-delay: 200ms;
	}
	.t2 {
		animation-delay: 900ms;
	}
	.t3 {
		animation-delay: 1400ms;
	}
	.t4 {
		animation-delay: 1900ms;
	}
	.t5 {
		animation-delay: 2700ms;
	}
	.t6 {
		animation-delay: 3400ms;
	}
	@keyframes t-reveal {
		from {
			opacity: 0;
			transform: translateY(4px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
	.t-prompt {
		color: #22d3ee;
		font-weight: 700;
	}
	.t-path {
		color: var(--sl-color-accent-high, #c4b5fd);
	}
	.ok {
		color: #4ade80;
	}
	.rust {
		color: #fb923c;
		font-weight: 700;
	}
	.dim {
		color: var(--sl-color-gray-2, #71717a);
	}
	.accent {
		color: var(--sl-color-accent, #8b5cf6);
	}
	.blink {
		animation: blink 1.1s steps(1) infinite;
		color: var(--sl-color-accent-high, #c4b5fd);
	}
	@keyframes blink {
		50% {
			opacity: 0;
		}
	}
	.term-glow {
		position: absolute;
		inset: auto -20% -50% -20%;
		height: 60%;
		background: radial-gradient(
			50% 100% at 50% 100%,
			color-mix(in srgb, var(--sl-color-accent) 25%, transparent),
			transparent 70%
		);
		pointer-events: none;
	}
	@media (prefers-reduced-motion: reduce) {
		.t-line {
			animation: none;
			opacity: 1;
		}
		.blink {
			animation: none;
		}
		.term {
			transform: none;
		}
	}

	/* ── Sections ─────────────────────────────────────────── */
	.section-head {
		margin: 0 0 1.75rem;
	}
	.section-head h2 {
		font-size: clamp(1.5rem, 3.5vw, 2.1rem);
		font-weight: 800;
		letter-spacing: -0.02em;
		margin: 0 0 0.4rem;
	}
	.hash {
		color: var(--sl-color-accent, #8b5cf6);
		font-family: var(--dsh-font-mono);
	}
	.section-head p {
		color: var(--sl-color-gray-2, #a1a1aa);
		margin: 0;
	}
	.inline-link {
		color: var(--sl-color-accent-high, #c4b5fd);
		text-decoration: underline;
		text-underline-offset: 3px;
	}
	.inline-link:hover {
		color: #fff;
	}

	/* ── Command cards ────────────────────────────────────── */
	.commands {
		padding: 2rem 0 4.5rem;
	}
	.command-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
		gap: 1.1rem;
	}
	.cmd-card {
		position: relative;
		border-radius: var(--dsh-radius-lg);
		padding: 1.4rem 1.4rem 1.5rem;
		background: linear-gradient(
			160deg,
			color-mix(
				in srgb,
				var(--sl-color-bg-nav, #18181b) 88%,
				var(--sl-color-accent)
			),
			#101016
		);
		border: 1px solid var(--sl-color-hairline, #27272a);
		transition:
			transform 220ms ease,
			border-color 220ms ease,
			box-shadow 220ms ease;
		overflow: hidden;
	}
	.cmd-card::before {
		content: '';
		position: absolute;
		inset: 0 0 auto;
		height: 1px;
		background: linear-gradient(
			90deg,
			transparent,
			color-mix(in srgb, var(--sl-color-accent) 60%, transparent),
			transparent
		);
		opacity: 0;
		transition: opacity 220ms ease;
	}
	.cmd-card:hover {
		transform: translateY(-4px);
		border-color: color-mix(
			in srgb,
			var(--sl-color-accent) 45%,
			transparent
		);
		box-shadow: 0 18px 50px rgba(0, 0, 0, 0.45);
	}
	.cmd-card:hover::before {
		opacity: 1;
	}
	.cmd-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
		margin-bottom: 1rem;
	}
	.cmd-code {
		font-family: var(--dsh-font-mono);
		font-size: var(--dsh-text-sm);
		padding: 0.35rem 0.6rem;
		border-radius: var(--dsh-radius-sm);
		background: rgba(0, 0, 0, 0.45);
		border: 1px solid rgba(255, 255, 255, 0.07);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	.cmd-name {
		color: #22d3ee;
		font-weight: 700;
	}
	.cmd-args {
		color: var(--sl-color-gray-2, #a1a1aa);
	}
	.cmd-tag {
		font-family: var(--dsh-font-mono);
		font-size: 0.65rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		padding: 0.2rem 0.55rem;
		border-radius: 999px;
		flex-shrink: 0;
	}
	.tag-game {
		color: #f0abfc;
		background: rgba(232, 121, 249, 0.12);
		border: 1px solid rgba(232, 121, 249, 0.3);
	}
	.tag-tools {
		color: #67e8f9;
		background: rgba(34, 211, 238, 0.1);
		border: 1px solid rgba(34, 211, 238, 0.3);
	}
	.tag-topsite {
		color: #c4b5fd;
		background: rgba(139, 92, 246, 0.12);
		border: 1px solid rgba(139, 92, 246, 0.35);
	}
	.cmd-title {
		margin: 0 0 0.45rem;
		font-size: var(--dsh-text-lg);
		font-weight: 750;
	}
	.cmd-body {
		margin: 0;
		font-size: var(--dsh-text-sm);
		line-height: 1.55;
		color: var(--sl-color-gray-2, #a1a1aa);
	}

	/* ── Directory ────────────────────────────────────────── */
	.directory .section-head {
		text-align: center;
	}
	.directory {
		scroll-margin-top: 5rem;
	}
</style>
