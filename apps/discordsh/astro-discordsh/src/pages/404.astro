---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="404 — command not found | Discord.sh"
	description="This page does not exist.">
	<main class="nf-main">
		<div class="nf-term" role="presentation">
			<div class="nf-bar">
				<span class="dot dot-r"></span>
				<span class="dot dot-y"></span>
				<span class="dot dot-g"></span>
				<span class="nf-title">discord.sh — zsh</span>
			</div>
			<div class="nf-body">
				<p class="nf-line">
					<span class="nf-prompt">➜</span>
					<span class="nf-path">~</span> cat {'{page}'}
				</p>
				<p class="nf-line nf-err">
					zsh: no such file or directory: <span
						class="nf-req"
						id="nf-req">
						/404
					</span>
				</p>
				<p class="nf-line">
					<span class="nf-prompt">➜</span>
					<span class="nf-path">~</span> echo $?
				</p>
				<p class="nf-line nf-code">404</p>
				<p class="nf-line">
					<span class="nf-prompt">➜</span>
					<span class="nf-path">~</span>
					<span class="blink">▊</span>
				</p>
			</div>
		</div>

		<h1 class="nf-heading">
			<span class="accent">404</span> — command not found
		</h1>
		<p class="nf-sub">
			The page you're looking for got moved, deleted, or never compiled.
		</p>

		<div class="nf-cta">
			<a class="btn btn-primary" href="/">
				<span class="btn-prompt">$</span> cd ~
			</a>
			<a class="btn btn-ghost" href="/#directory">
				<span class="btn-prompt">&gt;</span> browse servers
			</a>
		</div>
	</main>
</Layout>

<script>
	const el = document.getElementById('nf-req');
	if (el) el.textContent = window.location.pathname;
</script>

<style>
	.nf-main {
		max-width: 40rem;
		margin: 0 auto;
		padding: 5rem 1.25rem 6rem;
		text-align: center;
		color: var(--sl-color-white, #f4f4f5);
	}

	.nf-term {
		text-align: left;
		border-radius: var(--dsh-radius-lg);
		background: color-mix(in srgb, #0d0d14 92%, var(--sl-color-accent));
		border: 1px solid
			color-mix(in srgb, var(--sl-color-accent) 30%, #27272a);
		box-shadow:
			0 30px 80px rgba(0, 0, 0, 0.55),
			0 0 60px color-mix(in srgb, var(--sl-color-accent) 12%, transparent);
		overflow: hidden;
		margin-bottom: 2.5rem;
	}
	.nf-bar {
		display: flex;
		align-items: center;
		gap: 0.45rem;
		padding: 0.7rem 1rem;
		background: rgba(255, 255, 255, 0.04);
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
	}
	.dot {
		width: 0.7rem;
		height: 0.7rem;
		border-radius: 50%;
	}
	.dot-r {
		background: #ff5f57;
	}
	.dot-y {
		background: #febc2e;
	}
	.dot-g {
		background: #28c840;
	}
	.nf-title {
		margin-left: 0.6rem;
		font-family: var(--dsh-font-mono);
		font-size: 0.72rem;
		color: var(--sl-color-gray-2, #a1a1aa);
	}
	.nf-body {
		padding: var(--dsh-space-md) 1.4rem 1.5rem;
		font-family: var(--dsh-font-mono);
		font-size: var(--dsh-text-sm);
		line-height: 1.9;
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
	}
	.nf-line {
		white-space: nowrap;
	}
	@media (max-width: 26rem) {
		.nf-body {
			font-size: 0.72rem;
			padding: var(--dsh-space-sm) var(--dsh-space-md);
		}
	}
	.nf-line {
		margin: 0;
	}
	.nf-prompt {
		color: #22d3ee;
		font-weight: 700;
	}
	.nf-path {
		color: var(--sl-color-accent-high, #c4b5fd);
	}
	.nf-err {
		color: #f87171;
	}
	.nf-req {
		text-decoration: underline;
		text-underline-offset: 3px;
	}
	.nf-code {
		color: #fb923c;
		font-weight: 700;
	}
	.blink {
		animation: blink 1.1s steps(1) infinite;
		color: var(--sl-color-accent-high, #c4b5fd);
	}
	@keyframes blink {
		50% {
			opacity: 0;
		}
	}
	@media (prefers-reduced-motion: reduce) {
		.blink {
			animation: none;
		}
	}

	.nf-heading {
		font-size: clamp(1.8rem, 5vw, 2.6rem);
		font-weight: 850;
		letter-spacing: -0.02em;
		margin: 0 0 0.75rem;
	}
	.accent {
		background: linear-gradient(
			100deg,
			var(--sl-color-accent, #8b5cf6),
			#22d3ee
		);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}
	.nf-sub {
		color: var(--sl-color-gray-2, #a1a1aa);
		margin: 0 0 2rem;
	}

	.nf-cta {
		display: flex;
		gap: 0.85rem;
		justify-content: center;
		flex-wrap: wrap;
	}
	.btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-family: var(--dsh-font-mono);
		font-size: var(--dsh-text-base);
		font-weight: 600;
		padding: 0.8rem 1.6rem;
		border-radius: var(--dsh-radius-md);
		text-decoration: none;
		transition:
			transform 160ms ease,
			box-shadow 220ms ease,
			border-color 160ms ease;
	}
	.btn:hover {
		transform: translateY(-2px);
	}
	.btn-prompt {
		opacity: 0.7;
	}
	.btn-primary {
		background: linear-gradient(
			120deg,
			var(--sl-color-accent, #8b5cf6),
			#7c3aed 60%
		);
		color: #fff;
		box-shadow: 0 10px 30px
			color-mix(in srgb, var(--sl-color-accent) 40%, transparent);
	}
	.btn-ghost {
		background: color-mix(in srgb, #fff 4%, transparent);
		color: var(--sl-color-white, #f4f4f5);
		border: 1px solid var(--sl-color-gray-5, #3f3f46);
	}
	.btn-ghost:hover {
		border-color: #22d3ee;
	}
</style>
