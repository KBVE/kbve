# Unreal Engine 5.8 Cleanroom .gitignore

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/

# Rider cache directory
.idea/

# Visual Studio Code cache directory
.vscode/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# Unreal Engine Build Files
Binaries/
Build/
DerivedDataCache/
Intermediate/
Saved/
Script/

# Unreal Engine Plugin Intermediate
Plugins/*/Binaries/
Plugins/*/Intermediate/

# Compiled source files for the engine to use
*.VC.db
*.opensdf
*.opendb
*.sdf
*.sln
*.suo
*.xcodeproj
*.xcworkspace

# Cache files for the editor
DerivedDataCache/*

# Content - track only Fab Store evaluation assets
# Block all Content, then whitelist specific Fab assets
Content/*
!Content/Wildlands/
!Content/Wildwood/
# World Partition / One-File-Per-Actor external storage for the whitelisted maps.
# These dirs are SIBLINGS of the map folders (e.g. Content/__ExternalActors__/Wildlands/...),
# so the `Content/*` block above hides them. Re-include one level at a time, then
# scope back down to the same Fab packs so only their placed-actor files are tracked.
!Content/__ExternalActors__/
Content/__ExternalActors__/*
!Content/__ExternalActors__/Wildlands/
!Content/__ExternalActors__/Wildwood/
!Content/__ExternalObjects__/
Content/__ExternalObjects__/*
!Content/__ExternalObjects__/Wildlands/
!Content/__ExternalObjects__/Wildwood/
# Future Fab assets - add explicit whitelist entries here

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Thumbnails
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Crash logs
*.log
*.dmp

# Build artifacts
*.target.xml

# ShaderCache
/Saved/ShaderDebugInfo/

# Automation Testing Cache
/Saved/Automation/

# Analytics Cache
/Saved/Analytics/
