{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "chuck-launcher",
	"version": "0.1.0",
	"identifier": "com.kbve.chuckrpg.launcher",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:1422",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "ChuckRPG Launcher",
				"width": 900,
				"height": 600,
				"minWidth": 640,
				"minHeight": 420,
				"resizable": true,
				"visible": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
