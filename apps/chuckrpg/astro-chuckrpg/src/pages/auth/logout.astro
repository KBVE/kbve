---
// Sign-out handler — plain Astro page, no Starlight wrapper
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>Signing out... - ChuckRPG</title>
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Lora:ital,wght@0,400;0,600;1,400&display=swap"
		/>
		<style>
			body {
				margin: 0;
				padding: 0;
				font-family: 'Lora', 'Georgia', serif;
				display: flex;
				align-items: center;
				justify-content: center;
				min-height: 100vh;
				background: #1a1a1f;
				color: #e8dcc8;
			}
			.container {
				text-align: center;
			}
			.ck-spinner {
				width: 50px;
				height: 50px;
				margin: 0 auto 20px;
				border: 4px solid #3d2800;
				border-top-color: #d4a44c;
				border-radius: 50%;
				animation: spin 1s linear infinite;
			}
			@keyframes spin {
				to {
					transform: rotate(360deg);
				}
			}
			.ck-status-message {
				font-family: 'Cinzel', serif;
				font-size: 1.125rem;
				color: #e8dcc8;
				margin-bottom: 0.5rem;
			}
			.ck-status-sub {
				font-size: 0.875rem;
				color: #6b6356;
			}
		</style>
	</head>
	<body>
		<div class="container">
			<div class="ck-spinner"></div>
			<div class="ck-status-message">Signing out...</div>
			<div class="ck-status-sub">Please wait</div>
		</div>

		<script>
			import '../../lib/auth/logout';
		</script>
	</body>
</html>
