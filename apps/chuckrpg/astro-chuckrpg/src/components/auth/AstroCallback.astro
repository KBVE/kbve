---
import ReactAuthCallback from './ReactAuthCallback';
---

<ReactAuthCallback client:only="react" />

<style is:global>
	.ck-auth-status {
		text-align: center;
		padding: 3rem 1rem;
		min-height: 250px;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
	}

	.ck-spinner {
		width: 50px;
		height: 50px;
		margin: 0 auto 20px;
		border: 4px solid var(--sl-color-accent-low);
		border-top-color: var(--ck-firelight);
		border-radius: 50%;
		animation: ck-spin 1s linear infinite;
	}

	@keyframes ck-spin {
		to {
			transform: rotate(360deg);
		}
	}

	.ck-status-message {
		font-family: var(--sl-font);
		font-size: 1.125rem;
		color: var(--ck-parchment);
		margin-bottom: 0.5rem;
	}

	.ck-status-sub {
		font-size: 0.875rem;
		color: var(--sl-color-gray-3);
	}
</style>
