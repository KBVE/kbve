; Git LFS endpoint for chuck / unreal-chuck binary assets.
;
; Pointer files (~150 byte text stubs) live in this GitHub monorepo;
; the real blobs live on the self-hosted Forgejo instance at
; git.kbve.com/KBVE/chuck.git. Routing is via ingress-nginx (.74)
; not the Cilium gateway (.71) for the same Cloudflare-origin reason
; documented in the rareicon .lfsconfig at the repo root.
;
; LIMITATION: stock git-lfs only honors `lfs.url` from the .lfsconfig
; at the *repository root* (apps/.. is ignored). The repo-root
; .lfsconfig still points at KBVE/rareicon. To push/pull chuck LFS
; blobs to the correct endpoint, use the kbve.sh wrapper:
;
;   ./kbve.sh -lfs chuck push origin <branch>
;   ./kbve.sh -lfs chuck pull
;   ./kbve.sh -lfs chuck fetch --all
;
; The wrapper injects `-c lfs.url=<this url>` so devs never have to
; remember it. This .lfsconfig stays as the documented source of
; truth for the endpoint value the wrapper hard-codes.
[lfs]
    url = https://git.kbve.com/KBVE/chuck.git/info/lfs
