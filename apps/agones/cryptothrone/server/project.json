{
	"name": "cryptothrone-server",
	"$schema": "../../../../node_modules/nx/schemas/project-schema.json",
	"projectType": "application",
	"sourceRoot": "apps/agones/cryptothrone/server/src",
	"tags": ["rust", "game-server", "agones", "cryptothrone"],
	"targets": {
		"build": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cargo build -p cryptothrone-server"
			},
			"outputs": ["{workspaceRoot}/dist/target/debug/cryptothrone-server"]
		},
		"build-release": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cargo build --release -p cryptothrone-server"
			},
			"outputs": [
				"{workspaceRoot}/dist/target/release/cryptothrone-server"
			]
		},
		"run": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cargo run -p cryptothrone-server"
			}
		},
		"test": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cargo test -p cryptothrone-server"
			}
		},
		"lint": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cargo clippy -p cryptothrone-server --all-targets -- -D warnings"
			}
		},
		"e2e": {
			"executor": "nx:run-commands",
			"dependsOn": [
				{
					"target": "container",
					"projects": ["cryptothrone-server"],
					"params": "forward"
				}
			],
			"cache": false,
			"options": {
				"commands": [
					"docker rm -f cryptothrone-server-e2e 2>/dev/null || true",
					"docker run -d --name cryptothrone-server-e2e -p 7979:7979 -e CT_SERVER_ADDR=0.0.0.0:7979 kbve/cryptothrone-server:latest",
					"echo 'Waiting for cryptothrone-server...' && for i in $(seq 1 60); do if curl -fsS http://127.0.0.1:7979/healthz >/dev/null 2>&1; then echo 'ready after '\"$i\"'s'; break; fi; if [ $i -eq 60 ]; then echo 'did not start in 60s'; docker logs cryptothrone-server-e2e 2>&1 | tail -80; docker rm -f cryptothrone-server-e2e 2>/dev/null || true; exit 1; fi; sleep 1; done",
					"CT_HOST=127.0.0.1 CT_PORT=7979 npx vitest run; EC=$?; echo '--- container logs ---'; docker logs cryptothrone-server-e2e 2>&1 | tail -80; docker rm -f cryptothrone-server-e2e 2>/dev/null || true; exit $EC"
				],
				"parallel": false,
				"cwd": "apps/agones/cryptothrone/server"
			},
			"configurations": {
				"ci": {}
			}
		},
		"container": {
			"executor": "@nx-tools/nx-container:build",
			"defaultConfiguration": "local",
			"options": {
				"engine": "docker",
				"context": ".",
				"file": "apps/agones/cryptothrone/server/Dockerfile",
				"metadata": {
					"images": ["kbve/cryptothrone-server"],
					"load": true,
					"tags": ["latest"]
				}
			},
			"configurations": {
				"local": {
					"tags": ["latest"],
					"push": false
				},
				"production": {
					"tags": ["latest"],
					"push": false,
					"cache-from": [
						"type=registry,ref=ghcr.io/kbve/cryptothrone-server:buildcache"
					],
					"cache-to": [
						"type=registry,ref=ghcr.io/kbve/cryptothrone-server:buildcache,mode=max"
					]
				}
			}
		}
	}
}
