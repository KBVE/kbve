{
	"name": "isometric",
	"$schema": "../../../node_modules/nx/schemas/project-schema.json",
	"projectType": "application",
	"sourceRoot": "apps/kbve/isometric",
	"targets": {
		"lint": {
			"executor": "@nx/eslint:lint",
			"options": {
				"lintFilePatterns": ["apps/kbve/isometric/src/**/*.{ts,tsx}"]
			}
		},
		"dev": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"lsof -ti:1420 | xargs kill 2>/dev/null; export PATH=\"$HOME/.cargo/bin:$PATH\" && pnpm build:wasm && pnpm dev"
				],
				"cwd": "apps/kbve/isometric"
			}
		},
		"wasm": {
			"executor": "nx:run-commands",
			"cache": false,
			"options": {
				"parallel": false,
				"commands": [
					"lsof -ti:1420 | xargs kill 2>/dev/null || true",
					"mkdir -p certificates && (openssl x509 -checkend 86400 -noout -in certificates/cert.pem 2>/dev/null || mkcert -cert-file certificates/cert.pem -key-file certificates/key.pem localhost 127.0.0.1)",
					"export PATH=\"$HOME/.cargo/bin:$PATH\" && pnpm build:wasm",
					"GAME_API_TARGET=https://kbve.com pnpm dev"
				],
				"cwd": "apps/kbve/isometric"
			}
		},
		"quick": {
			"executor": "nx:run-commands",
			"options": {
				"commands": ["bash ../../../scripts/deploy_isometric_quick.sh"],
				"cwd": "apps/kbve/isometric"
			}
		},
		"build": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"export PATH=\"$HOME/.cargo/bin:$PATH\" && pnpm build"
				],
				"cwd": "apps/kbve/isometric"
			}
		},
		"deploy": {
			"dependsOn": ["build"],
			"executor": "nx:run-commands",
			"options": {
				"parallel": false,
				"commands": [
					"rm -rf ../astro-kbve/public/isometric",
					"mkdir -p ../astro-kbve/public",
					"cp -r dist ../astro-kbve/public/isometric"
				],
				"cwd": "apps/kbve/isometric"
			}
		},
		"run": {
			"executor": "nx:run-commands",
			"cache": false,
			"options": {
				"command": "cargo run -p isometric-game",
				"cwd": "{workspaceRoot}"
			},
			"configurations": {
				"production": {
					"command": "GAME_SERVER_URL=wss://kbve.com/ws cargo run -p isometric-game",
					"cwd": "{workspaceRoot}"
				}
			}
		},
		"build:tauri": {
			"executor": "nx:run-commands",
			"options": {
				"commands": ["cargo tauri build"],
				"cwd": "apps/kbve/isometric"
			},
			"configurations": {
				"production": {
					"commands": ["cargo tauri build --release"],
					"cwd": "apps/kbve/isometric"
				}
			}
		}
	},
	"tags": []
}
