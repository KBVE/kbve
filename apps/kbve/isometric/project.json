{
	"name": "isometric",
	"$schema": "../../../node_modules/nx/schemas/project-schema.json",
	"projectType": "application",
	"sourceRoot": "apps/kbve/isometric",
	"targets": {
		"dev": {
			"executor": "nx:run-commands",
			"options": {
				"commands": ["cargo tauri dev"],
				"cwd": "apps/kbve/isometric"
			}
		},
		"build": {
			"executor": "nx:run-commands",
			"options": {
				"commands": ["cargo tauri build"],
				"cwd": "apps/kbve/isometric"
			},
			"configurations": {
				"production": {
					"commands": ["cargo tauri build --release"],
					"cwd": "apps/kbve/isometric"
				}
			}
		}
	},
	"tags": []
}
