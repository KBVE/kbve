{
	"name": "isometric",
	"$schema": "../../../node_modules/nx/schemas/project-schema.json",
	"projectType": "application",
	"sourceRoot": "apps/kbve/isometric",
	"targets": {
		"lint": {
			"executor": "@nx/eslint:lint",
			"options": {
				"lintFilePatterns": ["apps/kbve/isometric/src/**/*.{ts,tsx}"]
			}
		},
		"dev": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"lsof -ti:1420 | xargs kill 2>/dev/null; export PATH=\"$HOME/.cargo/bin:$PATH\" && pnpm build:wasm && pnpm dev"
				],
				"cwd": "apps/kbve/isometric"
			}
		},
		"quick": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"lsof -ti:1420 | xargs kill 2>/dev/null; lsof -ti:5000 | xargs kill 2>/dev/null; set -a && [ -f ../../../.env ] && . ../../../.env && set +a && export PATH=\"$HOME/.cargo/bin:$PATH\" && cd src-tauri && wasm-pack build --dev --target web --out-dir ../wasm-pkg --out-name isometric_game && cd .. && cargo run -p axum-kbve & pnpm dev"
				],
				"cwd": "apps/kbve/isometric"
			}
		},
		"build": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"export PATH=\"$HOME/.cargo/bin:$PATH\" && pnpm build"
				],
				"cwd": "apps/kbve/isometric"
			}
		},
		"deploy": {
			"dependsOn": ["build"],
			"executor": "nx:run-commands",
			"options": {
				"parallel": false,
				"commands": [
					"rm -rf ../astro-kbve/public/isometric",
					"mkdir -p ../astro-kbve/public",
					"cp -r dist ../astro-kbve/public/isometric"
				],
				"cwd": "apps/kbve/isometric"
			}
		},
		"build:tauri": {
			"executor": "nx:run-commands",
			"options": {
				"commands": ["cargo tauri build"],
				"cwd": "apps/kbve/isometric"
			},
			"configurations": {
				"production": {
					"commands": ["cargo tauri build --release"],
					"cwd": "apps/kbve/isometric"
				}
			}
		}
	},
	"tags": []
}
