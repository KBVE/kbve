{
	"name": "isometric",
	"$schema": "../../../node_modules/nx/schemas/project-schema.json",
	"projectType": "application",
	"sourceRoot": "apps/kbve/isometric",
	"targets": {
		"lint": {
			"executor": "@nx/eslint:lint",
			"options": {
				"lintFilePatterns": ["apps/kbve/isometric/src/**/*.{ts,tsx}"]
			}
		},
		"dev": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"lsof -ti:1420 | xargs kill 2>/dev/null; pnpm build:wasm && pnpm dev"
				],
				"cwd": "apps/kbve/isometric",
				"env": {
					"PATH": "${HOME}/.cargo/bin:${PATH}"
				}
			}
		},
		"build": {
			"executor": "nx:run-commands",
			"options": {
				"commands": ["pnpm build"],
				"cwd": "apps/kbve/isometric",
				"env": {
					"PATH": "${HOME}/.cargo/bin:${PATH}"
				}
			}
		},
		"deploy": {
			"dependsOn": ["build"],
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"rm -rf ../astro-kbve/public/isometric",
					"cp -r dist ../astro-kbve/public/isometric"
				],
				"cwd": "apps/kbve/isometric"
			}
		},
		"build:tauri": {
			"executor": "nx:run-commands",
			"options": {
				"commands": ["cargo tauri build"],
				"cwd": "apps/kbve/isometric"
			},
			"configurations": {
				"production": {
					"commands": ["cargo tauri build --release"],
					"cwd": "apps/kbve/isometric"
				}
			}
		}
	},
	"tags": []
}
