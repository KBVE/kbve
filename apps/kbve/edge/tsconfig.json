{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022", "DOM"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"noUncheckedSideEffectImports": false,
		"types": ["*"],
		"esModuleInterop": false,
		"ignoreDeprecations": "6.0"
	},
	"include": ["functions/**/*.ts"]
}
