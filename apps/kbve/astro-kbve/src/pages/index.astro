---
import BaseLayout from '../layouts/BaseLayout.astro';

const features = [
	{
		icon: '<line x1="6" x2="10" y1="11" y2="11"/><line x1="8" x2="8" y1="9" y2="13"/><line x1="15" x2="15.01" y1="12" y2="12"/><line x1="18" x2="18.01" y1="10" y2="10"/><path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.544-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5z"/>',
		title: 'Games',
		body: 'Multiplayer worlds, ARPGs, and isometric sims — shipped across web, desktop, and native engines.',
	},
	{
		icon: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
		title: 'Engines & Tools',
		body: 'Unreal & Unity plugins, Bevy/Rust crates, and a shared component kit that powers every project.',
	},
	{
		icon: '<path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/>',
		title: 'Cloud Infrastructure',
		body: 'Kubernetes, ArgoCD, ClickHouse, Supabase — production infra, all declarative, all in the open.',
	},
	{
		icon: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
		title: 'Open Source',
		body: 'One monorepo, thousands of docs pages, and every line of it public on GitHub.',
	},
];

const projects = [
	{
		name: 'CryptoThrone',
		tag: 'Isometric MMO',
		body: 'A seeded, server-authoritative isometric world with a real in-game economy.',
		href: '/gaming/',
	},
	{
		name: 'RareIcon',
		tag: 'Unity DOTS',
		body: 'A 2D sci-fi action-RPG bullet-hell roguelite built on Burst-compiled ECS.',
		href: '/gaming/',
	},
	{
		name: 'Kilobase',
		tag: 'Postgres Platform',
		body: 'Supabase-on-CNPG with migrations, auth, and vault — self-hosted and battle-tested.',
		href: '/docs/',
	},
	{
		name: 'Chuck',
		tag: 'Unreal Engine',
		body: 'An Unreal multiplayer RPG with a Rust-backed dedicated server stack.',
		href: '/gaming/',
	},
];

const stats = [
	{ value: '7.8k+', label: 'Docs pages' },
	{ value: '100%', label: 'Open source' },
	{ value: '1', label: 'Monorepo' },
	{ value: '∞', label: 'Side quests' },
];
---

<BaseLayout
	title="KBVE — Open-source games, tools & cloud"
	description="KBVE builds open-source games, developer tools, and production cloud infrastructure — all in one public monorepo."
	canonical="/"
	jsonLd={{
		'@type': 'WebPage',
		name: 'KBVE',
		description:
			'Open-source games, developer tools, and cloud infrastructure.',
	}}>
	<section data-hero>
		<div data-hero-glow></div>
		<div data-hero-inner>
			<span data-eyebrow>open-source collective</span>
			<h1>
				We build <span data-grad>games, tools,</span> and the cloud they run
				on.
			</h1>
			<p>
				KBVE is a public monorepo of multiplayer games, engine plugins,
				Rust services, and the Kubernetes infrastructure that ships them
				— all out in the open.
			</p>
			<div data-cta>
				<a class="primary" href="/docs/">Explore the Docs</a>
				<a class="ghost" href="https://github.com/kbve/kbve">
					Star on GitHub →
				</a>
			</div>
		</div>
	</section>

	<section data-section>
		<div data-section-head>
			<h2>One stack, every layer</h2>
			<p>From pixels to pods — we own the whole pipeline.</p>
		</div>
		<div data-grid>
			{
				features.map((f) => (
					<article data-card>
						<span data-card-icon>
							<svg
								viewBox="0 0 24 24"
								width="26"
								height="26"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								aria-hidden="true"
								set:html={f.icon}
							/>
						</span>
						<h3>{f.title}</h3>
						<p>{f.body}</p>
					</article>
				))
			}
		</div>
	</section>

	<section data-stats-band>
		<div data-stats-inner>
			{
				stats.map((s) => (
					<div data-stat>
						<span data-stat-value>{s.value}</span>
						<span data-stat-label>{s.label}</span>
					</div>
				))
			}
		</div>
	</section>

	<section data-section>
		<div data-section-head>
			<h2>Built in the open</h2>
			<p>A few of the worlds and systems we're shipping.</p>
		</div>
		<div data-grid data-grid-2>
			{
				projects.map((p) => (
					<a data-project href={p.href}>
						<span data-project-tag>{p.tag}</span>
						<h3>{p.name}</h3>
						<p>{p.body}</p>
						<span data-project-link>Learn more →</span>
					</a>
				))
			}
		</div>
	</section>

	<section data-cta-band>
		<div data-cta-band-inner>
			<h2>Come build with us.</h2>
			<p>Jump into the docs or hang out in the community.</p>
			<div data-cta>
				<a class="primary" href="/docs/">Read the Docs</a>
				<a class="ghost" href="/discord/">Join the Discord</a>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	[data-site-main] {
		display: block;
	}

	/* ── Hero ── */
	[data-hero] {
		position: relative;
		overflow: hidden;
		padding: 7rem 1.5rem 6rem;
		text-align: center;
	}
	[data-hero-glow] {
		position: absolute;
		inset: -20% 0 auto 0;
		height: 120%;
		background:
			radial-gradient(
				40rem 28rem at 50% 0%,
				rgba(173, 0, 19, 0.28),
				transparent 70%
			),
			radial-gradient(
				34rem 24rem at 80% 10%,
				rgba(166, 125, 67, 0.22),
				transparent 70%
			);
		pointer-events: none;
		z-index: 0;
	}
	[data-hero-inner] {
		position: relative;
		z-index: 1;
		max-width: 52rem;
		margin: 0 auto;
	}
	[data-eyebrow] {
		display: inline-block;
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: var(--color-gold-light);
		padding: 0.35rem 0.85rem;
		border: 1px solid var(--color-gold-dark);
		border-radius: 999px;
		margin-bottom: 1.5rem;
	}
	[data-hero] h1 {
		font-family: var(--sl-font);
		font-size: clamp(2.4rem, 7vw, 4.25rem);
		line-height: 1.05;
		margin: 0 0 1.25rem;
		color: var(--color-parchment);
	}
	[data-grad] {
		background: linear-gradient(
			100deg,
			var(--color-gold-light),
			var(--color-red)
		);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}
	[data-hero] p {
		font-size: clamp(1rem, 2.5vw, 1.2rem);
		line-height: 1.6;
		color: var(--color-parchment);
		opacity: 0.82;
		max-width: 38rem;
		margin: 0 auto 2.25rem;
	}

	/* ── CTAs ── */
	[data-cta] {
		display: flex;
		gap: 0.85rem;
		justify-content: center;
		flex-wrap: wrap;
	}
	[data-cta] a {
		padding: 0.7rem 1.5rem;
		border-radius: 0.6rem;
		font-weight: 600;
		font-size: 0.98rem;
		text-decoration: none;
		transition:
			transform 0.15s ease,
			background-color 0.15s ease,
			border-color 0.15s ease,
			color 0.15s ease;
	}
	[data-cta] .primary {
		background: var(--color-red);
		color: #fff;
		box-shadow: 0 8px 24px -8px rgba(173, 0, 19, 0.7);
	}
	[data-cta] .primary:hover {
		background: var(--color-red-dark);
		transform: translateY(-2px);
	}
	[data-cta] .ghost {
		border: 1px solid var(--color-gold-dark);
		color: var(--color-parchment);
	}
	[data-cta] .ghost:hover {
		border-color: var(--color-gold);
		color: var(--color-gold);
		transform: translateY(-2px);
	}

	/* ── Sections ── */
	[data-section] {
		max-width: 1120px;
		margin: 0 auto;
		padding: 5rem 1.5rem;
	}
	[data-section-head] {
		text-align: center;
		margin-bottom: 3rem;
	}
	[data-section-head] h2 {
		font-family: var(--sl-font);
		font-size: clamp(1.8rem, 4vw, 2.6rem);
		margin: 0 0 0.6rem;
		color: var(--color-parchment);
	}
	[data-section-head] p {
		margin: 0;
		font-size: 1.05rem;
		color: var(--color-parchment);
		opacity: 0.7;
	}

	[data-grid] {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
		gap: 1.25rem;
	}
	[data-grid-2] {
		grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
	}

	/* ── Feature cards ── */
	[data-card] {
		padding: 1.75rem;
		border-radius: 1rem;
		background: linear-gradient(
			160deg,
			var(--color-bg-raised),
			var(--color-bg-sunken)
		);
		border: 1px solid var(--color-gold-dark);
		transition:
			transform 0.18s ease,
			border-color 0.18s ease;
	}
	[data-card]:hover {
		transform: translateY(-4px);
		border-color: var(--color-gold);
	}
	[data-card-icon] {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3rem;
		height: 3rem;
		border-radius: 0.75rem;
		color: var(--color-gold);
		background: rgba(166, 125, 67, 0.12);
		border: 1px solid var(--color-gold-dark);
	}
	[data-card] h3 {
		font-family: var(--sl-font);
		font-size: 1.25rem;
		margin: 0.75rem 0 0.5rem;
		color: var(--color-gold);
	}
	[data-card] p {
		margin: 0;
		font-size: 0.94rem;
		line-height: 1.55;
		color: var(--color-parchment);
		opacity: 0.78;
	}

	/* ── Stats band ── */
	[data-stats-band] {
		border-block: 1px solid var(--color-gold-dark);
		background: var(--color-bg-sunken);
	}
	[data-stats-inner] {
		max-width: 1120px;
		margin: 0 auto;
		padding: 2.5rem 1.5rem;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(8rem, 1fr));
		gap: 1.5rem;
		text-align: center;
	}
	[data-stat] {
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
	}
	[data-stat-value] {
		font-family: var(--sl-font);
		font-size: clamp(1.8rem, 4vw, 2.5rem);
		font-weight: 700;
		color: var(--color-gold);
	}
	[data-stat-label] {
		font-size: 0.82rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-parchment);
		opacity: 0.65;
	}

	/* ── Project cards ── */
	[data-project] {
		display: flex;
		flex-direction: column;
		padding: 1.75rem;
		border-radius: 1rem;
		background: var(--color-bg-raised);
		border: 1px solid var(--color-gold-dark);
		text-decoration: none;
		transition:
			transform 0.18s ease,
			border-color 0.18s ease,
			box-shadow 0.18s ease;
	}
	[data-project]:hover {
		transform: translateY(-4px);
		border-color: var(--color-gold);
		box-shadow: 0 18px 40px -24px rgba(166, 125, 67, 0.6);
	}
	[data-project-tag] {
		align-self: flex-start;
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-gold-light);
		padding: 0.2rem 0.6rem;
		border: 1px solid var(--color-gold-dark);
		border-radius: 999px;
		margin-bottom: 0.9rem;
	}
	[data-project] h3 {
		font-family: var(--sl-font);
		font-size: 1.4rem;
		margin: 0 0 0.5rem;
		color: var(--color-parchment);
	}
	[data-project] p {
		margin: 0 0 1.25rem;
		font-size: 0.94rem;
		line-height: 1.55;
		color: var(--color-parchment);
		opacity: 0.78;
		flex: 1;
	}
	[data-project-link] {
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--color-gold);
	}

	/* ── CTA band ── */
	[data-cta-band] {
		position: relative;
		overflow: hidden;
		text-align: center;
		padding: 5.5rem 1.5rem;
		background:
			radial-gradient(
				40rem 20rem at 50% 120%,
				rgba(173, 0, 19, 0.25),
				transparent 70%
			),
			var(--color-bg);
	}
	[data-cta-band-inner] {
		max-width: 40rem;
		margin: 0 auto;
	}
	[data-cta-band] h2 {
		font-family: var(--sl-font);
		font-size: clamp(2rem, 5vw, 3rem);
		margin: 0 0 0.75rem;
		color: var(--color-parchment);
	}
	[data-cta-band] p {
		margin: 0 0 2rem;
		font-size: 1.1rem;
		color: var(--color-parchment);
		opacity: 0.78;
	}
</style>
