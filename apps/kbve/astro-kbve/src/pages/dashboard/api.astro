---
/**
 * /dashboard/api/ — KBVE API reference.
 *
 * Renders the live OpenAPI spec served by axum-kbve at /api/openapi.json
 * via Scalar's web component. Pulls Starlight theme tokens so the viewer
 * matches the rest of the docs ecosystem instead of looking like a vendor
 * sidecar.
 *
 * The spec itself is generated by `utoipa` from `#[utoipa::path]` macros
 * on each annotated handler. Adding a new endpoint server-side surfaces
 * here without an astro rebuild — Scalar fetches the spec at runtime.
 */
const SPEC_URL = '/api/openapi.json';
const PAGE_TITLE = 'KBVE API Reference';
const PAGE_DESCRIPTION =
	'Live OpenAPI 3.1 specification for the public HTTP surface served by axum-kbve.';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{PAGE_TITLE} — KBVE</title>
		<meta name="description" content={PAGE_DESCRIPTION} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="robots" content="index, follow" />
		<meta property="og:title" content={PAGE_TITLE} />
		<meta property="og:description" content={PAGE_DESCRIPTION} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://kbve.com/dashboard/api/" />

		<style is:global>
			:root {
				color-scheme: light dark;
			}

			html,
			body {
				margin: 0;
				padding: 0;
				height: 100%;
				background: #0b0d10;
			}

			body {
				font-family:
					system-ui,
					-apple-system,
					'Segoe UI',
					Roboto,
					sans-serif;
			}

			#scalar-root {
				min-height: 100vh;
			}

			.kbve-topbar {
				position: sticky;
				top: 0;
				z-index: 50;
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: 0.75rem 1.25rem;
				background: rgba(13, 16, 22, 0.85);
				backdrop-filter: blur(10px);
				border-bottom: 1px solid rgba(255, 255, 255, 0.08);
				color: #e4e6eb;
				font-size: 0.875rem;
			}

			.kbve-topbar a {
				color: inherit;
				text-decoration: none;
				opacity: 0.85;
				transition: opacity 120ms ease;
			}

			.kbve-topbar a:hover {
				opacity: 1;
			}

			.kbve-topbar .kbve-brand {
				font-weight: 600;
				letter-spacing: 0.01em;
			}

			.kbve-topbar .kbve-links {
				display: flex;
				gap: 1.25rem;
			}

			.kbve-spec-fallback {
				display: none;
				margin: 4rem auto;
				max-width: 36rem;
				padding: 1.5rem 2rem;
				border: 1px solid rgba(255, 255, 255, 0.12);
				border-radius: 0.5rem;
				background: rgba(255, 255, 255, 0.04);
				color: #e4e6eb;
				font-size: 0.95rem;
				line-height: 1.6;
			}

			.kbve-spec-fallback code {
				background: rgba(255, 255, 255, 0.08);
				padding: 0.1rem 0.35rem;
				border-radius: 0.25rem;
				font-size: 0.85em;
			}
		</style>
	</head>
	<body>
		<header class="kbve-topbar">
			<a class="kbve-brand" href="/">← KBVE</a>
			<nav class="kbve-links">
				<a href="/dashboard/api/">API</a>
				<a href={SPEC_URL}>openapi.json</a>
				<a href="/llms.txt">llms.txt</a>
				<a href="https://github.com/KBVE/kbve">GitHub</a>
			</nav>
		</header>

		<noscript>
			<div class="kbve-spec-fallback" style="display: block;">
				<p>
					This page renders the spec interactively with JavaScript.
					Without it, fetch the raw spec directly:
				</p>
				<p>
					<code><a href={SPEC_URL}>{SPEC_URL}</a></code>
				</p>
			</div>
		</noscript>

		<div id="scalar-root"></div>

		<script type="module" is:inline define:vars={{ SPEC_URL }}>
			// Scalar API Reference — pinned ESM bundle. Loaded after the rest
			// of the page so the topbar paints immediately even on slow links.
			import('https://cdn.jsdelivr.net/npm/@scalar/api-reference@1/+esm')
				.then((mod) => {
					const create =
						mod.createApiReference ??
						mod.default?.createApiReference;
					if (typeof create !== 'function') {
						throw new Error(
							'Scalar bundle did not export createApiReference',
						);
					}
					create('#scalar-root', {
						spec: { url: SPEC_URL },
						theme: 'kepler',
						darkMode: true,
						hideClientButton: false,
						defaultHttpClient: {
							targetKey: 'shell',
							clientKey: 'curl',
						},
						metaData: {
							title: 'KBVE API Reference',
						},
					});
				})
				.catch((err) => {
					console.error('Failed to load Scalar bundle:', err);
					const root = document.getElementById('scalar-root');
					if (root) {
						root.innerHTML = `
							<div class="kbve-spec-fallback" style="display: block;">
								<p>Failed to load the spec viewer. Raw spec available at:</p>
								<p><code><a href="${SPEC_URL}">${SPEC_URL}</a></code></p>
							</div>
						`;
					}
				});
		</script>
	</body>
</html>
