---
import ReactNav from '@/components/navigation/ReactNav.tsx';
import DashboardNav from '@/components/navigation/DashboardNav.tsx';
import AppsNav from '@/components/navigation/AppsNav.tsx';
import GamingNav from '@/components/navigation/GamingNav.tsx';
---

<nav class="knav" aria-label="Site navigation">
	<DashboardNav client:load />

	<AppsNav client:load />

	<GamingNav client:load />

	<button
		type="button"
		class="knav__icon knav__search-mobile"
		data-kbve-search-trigger
		aria-label="Search">
		<svg
			viewBox="0 0 24 24"
			width="18"
			height="18"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
			aria-hidden="true">
			<circle cx="11" cy="11" r="8"></circle>
			<path d="M21 21l-4.35-4.35"></path>
		</svg>
	</button>

	<button
		type="button"
		class="kbve-search-trigger knav__search-desktop"
		data-kbve-search-trigger
		aria-label="Search">
		<svg
			viewBox="0 0 24 24"
			width="16"
			height="16"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
			aria-hidden="true">
			<circle cx="11" cy="11" r="8"></circle>
			<path d="M21 21l-4.35-4.35"></path>
		</svg>
		<span class="kbve-search-trigger__label">Search…</span>
		<span class="kbve-search-trigger__keycap">⌘K</span>
	</button>

	<div class="knav__profile">
		{
			/* Static trigger — server-rendered so it's present at first paint
		    (no CLS, no client:only pop-in). ReactNav patches the avatar/name
		    from $auth and owns the dropdown modal. */
		}
		<button
			id="knav-profile-trigger"
			class="knav-profile-trigger"
			type="button"
			aria-haspopup="dialog"
			aria-expanded="false"
			aria-label="Account menu"
			data-auth-tone="loading">
			<span id="knav-profile-avatar" class="knav-profile-avatar">
				<svg
					width="18"
					height="18"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					aria-hidden="true"
					style="opacity:0.8">
					<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
					<circle cx="12" cy="7" r="4"></circle>
				</svg>
			</span>
			<span id="knav-profile-name" class="knav-profile-name">Guest</span>
		</button>
		<ReactNav client:only="react" />
	</div>
</nav>

<style>
	.knav {
		display: flex;
		align-items: center;
		gap: 0.375rem;
	}

	.knav__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.25rem;
		height: 2.25rem;
		border-radius: 0.625rem;
		color: var(--sl-color-gray-2);
		background-color: color-mix(
			in srgb,
			var(--sl-color-white) 4%,
			transparent
		);
		border: 1px solid var(--bento-hairline-strong);
		cursor: pointer;
		text-decoration: none;
		transition:
			color 160ms ease,
			background-color 160ms ease,
			border-color 160ms ease;
	}

	.knav__icon:hover {
		color: var(--sl-color-white);
		border-color: var(--sl-color-accent);
	}

	/* Two static search buttons — icon on phones, pill on wider screens.
	   No JS, no keycap swap, so nothing reflows after paint.
	   `.knav` prefix wins the specificity tie against the global
	   `.kbve-search-trigger { display: inline-flex }`. */
	.knav .knav__search-desktop {
		display: none;
	}

	@media (min-width: 34rem) {
		.knav .knav__search-mobile {
			display: none;
		}

		.knav .knav__search-desktop {
			display: inline-flex;
		}
	}

	/* Site-wide profile control. Trigger is server-rendered (static) so it
	   holds its space from first paint; ReactNav only patches data + modal. */
	.knav__profile {
		display: inline-flex;
		align-items: center;
	}

	/* Trigger — matches the bento nav slot (.knav__icon / .dnav__trigger).
	   Mobile: 2.25rem square icon. Desktop: pill with label. */
	.knav-profile-trigger {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		width: 2.25rem;
		height: 2.25rem;
		padding: 0;
		border-radius: 0.625rem;
		color: var(--sl-color-gray-2);
		background-color: color-mix(
			in srgb,
			var(--sl-color-white) 4%,
			transparent
		);
		border: 1px solid var(--bento-hairline-strong, rgba(255, 255, 255, 0.1));
		cursor: pointer;
		transition:
			color 160ms ease,
			border-color 160ms ease,
			background-color 160ms ease;
	}

	.knav-profile-trigger:hover,
	.knav-profile-trigger:focus-visible {
		outline: none;
		color: var(--sl-color-white);
		border-color: var(--sl-color-accent);
	}

	.knav-profile-avatar {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.5rem;
		height: 1.5rem;
		border-radius: 9999px;
		overflow: hidden;
		flex-shrink: 0;
		opacity: 1;
		transition: opacity 160ms ease;
	}

	.knav-profile-avatar :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.knav-profile-name {
		display: none;
		opacity: 1;
		transition: opacity 160ms ease;
	}

	@media (min-width: 34rem) {
		.knav-profile-trigger {
			width: auto;
			padding: 0 0.7rem 0 0.45rem;
			justify-content: flex-start;
		}

		.knav-profile-name {
			display: inline;
			font-size: 0.8125rem;
			font-weight: 600;
			max-width: 130px;
			overflow: hidden;
			text-overflow: ellipsis;
			white-space: nowrap;
		}
	}
</style>
