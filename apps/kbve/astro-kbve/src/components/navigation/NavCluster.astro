---
import ReactNav from '@/components/navigation/ReactNav.tsx';
import DashboardNav from '@/components/navigation/DashboardNav.tsx';
---

<nav class="knav" aria-label="Site navigation">
	<DashboardNav client:visible />

	<button
		type="button"
		class="knav__icon knav__icon--placeholder"
		aria-label="Coming soon"
		disabled>
		<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
			<circle
				cx="12"
				cy="12"
				r="7"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-dasharray="3 3">
			</circle>
		</svg>
	</button>

	<button
		type="button"
		class="knav__icon knav__icon--placeholder"
		aria-label="Coming soon"
		disabled>
		<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
			<circle
				cx="12"
				cy="12"
				r="7"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-dasharray="3 3">
			</circle>
		</svg>
	</button>

	<button
		type="button"
		class="knav__icon knav__search-mobile"
		data-kbve-search-trigger
		aria-label="Search">
		<svg
			viewBox="0 0 24 24"
			width="18"
			height="18"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
			aria-hidden="true">
			<circle cx="11" cy="11" r="8"></circle>
			<path d="M21 21l-4.35-4.35"></path>
		</svg>
	</button>

	<button
		type="button"
		class="kbve-search-trigger knav__search-desktop"
		data-kbve-search-trigger
		aria-label="Search">
		<svg
			viewBox="0 0 24 24"
			width="16"
			height="16"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
			aria-hidden="true">
			<circle cx="11" cy="11" r="8"></circle>
			<path d="M21 21l-4.35-4.35"></path>
		</svg>
		<span class="kbve-search-trigger__label">Search…</span>
		<span class="kbve-search-trigger__keycap">⌘K</span>
	</button>

	<div class="knav__authboot" aria-hidden="true">
		<ReactNav client:only="react" />
	</div>
</nav>

<style>
	.knav {
		display: flex;
		align-items: center;
		gap: 0.375rem;
	}

	.knav__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.25rem;
		height: 2.25rem;
		border-radius: 0.625rem;
		color: var(--sl-color-gray-2);
		background-color: color-mix(
			in srgb,
			var(--sl-color-white) 4%,
			transparent
		);
		border: 1px solid var(--bento-hairline-strong);
		cursor: pointer;
		text-decoration: none;
		transition:
			color 160ms ease,
			background-color 160ms ease,
			border-color 160ms ease;
	}

	.knav__icon:hover {
		color: var(--sl-color-white);
		border-color: var(--sl-color-accent);
	}

	.knav__icon--placeholder {
		opacity: 0.45;
		border-style: dashed;
		cursor: default;
	}

	.knav__icon--placeholder:hover {
		color: var(--sl-color-gray-2);
		border-color: var(--bento-hairline-strong);
	}

	/* Two static search buttons — icon on phones, pill on wider screens.
	   No JS, no keycap swap, so nothing reflows after paint.
	   `.knav` prefix wins the specificity tie against the global
	   `.kbve-search-trigger { display: inline-flex }`. */
	.knav .knav__search-desktop {
		display: none;
	}

	@media (min-width: 34rem) {
		.knav .knav__search-mobile {
			display: none;
		}

		.knav .knav__search-desktop {
			display: inline-flex;
		}
	}

	/* Keep ReactNav mounted for auth boot + account modal, but out of the
	   visible bar while we settle the layout. */
	.knav__authboot {
		position: absolute;
		width: 1px;
		height: 1px;
		overflow: hidden;
		clip: rect(0 0 0 0);
		clip-path: inset(50%);
		white-space: nowrap;
	}
</style>
