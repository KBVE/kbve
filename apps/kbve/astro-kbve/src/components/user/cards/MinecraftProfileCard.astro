---
/**
 * MinecraftProfileCard — private MC identity card.
 *
 * Three states swapped by minecraft-card.controller.ts:
 *   - loading  (skeleton)
 *   - unlinked (CTA → /mc/)
 *   - linked   (Crafatar avatar + UUID + Manage CTA)
 *
 * Reserves min-height across states so the card never causes layout shift.
 */
---

<section
	class="profile-card profile-card--mc"
	data-card="minecraft"
	id="profile-mc-card">
	<header class="profile-mc-header">
		<div class="profile-mc-eyebrow">
			<svg
				width="16"
				height="16"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true">
				<rect x="3" y="3" width="18" height="18" rx="2"></rect>
				<path d="M7 7h4v4H7zM13 13h4v4h-4z"></path>
			</svg>
			<span>Minecraft</span>
		</div>
		<span
			id="profile-mc-status-badge"
			class="profile-mc-badge profile-mc-badge--unknown">
			…
		</span>
	</header>

	{/* ── Loading skeleton ───────────────────────────────────────── */}
	<div id="profile-mc-state-loading" class="profile-mc-body">
		<div class="profile-mc-row">
			<div class="profile-mc-avatar profile-mc-skeleton"></div>
			<div class="profile-mc-stack" style="flex:1">
				<div
					class="profile-mc-skeleton"
					style="width:60%;height:0.85rem;border-radius:4px">
				</div>
				<div
					class="profile-mc-skeleton"
					style="width:90%;height:0.7rem;border-radius:4px;margin-top:0.5rem">
				</div>
			</div>
		</div>
	</div>

	{/* ── Unlinked ───────────────────────────────────────────────── */}
	<div id="profile-mc-state-unlinked" class="profile-mc-body" hidden>
		<p class="profile-mc-muted">
			Your KBVE account isn't linked to a Minecraft player yet. Link one
			to track your in-game progress and survive the offline-vs-online
			UUID divergence cleanly.
		</p>
		<div class="profile-mc-actions">
			<a href="/mc/" class="profile-mc-btn">
				Link your Minecraft account →
			</a>
		</div>
	</div>

	{/* ── Linked ─────────────────────────────────────────────────── */}
	<div id="profile-mc-state-linked" class="profile-mc-body" hidden>
		<div class="profile-mc-row">
			<img
				id="profile-mc-avatar"
				class="profile-mc-avatar"
				src=""
				alt="Minecraft head"
				width="64"
				height="64"
				loading="lazy"
			/>
			<div class="profile-mc-stack" style="flex:1;min-width:0">
				<div
					id="profile-mc-username"
					class="profile-mc-username"
					title="Minecraft username">
				</div>
				<code
					id="profile-mc-uuid"
					class="profile-mc-uuid"
					title="Minecraft UUID">
				</code>
				<div id="profile-mc-linked-since" class="profile-mc-meta"></div>
			</div>
		</div>
		<div class="profile-mc-actions">
			<a href="/mc/" class="profile-mc-btn profile-mc-btn--ghost">
				Manage at /mc/
			</a>
			<a
				id="profile-mc-public-link"
				href="#"
				class="profile-mc-btn profile-mc-btn--ghost"
				hidden>
				Public skin viewer
			</a>
		</div>
	</div>
</section>

<style>
	.profile-card--mc {
		min-height: 200px;
	}
	.profile-mc-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 0.75rem;
		padding-bottom: 0.5rem;
		border-bottom: 1px solid var(--sl-color-hairline, #30363d);
	}
	.profile-mc-eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--sl-color-gray-3, #8b949e);
	}
	.profile-mc-badge {
		font-size: 0.7rem;
		font-weight: 600;
		padding: 0.125rem 0.5rem;
		border-radius: 9999px;
		text-transform: capitalize;
	}
	.profile-mc-badge--linked {
		background: rgba(34, 197, 94, 0.15);
		color: rgb(34, 197, 94);
		border: 1px solid rgba(34, 197, 94, 0.3);
	}
	.profile-mc-badge--pending {
		background: rgba(234, 179, 8, 0.15);
		color: rgb(234, 179, 8);
		border: 1px solid rgba(234, 179, 8, 0.3);
	}
	.profile-mc-badge--unlinked,
	.profile-mc-badge--unknown {
		background: rgba(156, 163, 175, 0.15);
		color: var(--sl-color-gray-3, #8b949e);
		border: 1px solid rgba(156, 163, 175, 0.3);
	}
	.profile-mc-body {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}
	.profile-mc-row {
		display: flex;
		gap: 0.875rem;
		align-items: center;
	}
	.profile-mc-stack {
		display: flex;
		flex-direction: column;
	}
	.profile-mc-avatar {
		width: 64px;
		height: 64px;
		border-radius: 0.375rem;
		image-rendering: pixelated;
		background: var(--sl-color-hairline, #30363d);
		flex-shrink: 0;
	}
	.profile-mc-skeleton {
		background: linear-gradient(
			90deg,
			var(--sl-color-hairline, #30363d) 25%,
			var(--sl-color-bg-accent, #164e63) 50%,
			var(--sl-color-hairline, #30363d) 75%
		);
		background-size: 200% 100%;
		animation: profile-mc-shimmer 1.5s ease-in-out infinite;
	}
	@keyframes profile-mc-shimmer {
		0% {
			background-position: 200% 0;
		}
		100% {
			background-position: -200% 0;
		}
	}
	.profile-mc-username {
		font-size: 1rem;
		font-weight: 600;
		color: var(--sl-color-white, #e6edf3);
		word-break: break-all;
	}
	.profile-mc-uuid {
		font-size: 0.7rem;
		font-family:
			ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		color: var(--sl-color-gray-3, #8b949e);
		margin-top: 0.125rem;
		word-break: break-all;
	}
	.profile-mc-meta {
		font-size: 0.75rem;
		color: var(--sl-color-gray-4, #6e7681);
		margin-top: 0.25rem;
	}
	.profile-mc-muted {
		font-size: 0.8125rem;
		color: var(--sl-color-gray-3, #8b949e);
		margin: 0;
		line-height: 1.5;
	}
	.profile-mc-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-top: 0.5rem;
	}
	.profile-mc-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
		padding: 0.5rem 0.875rem;
		border-radius: 0.375rem;
		font-size: 0.8125rem;
		font-weight: 500;
		text-decoration: none;
		background: linear-gradient(
			135deg,
			var(--sl-color-accent, #06b6d4),
			var(--sl-color-accent-high, #67e8f9)
		);
		color: #0d1117;
		border: 1px solid transparent;
		transition: opacity 0.15s ease;
		cursor: pointer;
	}
	.profile-mc-btn:hover {
		opacity: 0.9;
	}
	.profile-mc-btn--ghost {
		background: rgba(255, 255, 255, 0.04);
		color: var(--sl-color-white, #e6edf3);
		border-color: var(--sl-color-hairline, #30363d);
	}
	.profile-mc-btn--ghost:hover {
		background: rgba(255, 255, 255, 0.08);
	}
</style>
