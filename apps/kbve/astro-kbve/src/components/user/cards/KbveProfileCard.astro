---
/**
 * KbveProfileCard — KBVE identity card.
 *
 * Header (avatar, name, email, badges) + public profile link + connected
 * OAuth providers + account actions (Settings, Sign Out). Slots are
 * populated by profile-controller.ts after the API responds.
 */
---

<section class="profile-card profile-card--kbve" data-card="kbve">
	<header class="profile-header">
		<div class="profile-avatar" id="profile-slot-avatar">
			<span id="profile-slot-avatar-letter" class="profile-avatar-letter">
				U
			</span>
			<img
				id="profile-slot-avatar-img"
				class="profile-avatar-img"
				src=""
				alt=""
				hidden
			/>
		</div>
		<div class="profile-info">
			<h1 id="profile-slot-name" class="profile-name"></h1>
			<p id="profile-slot-email" class="profile-email"></p>
			<div id="profile-slot-badges" class="profile-badges">
				<span class="profile-badge">KBVE Member</span>
			</div>
		</div>
	</header>

	<a
		id="profile-slot-public-link"
		href="#"
		class="profile-public-link"
		target="_blank"
		rel="noopener noreferrer"
		hidden>
		<svg
			width="14"
			height="14"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round">
			<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6">
			</path>
			<polyline points="15 3 21 3 21 9"></polyline>
			<line x1="10" y1="14" x2="21" y2="3"></line>
		</svg>
		View Public Profile
	</a>

	<section class="profile-section">
		<h2 class="profile-section-title">Connected Accounts</h2>
		<div id="profile-slot-providers" class="profile-providers">
			<p class="profile-providers-empty">Loading connected accounts...</p>
		</div>
	</section>

	<section class="profile-section">
		<h2 class="profile-section-title">Account</h2>
		<div class="profile-actions">
			<a href="/settings" class="profile-action-card">
				<svg
					width="24"
					height="24"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round">
					<circle cx="12" cy="12" r="3"></circle>
					<path
						d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42">
					</path>
				</svg>
				<span>Settings</span>
			</a>
			<button
				id="profile-logout-btn"
				type="button"
				class="profile-action-card profile-action-danger">
				<svg
					width="24"
					height="24"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round">
					<path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
					<polyline points="16 17 21 12 16 7"></polyline>
					<line x1="21" y1="12" x2="9" y2="12"></line>
				</svg>
				<span>Sign Out</span>
			</button>
		</div>
	</section>
</section>

<style>
	.profile-card--kbve {
		background: linear-gradient(
			180deg,
			var(--sl-color-bg-accent, #164e63) 0%,
			transparent 100%
		);
		box-shadow: inset 0 0 0 1px var(--sl-color-hairline, #30363d);
		padding: 1.25rem;
		clip-path: polygon(
			0.75rem 0%,
			calc(100% - 0.75rem) 0%,
			100% 0.75rem,
			100% calc(100% - 0.75rem),
			calc(100% - 0.75rem) 100%,
			0.75rem 100%,
			0% calc(100% - 0.75rem),
			0% 0.75rem
		);
	}
	.profile-header {
		display: flex;
		gap: 1rem;
		align-items: center;
		margin-bottom: 1rem;
	}
	.profile-avatar {
		width: 72px;
		height: 72px;
		border-radius: 50%;
		overflow: hidden;
		background: var(--sl-color-hairline, #30363d);
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}
	.profile-avatar-letter {
		font-size: 1.5rem;
		font-weight: 700;
		color: var(--sl-color-white, #e6edf3);
	}
	.profile-avatar-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.profile-info {
		flex: 1;
		min-width: 0;
	}
	.profile-name {
		font-size: 1.125rem;
		font-weight: 700;
		color: var(--sl-color-white, #e6edf3);
		margin: 0;
		word-break: break-word;
	}
	.profile-email {
		font-size: 0.8125rem;
		color: var(--sl-color-gray-3, #8b949e);
		margin: 0.125rem 0 0.5rem;
	}
	.profile-badges {
		display: flex;
		gap: 0.375rem;
		flex-wrap: wrap;
	}
	.profile-badge {
		font-size: 0.6875rem;
		font-weight: 500;
		padding: 0.125rem 0.5rem;
		background: rgba(6, 182, 212, 0.15);
		color: #67e8f9;
		border: 1px solid rgba(6, 182, 212, 0.3);
		border-radius: 999px;
	}
	.profile-public-link {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		font-size: 0.8125rem;
		color: var(--sl-color-accent, #06b6d4);
		text-decoration: none;
		margin-bottom: 1rem;
	}
	.profile-public-link:hover {
		text-decoration: underline;
	}
	.profile-section {
		margin-bottom: 1rem;
	}
	.profile-section-title {
		font-size: 0.6875rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--sl-color-gray-3, #8b949e);
		margin: 0 0 0.5rem;
	}
	.profile-providers {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
	}
	.profile-providers-empty {
		font-size: 0.8125rem;
		color: var(--sl-color-gray-4, #6e7681);
		margin: 0;
	}
	:global(.profile-provider-badge) {
		font-size: 0.75rem;
		font-weight: 500;
		padding: 0.25rem 0.625rem;
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid var(--sl-color-hairline, #30363d);
		border-radius: 0.375rem;
		color: var(--sl-color-white, #e6edf3);
	}
	.profile-actions {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.5rem;
	}
	.profile-action-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.375rem;
		padding: 0.75rem;
		border-radius: 0.5rem;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid var(--sl-color-hairline, #30363d);
		color: var(--sl-color-white, #e6edf3);
		text-decoration: none;
		font-size: 0.8125rem;
		font-family: inherit;
		cursor: pointer;
		transition: background 0.2s;
	}
	.profile-action-card:hover {
		background: rgba(255, 255, 255, 0.06);
	}
	.profile-action-danger {
		color: #f87171;
	}
	.profile-action-danger:hover {
		background: rgba(239, 68, 68, 0.1);
	}
</style>
