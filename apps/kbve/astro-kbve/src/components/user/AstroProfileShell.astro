---
/**
 * AstroProfileShell — static HTML shell for all profile states.
 *
 * Every state (loading, unauthenticated, username-setup, profile) is
 * pre-rendered as hidden HTML. The profile-controller.ts script swaps
 * visibility via element IDs — O(1) DOM operations, no React needed
 * for layout-level transitions.
 *
 * React is only used for truly interactive islands (OAuth modal via
 * the NavDropdown, not here).
 */
---

<div id="profile-shell" class="not-content">
	<div class="profile-card">
		{/* ── State: Loading ─────────────────────────────────────────── */}
		<div id="profile-state-loading">
			<div class="profile-loading">
				<div class="profile-loading-avatar">
					<div
						class="skeleton-shimmer"
						style="width:100%;height:100%;border-radius:50%">
					</div>
				</div>
				<div
					class="skeleton-shimmer"
					style="width:10rem;height:1.25rem;border-radius:4px;margin-top:0.75rem">
				</div>
				<div
					class="skeleton-shimmer"
					style="width:7rem;height:0.875rem;border-radius:4px;margin-top:0.5rem">
				</div>
			</div>
		</div>

		{/* ── State: Unauthenticated ─────────────────────────────────── */}
		<div id="profile-state-unauth" hidden>
			<div class="profile-unauth">
				<div class="profile-unauth-icon">
					<svg
						width="40"
						height="40"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round">
						<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2">
						</path>
						<circle cx="12" cy="7" r="4"></circle>
					</svg>
				</div>
				<h2 class="profile-unauth-title">
					Sign in to view your profile
				</h2>
				<p class="profile-unauth-subtitle">
					Connect with GitHub, Twitch, or Discord to get started.
				</p>
				<p class="profile-unauth-hint">
					Use the sign-in button in the navigation bar above.
				</p>
			</div>
		</div>

		{/* ── State: Username Setup ──────────────────────────────────── */}
		<div id="profile-state-username" hidden>
			<div class="profile-username-setup">
				<div class="profile-username-icon">
					<svg
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						stroke="#06b6d4"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round">
						<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2">
						</path>
						<circle cx="12" cy="7" r="4"></circle>
					</svg>
				</div>
				<h2 class="profile-username-title">Choose your username</h2>
				<p class="profile-username-subtitle">
					This is your unique identity on KBVE. It'll be used for your
					public profile and across all KBVE services.
				</p>
				<form class="profile-username-form" onsubmit="return false;">
					<div class="profile-username-input-row">
						<span class="profile-username-prefix">@</span>
						<input
							id="profile-username-input"
							type="text"
							placeholder="your_username"
							maxlength="24"
							autocomplete="off"
							class="profile-username-input"
						/>
					</div>
					<p id="profile-username-hint" class="profile-username-hint">
						3-24 characters, letters, numbers, underscores
					</p>
					<p
						id="profile-username-error"
						class="profile-username-error-msg"
						hidden>
					</p>
					<button
						id="profile-username-submit"
						type="submit"
						class="profile-username-btn"
						disabled>
						Claim username
					</button>
				</form>
			</div>
		</div>

		{/* ── State: Authenticated Profile ───────────────────────────── */}
		<div id="profile-state-profile" hidden>
			{/* Header */}
			<header class="profile-header">
				<div class="profile-avatar" id="profile-slot-avatar">
					<span
						id="profile-slot-avatar-letter"
						class="profile-avatar-letter">
						U
					</span>
					<img
						id="profile-slot-avatar-img"
						class="profile-avatar-img"
						src=""
						alt=""
						hidden
					/>
				</div>
				<div class="profile-info">
					<h1 id="profile-slot-name" class="profile-name"></h1>
					<p id="profile-slot-email" class="profile-email"></p>
					<div id="profile-slot-badges" class="profile-badges">
						<span class="profile-badge">KBVE Member</span>
					</div>
				</div>
			</header>

			{/* Public profile link */}
			<a
				id="profile-slot-public-link"
				href="#"
				class="profile-public-link"
				target="_blank"
				rel="noopener noreferrer"
				hidden>
				<svg
					width="14"
					height="14"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round">
					<path
						d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6">
					</path>
					<polyline points="15 3 21 3 21 9"></polyline>
					<line x1="10" y1="14" x2="21" y2="3"></line>
				</svg>
				View Public Profile
			</a>

			{/* Connected accounts */}
			<section class="profile-section">
				<h2 class="profile-section-title">Connected Accounts</h2>
				<div id="profile-slot-providers" class="profile-providers">
					<p class="profile-providers-empty">
						Loading connected accounts...
					</p>
				</div>
			</section>

			{/* Quick links */}
			<section class="profile-section">
				<h2 class="profile-section-title">Quick links</h2>
				<div class="profile-quicklinks">
					<a class="profile-quicklink" href="/forum/">
						<svg
							width="20"
							height="20"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="1.8"
							stroke-linecap="round"
							stroke-linejoin="round">
							<path
								d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z">
							</path>
						</svg>
						<span>
							<strong>Forum</strong>
							<small>Discuss, trade, ship together</small>
						</span>
					</a>
					<a class="profile-quicklink" href="/forum/compose">
						<svg
							width="20"
							height="20"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="1.8"
							stroke-linecap="round"
							stroke-linejoin="round">
							<path d="M12 5v14"></path>
							<path d="M5 12h14"></path>
						</svg>
						<span>
							<strong>New thread</strong>
							<small>Markdown, polls, auctions</small>
						</span>
					</a>
					<a class="profile-quicklink" href="/discord">
						<svg
							width="20"
							height="20"
							viewBox="0 0 24 24"
							fill="currentColor"
							aria-hidden="true">
							<path
								d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z">
							</path>
						</svg>
						<span>
							<strong>Discord</strong>
							<small>Live chat + voice</small>
						</span>
					</a>
					<a
						class="profile-quicklink"
						href="https://github.com/kbve/kbve"
						target="_blank"
						rel="noopener noreferrer">
						<svg
							width="20"
							height="20"
							viewBox="0 0 24 24"
							fill="currentColor"
							aria-hidden="true">
							<path
								d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.387.6.113.82-.262.82-.582v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.418-1.305.762-1.605-2.665-.305-5.467-1.334-5.467-5.93 0-1.31.467-2.382 1.236-3.222-.124-.303-.535-1.523.117-3.176 0 0 1.008-.323 3.301 1.23A11.5 11.5 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.553 3.297-1.23 3.297-1.23.654 1.653.243 2.873.119 3.176.77.84 1.235 1.911 1.235 3.221 0 4.61-2.807 5.624-5.479 5.921.43.371.823 1.102.823 2.222v3.293c0 .322.218.699.825.58C20.565 21.795 24 17.297 24 12c0-6.63-5.37-12-12-12z">
							</path>
						</svg>
						<span>
							<strong>GitHub</strong>
							<small>Open-source monorepo</small>
						</span>
					</a>
				</div>
			</section>

			{/* Account actions */}
			<section class="profile-section">
				<h2 class="profile-section-title">Account</h2>
				<div class="profile-actions">
					<a href="/settings" class="profile-action-card">
						<svg
							width="24"
							height="24"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round">
							<circle cx="12" cy="12" r="3"></circle>
							<path
								d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42">
							</path>
						</svg>
						<span>Settings</span>
					</a>
					<button
						id="profile-logout-btn"
						type="button"
						class="profile-action-card profile-action-danger">
						<svg
							width="24"
							height="24"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round">
							<path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4">
							</path>
							<polyline points="16 17 21 12 16 7"></polyline>
							<line x1="21" y1="12" x2="9" y2="12"></line>
						</svg>
						<span>Sign Out</span>
					</button>
				</div>
			</section>

			<a href="/" class="profile-back-link">
				<svg
					width="16"
					height="16"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round">
					<line x1="19" y1="12" x2="5" y2="12"></line>
					<polyline points="12 19 5 12 12 5"></polyline>
				</svg>
				Back to KBVE
			</a>
		</div>
	</div>

	{/* ── Footer (always visible) ────────────────────────────────── */}
	<footer class="profile-footer">
		<nav class="profile-footer__nav" aria-label="Site links">
			<a href="/">Home</a>
			<a href="/forum/">Forum</a>
			<a href="/discord">Discord</a>
			<a href="/crypto/">Crypto</a>
			<a href="/legal/terms-of-service">Terms</a>
			<a href="/legal/privacy-policy">Privacy</a>
			<a href="/contact">Contact</a>
			<a
				href="https://github.com/kbve/kbve"
				target="_blank"
				rel="noopener noreferrer">
				GitHub ↗
			</a>
		</nav>
		<p class="profile-footer__copy">
			© <span id="profile-footer-year"></span> KBVE — open-source by builders,
			for builders.
		</p>
	</footer>
</div>

<script>
	import { bootProfile } from './profile-controller';
	bootProfile();

	// Tiny script: stamp the current year in the footer.
	const yearEl = document.getElementById('profile-footer-year');
	if (yearEl) yearEl.textContent = String(new Date().getFullYear());
</script>

<style>
	.profile-card {
		background: linear-gradient(
			180deg,
			var(--sl-color-bg-accent, #164e63) 0%,
			transparent 100%
		);
		box-shadow: inset 0 0 0 1px var(--sl-color-hairline, #30363d);
		padding: 1.25rem;
		max-width: 480px;
		width: 100%;
		clip-path: polygon(
			0.75rem 0%,
			calc(100% - 0.75rem) 0%,
			100% 0.75rem,
			100% calc(100% - 0.75rem),
			calc(100% - 0.75rem) 100%,
			0.75rem 100%,
			0% calc(100% - 0.75rem),
			0% 0.75rem
		);
	}

	/* ── Loading ──────────────────────────────────────────────────── */
	.profile-loading {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.25rem;
		padding: 1rem 0;
	}
	.profile-loading-avatar {
		width: 80px;
		height: 80px;
		border-radius: 50%;
		overflow: hidden;
		background: var(--sl-color-hairline, #30363d);
	}
	.skeleton-shimmer {
		background: linear-gradient(
			90deg,
			var(--sl-color-hairline, #30363d) 25%,
			var(--sl-color-bg-accent, #164e63) 50%,
			var(--sl-color-hairline, #30363d) 75%
		);
		background-size: 200% 100%;
		animation: shimmer 1.5s ease-in-out infinite;
	}
	@keyframes shimmer {
		0% {
			background-position: 200% 0;
		}
		100% {
			background-position: -200% 0;
		}
	}

	/* ── Unauthenticated ──────────────────────────────────────────── */
	.profile-unauth {
		text-align: center;
		padding: 1.5rem 0;
	}
	.profile-unauth-icon {
		width: 80px;
		height: 80px;
		margin: 0 auto 1rem;
		background: linear-gradient(
			135deg,
			var(--sl-color-accent, #06b6d4),
			var(--sl-color-accent-high, #67e8f9)
		);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		color: #0d1117;
	}
	.profile-unauth-title {
		font-size: 1.125rem;
		font-weight: 600;
		color: var(--sl-color-white, #e6edf3);
		margin: 0 0 0.25rem;
	}
	.profile-unauth-subtitle {
		font-size: 0.875rem;
		color: var(--sl-color-gray-3, #8b949e);
		margin: 0 0 1rem;
	}
	.profile-unauth-hint {
		font-size: 0.75rem;
		color: var(--sl-color-gray-4, #6e7681);
		margin: 0;
	}

	/* ── Username Setup ───────────────────────────────────────────── */
	.profile-username-setup {
		text-align: center;
	}
	.profile-username-icon {
		width: 48px;
		height: 48px;
		margin: 0 auto 0.75rem;
		background: rgba(6, 182, 212, 0.15);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.profile-username-title {
		font-size: 1.125rem;
		font-weight: 600;
		color: var(--sl-color-white, #e6edf3);
		margin: 0 0 0.25rem;
	}
	.profile-username-subtitle {
		font-size: 0.8125rem;
		color: var(--sl-color-gray-3, #8b949e);
		margin: 0 0 1rem;
		line-height: 1.5;
	}
	.profile-username-form {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.profile-username-input-row {
		display: flex;
		align-items: center;
		gap: 0.25rem;
		background: var(--sl-color-bg, #0d1117);
		border: 1px solid var(--sl-color-hairline, #30363d);
		border-radius: 0.5rem;
		padding: 0.5rem 0.75rem;
	}
	.profile-username-prefix {
		color: var(--sl-color-gray-3, #8b949e);
		font-size: 0.875rem;
		font-weight: 500;
		user-select: none;
	}
	.profile-username-input {
		flex: 1;
		background: transparent;
		border: none;
		outline: none;
		color: var(--sl-color-white, #e6edf3);
		font-size: 0.875rem;
		font-family: monospace;
	}
	.profile-username-hint {
		font-size: 0.75rem;
		color: var(--sl-color-gray-4, #6e7681);
		text-align: left;
		margin: 0;
	}
	.profile-username-error-msg {
		font-size: 0.75rem;
		color: #f87171;
		background: rgba(239, 68, 68, 0.1);
		border-radius: 0.375rem;
		padding: 0.375rem 0.5rem;
		margin: 0;
		text-align: left;
	}
	.profile-username-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		background: linear-gradient(
			135deg,
			var(--sl-color-accent, #06b6d4),
			var(--sl-color-accent-high, #67e8f9)
		);
		color: #0d1117;
		border: none;
		border-radius: 0.5rem;
		padding: 0.625rem 1rem;
		font-size: 0.875rem;
		font-weight: 600;
		margin-top: 0.25rem;
		transition: opacity 0.2s;
		cursor: pointer;
	}
	.profile-username-btn:disabled {
		opacity: 0.5;
		cursor: not-allowed;
	}

	/* ── Authenticated Profile ────────────────────────────────────── */
	.profile-header {
		display: flex;
		gap: 1rem;
		align-items: center;
		margin-bottom: 1rem;
	}
	.profile-avatar {
		width: 72px;
		height: 72px;
		border-radius: 50%;
		overflow: hidden;
		background: var(--sl-color-hairline, #30363d);
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}
	.profile-avatar-letter {
		font-size: 1.5rem;
		font-weight: 700;
		color: var(--sl-color-white, #e6edf3);
	}
	.profile-avatar-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.profile-info {
		flex: 1;
		min-width: 0;
	}
	.profile-name {
		font-size: 1.125rem;
		font-weight: 700;
		color: var(--sl-color-white, #e6edf3);
		margin: 0;
		word-break: break-word;
	}
	.profile-email {
		font-size: 0.8125rem;
		color: var(--sl-color-gray-3, #8b949e);
		margin: 0.125rem 0 0.5rem;
	}
	.profile-badges {
		display: flex;
		gap: 0.375rem;
		flex-wrap: wrap;
	}
	.profile-badge {
		font-size: 0.6875rem;
		font-weight: 500;
		padding: 0.125rem 0.5rem;
		background: rgba(6, 182, 212, 0.15);
		color: #67e8f9;
		border: 1px solid rgba(6, 182, 212, 0.3);
		border-radius: 999px;
	}
	.profile-public-link {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		font-size: 0.8125rem;
		color: var(--sl-color-accent, #06b6d4);
		text-decoration: none;
		margin-bottom: 1rem;
	}
	.profile-public-link:hover {
		text-decoration: underline;
	}
	.profile-section {
		margin-bottom: 1rem;
	}
	.profile-section-title {
		font-size: 0.6875rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--sl-color-gray-3, #8b949e);
		margin: 0 0 0.5rem;
	}
	.profile-providers {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
	}
	.profile-providers-empty {
		font-size: 0.8125rem;
		color: var(--sl-color-gray-4, #6e7681);
		margin: 0;
	}
	:global(.profile-provider-badge) {
		font-size: 0.75rem;
		font-weight: 500;
		padding: 0.25rem 0.625rem;
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid var(--sl-color-hairline, #30363d);
		border-radius: 0.375rem;
		color: var(--sl-color-white, #e6edf3);
	}
	.profile-actions {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.5rem;
