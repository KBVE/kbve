---
/**
 * AstroProfileShell — static HTML shell for all profile states.
 *
 * Loading / unauth / username-setup live in a single shared card.
 * The signed-in `profile` state stacks per-integration cards (KBVE,
 * Minecraft, …) so each surface owns its own data fetch + skeleton.
 *
 * profile-controller.ts swaps visibility via element IDs — O(1) DOM
 * ops, no React for layout-level transitions.
 */

import KbveProfileCard from './cards/KbveProfileCard.astro';
import MinecraftProfileCard from './cards/MinecraftProfileCard.astro';
---

<div id="profile-shell" class="not-content">
	{/* ── State: Loading ─────────────────────────────────────────────── */}
	<div
		id="profile-state-loading"
		class="profile-card profile-card--state bento-card bento-card--glass">
		<div class="profile-loading">
			<div class="profile-loading-avatar">
				<div
					class="skeleton-shimmer"
					style="width:100%;height:100%;border-radius:50%">
				</div>
			</div>
			<div
				class="skeleton-shimmer"
				style="width:10rem;height:1.25rem;border-radius:4px;margin-top:0.75rem">
			</div>
			<div
				class="skeleton-shimmer"
				style="width:7rem;height:0.875rem;border-radius:4px;margin-top:0.5rem">
			</div>
		</div>
	</div>

	{/* ── State: Unauthenticated ─────────────────────────────────────── */}
	<div
		id="profile-state-unauth"
		class="profile-card profile-card--state bento-card bento-card--glass"
		hidden>
		<div class="profile-unauth">
			<div class="profile-unauth-icon">
				<svg
					width="40"
					height="40"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round">
					<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
					<circle cx="12" cy="7" r="4"></circle>
				</svg>
			</div>
			<h2 class="profile-unauth-title">Sign in to view your profile</h2>
			<p class="profile-unauth-subtitle">
				Connect with GitHub, Twitch, or Discord to get started.
			</p>
			<p class="profile-unauth-hint">
				Use the sign-in button in the navigation bar above.
			</p>
		</div>
	</div>

	{/* ── State: Username Setup ──────────────────────────────────────── */}
	<div
		id="profile-state-username"
		class="profile-card profile-card--state bento-card bento-card--glass"
		hidden>
		<div class="profile-username-setup">
			<div class="profile-username-icon">
				<svg
					width="24"
					height="24"
					viewBox="0 0 24 24"
					fill="none"
					stroke="var(--sl-color-accent-high)"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round">
					<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
					<circle cx="12" cy="7" r="4"></circle>
				</svg>
			</div>
			<h2 class="profile-username-title">Choose your username</h2>
			<p class="profile-username-subtitle">
				This is your unique identity on KBVE. It'll be used for your
				public profile and across all KBVE services.
			</p>
			<form class="profile-username-form" onsubmit="return false;">
				<div class="profile-username-input-row">
					<span class="profile-username-prefix">@</span>
					<input
						id="profile-username-input"
						type="text"
						placeholder="your_username"
						maxlength="24"
						autocomplete="off"
						class="profile-username-input"
					/>
				</div>
				<p id="profile-username-hint" class="profile-username-hint">
					3-24 characters, letters, numbers, underscores
				</p>
				<p
					id="profile-username-error"
					class="profile-username-error-msg"
					hidden>
				</p>
				<button
					id="profile-username-submit"
					type="submit"
					class="profile-username-btn"
					disabled>
					Claim username
				</button>
			</form>
		</div>
	</div>

	{/* ── State: Authenticated Profile (card stack) ──────────────────── */}
	<div id="profile-state-profile" class="profile-card-stack" hidden>
		<KbveProfileCard />
		<MinecraftProfileCard />
	</div>
</div>

<script>
	import { bootProfile } from './profile-controller';
	import { onMount } from '@kbve/astro/utils/clientRouter';

	onMount(() => {
		// bootProfile() guards itself against double-init through the
		// supabase init OnceCell + persistent profile cache, so calling
		// it on every ClientRouter swap is cheap (cache-hit fast-paint).
		bootProfile();
	});
</script>

<style>
	/* The shell + card stack dissolve into the parent bento grid, so the
	   KBVE and Minecraft cards place themselves as first-class tiles. */
	#profile-shell {
		display: contents;
	}
	.profile-card {
		padding: 1.25rem;
		width: 100%;
	}
	.profile-card[hidden] {
		display: none;
	}

	.profile-card-stack {
		display: contents;
	}
	.profile-card-stack[hidden] {
		display: none;
	}

	/* ── Loading ──────────────────────────────────────────────────── */
	.profile-loading {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.25rem;
		padding: 1rem 0;
	}
	.profile-loading-avatar {
		width: 80px;
		height: 80px;
		border-radius: 50%;
		overflow: hidden;
		background: var(--sl-color-hairline, #30363d);
	}
	.skeleton-shimmer {
		background: linear-gradient(
			90deg,
			color-mix(in srgb, var(--sl-color-white) 6%, transparent) 25%,
			color-mix(in srgb, var(--sl-color-white) 12%, transparent) 50%,
			color-mix(in srgb, var(--sl-color-white) 6%, transparent) 75%
		);
		background-size: 200% 100%;
		animation: shimmer 1.5s ease-in-out infinite;
	}
	@keyframes shimmer {
		0% {
			background-position: 200% 0;
		}
		100% {
			background-position: -200% 0;
		}
	}

	/* ── Unauthenticated ──────────────────────────────────────────── */
	.profile-unauth {
		text-align: center;
		padding: 1.5rem 0;
	}
	.profile-unauth-icon {
		width: 80px;
		height: 80px;
		margin: 0 auto 1rem;
		background: color-mix(
			in srgb,
			var(--sl-color-accent-high) 16%,
			transparent
		);
		border: 1px solid
			color-mix(in srgb, var(--sl-color-accent-high) 35%, transparent);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--sl-color-accent-high);
	}
	.profile-unauth-title {
		font-size: 1.125rem;
		font-weight: 600;
		color: var(--sl-color-white, #e6edf3);
		margin: 0 0 0.25rem;
	}
	.profile-unauth-subtitle {
		font-size: 0.875rem;
		color: var(--sl-color-gray-3, #8b949e);
		margin: 0 0 1rem;
	}
	.profile-unauth-hint {
		font-size: 0.75rem;
		color: var(--sl-color-gray-4, #6e7681);
		margin: 0;
	}

	/* ── Username Setup ───────────────────────────────────────────── */
	.profile-username-setup {
		text-align: center;
	}
	.profile-username-icon {
		width: 48px;
		height: 48px;
		margin: 0 auto 0.75rem;
		background: color-mix(
			in srgb,
			var(--sl-color-accent-high) 15%,
			transparent
		);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.profile-username-title {
		font-size: 1.125rem;
		font-weight: 600;
		color: var(--sl-color-white, #e6edf3);
		margin: 0 0 0.25rem;
	}
	.profile-username-subtitle {
		font-size: 0.8125rem;
		color: var(--sl-color-gray-3, #8b949e);
		margin: 0 0 1rem;
		line-height: 1.5;
	}
	.profile-username-form {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.profile-username-input-row {
		display: flex;
		align-items: center;
		gap: 0.25rem;
		background: var(--sl-color-bg, #0d1117);
		border: 1px solid var(--sl-color-hairline, #30363d);
		border-radius: 0.5rem;
		padding: 0.5rem 0.75rem;
	}
	.profile-username-prefix {
		color: var(--sl-color-gray-3, #8b949e);
		font-size: 0.875rem;
		font-weight: 500;
		user-select: none;
	}
	.profile-username-input {
		flex: 1;
		background: transparent;
		border: none;
		outline: none;
		color: var(--sl-color-white, #e6edf3);
		font-size: 0.875rem;
		font-family: monospace;
	}
	.profile-username-hint {
		font-size: 0.75rem;
		color: var(--sl-color-gray-4, #6e7681);
		text-align: left;
		margin: 0;
	}
	.profile-username-error-msg {
		font-size: 0.75rem;
		color: #f87171;
		background: rgba(239, 68, 68, 0.1);
		border-radius: 0.375rem;
		padding: 0.375rem 0.5rem;
		margin: 0;
		text-align: left;
	}
	.profile-username-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		background: var(--sl-color-accent-high);
		color: var(--sl-color-black);
		border: none;
		border-radius: 0.5rem;
		padding: 0.625rem 1rem;
		font-size: 0.875rem;
		font-weight: 600;
		margin-top: 0.25rem;
		transition: opacity 0.2s;
		cursor: pointer;
	}
	.profile-username-btn:disabled {
		opacity: 0.5;
		cursor: not-allowed;
	}
</style>
