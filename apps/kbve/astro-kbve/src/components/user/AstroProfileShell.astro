---
/**
 * AstroProfileShell — static HTML shell for all profile states.
 *
 * Every state (loading, unauthenticated, username-setup, profile) is
 * pre-rendered as hidden HTML. The profile-controller.ts script swaps
 * visibility via element IDs — O(1) DOM operations, no React needed
 * for layout-level transitions.
 *
 * React is only used for truly interactive islands (OAuth modal via
 * the NavDropdown, not here).
 */
---

<div id="profile-shell" class="not-content">
	<div class="profile-card">
		{/* ── State: Loading ─────────────────────────────────────────── */}
		<div id="profile-state-loading">
			<div class="profile-loading">
				<div class="profile-loading-avatar">
					<div
						class="skeleton-shimmer"
						style="width:100%;height:100%;border-radius:50%">
					</div>
				</div>
				<div
					class="skeleton-shimmer"
					style="width:10rem;height:1.25rem;border-radius:4px;margin-top:0.75rem">
				</div>
				<div
					class="skeleton-shimmer"
					style="width:7rem;height:0.875rem;border-radius:4px;margin-top:0.5rem">
				</div>
			</div>
		</div>

		{/* ── State: Unauthenticated ─────────────────────────────────── */}
		<div id="profile-state-unauth" hidden>
			<div class="profile-unauth">
				<div class="profile-unauth-icon">
					<svg
						width="40"
						height="40"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round">
						<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2">
						</path>
						<circle cx="12" cy="7" r="4"></circle>
					</svg>
				</div>
				<h2 class="profile-unauth-title">
					Sign in to view your profile
				</h2>
				<p class="profile-unauth-subtitle">
					Connect with GitHub, Twitch, or Discord to get started.
				</p>
				<p class="profile-unauth-hint">
					Use the sign-in button in the navigation bar above.
				</p>
			</div>
		</div>

		{/* ── State: Username Setup ──────────────────────────────────── */}
		<div id="profile-state-username" hidden>
			<div class="profile-username-setup">
				<div class="profile-username-icon">
					<svg
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						stroke="#06b6d4"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round">
						<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2">
						</path>
						<circle cx="12" cy="7" r="4"></circle>
					</svg>
				</div>
				<h2 class="profile-username-title">Choose your username</h2>
				<p class="profile-username-subtitle">
					This is your unique identity on KBVE. It'll be used for your
					public profile and across all KBVE services.
				</p>
				<form class="profile-username-form" onsubmit="return false;">
					<div class="profile-username-input-row">
						<span class="profile-username-prefix">@</span>
						<input
							id="profile-username-input"
							type="text"
							placeholder="your_username"
							maxlength="24"
							autocomplete="off"
							class="profile-username-input"
						/>
					</div>
					<p id="profile-username-hint" class="profile-username-hint">
						3-24 characters, letters, numbers, underscores
					</p>
					<p
						id="profile-username-error"
						class="profile-username-error-msg"
						hidden>
					</p>
					<button
						id="profile-username-submit"
						type="submit"
						class="profile-username-btn"
						disabled>
						Claim username
					</button>
				</form>
			</div>
		</div>

		{/* ── State: Authenticated Profile ───────────────────────────── */}
		<div id="profile-state-profile" hidden>
			{/* Header */}
			<header class="profile-header">
				<div class="profile-avatar" id="profile-slot-avatar">
					<span
						id="profile-slot-avatar-letter"
						class="profile-avatar-letter">
						U
					</span>
					<img
						id="profile-slot-avatar-img"
						class="profile-avatar-img"
						src=""
						alt=""
						hidden
					/>
				</div>
				<div class="profile-info">
					<h1 id="profile-slot-name" class="profile-name"></h1>
					<p id="profile-slot-email" class="profile-email"></p>
					<div id="profile-slot-badges" class="profile-badges">
						<span class="profile-badge">KBVE Member</span>
					</div>
				</div>
			</header>

			{/* Public profile link */}
			<a
				id="profile-slot-public-link"
				href="#"
				class="profile-public-link"
				target="_blank"
				rel="noopener noreferrer"
				hidden>
				<svg
					width="14"
					height="14"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round">
					<path
						d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6">
					</path>
					<polyline points="15 3 21 3 21 9"></polyline>
					<line x1="10" y1="14" x2="21" y2="3"></line>
				</svg>
				View Public Profile
			</a>

			{/* Connected accounts */}
			<section class="profile-section">
				<h2 class="profile-section-title">Connected Accounts</h2>
				<div id="profile-slot-providers" class="profile-providers">
					<p class="profile-providers-empty">
						Loading connected accounts...
					</p>
				</div>
			</section>

			{/* Account actions */}
			<section class="profile-section">
				<h2 class="profile-section-title">Account</h2>
				<div class="profile-actions">
					<a href="/settings" class="profile-action-card">
						<svg
							width="24"
							height="24"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round">
							<circle cx="12" cy="12" r="3"></circle>
							<path
								d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42">
							</path>
						</svg>
						<span>Settings</span>
					</a>
					<a
						href="/auth/logout"
						class="profile-action-card profile-action-danger">
						<svg
							width="24"
							height="24"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round">
							<path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4">
							</path>
							<polyline points="16 17 21 12 16 7"></polyline>
							<line x1="21" y1="12" x2="9" y2="12"></line>
						</svg>
						<span>Sign Out</span>
					</a>
				</div>
			</section>

			<a href="/" class="profile-back-link">
				<svg
					width="16"
					height="16"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round">
					<line x1="19" y1="12" x2="5" y2="12"></line>
					<polyline points="12 19 5 12 12 5"></polyline>
				</svg>
				Back to KBVE
			</a>
		</div>
	</div>
</div>

<script>
	import { bootProfile } from './profile-controller';
	bootProfile();
</script>

<style>
	.profile-card {
		background: linear-gradient(
			180deg,
			var(--sl-color-bg-accent, #164e63) 0%,
			transparent 100%
		);
		box-shadow: inset 0 0 0 1px var(--sl-color-hairline, #30363d);
		padding: 1.25rem;
		max-width: 480px;
		width: 100%;
		clip-path: polygon(
			0.75rem 0%,
			calc(100% - 0.75rem) 0%,
			100% 0.75rem,
			100% calc(100% - 0.75rem),
			calc(100% - 0.75rem) 100%,
			0.75rem 100%,
			0% calc(100% - 0.75rem),
			0% 0.75rem
		);
	}

	/* ── Loading ──────────────────────────────────────────────────── */
	.profile-loading {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.25rem;
		padding: 1rem 0;
	}
	.profile-loading-avatar {
		width: 80px;
		height: 80px;
		border-radius: 50%;
		overflow: hidden;
		background: var(--sl-color-hairline, #30363d);
	}
	.skeleton-shimmer {
		background: linear-gradient(
			90deg,
			var(--sl-color-hairline, #30363d) 25%,
			var(--sl-color-bg-accent, #164e63) 50%,
			var(--sl-color-hairline, #30363d) 75%
		);
		background-size: 200% 100%;
		animation: shimmer 1.5s ease-in-out infinite;
	}
	@keyframes shimmer {
		0% {
			background-position: 200% 0;
		}
		100% {
			background-position: -200% 0;
		}
	}

	/* ── Unauthenticated ──────────────────────────────────────────── */
	.profile-unauth {
		text-align: center;
		padding: 1.5rem 0;
	}
	.profile-unauth-icon {
		width: 80px;
		height: 80px;
		margin: 0 auto 1rem;
		background: linear-gradient(
			135deg,
			var(--sl-color-accent, #06b6d4),
			var(--sl-color-accent-high, #67e8f9)
		);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		color: #0d1117;
	}
	.profile-unauth-title {
		font-size: 1.125rem;
		font-weight: 600;
		color: var(--sl-color-white, #e6edf3);
		margin: 0 0 0.25rem;
	}
	.profile-unauth-subtitle {
		font-size: 0.875rem;
		color: var(--sl-color-gray-3, #8b949e);
		margin: 0 0 1rem;
	}
	.profile-unauth-hint {
		font-size: 0.75rem;
		color: var(--sl-color-gray-4, #6e7681);
		margin: 0;
	}

	/* ── Username Setup ───────────────────────────────────────────── */
	.profile-username-setup {
		text-align: center;
	}
	.profile-username-icon {
		width: 48px;
		height: 48px;
		margin: 0 auto 0.75rem;
		background: rgba(6, 182, 212, 0.15);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.profile-username-title {
		font-size: 1.125rem;
		font-weight: 600;
		color: var(--sl-color-white, #e6edf3);
		margin: 0 0 0.25rem;
	}
	.profile-username-subtitle {
		font-size: 0.8125rem;
		color: var(--sl-color-gray-3, #8b949e);
		margin: 0 0 1rem;
		line-height: 1.5;
	}
	.profile-username-form {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.profile-username-input-row {
		display: flex;
		align-items: center;
		gap: 0.25rem;
		background: var(--sl-color-bg, #0d1117);
		border: 1px solid var(--sl-color-hairline, #30363d);
		border-radius: 0.5rem;
		padding: 0.5rem 0.75rem;
	}
	.profile-username-prefix {
		color: var(--sl-color-gray-3, #8b949e);
		font-size: 0.875rem;
		font-weight: 500;
		user-select: none;
	}
	.profile-username-input {
		flex: 1;
		background: transparent;
		border: none;
		outline: none;
		color: var(--sl-color-white, #e6edf3);
		font-size: 0.875rem;
		font-family: monospace;
	}
	.profile-username-hint {
		font-size: 0.75rem;
		color: var(--sl-color-gray-4, #6e7681);
		text-align: left;
		margin: 0;
	}
	.profile-username-error-msg {
		font-size: 0.75rem;
		color: #f87171;
		background: rgba(239, 68, 68, 0.1);
		border-radius: 0.375rem;
		padding: 0.375rem 0.5rem;
		margin: 0;
		text-align: left;
	}
	.profile-username-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		background: linear-gradient(
			135deg,
			var(--sl-color-accent, #06b6d4),
			var(--sl-color-accent-high, #67e8f9)
		);
		color: #0d1117;
		border: none;
		border-radius: 0.5rem;
		padding: 0.625rem 1rem;
		font-size: 0.875rem;
		font-weight: 600;
		margin-top: 0.25rem;
		transition: opacity 0.2s;
		cursor: pointer;
	}
	.profile-username-btn:disabled {
		opacity: 0.5;
		cursor: not-allowed;
	}

	/* ── Authenticated Profile ────────────────────────────────────── */
	.profile-header {
		display: flex;
		gap: 1rem;
		align-items: center;
		margin-bottom: 1rem;
	}
	.profile-avatar {
		width: 72px;
		height: 72px;
		border-radius: 50%;
		overflow: hidden;
		background: var(--sl-color-hairline, #30363d);
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}
	.profile-avatar-letter {
		font-size: 1.5rem;
		font-weight: 700;
		color: var(--sl-color-white, #e6edf3);
	}
	.profile-avatar-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.profile-info {
		flex: 1;
		min-width: 0;
	}
	.profile-name {
		font-size: 1.125rem;
		font-weight: 700;
		color: var(--sl-color-white, #e6edf3);
		margin: 0;
		word-break: break-word;
	}
	.profile-email {
		font-size: 0.8125rem;
		color: var(--sl-color-gray-3, #8b949e);
		margin: 0.125rem 0 0.5rem;
	}
	.profile-badges {
		display: flex;
		gap: 0.375rem;
		flex-wrap: wrap;
	}
	.profile-badge {
		font-size: 0.6875rem;
		font-weight: 500;
		padding: 0.125rem 0.5rem;
		background: rgba(6, 182, 212, 0.15);
		color: #67e8f9;
		border: 1px solid rgba(6, 182, 212, 0.3);
		border-radius: 999px;
	}
	.profile-public-link {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		font-size: 0.8125rem;
		color: var(--sl-color-accent, #06b6d4);
		text-decoration: none;
		margin-bottom: 1rem;
	}
	.profile-public-link:hover {
		text-decoration: underline;
	}
	.profile-section {
		margin-bottom: 1rem;
	}
	.profile-section-title {
		font-size: 0.6875rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--sl-color-gray-3, #8b949e);
		margin: 0 0 0.5rem;
	}
	.profile-providers {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
	}
	.profile-providers-empty {
		font-size: 0.8125rem;
		color: var(--sl-color-gray-4, #6e7681);
		margin: 0;
	}
	:global(.profile-provider-badge) {
		font-size: 0.75rem;
		font-weight: 500;
		padding: 0.25rem 0.625rem;
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid var(--sl-color-hairline, #30363d);
		border-radius: 0.375rem;
		color: var(--sl-color-white, #e6edf3);
	}
	.profile-actions {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.5rem;
	}
	.profile-action-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.375rem;
		padding: 0.75rem;
		border-radius: 0.5rem;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid var(--sl-color-hairline, #30363d);
		color: var(--sl-color-white, #e6edf3);
		text-decoration: none;
		font-size: 0.8125rem;
		transition: background 0.2s;
	}
	.profile-action-card:hover {
		background: rgba(255, 255, 255, 0.06);
	}
	.profile-action-danger {
		color: #f87171;
	}
	.profile-action-danger:hover {
		background: rgba(239, 68, 68, 0.1);
	}
	.profile-back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		font-size: 0.8125rem;
		color: var(--sl-color-gray-3, #8b949e);
		text-decoration: none;
		margin-top: 0.5rem;
	}
	.profile-back-link:hover {
		color: var(--sl-color-white, #e6edf3);
	}
</style>
