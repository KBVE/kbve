---
import { getCollection } from 'astro:content';

interface PkgRow {
	id: string;
	title: string;
	pkg: string;
	version: string;
	sourcePath: string;
	registryUrl: string;
	docsHref: string;
}

const projects = await getCollection('project');

const githubBase = 'https://github.com/kbve/kbve/tree/dev/';

const pipelineMeta: Record<
	string,
	{ label: string; registry: (name: string) => string; accent: string }
> = {
	crates: {
		label: 'Rust crates',
		registry: (n) => `https://crates.io/crates/${n}`,
		accent: '#e57448',
	},
	npm: {
		label: 'NPM packages',
		registry: (n) =>
			n.startsWith('@')
				? `https://www.npmjs.com/package/${n}`
				: `https://www.npmjs.com/package/${n}`,
		accent: '#cb3837',
	},
	python: {
		label: 'Python packages',
		registry: (n) => `https://pypi.org/project/${n}/`,
		accent: '#3776ab',
	},
};

const buckets: Record<string, PkgRow[]> = { crates: [], npm: [], python: [] };

for (const p of projects) {
	const data = p.data as Record<string, unknown>;
	const pipeline = String(data.pipeline ?? '');
	if (!(pipeline in buckets)) continue;
	const pkg = String(
		data.package_name ?? data.crate_name ?? data.app_name ?? '',
	);
	if (!pkg) continue;
	const id = String((p as any).id ?? (p as any).slug ?? '');
	if (!id) continue;
	const slug = id.replace(/^project\//, '').replace(/\.mdx?$/, '');
	buckets[pipeline].push({
		id,
		title: String(data.title ?? slug),
		pkg,
		version: String(data.version ?? '0.0.0'),
		sourcePath: String(data.source_path ?? ''),
		registryUrl: pipelineMeta[pipeline].registry(pkg),
		docsHref: `/project/${slug}/`,
	});
}

for (const k of Object.keys(buckets)) {
	buckets[k].sort((a, b) => a.pkg.localeCompare(b.pkg));
}

const orderedGroups = (['crates', 'npm', 'python'] as const).filter(
	(k) => buckets[k].length > 0,
);
---

<section class="pkg not-content">
	{
		orderedGroups.map((k) => (
			<div
				class="pkg__group"
				style={`--pkg-accent: ${pipelineMeta[k].accent};`}>
				<div class="pkg__head">
					<h3 class="pkg__heading">{pipelineMeta[k].label}</h3>
					<span class="pkg__count">
						{buckets[k].length} published
					</span>
				</div>
				<div class="pkg__grid">
					{buckets[k].map((row) => (
						<div class="pkg__row">
							<div class="pkg__main">
								<a
									href={row.docsHref}
									class="pkg__name"
									data-astro-prefetch>
									{row.pkg}
								</a>
								<span class="pkg__version">v{row.version}</span>
							</div>
							<div class="pkg__title">{row.title}</div>
							<div class="pkg__links">
								<a
									href={row.registryUrl}
									target="_blank"
									rel="noopener noreferrer"
									class="pkg__link">
									Registry ↗
								</a>
								{row.sourcePath && (
									<a
										href={`${githubBase}${row.sourcePath}`}
										target="_blank"
										rel="noopener noreferrer"
										class="pkg__link">
										Source ↗
									</a>
								)}
							</div>
						</div>
					))}
				</div>
			</div>
		))
	}
</section>

<style>
	.pkg {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
		margin: 2.5rem 0;
	}

	.pkg__group {
		--pkg-accent: var(--sl-color-text-accent, #c9a56a);
	}

	.pkg__head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		padding-bottom: 0.6rem;
		margin-bottom: 1rem;
		border-bottom: 1px solid
			color-mix(in oklab, var(--pkg-accent) 30%, transparent);
	}

	.pkg__heading {
		margin: 0;
		font-size: 1.15rem;
		font-weight: 700;
		color: var(--pkg-accent);
	}

	.pkg__count {
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--sl-color-gray-3, #8b949e);
	}

	.pkg__grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
		gap: 0.6rem;
	}

	.pkg__row {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		padding: 0.85rem 1rem;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #262626);
		background: var(--sl-color-bg-nav, #111);
		transition:
			border-color 180ms ease,
			transform 180ms ease;
	}
	.pkg__row:hover {
		border-color: color-mix(in oklab, var(--pkg-accent) 55%, transparent);
		transform: translateY(-2px);
	}

	.pkg__main {
		display: flex;
		align-items: baseline;
		gap: 0.6rem;
		justify-content: space-between;
	}

	.pkg__name {
		font-size: 0.9rem;
		font-weight: 700;
		color: var(--sl-color-white, #fff);
		text-decoration: none;
		font-family:
			ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		letter-spacing: -0.01em;
	}
	.pkg__name:hover {
		color: var(--pkg-accent);
	}

	.pkg__version {
		font-size: 0.7rem;
		color: var(--sl-color-gray-3, #8b949e);
		font-variant-numeric: tabular-nums;
	}

	.pkg__title {
		font-size: 0.78rem;
		color: var(--sl-color-gray-2, #c2c2c2);
		line-height: 1.3;
	}

	.pkg__links {
		display: flex;
		gap: 0.85rem;
		margin-top: 0.2rem;
	}

	.pkg__link {
		font-size: 0.7rem;
		color: var(--pkg-accent);
		text-decoration: none;
		opacity: 0.85;
	}
	.pkg__link:hover {
		opacity: 1;
		text-decoration: underline;
	}
</style>
