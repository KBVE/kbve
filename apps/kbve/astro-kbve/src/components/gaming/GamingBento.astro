---
import { getCollection } from 'astro:content';
import BentoShell from '@/components/hero/BentoShell.astro';

interface Card {
	href: string;
	title: string;
	description: string;
	img?: string;
	tags: string[];
	order: number;
	featured: boolean;
}

// Games that live in their own top-level section (so their canonical URL is
// NOT under /gaming/). Listed here so the hub surfaces them without duplicating
// the page at /gaming/<slug>/. `order` interleaves with each gaming doc's
// `sidebar.order`.
const EXTERNAL_GAMES: Omit<Card, 'featured'>[] = [
	{
		href: '/mc/',
		title: 'Minecraft',
		description:
			'Agones-managed Minecraft fleet — survival and creative backends behind a Velocity proxy, plus the block, item, enchant, and schematic databases.',
		img: 'https://images.unsplash.com/photo-1587573089734-09cb69c0f2b4?fit=crop&w=1400&h=700&q=75',
		tags: ['minecraft', 'sandbox', 'multiplayer'],
		order: 100,
	},
	{
		href: '/osrs/',
		title: 'Old School RuneScape',
		description:
			'Browse every OSRS item KBVE tracks — search by name or id, filter by equipment, food, potions, and quest items in the live item database.',
		img: 'https://images.unsplash.com/photo-1581276879432-15e50529f34b?fit=crop&w=1400&h=700&q=75',
		tags: ['osrs', 'mmorpg', 'database'],
		order: 101,
	},
	{
		href: '/arcade/',
		title: 'Arcade',
		description:
			'KBVE Arcade — the home for our in-browser games: card games, action RPGs, endless runners, and classic Flash titles via Ruffle.',
		img: 'https://images.unsplash.com/photo-1688413399498-e35ed74b554f?fit=crop&w=1400&h=700&q=75',
		tags: ['arcade', 'browser-games'],
		order: 102,
	},
];

const entries = await getCollection('docs');

const collectionCards: Omit<Card, 'featured'>[] = entries
	.filter(
		(entry) =>
			entry.id.startsWith('gaming/') && entry.id !== 'gaming/index',
	)
	.map((entry) => {
		const slug = entry.id.replace(/^gaming\//, '');
		const rawDesc = entry.data.description ?? '';
		const description =
			typeof rawDesc === 'string'
				? rawDesc.replace(/\s+/g, ' ').trim()
				: '';
		const tags = ((entry.data as { tags?: string[] }).tags ?? []).filter(
			(t: string) => t.toLowerCase() !== 'gaming',
		);
		return {
			href: `/gaming/${slug}/`,
			title: entry.data.sidebar?.label ?? entry.data.title ?? slug,
			description,
			img:
				typeof entry.data.img === 'string' ? entry.data.img : undefined,
			tags,
			order: entry.data.sidebar?.order ?? 9999,
		};
	});

const cards: Card[] = [...collectionCards, ...EXTERNAL_GAMES]
	.sort((a, b) => {
		if (a.order !== b.order) return a.order - b.order;
		return a.title.localeCompare(b.title);
	})
	.map((card, index) => ({ ...card, featured: index === 0 }));

function unsplashSrc(url: string, w: number, h: number): string {
	if (!url.includes('images.unsplash.com')) return url;
	return `${url.split('?')[0]}?fit=crop&w=${w}&h=${h}&q=70&auto=format`;
}

function featuredImage(url: string) {
	const widths: [number, number][] = [
		[560, 280],
		[900, 450],
		[1120, 560],
		[1800, 900],
	];
	return {
		src: unsplashSrc(url, 900, 450),
		srcset: widths
			.map(([w, h]) => `${unsplashSrc(url, w, h)} ${w}w`)
			.join(', '),
		sizes: '(min-width: 1024px) 560px, (min-width: 640px) 50vw, 100vw',
	};
}

const total = cards.length;
---

<BentoShell
	eyebrow="KBVE Gaming"
	heading="Guides for the games we actually play.">
	<div class="gbento" role="group" aria-label={`${total} game guides`}>
		{
			cards.map((card) => (
				<a
					href={card.href}
					class:list={[
						'gbento__cell',
						card.featured && 'gbento__cell--featured',
					]}
					aria-label={card.title}
					data-astro-prefetch>
					{card.featured && card.img && (
						<img
							class="gbento__cell-img"
							src={featuredImage(card.img).src}
							srcset={featuredImage(card.img).srcset}
							sizes={featuredImage(card.img).sizes}
							alt={`${card.title} artwork`}
							width="900"
							height="450"
							loading="lazy"
							decoding="async"
						/>
					)}
					<div class="gbento__cell-inner">
						<div class="gbento__cell-head">
							<h3 class="gbento__cell-title">{card.title}</h3>
							<span class="gbento__cell-cta" aria-hidden="true">
								<svg
									viewBox="0 0 24 24"
									width="14"
									height="14"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round">
									<path d="M7 17L17 7M9 7h8v8" />
								</svg>
							</span>
						</div>
						{card.description && (
							<p class="gbento__cell-body">{card.description}</p>
						)}
						{card.tags.length > 0 && (
							<div class="gbento__cell-tags">
								{card.tags.map((tag) => (
									<span class="gbento__tag">{tag}</span>
								))}
							</div>
						)}
					</div>
				</a>
			))
		}
	</div>
</BentoShell>

<style>
	.gbento {
		display: grid;
		grid-template-columns: repeat(1, minmax(0, 1fr));
		grid-auto-flow: dense;
		gap: 1px;
		background-color: var(--bento-hairline);
		border-top: 1px solid var(--bento-hairline);
	}

	.gbento__cell {
		position: relative;
		display: flex;
		min-height: 10rem;
		background-color: var(--bento-cell-bg);
		text-decoration: none;
		overflow: hidden;
		isolation: isolate;
	}

	.gbento__cell-img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0.28;
		z-index: -1;
		transition: opacity 300ms ease;
	}

	.gbento__cell:hover .gbento__cell-img {
		opacity: 0.42;
	}

	.gbento__cell-inner {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding: 1.5rem;
		width: 100%;
	}

	.gbento__cell-head {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 0.75rem;
	}

	.gbento__cell-title {
		font-size: 0.9375rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		color: var(--sl-color-white);
		margin: 0;
	}

	.gbento__cell-body {
		font-size: 0.8125rem;
		line-height: 1.5;
		color: var(--sl-color-gray-3);
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.gbento__cell-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
		margin-top: auto;
	}

	.gbento__tag {
		font-size: 0.625rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		padding: 0.15rem 0.5rem;
		border-radius: 999px;
		border: 1px solid var(--bento-hairline-strong);
		color: var(--sl-color-gray-3);
	}

	.gbento__cell-cta {
		flex-shrink: 0;
		color: var(--sl-color-gray-4);
		opacity: 0.55;
		transition:
			opacity 220ms ease,
			color 220ms ease;
	}

	.gbento__cell:hover .gbento__cell-cta {
		opacity: 1;
		color: var(--sl-color-accent-high);
	}

	@media (min-width: 640px) {
		.gbento {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1024px) {
		.gbento {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}

		.gbento__cell--featured {
			grid-column: span 2;
			grid-row: span 2;
		}

		.gbento__cell--featured .gbento__cell-title {
			font-size: 1.25rem;
		}

		.gbento__cell--featured .gbento__cell-body {
			font-size: 0.9375rem;
			-webkit-line-clamp: 5;
		}
	}
</style>
