---
import AstroDroidFooter from './AstroDroidFooter.astro';
import ReactNavBarStrip from '@/components/rnweb/ReactNavBarStrip.tsx';
import SocialTooltip from '@kbve/astro/components/tooltip/social/SocialTooltip.astro';
import SocialIcon from '@kbve/astro/components/social/icons/SocialIcon.astro';
import { SOCIALS, withUtm } from '@kbve/astro/data/socials';
// import AstroYukiDock from '@/components/jay/dock/AstroYukiDock.astro';

const legalLinks = [
	{ href: '/legal/privacy', label: 'Privacy' },
	{ href: '/legal/tos', label: 'Terms' },
	{ href: '/legal/', label: 'Legal' },
];

const resourceLinks = [
	{ href: '/docs', label: 'Documentation' },
	{ href: '/api', label: 'API Reference' },
	{ href: '/blog', label: 'Blog' },
	{ href: '/changelog', label: 'Changelog' },
];

const quickLinks = [
	{ href: '/dashboard/', label: 'Dashboard' },
	{ href: '/project/', label: 'Projects' },
	{ href: '/analysis/', label: 'Analytics' },
	{ href: '/dashboard/account/', label: 'Account' },
	{ href: '/support/', label: 'Support' },
];

const arcadeLinks = [
	{ href: '/arcade/', label: 'Arcade' },
	{ href: '/gdd/', label: 'Game Design Docs' },
	{ href: '/gaming/', label: 'Gaming' },
	{ href: '/music/', label: 'Music' },
];

const dataLinks = [
	{ href: '/itemdb/', label: 'Item DB' },
	{ href: '/mapdb/', label: 'Map DB' },
	{ href: '/spelldb/', label: 'Spell DB' },
	{ href: '/osrs/', label: 'OSRS' },
];

const communityLinks = [
	{ href: '/discord', label: 'Discord' },
	{ href: '/github', label: 'GitHub' },
	{ href: '/chat', label: 'Chat' },
	{ href: '/about', label: 'About' },
	{ href: '/donate/', label: 'Donate' },
	{ href: '/feature/', label: 'Features' },
];

const socials = SOCIALS;

const currentYear = new Date().getFullYear();
---

<footer id="kbve-footer" class="kf-footer not-content">
	<div class="kf-rn-navbar" aria-label="react-native-web nav (test strip)">
		<ReactNavBarStrip client:only="react">
			<div slot="fallback" class="kf-rn-navbar__skeleton" aria-hidden="true">
				<span class="kf-rn-navbar__brand"></span>
				<span class="kf-rn-navbar__links">
					<span class="kf-rn-navbar__chip"></span>
					<span class="kf-rn-navbar__chip"></span>
					<span class="kf-rn-navbar__chip"></span>
					<span class="kf-rn-navbar__chip"></span>
				</span>
			</div>
		</ReactNavBarStrip>
	</div>
	<div class="kf-container bento-frame">
		<div class="kf-grid">
			<div class="kf-brand">
				<a href="/" class="kf-brand-link" aria-label="KBVE home">
					<svg
						viewBox="0 0 76 76"
						class="kf-logo-svg"
						xmlns="http://www.w3.org/2000/svg"
						aria-hidden="true">
						<path
							fill="currentColor"
							d="M 19.3919,37.5442C 19.6211,31.4744 22.697,25.8757 28.3209,22.1759C 28.3375,22.1822 28.4831,22.1291 28.4166,22.255C 27.9707,22.668 19.9618,32.1286 27.3341,39.5966C 27.3341,39.5966 31.2074,43.3197 34.2103,39.7866C 34.2103,39.7866 37.1747,35.9499 34.173,30.134C 34.173,30.134 33.4135,28.2344 30.6765,27.057L 32.8808,24.6247C 32.8808,24.6247 34.7436,25.424 36.1859,27.5916C 36.1859,27.5916 36.2626,25.3093 34.5143,22.8771L 37.9323,19L 41.3153,22.8411C 41.3153,22.8411 39.7596,25.0452 39.645,27.6276C 39.645,27.6276 40.7072,25.8795 42.9887,24.6247L 45.1531,27.057C 45.1531,27.057 43.0717,27.7423 41.6775,30.1087C 40.4786,32.3015 39.5556,36.9906 41.7314,39.867C 41.7314,39.867 44.1662,43.3197 48.45,39.663C 48.45,39.663 56.3257,32.6062 47.6423,22.4039C 47.6423,22.4039 47.168,21.9846 47.7007,22.2127C 51.5385,25.0066 56.1339,28.6918 56.6082,37.8876C 56.4214,49.0393 48.9535,57 38.0487,57C 27.3715,57 19.0713,48.0899 19.3919,37.5442 Z">
						</path>
					</svg>
					<span class="kf-logo-text">KBVE</span>
				</a>
				<p class="kf-description">
					Open-source tools, games, and applications crafted for
					developers and creators.
				</p>
			</div>

			<nav class="kf-nav" aria-labelledby="kf-quicklinks-heading">
				<h6 id="kf-quicklinks-heading" class="kf-nav-title">
					Quick Links
				</h6>
				{
					quickLinks.map((link) => (
						<a
							href={link.href}
							class="kf-nav-link"
							data-astro-prefetch>
							{link.label}
						</a>
					))
				}
			</nav>

			<nav class="kf-nav" aria-labelledby="kf-resources-heading">
				<h6 id="kf-resources-heading" class="kf-nav-title">
					Resources
				</h6>
				{
					resourceLinks.map((link) => (
						<a
							href={link.href}
							class="kf-nav-link"
							data-astro-prefetch>
							{link.label}
						</a>
					))
				}
			</nav>

			<nav class="kf-nav" aria-labelledby="kf-legal-heading">
				<h6 id="kf-legal-heading" class="kf-nav-title">Legal</h6>
				{
					legalLinks.map((link) => (
						<a
							href={link.href}
							class="kf-nav-link"
							data-astro-prefetch>
							{link.label}
						</a>
					))
				}
			</nav>

			<nav class="kf-nav" aria-labelledby="kf-arcade-heading">
				<h6 id="kf-arcade-heading" class="kf-nav-title">Arcade</h6>
				{
					arcadeLinks.map((link) => (
						<a
							href={link.href}
							class="kf-nav-link"
							data-astro-prefetch>
							{link.label}
						</a>
					))
				}
			</nav>

			<nav class="kf-nav" aria-labelledby="kf-data-heading">
				<h6 id="kf-data-heading" class="kf-nav-title">Databases</h6>
				{
					dataLinks.map((link) => (
						<a
							href={link.href}
							class="kf-nav-link"
							data-astro-prefetch>
							{link.label}
						</a>
					))
				}
			</nav>

			<nav
				class="kf-nav kf-nav--wide"
				aria-labelledby="kf-community-heading">
				<h6 id="kf-community-heading" class="kf-nav-title">
					Community
				</h6>
				<div class="kf-nav-columns">
					{
						communityLinks.map((link) => (
							<a
								href={link.href}
								class="kf-nav-link"
								data-astro-prefetch>
								{link.label}
							</a>
						))
					}
				</div>
			</nav>
		</div>

		<div class="kf-bottom">
			<span class="kf-copyright">
				© {currentYear}{' '}<a href="/">KBVE</a>. All rights reserved.
			</span>
			<div class="kf-social" aria-label="Social links">
				{
					socials.map(
						({
							platform,
							href,
							title,
							description,
							badge,
							ringColor,
						}) => (
							<SocialTooltip
								href={withUtm(href, 'kbve', 'footer', platform)}
								target="_blank"
								rel="noopener noreferrer"
								ariaLabel={title}
								title={title}
								description={description}
								badge={badge}
								ringColor={ringColor}
								direction="top"
								size="sm">
								<span slot="icon" class="kf-social-glyph">
									<SocialIcon platform={platform} size={20} />
								</span>
								<Fragment slot="label">{title}</Fragment>
							</SocialTooltip>
						),
					)
				}
			</div>
		</div>
	</div>

	<AstroDroidFooter />
</footer>

{/* <AstroYukiDock /> */}

<style>
	.kf-footer {
		margin-top: 0;
		background-color: var(--sl-color-black);
		border-top: 1px solid var(--bento-hairline);
		overflow-x: clip;
	}

	.kf-container {
		padding: 0;
	}

	/* react-native-web NavBar test strip — sits above the bento footer grid.
	   Reserve the NavBar's 60px height so the client:only island can't shift
	   the footer when it hydrates (CLS = 0). The fallback skeleton fills the
	   same box until React mounts. */
	.kf-rn-navbar {
		min-height: 60px;
		border-bottom: 1px solid var(--bento-hairline);
	}

	.kf-rn-navbar__skeleton {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		width: 100%;
		max-width: 1120px;
		margin: 0 auto;
		min-height: 60px;
		padding: 0.5rem 2rem;
		box-sizing: border-box;
	}

	.kf-rn-navbar__links {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.kf-rn-navbar__brand,
	.kf-rn-navbar__chip {
		display: inline-block;
		height: 1rem;
		border-radius: 0.375rem;
		background: linear-gradient(
			90deg,
			var(--bento-cell-bg) 0%,
			var(--bento-hairline) 50%,
			var(--bento-cell-bg) 100%
		);
		background-size: 200% 100%;
		animation: kf-rn-navbar-shimmer 1.3s ease-in-out infinite;
	}

	.kf-rn-navbar__brand {
		width: 3.5rem;
		height: 1.25rem;
	}

	.kf-rn-navbar__chip {
		width: 3.5rem;
	}

	@keyframes kf-rn-navbar-shimmer {
		0% {
			background-position: 200% 0;
		}
		100% {
			background-position: -200% 0;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.kf-rn-navbar__brand,
		.kf-rn-navbar__chip {
			animation: none;
		}
	}

	/* Main grid: bento seams — 1px hairline gaps between cells */
	.kf-grid {
		display: grid;
		grid-template-columns: 1.5fr repeat(3, 1fr);
		gap: 1px;
		background-color: var(--bento-hairline);
	}

	.kf-grid > * {
		background-color: var(--bento-cell-bg);
		padding: 2rem 1.5rem;
	}

	/* Brand */
	.kf-brand-link {
		display: inline-flex;
		align-items: center;
		gap: 0.625rem;
		text-decoration: none;
		color: var(--sl-color-white);
		transition: color 150ms ease;
	}

	.kf-brand-link:hover {
		color: var(--sl-color-text-accent);
	}

	/* Logo keeps brand gold tone at idle; inherits on hover via currentColor */
	.kf-logo-svg {
		width: 1.75rem;
		height: 1.75rem;
		color: var(--sl-color-text-accent);
		transition: color 150ms ease;
	}

	.kf-brand-link:hover .kf-logo-svg {
		color: var(--sl-color-accent-high);
	}

	.kf-logo-text {
		font-size: 1.125rem;
		font-weight: 700;
		letter-spacing: 0.05em;
	}

	.kf-description {
		margin-top: 0.75rem;
		font-size: 0.8125rem;
		line-height: 1.6;
		color: var(--sl-color-gray-2);
		max-width: 22rem;
	}

	/* Link columns */
	.kf-nav {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 0.625rem;
	}

	.kf-nav-title {
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--sl-color-white);
		margin: 0 0 0.25rem;
	}

	.kf-nav-link {
		font-size: 0.8125rem;
		color: var(--sl-color-gray-2);
		text-decoration: none;
		transition: color 150ms ease;
	}

	.kf-nav-link:hover {
		color: var(--sl-color-text-accent);
	}

	.kf-nav--wide {
		grid-column: span 2;
	}

	.kf-nav-columns {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.625rem 1.5rem;
	}

	/* Bottom bar: copyright left, socials right */
	.kf-bottom {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 1.25rem 1.5rem;
		border-top: 1px solid var(--bento-hairline);
	}

	.kf-copyright {
		font-size: 0.8125rem;
		color: var(--sl-color-gray-3);
	}

	.kf-copyright a {
		color: var(--sl-color-gray-2);
		text-decoration: none;
		font-weight: 500;
		transition: color 150ms ease;
	}

	.kf-copyright a:hover {
		color: var(--sl-color-text-accent);
	}

	/* Socials: each wrapped in SocialTooltip (56px circle trigger + hover ring) */
	.kf-social {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 1.5rem;
	}

	/* Responsive */
	@media (max-width: 768px) {
		.kf-grid {
			grid-template-columns: 1fr 1fr;
		}

		.kf-brand {
			grid-column: 1 / -1;
		}

		.kf-nav--wide {
			grid-column: 1 / -1;
		}

		/* Tablet: tighter spacing, allow wrap. SocialTooltip ships a
		   fixed 56px trigger from packages/npm/astro — override via
		   :global() since the child markup is unscoped. */
		.kf-social {
			gap: 1rem;
			justify-content: center;
			width: 100%;
		}
		.kf-social :global(.stt__trigger),
		.kf-social :global(.stt__trigger .stt__layer) {
			width: 48px;
			height: 48px;
		}
	}

	@media (max-width: 480px) {
		.kf-grid {
			grid-template-columns: 1fr;
		}

		.kf-bottom {
			flex-direction: column;
			gap: 1rem;
			text-align: center;
		}

		/* Phone: 10 socials wrap to 2 rows. Five per row at 40px +
		   0.6rem gap fits a 360px viewport without horizontal
		   scroll. */
		.kf-social {
			gap: 0.6rem;
			row-gap: 0.75rem;
			justify-content: center;
		}
		.kf-social :global(.stt__trigger),
		.kf-social :global(.stt__trigger .stt__layer) {
			width: 40px;
			height: 40px;
		}
		.kf-social :global(.stt__icon) {
			width: 40px;
			height: 40px;
		}
		.kf-social :global(.kf-social-glyph svg) {
			width: 18px;
			height: 18px;
		}
	}
</style>
