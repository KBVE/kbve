---
/**
 * CollapsibleSection — static HTML <details> with persistent open state.
 *
 * The section header renders as static HTML (zero JS, zero virtual DOM).
 * The slot content is whatever React island you pass in. When collapsed,
 * the browser hides the slot via native <details>/<summary> — no React
 * re-renders, no unmounting.
 *
 * Open/closed state persists to localStorage via a tiny inline script.
 */
interface Props {
	id: string;
	title: string;
	icon?: string;
	accentColor?: string;
	defaultOpen?: boolean;
	badge?: string;
}

const {
	id,
	title,
	icon,
	accentColor = '#8b5cf6',
	defaultOpen = true,
	badge,
} = Astro.props;
---

<details
	id={`section-${id}`}
	class="dashboard-section"
	data-section-id={id}
	open={defaultOpen}>
	<summary class="dashboard-section-header">
		<div class="section-header-left">
			<svg
				class="chevron"
				width="16"
				height="16"
				viewBox="0 0 16 16"
				fill="currentColor">
				<path d="M6 4l4 4-4 4"></path>
			</svg>
			{
				icon && (
					<span
						class="section-icon"
						style={`color: ${accentColor}`}
						set:html={icon}
					/>
				)
			}
			<span class="section-title">{title}</span>
			{
				badge && (
					<span
						class="section-badge"
						style={`background: ${accentColor}22; color: ${accentColor}`}>
						{badge}
					</span>
				)
			}
		</div>
	</summary>
	<div class="section-content">
		<slot />
	</div>
</details>

<script>
	// Persist open/closed state per section — runs once on page load
	document
		.querySelectorAll<HTMLDetailsElement>('.dashboard-section')
		.forEach((el) => {
			const key = `dash-section-${el.dataset.sectionId}`;
			const saved = localStorage.getItem(key);
			if (saved !== null) {
				el.open = saved === '1';
			}
			el.addEventListener('toggle', () => {
				localStorage.setItem(key, el.open ? '1' : '0');
			});
		});
</script>

<style>
	.dashboard-section {
		border: 1px solid var(--sl-color-gray-5, #262626);
		border-radius: 12px;
		background: var(--sl-color-bg-nav, #111);
		overflow: hidden;
		margin-bottom: 1rem;
	}

	.dashboard-section[open] .chevron {
		transform: rotate(90deg);
	}

	.dashboard-section-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.75rem 1rem;
		cursor: pointer;
		user-select: none;
		list-style: none;
		border-bottom: 1px solid transparent;
		transition: border-color 0.15s;
	}

	.dashboard-section-header::-webkit-details-marker {
		display: none;
	}

	.dashboard-section[open] .dashboard-section-header {
		border-bottom-color: var(--sl-color-gray-5, #262626);
	}

	.dashboard-section-header:hover {
		background: rgba(255, 255, 255, 0.02);
	}

	.section-header-left {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.chevron {
		width: 16px;
		height: 16px;
		color: var(--sl-color-gray-3, #8b949e);
		transition: transform 0.15s ease;
		flex-shrink: 0;
	}

	.section-icon {
		font-size: 1.1rem;
		line-height: 1;
	}

	.section-title {
		font-weight: 600;
		font-size: 0.95rem;
		color: var(--sl-color-text, #e6edf3);
	}

	.section-badge {
		font-size: 0.7rem;
		font-weight: 600;
		padding: 2px 8px;
		border-radius: 10px;
		line-height: 1.4;
	}

	.section-content {
		padding: 1rem;
	}
</style>
