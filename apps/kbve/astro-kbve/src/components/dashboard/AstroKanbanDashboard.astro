---
import kanbanData from '@/data/nx-kanban.json';
import ReactKanbanBrowser from './ReactKanbanBrowser';

const summary = kanbanData.summary as Record<string, number>;
const project = kanbanData.project as {
	title: string;
	url: string;
	total_items: number;
};
const generatedAt = kanbanData.generated_at as string;

const columnOrder = [
	'Theory',
	'AI',
	'Todo',
	'Backlog',
	'Error',
	'Support',
	'Staging',
	'Review',
	'Done',
];
const columnColors: Record<string, string> = {
	Theory: '#8b5cf6',
	AI: '#06b6d4',
	Todo: '#3b82f6',
	Backlog: '#6366f1',
	Error: '#ef4444',
	Support: '#f59e0b',
	Staging: '#f97316',
	Review: '#eab308',
	Done: '#22c55e',
};
const phaseColors: Record<string, string> = {
	Planning: '#8b5cf6',
	Active: '#3b82f6',
	Blocked: '#ef4444',
	Done: '#22c55e',
};

const done = summary['Done'] ?? 0;
const errorCount = summary['Error'] ?? 0;
const supportCount = summary['Support'] ?? 0;
const active = ['Todo', 'Staging', 'Review'].reduce(
	(s, c) => s + (summary[c] ?? 0),
	0,
);
const planning = ['Theory', 'AI', 'Backlog'].reduce(
	(s, c) => s + (summary[c] ?? 0),
	0,
);
const blocked = errorCount + supportCount;
const total = project.total_items;

const entries = columnOrder
	.filter((k) => (summary[k] ?? 0) > 0)
	.map((k) => ({ name: k, count: summary[k], color: columnColors[k] }));
const barTotal = entries.reduce((s, e) => s + e.count, 0);

const syncDate = new Date(generatedAt);
const syncStr = syncDate.toLocaleDateString('en-US', {
	month: 'short',
	day: 'numeric',
	year: 'numeric',
});

// Phase breakdown for pie-style visualization
const phases = [
	{ label: 'Planning', value: planning, color: phaseColors.Planning },
	{ label: 'Active', value: active, color: phaseColors.Active },
	{ label: 'Blocked', value: blocked, color: phaseColors.Blocked },
	{ label: 'Done', value: done, color: phaseColors.Done },
].filter((p) => p.value > 0);
const phaseTotal = phases.reduce((s, p) => s + p.value, 0);

// Top labels
const columns = kanbanData.columns as Record<
	string,
	Array<{ labels: string[] }>
>;
const labelCounts: Record<string, number> = {};
for (const col of Object.values(columns)) {
	for (const item of col) {
		for (const label of item.labels) {
			labelCounts[label] = (labelCounts[label] ?? 0) + 1;
		}
	}
}
const topLabels = Object.entries(labelCounts)
	.sort((a, b) => b[1] - a[1])
	.slice(0, 8);

// Type breakdown
const issueCount = Object.values(columns)
	.flat()
	.filter((i: any) => i.type === 'ISSUE').length;
const prCount = Object.values(columns)
	.flat()
	.filter((i: any) => i.type === 'PULL_REQUEST').length;
---

<section
	id="kanban-dashboard-wrapper"
	class="kanban-dashboard-wrapper not-content"
	aria-label="Kanban dashboard">
	<div class="kanban-dashboard-content">
		<!-- ══ STATIC: Summary Header ══ -->
		<div class="kb-card">
			<div class="kb-header-row">
				<div class="kb-title-group">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="20"
						height="20"
						viewBox="0 0 24 24"
						fill="none"
						stroke="var(--sl-color-accent, #06b6d4)"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round">
						<rect x="3" y="3" width="18" height="18" rx="2">
						</rect><path d="M8 7v7"></path><path d="M12 7v4">
						</path><path d="M16 7v10"></path>
					</svg>
					<h2>{project.title} Project Board</h2>
				</div>
				<div class="kb-meta-group">
					<span class="kb-sync">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="11"
							height="11"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round">
							<circle cx="12" cy="12" r="10"></circle><polyline
								points="12 6 12 12 16 14">
							</polyline>
						</svg>
						Synced {syncStr}
					</span>
					<a
						href={project.url}
						target="_blank"
						rel="noopener noreferrer"
						class="kb-github-link">
						GitHub
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="11"
							height="11"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round">
							<path
								d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6">
							</path><polyline points="15 3 21 3 21 9">
							</polyline><line x1="10" y1="14" x2="21" y2="3">
							</line>
						</svg>
					</a>
				</div>
			</div>

			<!-- Stats row -->
			<div class="kb-stats-row">
				<div class="kb-stat">
					<span
						class="kb-stat-value"
						style={`color: var(--sl-color-accent, #06b6d4)`}>
						{total}
					</span>
					<span class="kb-stat-label">Total</span>
				</div>
				<div class="kb-stat">
					<span class="kb-stat-value" style="color: #f59e0b">
						{active}
					</span>
					<span class="kb-stat-label">Active</span>
				</div>
				<div class="kb-stat">
					<span
						class="kb-stat-value"
						style={`color: ${errorCount > 0 ? '#ef4444' : '#22c55e'}`}>
						{errorCount}
					</span>
					<span class="kb-stat-label">Error</span>
				</div>
				<div class="kb-stat">
					<span class="kb-stat-value" style="color: #22c55e">
						{done}
					</span>
					<span class="kb-stat-label">Done</span>
				</div>
			</div>

			<!-- Distribution bar -->
			<div class="kb-dist">
				<div class="kb-dist-bar">
					{
						entries.map((e) => (
							<div
								title={`${e.name}: ${e.count}`}
								style={`width:${(e.count / barTotal) * 100}%;background:${e.color};min-width:${e.count > 0 ? '2px' : '0'}`}
							/>
						))
					}
				</div>
				<div class="kb-dist-legend">
					{
						entries.map((e) => (
							<span class="kb-dist-item">
								<span
									class="kb-dist-dot"
									style={`background:${e.color}`}
								/>
								{e.name} {e.count}
							</span>
						))
					}
				</div>
			</div>
		</div>

		<!-- ══ STATIC: Charts Section ══ -->
		<div class="kb-charts-grid">
			<!-- Phase breakdown -->
			<div class="kb-card kb-chart-card">
				<h3 class="kb-section-title">Work Distribution</h3>
				<div class="kb-phase-bars">
					{
						phases.map((p) => (
							<div class="kb-phase-row">
								<span class="kb-phase-label">{p.label}</span>
								<div class="kb-phase-track">
									<div
										class="kb-phase-fill"
										style={`width:${(p.value / phaseTotal) * 100}%;background:${p.color}`}
									/>
								</div>
								<span
									class="kb-phase-count"
									style={`color:${p.color}`}>
									{p.value}
								</span>
							</div>
						))
					}
				</div>
			</div>

			<!-- Pipeline -->
			<div class="kb-card kb-chart-card">
				<h3 class="kb-section-title">Pipeline</h3>
				<div class="kb-pipeline">
					{
						columnOrder.map((col, i) => {
							const count = summary[col] ?? 0;
							const color = columnColors[col];
							return (
								<div class="kb-pipe-stage">
									<div
										class="kb-pipe-node"
										style={`border-color:${color};color:${color}`}>
										<span class="kb-pipe-count">
											{count}
										</span>
										<span class="kb-pipe-name">{col}</span>
									</div>
									{i < columnOrder.length - 1 && (
										<div class="kb-pipe-arrow">→</div>
									)}
								</div>
							);
						})
					}
				</div>
			</div>

			<!-- Breakdown -->
			<div class="kb-card kb-chart-card">
				<h3 class="kb-section-title">Breakdown</h3>
				<div class="kb-breakdown-grid">
					<div class="kb-breakdown-types">
						<div class="kb-type-row">
							<span class="kb-type-icon" style="color:#22c55e">
								●
							</span>
							<span class="kb-type-label">Issues</span>
							<span class="kb-type-value">{issueCount}</span>
						</div>
						<div class="kb-type-row">
							<span class="kb-type-icon" style="color:#8b5cf6">
								●
							</span>
							<span class="kb-type-label">Pull Requests</span>
							<span class="kb-type-value">{prCount}</span>
						</div>
					</div>
					<div class="kb-top-labels">
						<h4 class="kb-labels-title">Top Labels</h4>
						{
							topLabels.map(([label, count]) => (
								<div class="kb-label-row">
									<span class="kb-label-name">{label}</span>
									<span class="kb-label-bar-track">
										<span
											class="kb-label-bar-fill"
											style={`width:${(count / topLabels[0][1]) * 100}%`}
										/>
									</span>
									<span class="kb-label-count">{count}</span>
								</div>
							))
						}
					</div>
				</div>
			</div>
		</div>

		<!-- ══ REACT ISLAND: Interactive item browser ══ -->
		<ReactKanbanBrowser client:only="react" />
	</div>
</section>

<style>
	.kanban-dashboard-wrapper {
		background: transparent;
		min-height: 100vh;
		position: relative;
		width: 100vw;
		margin-left: calc(-50vw + 50%);
	}
	.kanban-dashboard-content {
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem 1rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	@media (min-width: 768px) {
		.kanban-dashboard-content {
			padding: 2rem 1.5rem;
		}
	}

	/* Card base */
	.kb-card {
		padding: 1.25rem;
		border-radius: 12px;
		border: 1px solid var(--sl-color-gray-5, #262626);
		background: var(--sl-color-bg-nav, #111);
	}

	/* Header row */
	.kb-header-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-bottom: 1rem;
	}
	.kb-title-group {
		display: flex;
		align-items: center;
		gap: 8px;
	}
	.kb-title-group h2 {
		margin: 0;
		font-size: 1.1rem;
		font-weight: 700;
		color: var(--sl-color-text, #e6edf3);
	}
	.kb-meta-group {
		display: flex;
		align-items: center;
		gap: 1rem;
	}
	.kb-sync {
		display: flex;
		align-items: center;
		gap: 4px;
		font-size: 0.7rem;
		color: var(--sl-color-gray-4, #6b7280);
	}
	.kb-github-link {
		display: flex;
		align-items: center;
		gap: 4px;
		font-size: 0.75rem;
		color: var(--sl-color-accent, #06b6d4);
		text-decoration: none;
		font-weight: 600;
	}

	/* Stats */
	.kb-stats-row {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
		margin-bottom: 1rem;
	}
	.kb-stat {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2px;
		padding: 8px 16px;
		border-radius: 8px;
		border: 1px solid var(--sl-color-gray-5, #262626);
		background: var(--sl-color-bg-nav, #111);
		min-width: 70px;
	}
	.kb-stat-value {
		font-size: 1.25rem;
		font-weight: 700;
		font-variant-numeric: tabular-nums;
		line-height: 1.2;
	}
	.kb-stat-label {
		font-size: 0.65rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--sl-color-gray-3, #8b949e);
	}

	/* Distribution bar */
	.kb-dist {
		width: 100%;
	}
	.kb-dist-bar {
		display: flex;
		height: 6px;
		border-radius: 3px;
		overflow: hidden;
		background: var(--sl-color-gray-5, #30363d);
	}
	.kb-dist-legend {
		display: flex;
		flex-wrap: wrap;
		gap: 0.25rem 0.75rem;
		margin-top: 6px;
	}
	.kb-dist-item {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		font-size: 0.65rem;
		color: var(--sl-color-gray-3, #8b949e);
	}
	.kb-dist-dot {
		width: 7px;
		height: 7px;
		border-radius: 50%;
		flex-shrink: 0;
	}

	/* Charts grid */
	.kb-charts-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
	}
	@media (max-width: 768px) {
		.kb-charts-grid {
			grid-template-columns: 1fr;
		}
	}
	.kb-chart-card {
		min-height: 0;
	}
	.kb-section-title {
		margin: 0 0 1rem 0;
		font-size: 0.8rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--sl-color-gray-3, #8b949e);
	}

	/* Phase bars */
	.kb-phase-bars {
		display: flex;
		flex-direction: column;
		gap: 10px;
	}
	.kb-phase-row {
		display: flex;
		align-items: center;
		gap: 10px;
	}
	.kb-phase-label {
		font-size: 0.75rem;
		font-weight: 500;
		color: var(--sl-color-gray-3, #8b949e);
		min-width: 60px;
		text-align: right;
	}
	.kb-phase-track {
		flex: 1;
		height: 8px;
		border-radius: 4px;
		background: var(--sl-color-gray-5, #262626);
		overflow: hidden;
	}
	.kb-phase-fill {
		height: 100%;
		border-radius: 4px;
		transition: width 0.3s ease;
	}
	.kb-phase-count {
		font-size: 0.8rem;
		font-weight: 700;
		font-variant-numeric: tabular-nums;
		min-width: 30px;
	}

	/* Pipeline */
	.kb-pipeline {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 4px;
	}
	.kb-pipe-stage {
		display: flex;
		align-items: center;
		gap: 4px;
	}
	.kb-pipe-node {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1px;
		padding: 6px 10px;
		border-radius: 6px;
		border: 1px solid;
		background: var(--sl-color-bg-nav, #111);
		min-width: 50px;
	}
	.kb-pipe-count {
		font-size: 0.9rem;
		font-weight: 700;
		font-variant-numeric: tabular-nums;
	}
	.kb-pipe-name {
		font-size: 0.55rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.03em;
		opacity: 0.7;
	}
	.kb-pipe-arrow {
		font-size: 0.7rem;
		color: var(--sl-color-gray-4, #6b7280);
	}

	/* Breakdown */
	.kb-breakdown-grid {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	/* Make breakdown card span full width */
	.kb-charts-grid .kb-chart-card:nth-child(3) {
		grid-column: 1 / -1;
	}
	.kb-breakdown-types {
		display: flex;
		gap: 1.5rem;
	}
	.kb-type-row {
		display: flex;
		align-items: center;
		gap: 6px;
		font-size: 0.8rem;
	}
	.kb-type-icon {
		font-size: 0.6rem;
	}
	.kb-type-label {
		color: var(--sl-color-gray-3, #8b949e);
	}
	.kb-type-value {
		font-weight: 700;
		font-variant-numeric: tabular-nums;
		color: var(--sl-color-text, #e6edf3);
	}

	/* Top labels */
	.kb-top-labels {
		display: flex;
		flex-direction: column;
		gap: 6px;
	}
	.kb-labels-title {
		margin: 0 0 4px 0;
		font-size: 0.7rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--sl-color-gray-4, #6b7280);
	}
	.kb-label-row {
		display: flex;
		align-items: center;
		gap: 8px;
		font-size: 0.75rem;
	}
	.kb-label-name {
		min-width: 80px;
		color: var(--sl-color-gray-3, #8b949e);
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
	.kb-label-bar-track {
		flex: 1;
		height: 4px;
		border-radius: 2px;
		background: var(--sl-color-gray-5, #262626);
		overflow: hidden;
	}
	.kb-label-bar-fill {
		height: 100%;
		border-radius: 2px;
		background: var(--sl-color-accent, #06b6d4);
	}
	.kb-label-count {
		font-weight: 600;
		font-variant-numeric: tabular-nums;
		color: var(--sl-color-gray-3, #8b949e);
		min-width: 28px;
		text-align: right;
	}
</style>
