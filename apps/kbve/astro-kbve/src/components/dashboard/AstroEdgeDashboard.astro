---
import ReactEdgeHeader from './ReactEdgeHeader';
import ReactEdgeSummary from './ReactEdgeSummary';
import ReactEdgeStatusGrid from './ReactEdgeStatusGrid';
---

<section
	id="edge-dashboard-wrapper"
	class="edge-dashboard-wrapper"
	aria-label="Edge function health dashboard">
	<div id="dashboard-content" class="dashboard-content">
		<div class="not-content edge-dashboard">
			<!-- Island: Header (title, cache badge, refresh button) -->
			<div id="edge-header">
				<ReactEdgeHeader client:only="react" />
			</div>

			<!-- Island: Summary bar + error banner -->
			<div id="edge-summary">
				<ReactEdgeSummary client:only="react" />
			</div>

			<!-- Island: Status card grid -->
			<div id="edge-status-grid">
				<ReactEdgeStatusGrid client:only="react" />
			</div>
		</div>
	</div>
</section>

<style>
	.edge-dashboard-wrapper {
		background: transparent;
		min-height: 100vh;
		position: relative;
		width: 100vw;
		margin-left: calc(-50vw + 50%);
	}

	.dashboard-content {
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem 1rem;
	}

	@media (min-width: 768px) {
		.dashboard-content {
			padding: 2rem 1.5rem;
		}
	}

	.edge-dashboard {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	:global(@keyframes spin) {
		to {
			transform: rotate(360deg);
		}
	}
</style>
