---
import ReactGrafanaDashboard from './ReactGrafanaDashboard';
---

<section
	id="grafana-dashboard-wrapper"
	class="grafana-dashboard-wrapper"
	aria-label="Grafana monitoring dashboard">
	<div id="dashboard-content" class="dashboard-content">
		<ReactGrafanaDashboard client:only="react" />
	</div>
</section>

<style>
	.grafana-dashboard-wrapper {
		background: transparent;
		min-height: 100vh;
		position: relative;
		width: 100vw;
		margin-left: calc(-50vw + 50%);
	}

	.dashboard-content {
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem 1rem;
	}

	@media (min-width: 768px) {
		.dashboard-content {
			padding: 2rem 1.5rem;
		}
	}
</style>
