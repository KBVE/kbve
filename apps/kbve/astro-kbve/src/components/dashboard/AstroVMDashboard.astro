---
/**
 * VM Dashboard — static HTML shell with React islands.
 *
 * Section headers are native <details>/<summary> (zero JS, zero vDOM).
 * React components hydrate only inside each section's content slot.
 * Collapse state persists to localStorage via CollapsibleSection.
 */
import CollapsibleSection from './CollapsibleSection.astro';
import ReactVMAuth from './ReactVMAuth';
import ReactVMHeader from './ReactVMHeader';
import ReactVMCards from './ReactVMCards';
import ReactVMVncViewer from './ReactVMVncViewer';
import ReactVMGuacViewer from './ReactVMGuacViewer';
import ReactKasmCards from './ReactKasmCards';
import ReactFirecrackerCards from './ReactFirecrackerCards';
---

<section
	id="vm-dashboard-wrapper"
	class="vm-dashboard-wrapper"
	aria-label="Virtual Machine dashboard">
	<div id="dashboard-content" class="dashboard-content">
		<ReactVMAuth client:only="react">
			<div class="not-content vm-dashboard">
				<!-- Static header — always visible, no React -->
				<div id="vm-header">
					<ReactVMHeader client:only="react" />
				</div>

				<!-- VNC / Guac viewers — outside collapsible sections, shown on demand -->
				<div id="vm-vnc">
					<ReactVMVncViewer client:only="react" />
				</div>
				<div id="vm-guac">
					<ReactVMGuacViewer client:only="react" />
				</div>

				<!-- KubeVirt VMs — collapsible -->
				<CollapsibleSection
					id="kubevirt-vms"
					title="KubeVirt Virtual Machines"
					accentColor="#8b5cf6"
					defaultOpen={true}>
					<ReactVMCards client:only="react" />
				</CollapsibleSection>

				<!-- KASM Workspaces — collapsible -->
				<CollapsibleSection
					id="kasm-workspaces"
					title="KASM Workspaces"
					accentColor="#22c55e"
					defaultOpen={true}>
					<ReactKasmCards client:only="react" />
				</CollapsibleSection>

				<!-- Firecracker microVMs — collapsible, collapsed by default -->
				<CollapsibleSection
					id="firecracker-vms"
					title="Firecracker microVMs"
					accentColor="#f59e0b"
					defaultOpen={false}>
					<ReactFirecrackerCards client:only="react" />
				</CollapsibleSection>
			</div>
		</ReactVMAuth>
	</div>
</section>

<style>
	.vm-dashboard-wrapper {
		background: transparent;
		min-height: 100vh;
		position: relative;
		width: 100vw;
		margin-left: calc(-50vw + 50%);
	}

	.dashboard-content {
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem 1rem;
	}

	@media (min-width: 768px) {
		.dashboard-content {
			padding: 2rem 1.5rem;
		}
	}

	.vm-dashboard {
		display: flex;
		flex-direction: column;
		color: var(--sl-color-text, #e6edf3);
		min-height: 60vh;
		gap: 0.5rem;
	}

	:global(@keyframes spin) {
		to {
			transform: rotate(360deg);
		}
	}
</style>
