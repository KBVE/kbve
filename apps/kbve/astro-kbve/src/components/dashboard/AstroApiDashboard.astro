---
import { getConfiguration } from '@scalar/client-side-rendering';

interface Source {
	url: string;
	slug?: string;
	title: string;
	default?: boolean;
}

interface Props {
	specUrl?: string;
	sources?: Source[];
	title?: string;
}

const SCALAR_CDN = 'https://cdn.jsdelivr.net/npm/@scalar/api-reference';

const {
	specUrl = '/api/openapi.json',
	sources,
	title = 'KBVE API Reference',
} = Astro.props as Props;

const sourceConfig =
	sources && sources.length > 0 ? { sources } : { url: specUrl };

const configuration = getConfiguration({
	...sourceConfig,
	theme: 'none',
	hideClientButton: false,
	defaultHttpClient: { targetKey: 'shell', clientKey: 'curl' },
	metaData: { title },
});

const configJson = JSON.stringify(configuration);
---

<div id="scalar-app"></div>

<style is:global>
	#scalar-app {
		min-height: calc(100vh - 4rem);
	}
	#scalar-app .scalar-app {
		min-height: inherit;
		--scalar-font:
			var(--sl-font, var(--sl-font-system)), var(--sl-font-system);
		--scalar-font-code:
			var(--sl-font-mono, var(--sl-font-system-mono)),
			var(--sl-font-system-mono);

		--scalar-color-1: var(--sl-color-white);
		--scalar-color-2: var(--sl-color-gray-2);
		--scalar-color-3: var(--sl-color-gray-3);
		--scalar-color-accent: var(--sl-color-accent-high);

		--scalar-background-1: var(--sl-color-bg);
		--scalar-background-2: var(--sl-color-bg-sidebar);
		--scalar-background-3: var(--sl-color-bg-nav);
		--scalar-background-accent: var(--sl-color-accent);

		--scalar-border-color: var(--sl-color-gray-5);

		--scalar-sidebar-background-1: var(--sl-color-bg-sidebar);
		--scalar-sidebar-color-1: var(--sl-color-text);
		--scalar-sidebar-color-2: var(--sl-color-gray-3);
		--scalar-sidebar-color-active: var(--sl-color-text-accent);
		--scalar-sidebar-background-active: var(--sl-color-gray-6);
		--scalar-sidebar-item-hover-background: var(--sl-color-gray-6);
		--scalar-sidebar-item-hover-color: var(--sl-color-white);
		--scalar-sidebar-border-color: var(--sl-color-gray-5);

		--scalar-button-1: var(--sl-color-accent);
		--scalar-button-1-hover: var(--sl-color-accent-high);
		--scalar-button-1-color: var(--sl-color-text-invert);
	}

	#scalar-app .scalar-api-client__container,
	#scalar-app .scalar-api-references__client,
	#scalar-app [data-scalar-modal],
	#scalar-app .scalar-app-layout {
		z-index: 100;
	}
</style>

<script is:inline src={SCALAR_CDN}></script>
<script is:inline define:vars={{ configJson }} data-astro-rerun>
	(function () {
		// Skip when the host mount node isn't on the swap target (router
		// can re-fire this script on any page; only run where the
		// Scalar mount exists).
		if (!document.getElementById('scalar-app')) return;
		var cfg = JSON.parse(configJson);
		window.__scalarBaseConfig = cfg;
		if (!window.Scalar) return;
		// Tear down any previous instance bound to the now-removed DOM.
		try {
			window.__scalarRef?.destroy?.();
		} catch (e) {}
		window.__scalarRef = window.Scalar.createApiReference(
			'#scalar-app',
			cfg,
		);
	})();
</script>

<script>
	import '@/components/api/scalar-auth-bridge';
</script>
