---
import ReactScalar from '@/components/api/ReactScalar';

interface Source {
	url: string;
	slug?: string;
	title: string;
	default?: boolean;
}

interface Props {
	specUrl?: string;
	sources?: Source[];
	title?: string;
	hubHref?: string;
}

const {
	specUrl = '/api/openapi.json',
	sources,
	title = 'KBVE API Reference',
	hubHref = '/api/',
} = Astro.props as Props;
---

<div class="api-dash not-content">
	<ReactScalar
		client:only="react"
		sources={sources}
		specUrl={specUrl}
		title={title}
	/>
	<p class="api-foot">
		Looking for the static JSON data endpoints and feeds? Browse the full
		<a href={hubHref}>API hub</a>.
	</p>
</div>

<style>
	.api-dash {
		padding: 1.5rem 1rem 3rem;
	}

	@media (min-width: 640px) {
		.api-dash {
			padding-inline: 1.5rem;
		}
	}

	.api-foot {
		margin: 1rem 0 0;
		font-size: 0.8125rem;
		color: var(--sl-color-gray-3);
	}

	.api-foot a {
		color: var(--sl-color-accent-high);
	}
</style>

<style is:global>
	#scalar-app {
		min-height: calc(100vh - 8rem);
		border: 1px solid var(--bento-hairline-strong);
		border-radius: var(--bento-radius, 0.625rem);
		overflow: hidden;
		box-shadow: var(--bento-shadow);
	}
	#scalar-app .scalar-app {
		min-height: inherit;
		--scalar-font:
			var(--sl-font, var(--sl-font-system)), var(--sl-font-system);
		--scalar-font-code:
			var(--sl-font-mono, var(--sl-font-system-mono)),
			var(--sl-font-system-mono);

		--scalar-color-1: var(--sl-color-white);
		--scalar-color-2: var(--sl-color-gray-2);
		--scalar-color-3: var(--sl-color-gray-3);
		--scalar-color-accent: var(--sl-color-accent-high);

		--scalar-background-1: var(--bento-cell-bg, var(--sl-color-black));
		--scalar-background-2: color-mix(
			in srgb,
			var(--sl-color-white) 3%,
			transparent
		);
		--scalar-background-3: color-mix(
			in srgb,
			var(--sl-color-white) 5%,
			transparent
		);
		--scalar-background-accent: var(--sl-color-accent);

		--scalar-border-color: var(--bento-hairline-strong);

		--scalar-sidebar-background-1: var(
			--bento-cell-bg,
			var(--sl-color-black)
		);
		--scalar-sidebar-color-1: var(--sl-color-text);
		--scalar-sidebar-color-2: var(--sl-color-gray-3);
		--scalar-sidebar-color-active: var(--sl-color-accent-high);
		--scalar-sidebar-background-active: color-mix(
			in srgb,
			var(--sl-color-accent-high) 14%,
			transparent
		);
		--scalar-sidebar-item-hover-background: color-mix(
			in srgb,
			var(--sl-color-white) 5%,
			transparent
		);
		--scalar-sidebar-item-hover-color: var(--sl-color-white);
		--scalar-sidebar-border-color: var(--bento-hairline);

		--scalar-button-1: var(--sl-color-accent-high);
		--scalar-button-1-hover: var(--sl-color-accent);
		--scalar-button-1-color: var(--sl-color-black);
	}

	#scalar-app .scalar-api-client__container,
	#scalar-app .scalar-api-references__client,
	#scalar-app [data-scalar-modal],
	#scalar-app .scalar-app-layout {
		z-index: 100;
	}

	.scalar-host {
		position: relative;
	}

	.scalar-state {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		padding: 1rem;
		text-align: center;
		font-size: 0.875rem;
		color: var(--sl-color-gray-3);
	}

	.scalar-state__hint {
		max-width: 34ch;
		font-size: 0.75rem;
		color: var(--sl-color-gray-4);
	}

	.scalar-spinner {
		width: 1.5rem;
		height: 1.5rem;
		border-radius: 50%;
		border: 2px solid var(--bento-hairline-strong);
		border-top-color: var(--sl-color-accent-high);
		animation: scalar-spin 0.7s linear infinite;
	}

	@keyframes scalar-spin {
		to {
			transform: rotate(360deg);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.scalar-spinner {
			animation: none;
		}
	}

	/* Scalar's API-client modal is position:fixed. BentoShell's scroll-reveal
	   sets a transform on the wrapper, which would make it the containing block
	   and mis-position the modal. Drop the transform on this page — the reveal
	   still fades via opacity. */
	#api-reference[data-bento-reveal] {
		transform: none;
	}
</style>
