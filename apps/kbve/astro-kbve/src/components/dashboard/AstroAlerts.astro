---
import ReactHomeAuth from './ReactHomeAuth';
import ReactAlerts from './ReactAlerts';
---

<section
	id="alerts-wrapper"
	class="alerts-wrapper kbve-dashboard-page"
	aria-label="Prometheus Alerts — ClickHouse-backed history">
	<div id="alerts-content" class="alerts-content">
		<ReactHomeAuth client:only="react">
			<div class="not-content alerts-panel">
				<ReactAlerts client:only="react" variant="full" />
			</div>
		</ReactHomeAuth>
	</div>
</section>

<style>
	.alerts-wrapper {
		background: transparent;
		position: relative;
		width: 100%;
	}

	.alerts-content {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1rem 2rem;
	}

	@media (min-width: 768px) {
		.alerts-content {
			padding: 0 1.5rem 2rem;
		}
	}

	.alerts-panel {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.alerts-panel :global(.recharts-cartesian-grid line) {
		stroke: var(--sl-color-gray-5);
	}

	.alerts-panel :global(.recharts-cartesian-axis-tick-value) {
		fill: var(--sl-color-gray-2);
	}

	.alerts-panel :global(.recharts-label-list text) {
		fill: var(--sl-color-text);
		paint-order: stroke;
		stroke: var(--sl-color-bg-nav);
		stroke-width: 3px;
	}
</style>
