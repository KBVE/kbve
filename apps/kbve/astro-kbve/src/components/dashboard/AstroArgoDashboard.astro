---
import ReactArgoAuth from './ReactArgoAuth';
import ReactArgoHeader from './ReactArgoHeader';
import ReactArgoSummary from './ReactArgoSummary';
import ReactArgoAppTable from './ReactArgoAppTable';
---

<section
	id="argo-dashboard-wrapper"
	class="argo-dashboard-wrapper"
	aria-label="ArgoCD deployment dashboard">
	<div id="dashboard-content" class="dashboard-content">
		<ReactArgoAuth client:only="react">
			<div class="not-content argo-dashboard">
				<!-- Island: Header (title, last updated, refresh) -->
				<div id="argo-header">
					<ReactArgoHeader client:only="react" />
				</div>

				<!-- Island: Error banner + summary stat cards + loading state -->
				<div id="argo-summary">
					<ReactArgoSummary client:only="react" />
				</div>

				<!-- Island: Application table with expandable resource trees -->
				<div id="argo-app-table">
					<ReactArgoAppTable client:only="react" />
				</div>
			</div>
		</ReactArgoAuth>
	</div>
</section>

<style>
	.argo-dashboard-wrapper {
		background: transparent;
		min-height: 100vh;
		position: relative;
		width: 100vw;
		margin-left: calc(-50vw + 50%);
	}

	.dashboard-content {
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem 1rem;
	}

	@media (min-width: 768px) {
		.dashboard-content {
			padding: 2rem 1.5rem;
		}
	}

	.argo-dashboard {
		display: flex;
		flex-direction: column;
		color: var(--sl-color-text, #e6edf3);
		min-height: 60vh;
	}

	:global(@keyframes spin) {
		to {
			transform: rotate(360deg);
		}
	}
</style>
