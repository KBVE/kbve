---
import MonorepoGraphExplorer from './graphExplorer/MonorepoGraphExplorer';
---

<div id="graph-explorer-shell" class="graph-explorer-shell not-content">
	<MonorepoGraphExplorer client:only="react" />
</div>

<style>
	.graph-explorer-shell {
		position: relative;
		width: 100%;
		height: min(78vh, 900px);
		min-height: 520px;
		border-radius: 12px;
		overflow: hidden;
		background: #0a0e16;
		border: 1px solid var(--bento-hairline, rgba(148, 163, 184, 0.18));
	}
</style>
