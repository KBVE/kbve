---
import CollapsibleSection from './CollapsibleSection.astro';
import ReactCHAuth from './ReactCHAuth';
import ReactCHHeader from './ReactCHHeader';
import ReactCHSummary from './ReactCHSummary';
import ReactCHNamespaceGrid from './ReactCHNamespaceGrid';
import ReactCHFilterBar from './ReactCHFilterBar';
import ReactCHLogStream from './ReactCHLogStream';
import ReactCHQueryTabs from './ReactCHQueryTabs';
---

<section
	id="clickhouse-dashboard-wrapper"
	class="clickhouse-dashboard-wrapper"
	aria-label="ClickHouse logs dashboard">
	<div id="dashboard-content" class="dashboard-content">
		<ReactCHAuth client:only="react">
			<div class="not-content ch-dashboard">
				<div id="ch-header">
					<ReactCHHeader client:only="react" />
				</div>

				<div id="ch-summary">
					<ReactCHSummary client:only="react" />
				</div>

				<CollapsibleSection
					id="ch-namespaces"
					title="Namespace Overview"
					accentColor="#f59e0b"
					defaultOpen={true}>
					<ReactCHNamespaceGrid client:only="react" />
				</CollapsibleSection>

				<CollapsibleSection
					id="ch-log-explorer"
					title="Log Explorer"
					accentColor="#22c55e"
					defaultOpen={true}>
					<div class="ch-log-explorer-inner">
						<div id="ch-filter-bar">
							<ReactCHFilterBar client:only="react" />
						</div>
						<div id="ch-log-stream">
							<ReactCHLogStream client:only="react" />
						</div>
					</div>
				</CollapsibleSection>

				<CollapsibleSection
					id="ch-queries"
					title="Saved Queries"
					accentColor="#8b5cf6"
					defaultOpen={false}>
					<ReactCHQueryTabs client:only="react" />
				</CollapsibleSection>
			</div>
		</ReactCHAuth>
	</div>
</section>

<style>
	.clickhouse-dashboard-wrapper {
		background: transparent;
		min-height: 100vh;
		position: relative;
		width: 100vw;
		margin-left: calc(-50vw + 50%);
	}

	.dashboard-content {
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem 1rem;
	}

	@media (min-width: 768px) {
		.dashboard-content {
			padding: 2rem 1.5rem;
		}
	}

	.ch-dashboard {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		min-height: 60vh;
	}

	.ch-log-explorer-inner {
		border-radius: 8px;
		border: 1px solid var(--sl-color-gray-5, #262626);
		background: var(--sl-color-bg-nav, #111);
		overflow: hidden;
	}

	:global(@keyframes spin) {
		to {
			transform: rotate(360deg);
		}
	}
</style>
