---
import ReactCHAuth from './ReactCHAuth';
import ReactCHHeader from './ReactCHHeader';
import ReactCHSummary from './ReactCHSummary';
import ReactCHNamespaceGrid from './ReactCHNamespaceGrid';
import ReactCHFilterBar from './ReactCHFilterBar';
import ReactCHLogStream from './ReactCHLogStream';
---

<section
	id="clickhouse-dashboard-wrapper"
	class="clickhouse-dashboard-wrapper"
	aria-label="ClickHouse logs dashboard">
	<div id="dashboard-content" class="dashboard-content">
		<ReactCHAuth client:only="react">
			<div class="not-content ch-dashboard">
				<!-- Island: Header (time range selector, refresh) -->
				<div id="ch-header">
					<ReactCHHeader client:only="react" />
				</div>

				<!-- Island: Summary bar (total logs, errors, warnings, namespace count) -->
				<div id="ch-summary">
					<ReactCHSummary client:only="react" />
				</div>

				<!-- Island: Sort controls + namespace card grid -->
				<div id="ch-namespace-grid" class="ch-namespace-section">
					<ReactCHNamespaceGrid client:only="react" />
				</div>

				<!-- Static shell: Log explorer container -->
				<div id="ch-log-explorer" class="ch-log-explorer">
					<!-- Island: Filter bar (dropdowns, search, chips) -->
					<div id="ch-filter-bar">
						<ReactCHFilterBar client:only="react" />
					</div>

					<!-- Island: Log stream (entries, footer) -->
					<div id="ch-log-stream">
						<ReactCHLogStream client:only="react" />
					</div>
				</div>
			</div>
		</ReactCHAuth>
	</div>
</section>

<style>
	.clickhouse-dashboard-wrapper {
		background: transparent;
		min-height: 100vh;
		position: relative;
		width: 100vw;
		margin-left: calc(-50vw + 50%);
	}

	.dashboard-content {
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem 1rem;
	}

	@media (min-width: 768px) {
		.dashboard-content {
			padding: 2rem 1.5rem;
		}
	}

	/* Static layout shell - zero JS cost */
	.ch-dashboard {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		min-height: 60vh;
	}

	.ch-log-explorer {
		border-radius: 12px;
		border: 1px solid var(--sl-color-gray-5, #262626);
		background: var(--sl-color-bg-nav, #111);
		overflow: hidden;
	}

	.ch-namespace-section {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	:global(@keyframes spin) {
		to {
			transform: rotate(360deg);
		}
	}
</style>
