---
import ReactHomeAuth from './ReactHomeAuth';
import ReactHomeStatusBanner from './ReactHomeStatusBanner';
import ReactHomeServiceCards from './ReactHomeServiceCards';
---

<section
	id="dashboard-home-wrapper"
	class="dashboard-home-wrapper"
	aria-label="Dashboard home">
	<div id="dashboard-home-content" class="dashboard-home-content">
		<ReactHomeAuth client:only="react">
			<div class="not-content home-dashboard">
				<!-- Island: Header + System Status Banner -->
				<div id="home-status-banner">
					<ReactHomeStatusBanner client:only="react" />
				</div>

				<!-- Island: Service cards grid -->
				<div id="home-service-cards">
					<ReactHomeServiceCards client:only="react" />
				</div>
			</div>
		</ReactHomeAuth>
	</div>
</section>

<style>
	.dashboard-home-wrapper {
		background: transparent;
		min-height: 100vh;
		position: relative;
		width: 100vw;
		margin-left: calc(-50vw + 50%);
	}

	.dashboard-home-content {
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem 1rem;
	}

	@media (min-width: 768px) {
		.dashboard-home-content {
			padding: 2rem 1.5rem;
		}
	}

	.home-dashboard {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		min-height: 60vh;
	}

	:global(@keyframes spin) {
		to {
			transform: rotate(360deg);
		}
	}
</style>
