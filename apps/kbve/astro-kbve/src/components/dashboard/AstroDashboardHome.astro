---
import ReactHomeAuth from './ReactHomeAuth';
import ReactHomeStatusBanner from './ReactHomeStatusBanner';
import ReactHomeServiceCards from './ReactHomeServiceCards';
---

<section
	id="dashboard-home-wrapper"
	class="relative min-h-screen w-screen bg-transparent ml-[calc(-50vw+50%)]"
	aria-label="Dashboard home">
	<div
		id="dashboard-home-content"
		class="mx-auto w-full max-w-[1200px] px-4 py-8 md:px-6">
		<ReactHomeAuth client:only="react">
			<div class="not-content flex min-h-[60vh] flex-col gap-5">
				<!-- Island: Header + System Status Banner -->
				<div id="home-status-banner">
					<ReactHomeStatusBanner client:only="react" />
				</div>

				<!-- Island: Service cards grid -->
				<div id="home-service-cards">
					<ReactHomeServiceCards client:only="react" />
				</div>
			</div>
		</ReactHomeAuth>
	</div>
</section>
