---
import Default from '@astrojs/starlight/components/MarkdownContent.astro';
import DashboardGutterNav from './DashboardGutterNav.astro';
import { buildBreadcrumb } from './dashboardNav';

const pathname = Astro.url.pathname;
const isDashboard = pathname.startsWith('/dashboard');
const crumbs = isDashboard ? buildBreadcrumb(pathname) : [];
---

{
	isDashboard ? (
		<div class="dash-shell">
			<DashboardGutterNav pathname={pathname} />
			<div class="dash-main">
				<nav
					class="dash-breadcrumb dash-breadcrumb--top"
					aria-label="Breadcrumb">
					<ol>
						{crumbs.map((crumb, i) => (
							<li>
								{i < crumbs.length - 1 ? (
									<a href={crumb.href}>{crumb.label}</a>
								) : (
									<span aria-current="page">
										{crumb.label}
									</span>
								)}
							</li>
						))}
					</ol>
				</nav>
				<Default>
					<slot />
				</Default>
				<nav
					class="dash-breadcrumb dash-breadcrumb--bottom"
					aria-label="Breadcrumb">
					<ol>
						{crumbs.map((crumb, i) => (
							<li>
								{i < crumbs.length - 1 ? (
									<a href={crumb.href}>{crumb.label}</a>
								) : (
									<span aria-current="page">
										{crumb.label}
									</span>
								)}
							</li>
						))}
					</ol>
				</nav>
			</div>
		</div>
	) : (
		<Default>
			<slot />
		</Default>
	)
}

<style>
	.dash-shell {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.dash-main {
		min-width: 0;
	}

	@media (min-width: 1024px) {
		/* Sidebar layout: rail flush to the left gutter, content fills the
		   rest beside it. No centered cap (which left big empty margins),
		   no page-wide shift. */
		.dash-shell {
			flex-direction: row;
			align-items: flex-start;
			gap: 1.5rem;
			padding-inline: 1.5rem;
		}

		.dash-main {
			flex: 1 1 0;
			min-width: 0;
		}

		/* Left-align BentoShell's frame beside the rail; keep its 80rem cap
		   so content stays readable, with any extra width falling to the
		   right on ultra-wide screens. */
		.dash-main :global(.bento-frame) {
			margin-inline: 0;
			max-width: 80rem;
		}
	}

	.dash-breadcrumb {
		display: flex;
		border-radius: 0.625rem;
		border: 1px solid var(--sl-color-hairline, rgba(255, 255, 255, 0.08));
		background: color-mix(
			in srgb,
			var(--sl-color-gray-6, #17181d) 65%,
			transparent
		);
	}

	.dash-breadcrumb--top {
		margin-bottom: 1rem;
	}

	.dash-breadcrumb--bottom {
		margin-top: 1.5rem;
	}

	.dash-breadcrumb ol {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.25rem 0.5rem;
		width: 100%;
		margin: 0;
		padding: 0.5rem 0.75rem;
		list-style: none;
		font-size: 0.8125rem;
		line-height: 1.4;
	}

	.dash-breadcrumb li {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		min-width: 0;
	}

	.dash-breadcrumb li:not(:first-child)::before {
		content: '';
		flex: none;
		width: 0.375rem;
		height: 0.375rem;
		border-top: 1.5px solid var(--sl-color-gray-4);
		border-right: 1.5px solid var(--sl-color-gray-4);
		transform: rotate(45deg);
		opacity: 0.6;
	}

	.dash-breadcrumb a,
	.dash-breadcrumb span[aria-current='page'] {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		max-width: 14rem;
	}

	.dash-breadcrumb a {
		color: var(--sl-color-gray-2);
		text-decoration: none;
		padding: 0.125rem 0.375rem;
		border-radius: 0.375rem;
		transition:
			color 150ms ease,
			background-color 150ms ease;
	}

	.dash-breadcrumb a:hover {
		color: var(--sl-color-white);
		background: color-mix(
			in srgb,
			var(--sl-color-accent-low) 30%,
			transparent
		);
	}

	.dash-breadcrumb span[aria-current='page'] {
		color: var(--sl-color-white);
		font-weight: 600;
		padding: 0.125rem 0.375rem;
	}
</style>
