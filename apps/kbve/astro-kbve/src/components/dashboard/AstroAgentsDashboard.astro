---
import BentoShell from '@/components/hero/BentoShell.astro';

type CardKind = 'bot' | 'provider';

interface AgentCard {
	key: string;
	name: string;
	kind: CardKind;
	tagline: string;
	description: string;
	docs_url: string;
	manage_url: string | null;
	services: string[];
	status: 'available' | 'coming_soon';
}

const CARDS: AgentCard[] = [
	{
		key: 'github',
		name: 'GitHub',
		kind: 'provider',
		tagline:
			'Per-guild GitHub integration — webhook HMAC, PAT, repo allowlist (future).',
		description:
			'Provider page. Stores github_webhook:<guild> + github:<guild> (PAT) rows in Supabase Vault. Any agent consuming GitHub credentials (discordsh today, future bots later) reads the same rows. Run the guided wizard to provision everything end-to-end + smoke-test the webhook + backfill path.',
		docs_url: '/project/discordsh-bot/',
		manage_url: '/dashboard/agents/github/',
		services: ['github', 'github_webhook', 'github_repos'],
		status: 'available',
	},
	{
		key: 'discordsh',
		name: 'DiscordSH',
		kind: 'bot',
		tagline:
			'Discord gateway bot — slash commands, GitHub bridge, dungeon game.',
		description:
			'Embed dungeon, /gh claim self-assign, /github board reads, GitHub issue → Discord forum thread sync (Phase 2). Reads its per-guild GitHub PAT + webhook secret from the rows you provision under the GitHub provider page.',
		docs_url: '/project/discordsh-bot/',
		manage_url: '/dashboard/agents/discordsh/',
		services: ['github', 'github_webhook'],
		status: 'available',
	},
	{
		key: 'irc_gateway',
		name: 'irc-gateway',
		kind: 'bot',
		tagline: 'JWT-authenticated IRC bridge for chat services.',
		description:
			'Bridges KBVE chat traffic to IRC backends. Per-guild routing not yet wired through the agents surface.',
		docs_url: '/project/irc-gateway/',
		manage_url: null,
		services: ['irc'],
		status: 'coming_soon',
	},
];

const BOTS = CARDS;

const statusLabel = (s: AgentCard['status']) =>
	s === 'available' ? 'Available' : 'Coming soon';

const kindLabel = (k: CardKind) => (k === 'provider' ? 'Provider' : 'Bot');
---

<BentoShell
	id="agents-dashboard-wrapper"
	eyebrow="Bot integrations"
	heading="Agents — provision per-guild secrets from one surface.">
	<p class="agents-lede">
		Self-service registration for KBVE bot integrations. Each bot reads its
		per-guild secrets (PATs, webhook HMACs, repo allowlists) from Supabase
		Vault, scoped by your Discord guild ID. Pick a bot to manage its tokens
		for guilds you own.
	</p>

	<div class="agents-grid">
		{
			BOTS.map((bot) => (
				<article
					class:list={[
						'agents-cell',
						'bento-card',
						'bento-card--interactive',
						bot.status === 'coming_soon' && 'agents-cell--muted',
					]}
					data-agent={bot.key}>
					<div class="agents-cell__glow" aria-hidden="true" />

					<div class="agents-cell__head">
						<h3 class="agents-cell__name">{bot.name}</h3>
						<div class="agents-cell__badges">
							<span
								class:list={[
									'bento-chip',
									`agents-chip--${bot.kind}`,
								]}>
								{kindLabel(bot.kind)}
							</span>
							<span
								class:list={[
									'bento-chip',
									`agents-chip--${bot.status}`,
								]}>
								{statusLabel(bot.status)}
							</span>
						</div>
					</div>

					<p class="agents-cell__tagline">{bot.tagline}</p>
					<p class="agents-cell__desc">{bot.description}</p>

					<div class="agents-cell__services">
						{bot.services.map((svc) => (
							<code class="agents-cell__service">{svc}</code>
						))}
					</div>

					<div class="agents-cell__actions">
						<a
							class="agents-cell__cta agents-cell__cta--secondary"
							href={bot.docs_url}>
							Docs
						</a>
						{bot.manage_url ? (
							<a
								class="agents-cell__cta agents-cell__cta--primary"
								href={bot.manage_url}>
								Manage
								<svg
									viewBox="0 0 24 24"
									width="13"
									height="13"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
									aria-hidden="true">
									<path d="M7 17L17 7M9 7h8v8" />
								</svg>
							</a>
						) : (
							<span
								class="agents-cell__cta agents-cell__cta--disabled"
								aria-disabled="true">
								Manage
							</span>
						)}
					</div>
				</article>
			))
		}
	</div>
</BentoShell>

<style>
	.agents-lede {
		margin: 0 1rem 2rem;
		max-width: 56ch;
		font-size: 0.9375rem;
		line-height: 1.6;
		color: var(--sl-color-gray-3);
	}

	@media (min-width: 640px) {
		.agents-lede {
			margin-inline: 1.5rem;
		}
	}

	.agents-grid {
		display: grid;
		grid-template-columns: repeat(1, minmax(0, 1fr));
		gap: 1px;
		margin-inline: 1rem;
		background-color: var(--bento-hairline);
		border: 1px solid var(--bento-hairline);
		border-radius: var(--bento-radius);
		overflow: hidden;
	}

	@media (min-width: 640px) {
		.agents-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			margin-inline: 1.5rem;
		}
	}

	.agents-cell {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		overflow: hidden;
		padding: 1.5rem;
		border: none;
		border-radius: 0;
		box-shadow: none;
	}

	.agents-cell--muted {
		opacity: 0.72;
	}

	.agents-cell__glow {
		position: absolute;
		inset: 0;
		opacity: 0;
		background: radial-gradient(
			circle 220px at var(--glow-x, 30%) var(--glow-y, 20%),
			var(--sl-color-accent-low) 0%,
			transparent 70%
		);
		transition: opacity 300ms ease;
		pointer-events: none;
	}

	.agents-cell:hover .agents-cell__glow {
		opacity: 0.5;
	}

	.agents-cell__head {
		position: relative;
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 0.5rem;
	}

	.agents-cell__name {
		margin: 0;
		font-size: 1.0625rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		color: var(--sl-color-white);
	}

	.agents-cell__badges {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.35rem;
	}

	.agents-chip--provider {
		color: color-mix(in srgb, var(--sl-color-accent-high) 80%, white);
		border-color: color-mix(
			in srgb,
			var(--sl-color-accent-high) 45%,
			transparent
		);
	}

	.agents-chip--bot {
		color: var(--sl-color-gray-2);
	}

	.agents-chip--available {
		color: color-mix(in srgb, var(--color-green, #22c55e) 55%, white);
		border-color: color-mix(
			in srgb,
			var(--color-green, #22c55e) 40%,
			transparent
		);
	}

	.agents-chip--coming_soon {
		color: var(--sl-color-gray-4);
	}

	.agents-cell__tagline {
		position: relative;
		margin: 0;
		font-size: 0.875rem;
		line-height: 1.5;
		color: var(--sl-color-gray-2);
	}

	.agents-cell__desc {
		position: relative;
		margin: 0;
		font-size: 0.8125rem;
		line-height: 1.55;
		color: var(--sl-color-gray-3);
	}

	.agents-cell__services {
		position: relative;
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
		margin-top: 0.25rem;
	}

	.agents-cell__service {
		padding: 0.15rem 0.5rem;
		font-size: 0.75rem;
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		color: var(--sl-color-gray-2);
		background-color: color-mix(
			in srgb,
			var(--sl-color-white) 5%,
			transparent
		);
		border: 1px solid var(--bento-hairline);
		border-radius: 6px;
	}

	.agents-cell__actions {
		position: relative;
		display: flex;
		gap: 0.5rem;
		margin-top: auto;
		padding-top: 0.75rem;
	}

	.agents-cell__cta {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.45rem 0.9rem;
		font-size: 0.8125rem;
		font-weight: 500;
		border-radius: 8px;
		text-decoration: none;
		transition:
			background-color 180ms ease,
			border-color 180ms ease,
			color 180ms ease;
	}

	.agents-cell__cta--primary {
		color: var(--sl-color-black);
		background-color: var(--sl-color-accent-high);
		border: 1px solid var(--sl-color-accent-high);
	}

	.agents-cell__cta--primary:hover {
		background-color: color-mix(
			in srgb,
			var(--sl-color-accent-high) 85%,
			white
		);
	}

	.agents-cell__cta--secondary {
		color: var(--sl-color-white);
		background-color: color-mix(
			in srgb,
			var(--sl-color-white) 4%,
			transparent
		);
		border: 1px solid var(--bento-hairline-strong);
	}

	.agents-cell__cta--secondary:hover {
		border-color: var(--sl-color-accent-high);
	}

	.agents-cell__cta--disabled {
		color: var(--sl-color-gray-4);
		background-color: color-mix(
			in srgb,
			var(--sl-color-white) 3%,
			transparent
		);
		border: 1px solid var(--bento-hairline);
		cursor: not-allowed;
	}
</style>

<script>
	import { onMount } from '@kbve/astro/utils/clientRouter';

	onMount(() => {
		const teardowns: Array<() => void> = [];

		document
			.querySelectorAll<HTMLElement>('.agents-cell')
			.forEach((cell) => {
				const onMove = (e: PointerEvent) => {
					const rect = cell.getBoundingClientRect();
					cell.style.setProperty(
						'--glow-x',
						`${e.clientX - rect.left}px`,
					);
					cell.style.setProperty(
						'--glow-y',
						`${e.clientY - rect.top}px`,
					);
				};
				cell.addEventListener('pointermove', onMove);
				teardowns.push(() =>
					cell.removeEventListener('pointermove', onMove),
				);
			});

		return () => teardowns.forEach((fn) => fn());
	});
</script>
