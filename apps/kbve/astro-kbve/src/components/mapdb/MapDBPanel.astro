---
import { IMapObjectSchema } from '@/data/schema';
import { ServiceMapDB } from './ServiceMapDB';
import ReactMapDBPanel from './ReactMapDBPanel';

const { data } = Astro.props;
const mapObject = IMapObjectSchema.parse(data);

const typeIcon = ServiceMapDB.getTypeIcon(mapObject.type);
const subKindIcon = mapObject.sub_kind
	? ServiceMapDB.getSubKindIcon(mapObject.sub_kind)
	: '';

const harvestTimeSecs = mapObject.harvest_time_ms
	? (mapObject.harvest_time_ms / 1000).toFixed(1)
	: null;
---

<section class="px-6 py-6 sm:px-8 lg:px-12">
	<div class="max-w-3xl mx-auto">
		<div
			class="relative rounded-2xl p-6 border transition duration-300 space-y-3
			backdrop-blur-md bg-white/5 dark:bg-white/10
			border-white/10 dark:border-white/10
			shadow-[inset_0_0_0.5px_rgba(255,255,255,0.1)]
			hover:shadow-cyan-400/30 dark:hover:shadow-cyan-300/30">
			<!-- Header with Image and Name -->
			<div class="flex items-center gap-3">
				{
					mapObject.img && (
						<img
							src={mapObject.img}
							alt={mapObject.name}
							class="w-16 h-16 rounded-lg object-contain bg-black/20 p-1"
							data-tooltip="image"
						/>
					)
				}
				<div>
					<div class="flex items-center gap-2" data-tooltip="name">
						<span class="text-2xl" set:html={typeIcon} />
						<h3 class="text-lg font-semibold">{mapObject.name}</h3>
					</div>
					{
						mapObject.description && (
							<p class="text-sm text-zinc-400 mt-1">
								{mapObject.description}
							</p>
						)
					}
				</div>
			</div>

			<!-- Common Properties -->
			<ul class="text-sm text-zinc-400 space-y-1.5">
				<li class="flex items-center gap-2" data-tooltip="type">
					<strong>Type:</strong>
					<span class="capitalize">{mapObject.type}</span>
				</li>
				{
					mapObject.sub_kind && (
						<li
							class="flex items-center gap-2"
							data-tooltip="sub_kind">
							<strong>Kind:</strong>
							<span class="capitalize text-cyan-300">
								{mapObject.sub_kind.replace(/_/g, ' ')}
							</span>
						</li>
					)
				}
			</ul>

			<!-- Resource / Harvest Stats -->
			{
				mapObject.harvest_yield !== undefined && (
					<>
						<hr class="my-4 border-white/10" />
						<div class="text-sm space-y-2">
							<div class="flex items-center gap-2 text-base font-medium text-cyan-400">
								<span set:html={subKindIcon} />
								<span>Resource Stats</span>
							</div>
							<ul class="text-zinc-300 space-y-1.5 ml-6">
								<li data-tooltip="amount">
									<strong>Amount:</strong>{' '}
									<span class="text-green-400">
										{mapObject.initial_amount ?? '—'} /{' '}
										{mapObject.max_amount ?? '—'}
									</span>
								</li>
								<li data-tooltip="harvest_yield">
									<strong>Harvest Yield:</strong>{' '}
									<span class="text-yellow-400">
										{mapObject.harvest_yield}
									</span>{' '}
									per action
								</li>
								{harvestTimeSecs && (
									<li data-tooltip="harvest_time">
										<strong>Harvest Time:</strong>{' '}
										<span class="text-orange-400">
											{harvestTimeSecs}s
										</span>
									</li>
								)}
								<li data-tooltip="interactable">
									<strong>Harvestable:</strong>{' '}
									<span
										class={
											mapObject.interactable
												? 'text-green-400'
												: 'text-red-400'
										}>
										{mapObject.interactable
											? '\u2713 Yes'
											: '\u2717 No'}
									</span>
								</li>
								{mapObject.spawn_weight !== undefined && (
									<li data-tooltip="spawn_weight">
										<strong>Spawn Weight:</strong>{' '}
										<span class="text-blue-400">
											{(
												mapObject.spawn_weight * 100
											).toFixed(0)}
											%
										</span>
									</li>
								)}
								{mapObject.spawn_count !== undefined && (
									<li data-tooltip="spawn_count">
										<strong>Spawn Count:</strong>{' '}
										<span class="text-purple-400">
											{mapObject.spawn_count}
										</span>{' '}
										per map
									</li>
								)}
							</ul>
						</div>
					</>
				)
			}

			<!-- Structure Stats -->
			{
				mapObject.max_health !== undefined && (
					<>
						<hr class="my-4 border-white/10" />
						<div class="text-sm space-y-2">
							<div class="flex items-center gap-2 text-base font-medium text-cyan-400">
								<span>{'\u{1F3DB}\u{FE0F}'}</span>
								<span>Structure Stats</span>
							</div>
							<ul class="text-zinc-300 space-y-1.5 ml-6">
								{mapObject.footprint_width && (
									<li data-tooltip="footprint">
										<strong>Footprint:</strong>{' '}
										<span class="text-blue-400">
											{mapObject.footprint_width} &times;{' '}
											{mapObject.footprint_height ?? 1}
										</span>
									</li>
								)}
								<li data-tooltip="health">
									<strong>Max Health:</strong>{' '}
									<span class="text-red-400">
										{mapObject.max_health} HP
									</span>
								</li>
								{mapObject.construction_time_secs !==
									undefined && (
									<li data-tooltip="construction_time">
										<strong>Construction Time:</strong>{' '}
										<span class="text-orange-400">
											{mapObject.construction_time_secs}s
										</span>
									</li>
								)}
								{mapObject.blocks_movement !== undefined && (
									<li data-tooltip="walkable">
										<strong>Walkable:</strong>{' '}
										<span
											class={
												mapObject.blocks_movement
													? 'text-red-400'
													: 'text-green-400'
											}>
											{mapObject.blocks_movement
												? '\u2717 No'
												: '\u2713 Yes'}
										</span>
									</li>
								)}
								{mapObject.blocks_placement !== undefined && (
									<li data-tooltip="placement">
										<strong>Blocks Placement:</strong>{' '}
										<span
											class={
												mapObject.blocks_placement
													? 'text-red-400'
													: 'text-green-400'
											}>
											{mapObject.blocks_placement
												? '\u2713 Yes'
												: '\u2717 No'}
										</span>
									</li>
								)}
							</ul>

							{mapObject.build_costs &&
								mapObject.build_costs.length > 0 && (
									<div class="mt-3 pt-3 border-t border-white/10">
										<strong class="text-yellow-400">
											Build Costs:
										</strong>
										<ul class="list-disc list-inside ml-3 mt-1 space-y-1">
											{mapObject.build_costs.map(
												(cost) => (
													<li>
														<span class="capitalize">
															{cost.resource_type.replace(
																/_/g,
																' ',
															)}
															:
														</span>{' '}
														<span class="text-yellow-300">
															{cost.amount}
														</span>
													</li>
												),
											)}
										</ul>
									</div>
								)}
						</div>
					</>
				)
			}

			<!-- Animation Info (if present) -->
			{
				mapObject.animation?.hasAnimation && (
					<>
						<hr class="my-4 border-white/10" />
						<div class="text-sm space-y-2">
							<div class="flex items-center gap-2 text-base font-medium text-purple-400">
								<span>{'\u{1F3AC}'}</span>
								<span>Animation</span>
							</div>
							<ul class="text-zinc-300 space-y-1.5 ml-6">
								<li>
									<strong>Animated:</strong>{' '}
									<span class="text-green-400">
										{'\u2713'} Yes
									</span>
								</li>
								{mapObject.animation.defaultClip && (
									<li>
										<strong>Default Clip:</strong>{' '}
										<span class="text-cyan-300">
											{mapObject.animation.defaultClip}
										</span>
									</li>
								)}
								{mapObject.animation.clips &&
									mapObject.animation.clips.length > 0 && (
										<li>
											<strong>Animation Clips:</strong>{' '}
											<span class="text-purple-300">
												{mapObject.animation.clips
													.map((clip) => clip.id)
													.join(', ')}
											</span>
										</li>
									)}
							</ul>
						</div>
					</>
				)
			}

			<!-- Technical Details -->
			<hr class="my-4 border-white/10" />
			<div
				class="text-xs text-zinc-500 space-y-1"
				data-tooltip="technical">
				<div>
					<strong>ID:</strong>
					<code class="text-zinc-400">{mapObject.id}</code>
				</div>
				<div>
					<strong>Slug:</strong>
					<code class="text-zinc-400">{mapObject.slug}</code>
				</div>
				<div>
					<strong>Rendering:</strong> Layer: {
						mapObject.sorting_layer
					}, PPU: {mapObject.pixels_per_unit}
				</div>
			</div>
			<!-- React overlay for interactive tooltips -->
			<ReactMapDBPanel data={mapObject} client:only="react" />
		</div>
	</div>
</section>
