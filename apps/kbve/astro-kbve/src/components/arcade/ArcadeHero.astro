---
export interface Props {
	title?: string;
	tagline?: string;
	stats?: Array<{ label: string; value: string }>;
}

const {
	title = 'KBVE Arcade',
	tagline = 'Browser games we built ourselves — plus a few classics on the way.',
	stats = [],
} = Astro.props;
---

<section
	aria-labelledby="arcade-hero-title"
	class="not-content relative isolate mb-10 overflow-hidden rounded-2xl border border-purple-500/35 px-5 py-12 shadow-[0_24px_60px_-20px_rgba(0,0,0,0.55),inset_0_0_0_1px_rgba(0,0,0,0.35)] sm:px-14">
	<!-- Layered animated gradient background -->
	<div
		aria-hidden="true"
		class="arcade-hero-pulse absolute inset-0 -z-30 bg-[radial-gradient(circle_at_12%_10%,rgba(236,72,153,0.55)_0%,transparent_45%),radial-gradient(circle_at_88%_80%,rgba(56,189,248,0.45)_0%,transparent_50%),linear-gradient(135deg,#0b0a18_0%,#1c1438_50%,#1f0c2e_100%)]">
	</div>
	<!-- Faded grid behind content -->
	<div
		aria-hidden="true"
		class="pointer-events-none absolute inset-0 -z-20 bg-[linear-gradient(rgba(168,85,247,0.08)_1px,transparent_1px),linear-gradient(90deg,rgba(168,85,247,0.08)_1px,transparent_1px)] [background-size:36px_36px] [mask-image:linear-gradient(to_bottom,transparent,black_30%,black_70%,transparent)] [-webkit-mask-image:linear-gradient(to_bottom,transparent,black_30%,black_70%,transparent)]">
	</div>
	<!-- CRT scanlines -->
	<div
		aria-hidden="true"
		class="pointer-events-none absolute inset-0 -z-10 opacity-65 mix-blend-overlay bg-[repeating-linear-gradient(to_bottom,rgba(0,0,0,0.16)_0px,rgba(0,0,0,0.16)_1px,transparent_1px,transparent_4px)]">
	</div>

	<div class="relative z-10 max-w-[56ch]">
		<p
			class="mb-3 font-mono text-[11px] uppercase tracking-[0.18em] text-fuchsia-300 [text-shadow:0_0_10px_rgba(240,171,252,0.45)]">
			▸ NOW PLAYING
		</p>
		<h1
			id="arcade-hero-title"
			class="mb-3 text-[clamp(34px,6vw,56px)] font-extrabold leading-[1.05] -tracking-[0.01em] text-white [text-shadow:0_0_18px_rgba(236,72,153,0.55),0_0_38px_rgba(56,189,248,0.35)]">
			{title}
		</h1>
		<p
			class="mb-5 max-w-[60ch] text-[clamp(15px,1.4vw,17px)] leading-relaxed text-purple-200">
			{tagline}
		</p>
		{
			stats.length > 0 && (
				<ul class="m-0 flex list-none flex-wrap gap-6 p-0">
					{stats.map((s, i) => (
						<li
							class:list={[
								'flex flex-col gap-0.5 border-purple-500/30 pr-6',
								i < stats.length - 1 && 'border-r',
							]}>
							<span
								class="font-serif text-[22px] font-bold text-amber-200"
								data-arcade-stat
								data-arcade-stat-value={s.value}
								data-arcade-stat-delay={i * 140}>
								{s.value}
							</span>
							<span class="font-mono text-[11px] uppercase tracking-[0.12em] text-purple-300">
								{s.label}
							</span>
						</li>
					))}
				</ul>
			)
		}
	</div>
</section>

<style>
	@keyframes arcade-hero-hue {
		0%,
		100% {
			filter: hue-rotate(0deg) brightness(1);
		}
		50% {
			filter: hue-rotate(20deg) brightness(1.08);
		}
	}
	.arcade-hero-pulse {
		animation: arcade-hero-hue 14s ease-in-out infinite;
	}
	@media (prefers-reduced-motion: reduce) {
		.arcade-hero-pulse {
			animation: none;
		}
	}
</style>

<script is:inline>
	(() => {
		const reduceMotion =
			typeof window !== 'undefined' &&
			window.matchMedia &&
			window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		const NUMERIC = /^\d+$/;

		function rollOdometer(el, target, baseDelay) {
			const digits = String(target).split('');
			el.textContent = '';
			el.style.display = 'inline-flex';
			el.style.gap = '0';
			el.style.lineHeight = '1';
			el.style.verticalAlign = 'baseline';

			digits.forEach((digit, i) => {
				const col = document.createElement('span');
				col.style.cssText =
					'display:inline-block;height:1em;overflow:hidden;line-height:1;vertical-align:baseline;';
				const reel = document.createElement('span');
				reel.style.cssText =
					'display:block;transition:transform 1400ms cubic-bezier(0.16,1,0.3,1);will-change:transform;';
				/* 30 digits stacked = 2 full spins + landing digit. */
				for (let rep = 0; rep < 3; rep++) {
					for (let n = 0; n <= 9; n++) {
						const d = document.createElement('span');
						d.textContent = String(n);
						d.style.cssText =
							'display:block;height:1em;line-height:1;';
						reel.appendChild(d);
					}
				}
				col.appendChild(reel);
				el.appendChild(col);
				const targetDigit = parseInt(digit, 10);
				const finalIdx = 20 + targetDigit;
				const colDelay = baseDelay + i * 90;
				if (reduceMotion) {
					reel.style.transition = 'none';
					reel.style.transform = `translateY(-${finalIdx}em)`;
				} else {
					requestAnimationFrame(() => {
						setTimeout(() => {
							reel.style.transform = `translateY(-${finalIdx}em)`;
						}, colDelay);
					});
				}
			});
		}

		function fadeIn(el, baseDelay) {
			if (reduceMotion) return;
			el.style.opacity = '0';
			el.style.transition = 'opacity 800ms cubic-bezier(0.16,1,0.3,1)';
			setTimeout(() => {
				el.style.opacity = '1';
			}, baseDelay);
		}

		function init() {
			const stats = document.querySelectorAll('[data-arcade-stat]');
			stats.forEach((el) => {
				const val = el.dataset.arcadeStatValue ?? '';
				const baseDelay = parseInt(
					el.dataset.arcadeStatDelay ?? '0',
					10,
				);
				if (NUMERIC.test(val)) {
					rollOdometer(el, parseInt(val, 10), baseDelay);
				} else {
					fadeIn(el, baseDelay);
				}
			});
		}

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', init);
		} else {
			init();
		}
	})();
</script>
