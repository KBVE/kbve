---
import MCLinkTooltip from './MCLinkTooltip';
---

<MCLinkTooltip client:load />

<style is:global>
	.mc-link-tooltip {
		position: fixed;
		z-index: 9999;
		pointer-events: none;
		min-width: 200px;
		max-width: 280px;
		padding: 0.7rem 0.85rem;
		border-radius: 12px;
		background: linear-gradient(
			165deg,
			var(--sl-color-bg-sidebar) 0%,
			var(--sl-color-bg) 100%
		);
		border: 1px solid var(--sl-color-hairline, var(--sl-color-gray-5));
		box-shadow: 0 18px 32px -12px
			color-mix(in srgb, var(--sl-color-black) 60%, transparent);
		color: var(--sl-color-text);
		font-size: 0.85rem;
	}
	.mc-link-tooltip__head {
		display: flex;
		gap: 0.65rem;
		align-items: center;
		margin-bottom: 0.45rem;
	}
	.mc-link-tooltip__icon {
		width: 40px;
		height: 40px;
		image-rendering: pixelated;
		border-radius: 8px;
		background: var(--sl-color-bg-nav);
		border: 1px solid var(--sl-color-hairline, var(--sl-color-gray-5));
		padding: 4px;
		object-fit: contain;
	}
	.mc-link-tooltip__name {
		font-weight: 800;
		color: var(--sl-color-white, var(--sl-color-text));
		font-size: 0.95rem;
	}
	.mc-link-tooltip__qty {
		color: var(--sl-color-accent-high, var(--sl-color-accent));
		font-weight: 700;
		font-variant-numeric: tabular-nums;
		font-size: 0.8rem;
	}
	.mc-link-tooltip__rows {
		display: grid;
		gap: 0.25rem;
		margin: 0;
	}
	.mc-link-tooltip__rows > div {
		display: flex;
		justify-content: space-between;
		gap: 0.5rem;
		font-size: 0.8rem;
	}
	.mc-link-tooltip__rows dt {
		color: var(--sl-color-gray-3);
		text-transform: uppercase;
		letter-spacing: 0.04em;
		font-size: 0.7rem;
	}
	.mc-link-tooltip__rows dd {
		margin: 0;
		font-weight: 600;
	}
</style>
