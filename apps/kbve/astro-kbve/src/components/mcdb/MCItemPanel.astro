---
import { MCItemSchema } from '@/data/schema';
import MCTextureImage from './MCTextureImage';
import MCTooltipMount from './MCTooltipMount.astro';
import MCItemJsonLd from './MCItemJsonLd.astro';
import MCItemMarketSidecar from '@/components/market/MCItemMarketSidecar';

const { data } = Astro.props;
const item = MCItemSchema.parse(data);

const CATEGORY_ACCENT: Record<string, string> = {
	tool: '210 90% 62%',
	weapon: '0 80% 62%',
	armor: '190 70% 58%',
	food: '30 90% 58%',
	block: '150 45% 52%',
	material: '260 75% 66%',
	redstone: '355 85% 58%',
	transport: '45 90% 58%',
	decoration: '320 70% 64%',
	brewing: '280 70% 62%',
	spawn_egg: '120 60% 55%',
	music: '175 65% 55%',
	banner: '340 70% 60%',
	map: '35 70% 55%',
	misc: '220 10% 60%',
};
const accent = CATEGORY_ACCENT[item.category] ?? CATEGORY_ACCENT.misc;

interface Stat {
	label: string;
	value: string | number;
}
const stats: Stat[] = [{ label: 'Stack', value: item.stack_size }];
if (item.max_durability > 0)
	stats.push({
		label: 'Durability',
		value: item.max_durability.toLocaleString(),
	});
if (item.damage) {
	stats.push({ label: 'Attack Damage', value: item.damage.attack_damage });
	stats.push({ label: 'Attack Speed', value: item.damage.attack_speed });
}
if (item.equipment?.slot) {
	stats.push({ label: 'Slot', value: item.equipment.slot });
	if (item.equipment.armor_points > 0)
		stats.push({ label: 'Armor', value: item.equipment.armor_points });
	if (item.equipment.toughness > 0)
		stats.push({ label: 'Toughness', value: item.equipment.toughness });
}
if (item.food) {
	stats.push({ label: 'Nutrition', value: item.food.nutrition });
	stats.push({ label: 'Saturation', value: item.food.saturation });
}
if (item.mining) {
	stats.push({ label: 'Tool', value: item.mining.tool_type });
	stats.push({ label: 'Mining Tier', value: item.mining.tier });
}
---

<MCItemJsonLd data={item} />
<MCTooltipMount />

<section
	class="mcdb not-content kbve-dashboard-page"
	style={`--bento-accent: hsl(${accent}); --sl-color-accent: hsl(${accent}); --sl-color-accent-high: hsl(${accent.replace(/(\d+)%\)?$/, '')}72%);`}>
	<div class="bento-frame">
		<div class="bento-board bento-board--cols-4">
			<div class="bento-card bento-cell--wide mcdb-id">
				<div class="mcdb-id__icon">
					<MCTextureImage
						client:load
						ref={item.ref}
						category={item.category}
						alt={item.display_name}
						size={96}
					/>
				</div>
				<div class="mcdb-id__body">
					<h2 class="mcdb-id__title">{item.display_name}</h2>
					<div class="mcdb-id__chips">
						<span class="bento-chip mcdb-chip--kind">
							{item.category}
						</span>
						{
							item.rarity !== 'common' && (
								<span
									class={`bento-chip mcdb-chip--rarity-${item.rarity}`}>
									{item.rarity}
								</span>
							)
						}
						{
							item.tier && (
								<span class="bento-chip">{item.tier}</span>
							)
						}
					</div>
					<code class="mcdb-id__ref">minecraft:{item.ref}</code>
					{
						item.about?.description && (
							<p class="mcdb-id__desc">
								{item.about.description}
							</p>
						)
					}
				</div>
			</div>

			{
				stats.map((s) => (
					<div class="bento-card bento-stat mcdb-stat">
						<span class="bento-stat__value">{s.value}</span>
						<span class="bento-stat__label">{s.label}</span>
					</div>
				))
			}

			{
				item.enchants && item.enchants.allowed.length > 0 && (
					<div class="bento-card bento-cell--wide mcdb-block">
						<h3 class="mcdb-block__title">Compatible Enchants</h3>
						<ul class="mcdb-chips">
							{item.enchants.allowed.map((ref) => (
								<li>
									<a
										class="bento-chip"
										href={`/mc/enchants/${ref.replace(/_/g, '-')}/`}>
										{ref.replace(/_/g, ' ')}
									</a>
								</li>
							))}
						</ul>
					</div>
				)
			}

			{
				item.tags.length > 0 && (
					<div class="bento-card bento-cell--wide mcdb-block">
						<h3 class="mcdb-block__title">Tags</h3>
						<ul class="mcdb-chips">
							{item.tags.map((t) => (
								<li>
									<span class="bento-chip mcdb-chip--muted">
										{t}
									</span>
								</li>
							))}
						</ul>
					</div>
				)
			}

			{
				item.recipes.length > 0 && (
					<div class="bento-card bento-cell--wide mcdb-block">
						<h3 class="mcdb-block__title">Recipes</h3>
						{item.recipes.map((r) => {
							const isShaped =
								r.kind === 'shaped' &&
								r.width > 0 &&
								r.height > 0;
							const GRID_DIM = 3;
							const grid: (
								| (typeof r.ingredients)[number]
								| null
							)[][] = Array.from({ length: GRID_DIM }, () =>
								Array.from({ length: GRID_DIM }, () => null),
							);
							if (isShaped) {
								for (const ing of r.ingredients) {
									if (
										ing.row >= 0 &&
										ing.row < GRID_DIM &&
										ing.col >= 0 &&
										ing.col < GRID_DIM &&
										grid[ing.row][ing.col] === null
									) {
										grid[ing.row][ing.col] = ing;
									}
								}
							}
							return (
								<div class="mcdb-recipe-card">
									<div class="mcdb-recipe-card__meta">
										<span class="mcdb-recipe-kind">
											{r.kind}
										</span>
										{r.station !== 'none' && (
											<span class="mcdb-recipe-station">
												@ {r.station}
											</span>
										)}
										<span class="mcdb-recipe-yields">
											yields × {r.yields}
										</span>
										{r.cook_time_ticks > 0 && (
											<span class="mcdb-recipe-station">
												{(
													r.cook_time_ticks / 20
												).toFixed(1)}
												s
											</span>
										)}
										{r.experience > 0 && (
											<span class="mcdb-recipe-station">
												{r.experience} XP
											</span>
										)}
									</div>
									{isShaped ? (
										<div
											class="mcdb-grid-recipe"
											style={`--cols: ${GRID_DIM};`}>
											{grid.flat().map((cell) => {
												if (!cell)
													return (
														<div class="mcdb-grid-cell" />
													);
												const ingRef =
													cell.ref || cell.tag_ref;
												return (
													<a
														class="mcdb-grid-cell mcdb-grid-cell--filled"
														href={`/mc/items/${ingRef.replace(/_/g, '-')}/`}
														data-mc-tooltip
														data-mc-ref={
															cell.ref || ''
														}
														data-mc-tag-ref={
															cell.tag_ref || ''
														}
														data-mc-qty={cell.qty}
														title={`${cell.qty}× ${ingRef}`}>
														{cell.qty > 1 && (
															<span class="mcdb-grid-qty">
																{cell.qty}
															</span>
														)}
														{cell.ref ? (
															<MCTextureImage
																client:visible
																ref={cell.ref}
																alt={cell.ref}
																size={56}
																className="mcdb-grid-img"
															/>
														) : (
															<span class="mcdb-grid-ref">
																#{cell.tag_ref}
															</span>
														)}
													</a>
												);
											})}
										</div>
									) : (
										<ul class="mcdb-recipes">
											{r.ingredients.map((ing) => {
												const ingRef =
													ing.ref || ing.tag_ref;
												return (
													<li>
														{ing.ref && (
															<MCTextureImage
																client:visible
																ref={ing.ref}
																alt={ing.ref}
																size={28}
																className="mcdb-recipe-img"
															/>
														)}
														<span class="mcdb-recipe-yields">
															× {ing.qty}
														</span>
														<a
															href={`/mc/items/${ingRef.replace(/_/g, '-')}/`}
															data-mc-tooltip
															data-mc-ref={
																ing.ref || ''
															}
															data-mc-tag-ref={
																ing.tag_ref ||
																''
															}
															data-mc-qty={
																ing.qty
															}>
															{ing.ref ||
																`#${ing.tag_ref}`}
														</a>
													</li>
												);
											})}
										</ul>
									)}
								</div>
							);
						})}
					</div>
				)
			}

			<div class="bento-card bento-cell--wide mcdb-block">
				<h3 class="mcdb-block__title">Marketplace</h3>
				<MCItemMarketSidecar client:visible ref={item.ref} />
				<div class="mcdb-block__foot">
					<a
						href={`/market/?kind=mc_item&q=${item.ref}`}
						class="mcdb-block__market">
						Open marketplace listings →
					</a>
					{
						item.data_version && (
							<span class="mcdb-block__version">
								data: {item.data_version}
							</span>
						)
					}
				</div>
			</div>
		</div>
	</div>
</section>

<style is:global>
	.mcdb {
		display: block;
		padding-block: 1rem;
	}
	.mcdb .bento-board {
		border-radius: 18px;
		overflow: hidden;
	}
	.mcdb .bento-card {
		padding: 1rem 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}
	.mcdb-id {
		flex-direction: row !important;
		align-items: flex-start;
		gap: 1rem;
	}
	.mcdb-id__icon {
		flex-shrink: 0;
		width: 84px;
		height: 84px;
		border-radius: 14px;
		background:
			repeating-linear-gradient(
				45deg,
				color-mix(in srgb, var(--sl-color-black) 18%, transparent) 0 6px,
				transparent 6px 12px
			),
			linear-gradient(
				135deg,
				var(--sl-color-bg-nav) 0%,
				var(--sl-color-bg-sidebar) 100%
			);
		border: 1px solid var(--sl-color-hairline, var(--sl-color-gray-5));
		padding: 10%;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.mcdb-id__icon img {
		width: 100%;
		height: 100%;
		image-rendering: pixelated;
		object-fit: contain;
	}
	.mcdb-id__body {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
		min-width: 0;
	}
	.mcdb-id__title {
		margin: 0;
		font-size: clamp(1.4rem, 2.5vw, 1.75rem);
		font-weight: 800;
		letter-spacing: -0.01em;
		color: var(--sl-color-white, var(--sl-color-text));
	}
	.mcdb-id__chips {
		display: flex;
		gap: 0.4rem;
		flex-wrap: wrap;
	}
	.mcdb-chip--kind {
		color: var(--sl-color-accent-high, var(--sl-color-accent));
		border-color: color-mix(
			in srgb,
			var(--sl-color-accent) 55%,
			transparent
		);
		background: color-mix(in srgb, var(--sl-color-accent) 16%, transparent);
	}
	.mcdb-chip--rarity-uncommon {
		color: rgb(120, 200, 120);
	}
	.mcdb-chip--rarity-rare {
		color: rgb(120, 180, 240);
	}
	.mcdb-chip--rarity-epic {
		color: rgb(210, 120, 240);
	}
	.mcdb-chip--muted {
		color: var(--sl-color-gray-3);
	}
	.mcdb-id__ref {
		align-self: flex-start;
		font-size: 0.78rem;
		padding: 0.05rem 0.45rem;
		border-radius: 6px;
		background: var(--sl-color-bg-inline-code);
		color: var(--sl-color-text);
	}
	.mcdb-id__desc {
		margin: 0.2rem 0 0;
		color: var(--sl-color-gray-3);
		line-height: 1.55;
		font-size: 0.9rem;
	}
	.mcdb-stat {
		gap: 0.2rem !important;
	}
	.mcdb-block__title {
		margin: 0 0 0.2rem;
		font-size: 1rem;
		font-weight: 800;
	}
	.mcdb-chips {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		gap: 0.4rem;
		flex-wrap: wrap;
	}
	.mcdb-chips a.bento-chip {
		text-decoration: none;
	}
	.mcdb-chips a.bento-chip:hover {
		color: var(--sl-color-accent-high, var(--sl-color-accent));
		border-color: var(--sl-color-accent);
	}
	.mcdb-block__foot {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		flex-wrap: wrap;
		margin-top: 0.5rem;
		padding-top: 0.5rem;
		border-top: 1px solid var(--sl-color-hairline, var(--sl-color-gray-5));
	}
	.mcdb-block__market {
		color: var(--sl-color-text-accent);
		font-weight: 700;
		text-decoration: none;
	}
	.mcdb-block__market:hover {
		text-decoration: underline;
	}
	.mcdb-block__version {
		color: var(--sl-color-gray-3);
		font-size: 0.78rem;
		font-variant-numeric: tabular-nums;
	}

	.mcdb-recipes {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 0.4rem;
	}
	.mcdb-recipes li {
		padding: 0.5rem 0.75rem;
		border-radius: 10px;
		background: var(--sl-color-bg-nav);
		border: 1px solid var(--sl-color-hairline, var(--sl-color-gray-5));
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
		font-size: 0.85rem;
	}
	.mcdb-recipe-kind {
		font-weight: 700;
		text-transform: uppercase;
		font-size: 0.7rem;
		letter-spacing: 0.05em;
		color: var(--sl-color-accent-high, var(--sl-color-accent));
	}
	.mcdb-recipe-card {
		display: grid;
		gap: 0.5rem;
		padding: 0.75rem;
		border-radius: 12px;
		background: var(--sl-color-bg-nav);
		border: 1px solid var(--sl-color-hairline, var(--sl-color-gray-5));
		margin-top: 0.5rem;
	}
	.mcdb-recipe-card__meta {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
		align-items: center;
	}
	.mcdb-recipe-station {
		font-size: 0.78rem;
		color: var(--sl-color-gray-3);
	}
	.mcdb-recipe-yields {
		font-size: 0.85rem;
	}
	.mcdb-grid-recipe {
		display: grid;
		grid-template-columns: repeat(var(--cols, 3), 72px);
		gap: 0.4rem;
		justify-content: start;
	}
	.mcdb-grid-cell {
		width: 72px;
		height: 72px;
		border-radius: 10px;
		background: var(--sl-color-bg-sidebar, var(--sl-color-bg-nav));
		border: 1px solid var(--sl-color-hairline, var(--sl-color-gray-5));
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.15rem;
		padding: 0.3rem;
		font-size: 0.7rem;
		text-align: center;
	}
	.mcdb-grid-qty {
		font-weight: 800;
		color: var(--sl-color-accent-high, var(--sl-color-accent));
	}
	.mcdb-grid-ref {
		color: var(--sl-color-gray-3);
		font-size: 0.65rem;
		line-height: 1.1;
		word-break: break-all;
	}
	.kbve-mc-tex {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		image-rendering: pixelated;
		object-fit: contain;
	}
	.kbve-mc-tex--missing {
		background: var(--sl-color-bg-nav);
		border: 1px solid var(--sl-color-hairline, var(--sl-color-gray-5));
		border-radius: 6px;
		color: var(--sl-color-gray-3);
		font-weight: 800;
	}
	.mcdb-grid-cell .kbve-mc-tex,
	.mcdb-grid-img.kbve-mc-tex {
		max-width: 80%;
		max-height: 80%;
	}
	.mcdb-recipe-img.kbve-mc-tex {
		flex-shrink: 0;
		margin-right: 0.25rem;
	}
</style>
