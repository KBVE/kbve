---
import ReactWebmaster from './ReactWebmaster';
import { CATEGORIES, TOOLS_BY_CATEGORY, TOOLS_POPULAR } from './toolsCatalog';
import { cn } from '@/lib/utils';

const buttonClass = cn(
	'group inline-flex items-center justify-between gap-2',
	'px-3 py-2 rounded-md text-sm font-medium',
	'border transition-colors',
	'border-[var(--sl-color-gray-5,#30363d)]',
	'bg-[var(--sl-color-gray-6,#161b22)]',
	'text-[var(--sl-color-text,#e6edf3)]',
	'opacity-50 cursor-not-allowed',
	'data-[disabled=false]:opacity-100 data-[disabled=false]:cursor-pointer',
	'data-[disabled=false]:hover:bg-[var(--sl-color-accent-low,#1f6feb33)]',
	'data-[disabled=false]:hover:border-[var(--sl-color-accent,#1f6feb)]',
);

const gridClass = cn(
	'not-content grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2',
);

const sectionClass = 'not-content flex flex-col gap-2';

const sectionLabelClass = cn(
	'text-xs uppercase tracking-wider',
	'text-[var(--sl-color-gray-3,#8b949e)]',
);

const dividerClass = 'h-px bg-[var(--sl-color-gray-5,#30363d)]';
---

<section
	id="webmaster-tool-wrapper"
	aria-label="Webmaster tools"
	class="relative w-full bg-transparent">
	<div
		class="mx-auto max-w-[1100px] flex flex-col gap-6 px-4 py-6 md:px-6 md:py-8">
		<header class="not-content flex flex-col gap-1">
			<h2
				class="m-0 text-2xl font-bold text-[var(--sl-color-text,#e6edf3)]">
				Webmaster Tools
			</h2>
			<p class="m-0 text-sm text-[var(--sl-color-gray-3,#8b949e)]">
				Enter a domain and launch SEO, performance, security, and tech
				audits in one click.
			</p>
		</header>

		<div id="webmaster-tool-mount">
			<ReactWebmaster client:only="react" />
		</div>

		<div class={sectionClass}>
			<span class={sectionLabelClass}>Quick links</span>
			<div class={gridClass}>
				{
					TOOLS_POPULAR.map((tool) => (
						<a
							data-webmaster-tool={tool.id}
							data-url-tpl={tool.urlTemplate}
							data-disabled="true"
							aria-disabled="true"
							tabindex="-1"
							target="_blank"
							rel="noopener noreferrer"
							class={buttonClass}>
							<span class="truncate">{tool.name}</span>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="14"
								height="14"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								class="shrink-0 opacity-60 group-hover:opacity-100"
								aria-hidden="true">
								<path d="M15 3h6v6" />
								<path d="M10 14 21 3" />
								<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
							</svg>
						</a>
					))
				}
			</div>
		</div>

		<div class={dividerClass}></div>

		<div class="not-content flex flex-col gap-6">
			{
				CATEGORIES.map((cat) => {
					const tools = TOOLS_BY_CATEGORY[cat.id];
					if (tools.length === 0) return null;
					return (
						<section class="flex flex-col gap-2">
							<header class="flex flex-col gap-0.5">
								<h3 class="m-0 text-sm font-semibold text-[var(--sl-color-text,#e6edf3)]">
									{cat.label}
								</h3>
								<p class="m-0 text-xs text-[var(--sl-color-gray-3,#8b949e)]">
									{cat.description}
								</p>
							</header>
							<div class={gridClass}>
								{tools.map((tool) => (
									<a
										data-webmaster-tool={tool.id}
										data-url-tpl={tool.urlTemplate}
										data-disabled="true"
										aria-disabled="true"
										tabindex="-1"
										target="_blank"
										rel="noopener noreferrer"
										class={buttonClass}>
										<span class="truncate">
											{tool.name}
										</span>
										<svg
											xmlns="http://www.w3.org/2000/svg"
											width="14"
											height="14"
											viewBox="0 0 24 24"
											fill="none"
											stroke="currentColor"
											stroke-width="2"
											stroke-linecap="round"
											stroke-linejoin="round"
											class="shrink-0 opacity-60 group-hover:opacity-100"
											aria-hidden="true">
											<path d="M15 3h6v6" />
											<path d="M10 14 21 3" />
											<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
										</svg>
									</a>
								))}
							</div>
						</section>
					);
				})
			}
		</div>
	</div>
</section>
