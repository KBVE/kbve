---
/**
 * BentoGrid — Astro bridge for the interactive React bento dashboard.
 *
 * Renders each card's MDX Content into hidden DOM containers with
 * data-bento-id and data-bento-meta attributes. The ReactBentoGrid
 * island reads these on mount and takes over layout with
 * react-grid-layout (drag, resize, hide/show).
 *
 * Items shape (from frontmatter):
 *   - bentoId: string (unique ID, e.g. 'bitcoin-tradingview')
 *   - title: string
 *   - description?: string
 *   - bentoSize?: 'small' | 'medium' | 'large' | 'wide' | 'tall'
 *   - bentoColor?: string (tailwind gradient classes)
 *   - bentoOrder?: number (explicit grid order, lower = first)
 *   - icon?: string (lucide icon name)
 */

import ReactBentoGrid from './ReactBentoGrid.tsx';

interface BentoItem {
	bentoId: string;
	title: string;
	description?: string;
	bentoSize?: 'small' | 'medium' | 'large' | 'wide' | 'tall';
	bentoColor?: string;
	bentoOrder?: number;
	icon?: string;
	Content?: any;
}

interface Props {
	items: BentoItem[];
	pageKey: string;
}

const { items, pageKey } = Astro.props;

// Sort by bentoOrder (default 99)
const sorted = [...items].sort(
	(a, b) => (a.bentoOrder ?? 99) - (b.bentoOrder ?? 99),
);

// ── Build-time bento layout computation (bin-packing, 4-col grid) ──
const COLS = 4;
const SIZE_MAP: Record<
	string,
	{ w: number; h: number; minW: number; minH: number }
> = {
	small: { w: 1, h: 1, minW: 1, minH: 1 },
	medium: { w: 2, h: 2, minW: 1, minH: 1 },
	large: { w: 2, h: 3, minW: 2, minH: 2 },
	wide: { w: 3, h: 1, minW: 2, minH: 1 },
	tall: { w: 1, h: 3, minW: 1, minH: 2 },
};

// Simple bin-packing: for each card, find the first row where it fits
function packBento(cards: typeof sorted) {
	// Track the height of each column
	const colHeights = new Array(COLS).fill(0);

	return cards.map((card) => {
		const dims = SIZE_MAP[card.bentoSize || 'medium'] || SIZE_MAP.medium;
		const w = Math.min(dims.w, COLS);

		// Find the best x position (leftmost column group with lowest max height)
		let bestX = 0;
		let bestY = Infinity;

		for (let x = 0; x <= COLS - w; x++) {
			// The y position is the max height of the columns this card would span
			const maxH = Math.max(...colHeights.slice(x, x + w));
			if (maxH < bestY) {
				bestY = maxH;
				bestX = x;
			}
		}

		// Place the card
		const item = {
			i: card.bentoId,
			x: bestX,
			y: bestY,
			w,
			h: dims.h,
			minW: dims.minW,
			minH: dims.minH,
		};

		// Update column heights
		for (let c = bestX; c < bestX + w; c++) {
			colHeights[c] = bestY + dims.h;
		}

		return item;
	});
}

const defaultLayout = packBento(sorted);
---

<!-- Hidden card containers: Astro renders MDX content here, React reads it on mount -->{
	sorted.map((item) => {
		const meta = JSON.stringify({
			title: item.title,
			description: item.description || '',
			bentoSize: item.bentoSize || 'medium',
			bentoColor: item.bentoColor || 'from-zinc-700/30 to-zinc-900/60',
			icon: item.icon || '',
			bentoOrder: item.bentoOrder ?? 99,
		});
		return (
			<div
				data-bento-id={item.bentoId}
				data-bento-meta={meta}
				style="display:none;">
				{item.Content && <item.Content />}
			</div>
		);
	})
}

<!-- React island takes over layout — defaultLayout is precomputed at build time -->
<ReactBentoGrid
	client:only="react"
	pageKey={pageKey}
	defaultLayout={defaultLayout}
/>
