---

<footer data-site-footer>
	<div data-site-footer-inner>
		<div data-site-footer-brand>
			<img
				data-site-footer-logo
				src="/assets/images/brand/letter_logo.webp"
				alt="KBVE"
				width="105"
				height="35"
				decoding="async"
			/>
			<p>Open-source games, tools, and cloud infrastructure.</p>
			<ul data-social aria-label="Social links">
				{
					socials.map((s) => (
						<li>
							<a
								href={s.href}
								aria-label={s.label}
								rel="noopener noreferrer"
								target="_blank">
								<svg
									viewBox="0 0 24 24"
									width="20"
									height="20"
									fill="currentColor"
									aria-hidden="true">
									<path d={s.path} />
								</svg>
							</a>
						</li>
					))
				}
			</ul>
		</div>
		<nav data-site-footer-cols aria-label="Footer">
			{
				groups.map((group) => (
					<div>
						<h2>{group.heading}</h2>
						<ul>
							{group.links.map((link) => (
								<li>
									<a href={link.href}>{link.label}</a>
								</li>
							))}
						</ul>
					</div>
				))
			}
		</nav>
	</div>
	<div data-site-footer-base>
		<span>© {year} KBVE · Built in the open</span>
		<a data-totop href="#top" aria-label="Back to top">
			Back to top
			<svg
				viewBox="0 0 24 24"
				width="16"
				height="16"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true">
				<path d="M12 19V5M5 12l7-7 7 7"></path>
			</svg>
		</a>
	</div>
</footer>

<style>
	[data-site-footer] {
		width: 100%;
		background: var(--color-bg-sunken);
		color: var(--color-parchment);
		border-top: 1px solid var(--color-gold-dark);
	}
	[data-site-footer]::before {
		content: '';
		display: block;
		height: 2px;
		background: linear-gradient(
			90deg,
			transparent,
			var(--color-gold),
			var(--color-red),
			var(--color-gold),
			transparent
		);
		background-size: 200% 100%;
		animation: footer-shimmer 7s linear infinite;
	}
	@keyframes footer-shimmer {
		to {
			background-position: 200% 0;
		}
	}

	[data-site-footer-inner] {
		display: flex;
		flex-wrap: wrap;
		gap: 2.5rem;
		justify-content: space-between;
		max-width: 1120px;
		margin: 0 auto;
		padding: 3rem 1.5rem;
	}
	[data-site-footer-brand] {
		max-width: 20rem;
	}
	[data-site-footer-logo] {
		display: block;
		height: 35px;
		width: auto;
	}
	[data-site-footer-brand] p {
		margin: 0.75rem 0 1.25rem;
		font-size: 0.9rem;
		line-height: 1.55;
		opacity: 0.8;
	}

	[data-social] {
		display: flex;
		gap: 0.6rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}
	[data-social] a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.25rem;
		height: 2.25rem;
		border-radius: 0.6rem;
		color: var(--color-parchment);
		opacity: 0.7;
		border: 1px solid var(--color-gold-dark);
		transition:
			transform 0.2s ease,
			color 0.2s ease,
			opacity 0.2s ease,
			border-color 0.2s ease,
			background-color 0.2s ease;
	}
	[data-social] a:hover {
		color: var(--color-gold);
		opacity: 1;
		transform: translateY(-3px) scale(1.08);
		border-color: var(--color-gold);
		background: rgba(166, 125, 67, 0.1);
	}

	[data-site-footer-cols] {
		display: flex;
		flex-wrap: wrap;
		gap: 2.5rem;
	}
	[data-site-footer-cols] h2 {
		margin: 0 0 0.7rem;
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-gold-light);
	}
	[data-site-footer-cols] ul {
		margin: 0;
		padding: 0;
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.45rem;
	}
	[data-site-footer-cols] a {
		font-size: 0.9rem;
		color: var(--color-parchment);
		text-decoration: none;
		opacity: 0.78;
		transition:
			color 0.15s ease,
			opacity 0.15s ease;
	}
	[data-site-footer-cols] a:hover {
		color: var(--color-gold);
		opacity: 1;
	}

	[data-site-footer-base] {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		align-items: center;
		justify-content: space-between;
		max-width: 1120px;
		margin: 0 auto;
		padding: 1.1rem 1.5rem;
		border-top: 1px solid var(--color-gold-dark);
		font-size: 0.8rem;
		opacity: 0.75;
	}
	[data-totop] {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		color: var(--color-parchment);
		text-decoration: none;
		transition: color 0.15s ease;
	}
	[data-totop]:hover {
		color: var(--color-gold);
	}
	[data-totop] svg {
		transition: transform 0.2s ease;
	}
	[data-totop]:hover svg {
		transform: translateY(-3px);
	}
</style>
