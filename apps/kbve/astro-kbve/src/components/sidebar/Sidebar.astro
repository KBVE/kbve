---
import MobileMenuFooter from 'virtual:starlight/components/MobileMenuFooter';
import SidebarPersister from '@astrojs/starlight/components/SidebarPersister.astro';
import CustomSidebarList from './CustomSidebarList.astro';

const { sidebar } = Astro.locals.starlightRoute;

const sidebarIcons = [
	{
		label: 'Dashboard',
		icon: 'M4 5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V5Zm10 0a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1h-4a1 1 0 0 1-1-1V5ZM4 15a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-4Zm10 0a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1h-4a1 1 0 0 1-1-1v-4Z',
	},
	{
		label: 'Guides',
		icon: 'M4 19V5a2 2 0 0 1 2-2h13v16H6a2 2 0 0 0-2 2Zm0 0a2 2 0 0 1 2-2h13',
	},
	{
		label: 'Applications',
		icon: 'M3 5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5Zm4 3h10M7 12h10M7 16h6',
	},
	{
		label: 'Project',
		icon: 'M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7Z',
	},
	{
		label: 'Memes',
		icon: 'M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10Zm-3-13a1 1 0 1 0 0 2 1 1 0 0 0 0-2Zm6 0a1 1 0 1 0 0 2 1 1 0 0 0 0-2Zm-8 5s1.5 3 5 3 5-3 5-3',
	},
	{
		label: 'Minecraft',
		icon: 'M3 3h18v18H3V3Zm4 4h4v4H7V7Zm6 0h4v4h-4V7ZM7 13h4v4H7v-4Zm6 0h4v4h-4v-4Z',
	},
	{
		label: 'Gaming',
		icon: 'M6 12h4m-2-2v4m5-1h2m-1-2v0M21 7v7.8a2.2 2.2 0 0 1-2.2 2.2H5.2A2.2 2.2 0 0 1 3 14.8V7m0 0 3.5-3h11L21 7m-18 0h18',
	},
	{
		label: 'Arcade',
		icon: 'M12 8V4m-2 4h4m-5 4H7m10 0h-2m-8.5 6h11a1.5 1.5 0 0 0 1.5-1.5v-7A1.5 1.5 0 0 0 17.5 4h-11A1.5 1.5 0 0 0 5 5.5v7A1.5 1.5 0 0 0 6.5 14Z',
	},
	{
		label: 'Assets',
		icon: 'M19 7V4H5v3m7 10v-7m-4 0h8m-9 7h10a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2Z',
	},
	{
		label: 'Game Data',
		icon: 'M4 6a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v1H4V6Zm0 4h16v1H4v-1Zm0 4h16v6a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-6Z',
	},
	{
		label: 'Theory',
		icon: 'M9 21h6m-3-4v4M12 3a5 5 0 0 0-5 5c0 2.76 2.5 5 5 5s5-2.24 5-5a5 5 0 0 0-5-5Z',
	},
	{
		label: 'Blog',
		icon: 'M4 4h16v16H4V4Zm2 2v4h4V6H6Zm6 0v2h6V6h-6Zm-6 6v2h14v-2H6Zm0 4v2h14v-2H6Z',
	},
	{ label: 'Journal', icon: 'M15.5 3H5v18h14V6.5L15.5 3ZM8 11h8M8 15h5' },
	{
		label: 'Recipe',
		icon: 'M12 4C9 4 6 6 6 10c0 2.5 1 4 2.5 5L8 20h8l-.5-5C17 14 18 12.5 18 10c0-4-3-6-6-6Zm-2 16h4',
	},
	{
		label: 'Legal',
		icon: 'M9 12h6m-3-3v6m-7 3V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2Z',
	},
];

const iconMap = new Map(sidebarIcons.map(({ label, icon }) => [label, icon]));
---

<!-- Top collapse toggle (always visible on desktop) -->
<div class="sl-sidebar-toggle-wrap sl-sidebar-toggle-wrap--top">
	<button
		class="sl-sidebar-collapse-btn sl-sidebar-collapse-btn--top"
		aria-label="Toggle sidebar"
		title="Toggle sidebar">
		<svg
			class="sl-sidebar-collapse-icon"
			xmlns="http://www.w3.org/2000/svg"
			width="20"
			height="20"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round">
			<polyline class="chevron-left" points="15 18 9 12 15 6"></polyline>
		</svg>
	</button>
</div>

<!-- Unified sidebar list: icons + labels in same DOM nodes -->
<div class="sl-sidebar-list-wrap not-content">
	<SidebarPersister>
		<CustomSidebarList sublist={sidebar} iconMap={iconMap} />
	</SidebarPersister>
</div>

<!-- Bottom collapse toggle -->
<div class="sl-sidebar-toggle-wrap">
	<button
		id="sl-sidebar-collapse-btn"
		class="sl-sidebar-collapse-btn"
		aria-label="Toggle sidebar"
		title="Toggle sidebar">
		<svg
			class="sl-sidebar-collapse-icon"
			xmlns="http://www.w3.org/2000/svg"
			width="20"
			height="20"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round">
			<polyline class="chevron-left" points="15 18 9 12 15 6"></polyline>
		</svg>
	</button>
</div>

<script>
	import './sidebar-toggle';
</script>

<div class="md:sl-hidden">
	<MobileMenuFooter />
</div>
