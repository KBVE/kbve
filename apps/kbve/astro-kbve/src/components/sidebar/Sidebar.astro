---
import MobileMenuFooter from 'virtual:starlight/components/MobileMenuFooter';
import SidebarPersister from '@astrojs/starlight/components/SidebarPersister.astro';
import SidebarSublist from '@astrojs/starlight/components/SidebarSublist.astro';
import SidebarToggle from './SidebarToggle';

const { sidebar } = Astro.locals.starlightRoute;
---

<div class="sl-sidebar-toggle-wrap">
	<button
		id="sl-sidebar-collapse-btn"
		class="sl-sidebar-collapse-btn"
		aria-label="Toggle sidebar"
		title="Toggle sidebar">
		<svg
			class="sl-sidebar-collapse-icon"
			xmlns="http://www.w3.org/2000/svg"
			width="20"
			height="20"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round">
			<polyline class="chevron-left" points="15 18 9 12 15 6"></polyline>
		</svg>
	</button>
</div>

<SidebarToggle client:load side="left" targetId="sl-sidebar-collapse-btn" />

<SidebarPersister>
	<SidebarSublist sublist={sidebar} />
</SidebarPersister>

<div class="md:sl-hidden">
	<MobileMenuFooter />
</div>
