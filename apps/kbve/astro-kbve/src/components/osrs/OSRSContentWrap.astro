<section class="osrs-content-wrap">
	<slot />
</section>

<style>
	.osrs-content-wrap {
		margin-top: 1rem;
		border-radius: 0.75rem;
		border: 1px solid var(--sl-color-gray-5);
		background: var(--sl-color-bg-nav);
		padding: 1rem 1.25rem;
	}

	/* Headings */
	.osrs-content-wrap :global(h2) {
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--sl-color-white);
		margin: 0 0 0.625rem;
		padding-bottom: 0.375rem;
		border-bottom: 1px solid var(--sl-color-gray-5);
	}

	/* Remove margin on last child to tighten card bottoms */
	.osrs-content-wrap :global(:last-child) {
		margin-bottom: 0;
	}

	/* Paragraphs */
	.osrs-content-wrap :global(p) {
		font-size: 0.875rem;
		color: var(--sl-color-gray-2);
		line-height: 1.6;
		margin: 0.5rem 0;
	}

	/* Blockquotes */
	.osrs-content-wrap :global(blockquote) {
		margin: 0.5rem 0;
		padding: 0.5rem 0.75rem;
		border-left: 3px solid var(--sl-color-accent);
		background: var(--sl-color-gray-6);
		border-radius: 0 0.375rem 0.375rem 0;
		font-style: italic;
		color: var(--sl-color-gray-2);
	}

	.osrs-content-wrap :global(blockquote p) {
		margin: 0;
	}

	/* Unordered lists */
	.osrs-content-wrap :global(ul) {
		list-style: none;
		padding: 0;
		margin: 0.5rem 0;
		display: grid;
		gap: 0.375rem;
	}

	.osrs-content-wrap :global(ul li) {
		font-size: 0.8125rem;
		color: var(--sl-color-gray-2);
		padding: 0.375rem 0.625rem;
		background: var(--sl-color-gray-6);
		border-radius: 0.375rem;
		border: 1px solid var(--sl-color-gray-5);
		line-height: 1.5;
	}

	.osrs-content-wrap :global(ul li strong) {
		color: var(--sl-color-gray-1);
	}

	/* Ordered lists */
	.osrs-content-wrap :global(ol) {
		padding-left: 1.25rem;
		margin: 0.5rem 0;
		display: grid;
		gap: 0.25rem;
	}

	.osrs-content-wrap :global(ol li) {
		font-size: 0.8125rem;
		color: var(--sl-color-gray-2);
		line-height: 1.5;
	}

	/* Tables */
	.osrs-content-wrap :global(table) {
		width: 100%;
		border-collapse: separate;
		border-spacing: 0;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.5rem;
		overflow: hidden;
		margin: 0.75rem 0;
		font-size: 0.8125rem;
	}

	.osrs-content-wrap :global(thead) {
		background: var(--sl-color-gray-6);
	}

	.osrs-content-wrap :global(th) {
		font-size: 0.6875rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: var(--sl-color-gray-3);
		padding: 0.5rem 0.75rem;
		text-align: left;
		border-bottom: 1px solid var(--sl-color-gray-5);
	}

	.osrs-content-wrap :global(td) {
		padding: 0.5rem 0.75rem;
		color: var(--sl-color-gray-2);
		border-bottom: 1px solid var(--sl-color-gray-6);
	}

	.osrs-content-wrap :global(tr:last-child td) {
		border-bottom: none;
	}

	.osrs-content-wrap :global(tbody tr:hover) {
		background: var(--sl-color-gray-6);
	}

	/* Links */
	.osrs-content-wrap :global(a) {
		color: var(--sl-color-accent-high);
		text-decoration: none;
		transition: color 0.15s ease;
	}

	.osrs-content-wrap :global(a:hover) {
		color: var(--sl-color-accent);
		text-decoration: underline;
	}

	/* Inline code */
	.osrs-content-wrap :global(code) {
		font-size: 0.75rem;
		padding: 0.125rem 0.375rem;
		background: var(--sl-color-gray-6);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.25rem;
		color: var(--sl-color-accent-high);
	}

	/* Strong */
	.osrs-content-wrap :global(strong) {
		color: var(--sl-color-white);
		font-weight: 600;
	}
</style>
