---
import type { OSRSShopSource } from '@/data/schema';

interface Props {
	shops: OSRSShopSource[];
}

const { shops } = Astro.props;

function fmtPrice(p: number | string | undefined): string {
	if (p === undefined || p === null) return '—';
	if (typeof p === 'number') return `${p.toLocaleString()} gp`;
	return p;
}

function fmtStock(s: number | string | undefined): string {
	if (s === undefined || s === null) return '—';
	if (typeof s === 'number') return s.toLocaleString();
	return s;
}
---

<div class="osrs-shops">
	<div class="osrs-shops__header">
		<span class="osrs-shops__icon">
			<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
				<path
					d="M19 6h-2c0-2.76-2.24-5-5-5S7 3.24 7 6H5c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-7-3c1.66 0 3 1.34 3 3H9c0-1.66 1.34-3 3-3zm0 10c-2.76 0-5-2.24-5-5h2c0 1.66 1.34 3 3 3s3-1.34 3-3h2c0 2.76-2.24 5-5 5z">
				</path>
			</svg>
		</span>
		<h4 class="osrs-shops__title">
			Shops <span class="osrs-shops__count">({shops.length})</span>
		</h4>
	</div>
	<div class="osrs-shops__table-wrap">
		<table class="osrs-shops__table">
			<thead>
				<tr>
					<th>Shop</th>
					<th>Location</th>
					<th class="osrs-shops__num">Stock</th>
					<th class="osrs-shops__num">Price</th>
					<th>World</th>
				</tr>
			</thead>
			<tbody>
				{
					shops.map((s) => (
						<tr>
							<td class="osrs-shops__name">{s.shop_name}</td>
							<td>{s.location ?? '—'}</td>
							<td class="osrs-shops__num">{fmtStock(s.stock)}</td>
							<td class="osrs-shops__num">{fmtPrice(s.price)}</td>
							<td>
								<span
									class={`osrs-shops__badge ${s.members_only ? 'osrs-shops__badge--p2p' : 'osrs-shops__badge--f2p'}`}>
									{s.members_only ? 'P2P' : 'F2P'}
								</span>
							</td>
						</tr>
					))
				}
			</tbody>
		</table>
	</div>
</div>

<style>
	.osrs-shops {
		margin-top: 1rem;
		border-radius: 0.5rem;
		border: 1px solid var(--sl-color-gray-5);
		background: var(--sl-color-bg-nav);
		overflow: hidden;
	}

	.osrs-shops__header {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.625rem 0.75rem;
		background: var(--sl-color-gray-6);
		border-bottom: 1px solid var(--sl-color-gray-5);
	}

	.osrs-shops__icon {
		color: var(--sl-color-accent);
	}

	.osrs-shops__title {
		font-size: 0.8125rem;
		font-weight: 600;
		color: var(--sl-color-white);
		margin: 0;
	}

	.osrs-shops__count {
		color: var(--sl-color-gray-3);
		font-weight: 400;
		font-size: 0.75rem;
	}

	.osrs-shops__table-wrap {
		overflow-x: auto;
		max-height: 24rem;
		overflow-y: auto;
	}

	.osrs-shops__table {
		width: 100%;
		border-collapse: collapse;
		font-size: 0.75rem;
	}

	.osrs-shops__table thead {
		position: sticky;
		top: 0;
		background: var(--sl-color-gray-6);
		z-index: 1;
	}

	.osrs-shops__table th,
	.osrs-shops__table td {
		padding: 0.375rem 0.625rem;
		text-align: left;
		border-bottom: 1px solid var(--sl-color-gray-5);
	}

	.osrs-shops__table th {
		font-size: 0.5rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--sl-color-gray-3);
		font-weight: 600;
	}

	.osrs-shops__name {
		font-weight: 500;
		color: var(--sl-color-white);
	}

	.osrs-shops__num {
		text-align: right;
		font-variant-numeric: tabular-nums;
	}

	.osrs-shops__badge {
		display: inline-block;
		padding: 0.0625rem 0.25rem;
		font-size: 0.5rem;
		font-weight: 700;
		border-radius: 0.1875rem;
		text-transform: uppercase;
	}

	.osrs-shops__badge--p2p {
		background: var(--sl-color-accent);
		color: var(--sl-color-black);
	}

	.osrs-shops__badge--f2p {
		background: var(--sl-color-gray-4);
		color: var(--sl-color-white);
	}
</style>
