---
import { getCollection } from 'astro:content';
import type { OSRSExtended } from '@/data/schema';
import { buildOsrsTags } from '@/data/osrs/tags';
import { findOsrsCategory } from '@/data/osrs/categories';

interface Props {
	slug: string;
}

const { slug } = Astro.props;
const category = findOsrsCategory(slug);
if (!category) {
	throw new Error(`Unknown OSRS category: ${slug}`);
}

const ICON_BASE = 'https://oldschool.runescape.wiki/images/';
const iconUrl = (icon: string): string =>
	ICON_BASE + encodeURIComponent((icon ?? '').replace(/ /g, '_'));
const formatGP = (v: number | null | undefined): string =>
	v === null || v === undefined || v === 0 ? '—' : v.toLocaleString();

interface Row {
	id: number;
	name: string;
	slug: string;
	icon: string;
	members: boolean;
	value: number;
	highalch: number | null;
	limit: number | null;
	slot?: string;
}

const docs = await getCollection('docs');
const rows: Row[] = [];
for (const entry of docs) {
	const o = (entry.data as { osrs?: OSRSExtended }).osrs;
	if (!o || !o.id || !o.slug || !o.name) continue;
	if (!buildOsrsTags(o).includes(category.tag)) continue;
	rows.push({
		id: o.id,
		name: o.name,
		slug: o.slug,
		icon: o.icon,
		members: !!o.members,
		value: o.value ?? 0,
		highalch: o.highalch ?? null,
		limit: o.limit ?? null,
		slot: o.equipment?.slot ?? undefined,
	});
}
rows.sort((a, b) => a.name.localeCompare(b.name));

const accent = category.accent;
const accentHigh = accent.replace(/(\d+)%\)?$/, '') + '72%';
---

<section
	class="osrs-category not-content kbve-dashboard-page relative w-full bg-transparent"
	style={`--bento-accent: hsl(${accent}); --sl-color-accent: hsl(${accent}); --sl-color-accent-high: hsl(${accentHigh});`}>
	<div class="bento-frame">
		<div class="bento-board bento-board--cols-4">
			<div class="bento-card bento-cell--wide osrs-cat-head">
				<p class="osrs-cat-head__eyebrow">OSRS · {category.group}</p>
				<h1 class="osrs-cat-head__title">{category.label}</h1>
				<p class="osrs-cat-head__blurb">{category.blurb}</p>
			</div>
			<div class="bento-stat osrs-cat-stat">
				<span class="osrs-cat-stat__value">
					{rows.length.toLocaleString()}
				</span>
				<span class="osrs-cat-stat__label">items</span>
			</div>
			<a
				href="/osrs/"
				class="bento-stat osrs-cat-stat osrs-cat-stat--link">
				<span class="osrs-cat-stat__value">All</span>
				<span class="osrs-cat-stat__label">browse database</span>
			</a>
		</div>
	</div>

	<div class="bento-frame">
		<div class="osrs-cat-grid">
			{
				rows.map((item) => (
					<a href={`/osrs/${item.slug}/`} class="osrs-cat-row">
						<img
							src={iconUrl(item.icon)}
							alt=""
							loading="lazy"
							width={32}
							height={32}
							class="osrs-cat-row__icon"
						/>
						<div class="osrs-cat-row__body">
							<div class="osrs-cat-row__top">
								<span class="osrs-cat-row__name">
									{item.name}
								</span>
								{item.members && (
									<span class="osrs-cat-row__tag osrs-cat-row__tag--p2p">
										P2P
									</span>
								)}
								{item.slot && (
									<span class="osrs-cat-row__tag osrs-cat-row__tag--slot">
										{item.slot}
									</span>
								)}
							</div>
							<div class="osrs-cat-row__meta">
								<span>id {item.id}</span>
								<span>value {formatGP(item.value)}</span>
								{item.highalch !== null && (
									<span>alch {formatGP(item.highalch)}</span>
								)}
								{item.limit !== null && (
									<span>ge {formatGP(item.limit)}</span>
								)}
							</div>
						</div>
					</a>
				))
			}
			{
				rows.length === 0 && (
					<p class="osrs-cat-empty">No items in this category yet.</p>
				)
			}
		</div>
	</div>
</section>

<style>
	.osrs-category {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.osrs-cat-head {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		justify-content: center;
	}

	.osrs-cat-head__eyebrow {
		margin: 0;
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--sl-color-accent-high);
	}

	.osrs-cat-head__title {
		margin: 0;
		font-size: 1.6rem;
		line-height: 1.1;
	}

	.osrs-cat-head__blurb {
		margin: 0;
		font-size: 0.85rem;
		color: var(--sl-color-gray-2);
	}

	.osrs-cat-stat {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 0.15rem;
		text-decoration: none;
	}

	.osrs-cat-stat__value {
		font-size: 1.5rem;
		font-weight: 700;
		color: var(--sl-color-accent-high);
	}

	.osrs-cat-stat__label {
		font-size: 0.72rem;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3);
	}

	.osrs-cat-stat--link:hover .osrs-cat-stat__value {
		text-decoration: underline;
	}

	.osrs-cat-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(min(100%, 20rem), 1fr));
		gap: 0.5rem;
		padding: 0.5rem;
	}

	.osrs-cat-row {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		padding: 0.55rem 0.7rem;
		border: 1px solid var(--bento-hairline);
		border-radius: 10px;
		text-decoration: none;
		color: inherit;
		background: color-mix(in srgb, var(--sl-color-white) 2%, transparent);
		transition:
			background-color 140ms ease,
			border-color 140ms ease;
	}

	.osrs-cat-row:hover {
		background: color-mix(in srgb, var(--sl-color-accent) 12%, transparent);
		border-color: var(--sl-color-accent);
	}

	.osrs-cat-row__icon {
		width: 2rem;
		height: 2rem;
		flex: none;
		object-fit: contain;
	}

	.osrs-cat-row__body {
		min-width: 0;
		flex: 1;
	}

	.osrs-cat-row__top {
		display: flex;
		align-items: center;
		gap: 0.4rem;
	}

	.osrs-cat-row__name {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		font-weight: 600;
		font-size: 0.85rem;
	}

	.osrs-cat-row__tag {
		flex: none;
		border-radius: 5px;
		padding: 0.05rem 0.3rem;
		font-size: 0.6rem;
		font-weight: 700;
		text-transform: uppercase;
	}

	.osrs-cat-row__tag--p2p {
		background: color-mix(in srgb, #f59e0b 22%, transparent);
		color: #fbbf24;
	}

	.osrs-cat-row__tag--slot {
		background: color-mix(in srgb, #38bdf8 20%, transparent);
		color: #7dd3fc;
	}

	.osrs-cat-row__meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		margin-top: 0.1rem;
		font-size: 0.68rem;
		color: var(--sl-color-gray-3);
	}

	.osrs-cat-empty {
		padding: 1rem;
		color: var(--sl-color-gray-3);
	}
</style>
