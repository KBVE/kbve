---
import { getCollection } from 'astro:content';
import { buildNpcNav, FAMILY_META } from './npcNav';

const raw = await getCollection('npcdb');
const entries = raw.map((e: { id: string; data: Record<string, unknown> }) => ({
	id: e.id,
	data: e.data,
}));

const groups = buildNpcNav(entries as any);

const iconFor = (label: string): string => {
	const meta = FAMILY_META.find((m) => m.label === label);
	return (
		meta?.icon ??
		'M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zM9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3M12 17h.01'
	);
};

const anchorFor = (href: string): string =>
	href.split('#')[1] ?? href.replace(/\W+/g, '');

const total = groups.reduce((n, g) => n + g.items.length, 0);

const active = (entries as { data: Record<string, unknown> }[]).filter(
	(e) => e.data.drafted !== true && e.data.name !== 'Index',
);
const bosses = active.filter((e) =>
	['world_boss', 'rare_elite', 'elite'].includes(String(e.data.rank)),
).length;

const stats = [
	{
		label: 'Cataloged NPCs',
		value: String(total),
		icon: 'M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2M12 7a4 4 0 1 0 0 8 4 4 0 0 0 0-8z',
	},
	{
		label: 'Families',
		value: String(groups.length),
		icon: 'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75',
	},
	{
		label: 'Elites & bosses',
		value: String(bosses),
		icon: 'M12 2 15 8l7 1-5 5 1 7-6-3-6 3 1-7-5-5 7-1 3-6z',
	},
];
---

<div class="npc-directory">
	<div class="bento-board npc-directory__stats">
		{
			stats.map((s) => (
				<div class="bento-cell bento-stat bento-card bento-card--glass bento-card--interactive">
					<span class="bento-icon-tile">
						<svg
							viewBox="0 0 24 24"
							width="16"
							height="16"
							fill="none"
							stroke="currentColor"
							stroke-width="1.75"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true">
							<path d={s.icon} />
						</svg>
					</span>
					<span class="bento-stat__value">{s.value}</span>
					<span class="bento-stat__label">{s.label}</span>
				</div>
			))
		}
	</div>

	{
		groups.map((group) => (
			<section
				id={anchorFor(group.href ?? group.label)}
				class="npc-family">
				<header class="npc-family__header">
					<span class="bento-icon-tile">
						<svg
							viewBox="0 0 24 24"
							width="17"
							height="17"
							fill="none"
							stroke="currentColor"
							stroke-width="1.75"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true">
							<path d={iconFor(group.label)} />
						</svg>
					</span>
					<div class="npc-family__heading">
						<p class="bento-eyebrow">{group.eyebrow}</p>
						<h3 class="npc-family__title">{group.label}</h3>
					</div>
					<span class="npc-family__count">{group.items.length}</span>
				</header>
				<div class="bento-board bento-board--cols-3">
					{group.items.map((item) => (
						<a
							class="bento-cell bento-linkcard bento-card bento-card--glass bento-card--interactive"
							href={item.href}>
							<span class="bento-linkcard__title">
								{item.label}
							</span>
							<span class="bento-linkcard__go" aria-hidden="true">
								<svg
									viewBox="0 0 24 24"
									width="16"
									height="16"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round">
									<path d="M5 12h14M13 6l6 6-6 6" />
								</svg>
							</span>
						</a>
					))}
				</div>
			</section>
		))
	}
</div>

<style>
	.npc-directory {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
	}

	.npc-directory__stats {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1px;
		background-color: var(--bento-hairline);
	}

	@media (max-width: 640px) {
		.npc-directory__stats {
			grid-template-columns: 1fr;
		}
	}

	.npc-family {
		scroll-margin-top: 5rem;
	}

	.npc-family__header {
		display: flex;
		align-items: center;
		gap: 0.85rem;
		padding: 0 0.25rem 1rem;
	}

	.npc-family__heading {
		flex: 1;
		min-width: 0;
	}

	.npc-family__heading .bento-eyebrow {
		margin: 0;
	}

	.npc-family__title {
		margin: 0.1rem 0 0;
		font-size: 1.25rem;
		font-weight: 700;
		letter-spacing: -0.02em;
		color: var(--sl-color-white);
	}

	.npc-family__count {
		flex-shrink: 0;
		font-size: 0.75rem;
		font-weight: 600;
		font-variant-numeric: tabular-nums;
		padding: 0.2rem 0.55rem;
		border-radius: 999px;
		color: var(--sl-color-gray-2);
		background-color: color-mix(
			in srgb,
			var(--sl-color-white) 6%,
			transparent
		);
	}

	.npc-directory .bento-linkcard {
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
	}
</style>
