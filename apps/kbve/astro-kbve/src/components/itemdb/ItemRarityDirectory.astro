---
import { getCollection } from 'astro:content';
import { buildItemNav, RARITY_META } from './itemNav';

const raw = await getCollection('itemdb');
const entries = raw.map((e: { id: string; data: Record<string, unknown> }) => ({
	id: e.id,
	data: e.data,
}));

const groups = buildItemNav(entries as any);

const iconFor = (label: string): string => {
	const meta = RARITY_META.find((m) => m.label === label);
	return meta?.icon ?? 'M4 7V4h16v3M4 12h16M4 17v3h16v-3M12 4v16';
};

const anchorFor = (href: string): string =>
	href.split('#')[1] ?? href.replace(/\W+/g, '');

const total = groups.reduce((n, g) => n + g.items.length, 0);
const highTier = groups
	.filter((g) => ['Mythic', 'Legendary', 'Epic'].includes(g.label))
	.reduce((n, g) => n + g.items.length, 0);

const stats = [
	{
		label: 'Cataloged items',
		value: String(total),
		icon: 'M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z',
	},
	{
		label: 'Rarity tiers',
		value: String(groups.length),
		icon: 'M6 20h12M6 20l-2-9 5 3 3-7 3 7 5-3-2 9',
	},
	{
		label: 'Epic & above',
		value: String(highTier),
		icon: 'M12 2 15 8l7 1-5 5 1 7-6-3-6 3 1-7-5-5 7-1 3-6z',
	},
];
---

<div class="item-directory">
	<div class="bento-board item-directory__stats">
		{
			stats.map((s) => (
				<div class="bento-cell bento-stat bento-card bento-card--glass bento-card--interactive">
					<span class="bento-icon-tile">
						<svg
							viewBox="0 0 24 24"
							width="16"
							height="16"
							fill="none"
							stroke="currentColor"
							stroke-width="1.75"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true">
							<path d={s.icon} />
						</svg>
					</span>
					<span class="bento-stat__value">{s.value}</span>
					<span class="bento-stat__label">{s.label}</span>
				</div>
			))
		}
	</div>

	{
		groups.map((group) => (
			<section
				id={anchorFor(group.href ?? group.label)}
				class="item-rarity">
				<header class="item-rarity__header">
					<span class="bento-icon-tile">
						<svg
							viewBox="0 0 24 24"
							width="17"
							height="17"
							fill="none"
							stroke="currentColor"
							stroke-width="1.75"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true">
							<path d={iconFor(group.label)} />
						</svg>
					</span>
					<div class="item-rarity__heading">
						<p class="bento-eyebrow">{group.eyebrow}</p>
						<h3 class="item-rarity__title">{group.label}</h3>
					</div>
					<span class="item-rarity__count">{group.items.length}</span>
				</header>
				<div class="bento-board bento-board--cols-3">
					{group.items.map((item) => (
						<a
							class="bento-cell bento-linkcard bento-card bento-card--glass bento-card--interactive"
							href={item.href}>
							<span class="bento-linkcard__title">
								{item.label}
							</span>
							<span class="bento-linkcard__go" aria-hidden="true">
								<svg
									viewBox="0 0 24 24"
									width="16"
									height="16"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round">
									<path d="M5 12h14M13 6l6 6-6 6" />
								</svg>
							</span>
						</a>
					))}
				</div>
			</section>
		))
	}
</div>

<style>
	.item-directory {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
	}

	.item-directory__stats {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1px;
		background-color: var(--bento-hairline);
	}

	@media (max-width: 640px) {
		.item-directory__stats {
			grid-template-columns: 1fr;
		}
	}

	.item-rarity {
		scroll-margin-top: 5rem;
	}

	.item-rarity__header {
		display: flex;
		align-items: center;
		gap: 0.85rem;
		padding: 0 0.25rem 1rem;
	}

	.item-rarity__heading {
		flex: 1;
		min-width: 0;
	}

	.item-rarity__heading .bento-eyebrow {
		margin: 0;
	}

	.item-rarity__title {
		margin: 0.1rem 0 0;
		font-size: 1.25rem;
		font-weight: 700;
		letter-spacing: -0.02em;
		color: var(--sl-color-white);
	}

	.item-rarity__count {
		flex-shrink: 0;
		font-size: 0.75rem;
		font-weight: 600;
		font-variant-numeric: tabular-nums;
		padding: 0.2rem 0.55rem;
		border-radius: 999px;
		color: var(--sl-color-gray-2);
		background-color: color-mix(
			in srgb,
			var(--sl-color-white) 6%,
			transparent
		);
	}

	.item-directory .bento-linkcard {
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
	}
</style>
