---
import DefaultThemeProvider from '@astrojs/starlight/components/ThemeProvider.astro';
---

<DefaultThemeProvider />

{/* Right sidebar state — inlined to prevent flash of expanded panel */}
<script is:inline>
	(function () {
		try {
			var d = document.documentElement;
			var l = localStorage;
			d.setAttribute(
				'data-right-sidebar-collapsed',
				l.getItem('sl-right-sidebar-collapsed') !== 'false'
					? 'true'
					: 'false',
			);
		} catch (e) {}
	})();
</script>

<script>
	import './auth-sync';
</script>
