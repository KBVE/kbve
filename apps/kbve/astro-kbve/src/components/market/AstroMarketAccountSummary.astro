---

---

<section
	class="kbve-market-summary not-content"
	data-kbve-market-shell
	data-kbve-market-state="loading"
	aria-label="Marketplace summary">
	<header class="kbve-market-summary__head">
		<h2>Marketplace</h2>
		<a class="kbve-market-summary__link" href="/dashboard/market/">
			Open →
		</a>
	</header>
	<dl class="kbve-market-summary__grid">
		<div>
			<dt>Active listings</dt>
			<dd data-kbve-market-stat="active-listings">—</dd>
		</div>
		<div>
			<dt>Sold</dt>
			<dd data-kbve-market-stat="sold-listings">—</dd>
		</div>
		<div>
			<dt>Active bids</dt>
			<dd data-kbve-market-stat="active-bids">—</dd>
		</div>
		<div>
			<dt>Won</dt>
			<dd data-kbve-market-stat="won-bids">—</dd>
		</div>
	</dl>
	<div class="kbve-market-summary__error" data-kbve-market-error hidden></div>
</section>

<script>
	import { myBids, myListings, MarketApiError } from './api';
	import { initSupa, getSupa } from '@/lib/supa';

	const shell = document.querySelector<HTMLElement>(
		'[data-kbve-market-shell]',
	);
	if (shell) {
		const errorEl = shell.querySelector<HTMLElement>(
			'[data-kbve-market-error]',
		);
		const setStat = (key: string, value: number | string) => {
			const el = shell.querySelector<HTMLElement>(
				`[data-kbve-market-stat="${key}"]`,
			);
			if (el) el.textContent = String(value);
		};
		const setError = (msg: string | null) => {
			if (!errorEl) return;
			if (msg) {
				errorEl.textContent = msg;
				errorEl.removeAttribute('hidden');
			} else {
				errorEl.setAttribute('hidden', '');
				errorEl.textContent = '';
			}
		};

		(async () => {
			try {
				await initSupa();
			} catch {
				shell.dataset.kbveMarketState = 'signed-out';
				return;
			}
			const supa = getSupa();
			const sessionResult = await supa.getSession().catch(() => null);
			const token = sessionResult?.session?.access_token;
			if (!token) {
				shell.dataset.kbveMarketState = 'signed-out';
				return;
			}

			try {
				const [ls, bs] = await Promise.all([
					myListings({ limit: 100 }),
					myBids({ limit: 100 }),
				]);
				setStat(
					'active-listings',
					ls.filter((l) => l.listing_status === 'active').length,
				);
				setStat(
					'sold-listings',
					ls.filter((l) => l.listing_status === 'sold').length,
				);
				setStat(
					'active-bids',
					bs.filter((b) => b.bid_status === 'active').length,
				);
				setStat(
					'won-bids',
					bs.filter((b) => b.bid_status === 'won').length,
				);
				setError(null);
				shell.dataset.kbveMarketState = 'ready';
			} catch (e) {
				setError(
					e instanceof MarketApiError
						? e.message
						: 'market summary failed',
				);
				shell.dataset.kbveMarketState = 'error';
			}
		})();
	}
</script>

<style is:global>
	.kbve-market-summary {
		margin-top: 1rem;
		padding: 1.25rem;
		border-radius: 16px;
		background: linear-gradient(
			145deg,
			rgba(30, 41, 59, 0.9) 0%,
			rgba(15, 23, 42, 0.95) 100%
		);
		border: 1px solid rgba(255, 255, 255, 0.08);
		color: rgba(255, 255, 255, 0.9);
		box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
		min-height: 188px;
	}
	.kbve-market-summary[data-kbve-market-state='signed-out'] {
		display: none;
	}
	.kbve-market-summary__head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 0.85rem;
	}
	.kbve-market-summary__head h2 {
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 2px;
		text-transform: uppercase;
		margin: 0;
		color: rgba(255, 255, 255, 0.9);
	}
	.kbve-market-summary__link {
		font-size: 0.8rem;
		font-weight: 600;
		color: rgb(103, 232, 249);
		text-decoration: none;
	}
	.kbve-market-summary__link:hover {
		text-decoration: underline;
	}
	.kbve-market-summary__grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 0.75rem;
		margin: 0;
	}
	.kbve-market-summary__grid > div {
		padding: 0.85rem 1rem;
		border-radius: 12px;
		background: rgba(255, 255, 255, 0.04);
		border: 1px solid rgba(255, 255, 255, 0.06);
	}
	.kbve-market-summary__grid dt {
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 1.5px;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.55);
		margin: 0;
	}
	.kbve-market-summary__grid dd {
		margin: 0.25rem 0 0;
		font-family:
			ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 1.5rem;
		font-weight: 700;
		color: rgba(255, 255, 255, 0.95);
	}
	.kbve-market-summary__error {
		margin-top: 0.75rem;
		font-size: 0.8rem;
		color: rgb(248, 113, 113);
	}
	@media (min-width: 640px) {
		.kbve-market-summary__grid {
			grid-template-columns: repeat(4, 1fr);
		}
	}
</style>
