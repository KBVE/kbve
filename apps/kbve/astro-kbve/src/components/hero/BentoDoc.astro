---
import { Code } from 'astro:components';
import BentoShell from './BentoShell.astro';
import Adsense from '@/components/astropad/adsense/Adsense.astro';
import { bentoIcon } from '@/data/bento-icons';
import type { BentoDoc, BentoFaq } from '@/data/schema';

interface Props {
	/** The `bento:` frontmatter block (proto-derived shape). */
	data: BentoDoc;
	/** Fallback FAQ source, typically `frontmatter.jsonld?.faq`. */
	faq?: BentoFaq[];
	class?: string;
}

const { data, faq = [], class: klass = '' } = Astro.props;

const {
	badge,
	title,
	accent,
	lede,
	ctas = [],
	aside,
	stats = [],
	features = [],
	related = [],
	usage,
	theme,
	features_eyebrow = 'What it gives you',
	features_heading = 'Features',
	related_eyebrow = 'Elsewhere',
	related_heading = 'Related',
	usage_eyebrow = 'Get started',
	usage_heading = 'Usage',
} = data;

const faqs = (data.faqs?.length ? data.faqs : faq) ?? [];

const styleVars = [
	theme?.hero_bg && `--bento-hero-bg: url('${theme.hero_bg}')`,
	theme?.accent && `--bento-accent: ${theme.accent}`,
	theme?.accent2 && `--bento-accent-2: ${theme.accent2}`,
	theme?.btn_fg && `--bento-btn-fg: ${theme.btn_fg}`,
	theme?.live && `--bento-live: ${theme.live}`,
]
	.filter(Boolean)
	.join('; ');

const ARROW = 'M5 12h14M13 6l6 6-6 6';
---

<div class:list={['bento-doc', klass]} style={styleVars}>
	<section
		class="bento-hero bento-section not-content"
		aria-label={`${title} ${accent}`}>
		{theme?.hero_bg && <div class="bento-hero__bg" aria-hidden="true" />}
		<div class="bento-hero__frame bento-frame">
			<div class="bento-board bento-board--hero">
				<div
					class="bento-cell bento-hero-copy bento-card bento-card--glass">
					{
						badge && (
							<span class="bento-badge bento-chip">
								<span>{badge}</span>
							</span>
						)
					}
					<h1 class="bento-title">
						{title}
						<span class="bento-title__accent">{accent}</span>
					</h1>
					{lede && <p class="bento-lede">{lede}</p>}
					{
						ctas.length > 0 && (
							<div class="bento-cta">
								{ctas.map((c) => (
									<a
										class:list={[
											'bento-btn',
											c.primary
												? 'bento-btn--primary'
												: 'bento-btn--ghost',
										]}
										href={c.href}
										target={
											c.external ? '_blank' : undefined
										}
										rel={
											c.external
												? 'noopener noreferrer'
												: undefined
										}>
										{c.label}
										{c.primary && (
											<svg
												viewBox="0 0 24 24"
												fill="none"
												stroke="currentColor"
												aria-hidden="true">
												<path
													stroke-linecap="round"
													stroke-linejoin="round"
													stroke-width="2"
													d={ARROW}
												/>
											</svg>
										)}
									</a>
								))}
							</div>
						)
					}
				</div>

				{
					aside && (
						<div class="bento-cell bento-hero-aside bento-card bento-card--glass">
							{aside.icon && (
								<span class="bento-icon-tile bento-doc__aside-icon">
									<svg
										viewBox="0 0 24 24"
										width="18"
										height="18"
										fill="none"
										stroke="currentColor"
										stroke-width="1.75"
										stroke-linecap="round"
										stroke-linejoin="round"
										aria-hidden="true">
										<path d={bentoIcon(aside.icon)} />
									</svg>
								</span>
							)}
							{aside.title && (
								<h2 class="bento-featurecard__title">
									{aside.title}
								</h2>
							)}
							{aside.body && (
								<p
									class="bento-featurecard__body"
									set:html={aside.body}
								/>
							)}
							{aside.points && aside.points.length > 0 && (
								<ul class="bento-list">
									{aside.points.map((p) => (
										<li set:html={p} />
									))}
								</ul>
							)}
						</div>
					)
				}

				{
					stats.map((s) => (
						<div class="bento-cell bento-stat bento-card bento-card--glass bento-card--interactive">
							<span class="bento-icon-tile">
								<svg
									viewBox="0 0 24 24"
									width="16"
									height="16"
									fill="none"
									stroke="currentColor"
									stroke-width="1.75"
									stroke-linecap="round"
									stroke-linejoin="round"
									aria-hidden="true">
									<path d={bentoIcon(s.icon)} />
								</svg>
							</span>
							<span class="bento-stat__value">{s.value}</span>
							<span class="bento-stat__label">{s.label}</span>
						</div>
					))
				}
			</div>

			<nav class="bento-jump" aria-label="On this page">
				{
					features.length > 0 && (
						<a class="bento-chip" href="#features">
							Features
						</a>
					)
				}
				{
					usage && (
						<a class="bento-chip" href="#usage">
							Usage
						</a>
					)
				}
				{
					faqs.length > 0 && (
						<a class="bento-chip" href="#faq">
							FAQ
						</a>
					)
				}
				{
					related.length > 0 && (
						<a class="bento-chip" href="#related">
							Related
						</a>
					)
				}
			</nav>
		</div>
	</section>

	{
		features.length > 0 && (
			<BentoShell
				id="features"
				eyebrow={features_eyebrow}
				heading={features_heading}>
				<div class="bento-board bento-board--auto-wide">
					{features.map((f) => (
						<div class="bento-cell bento-featurecard bento-card bento-card--glass bento-card--interactive">
							<span class="bento-icon-tile">
								<svg
									viewBox="0 0 24 24"
									width="18"
									height="18"
									fill="none"
									stroke="currentColor"
									stroke-width="1.75"
									stroke-linecap="round"
									stroke-linejoin="round"
									aria-hidden="true">
									<path d={bentoIcon(f.icon)} />
								</svg>
							</span>
							<h3 class="bento-featurecard__title">{f.title}</h3>
							<p
								class="bento-featurecard__body"
								set:html={f.body}
							/>
						</div>
					))}
				</div>
			</BentoShell>
		)
	}

	{
		usage && (
			<BentoShell
				id="usage"
				eyebrow={usage_eyebrow}
				heading={usage_heading}>
				<div class="bento-board bento-doc__usage">
					<div class="bento-cell bento-card bento-card--glass bento-doc__code">
						{usage.label && (
							<span class="bento-doc__code-label">
								{usage.label}
							</span>
						)}
						<Code code={usage.code} lang={usage.lang as any} />
					</div>
				</div>
			</BentoShell>
		)
	}

	<slot />

	{
		faqs.length > 0 && (
			<BentoShell id="faq" eyebrow="Questions" heading="Frequently asked">
				<div class="bento-board bento-board--auto-wide">
					{faqs.map((f) => (
						<div class="bento-cell bento-faqcard bento-card bento-card--glass bento-card--interactive">
							<h3 class="bento-faqcard__q">{f.question}</h3>
							<p class="bento-faqcard__a">{f.answer}</p>
						</div>
					))}
				</div>
			</BentoShell>
		)
	}

	{
		related.length > 0 && (
			<BentoShell
				id="related"
				eyebrow={related_eyebrow}
				heading={related_heading}>
				<div class="bento-board bento-board--cols-2">
					{related.map((r) => (
						<a
							class="bento-cell bento-linkcard bento-card bento-card--glass bento-card--interactive"
							href={r.href}
							target={r.external ? '_blank' : undefined}
							rel={
								r.external ? 'noopener noreferrer' : undefined
							}>
							<span class="bento-icon-tile">
								<svg
									viewBox="0 0 24 24"
									width="18"
									height="18"
									fill="none"
									stroke="currentColor"
									stroke-width="1.75"
									stroke-linecap="round"
									stroke-linejoin="round"
									aria-hidden="true">
									<path d={bentoIcon(r.icon)} />
								</svg>
							</span>
							<span class="bento-linkcard__title">{r.title}</span>
							<span class="bento-linkcard__copy">{r.copy}</span>
							<span class="bento-linkcard__go" aria-hidden="true">
								<svg
									viewBox="0 0 24 24"
									width="16"
									height="16"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round">
									<path d={ARROW} />
								</svg>
							</span>
						</a>
					))}
				</div>
			</BentoShell>
		)
	}

	<section class="bento-section not-content">
		<div class="bento-frame bento-band">
			<Adsense />
		</div>
	</section>
</div>

<style>
	.bento-doc :global(.bento-doc__aside-icon) {
		width: 2.25rem;
		height: 2.25rem;
		color: var(--bento-accent, var(--sl-color-accent-high));
	}
	.bento-doc :global(.bento-doc__usage) {
		grid-template-columns: 1fr;
	}
	.bento-doc :global(.bento-doc__code) {
		gap: 0.5rem;
	}
	.bento-doc :global(.bento-doc__code-label) {
		font-size: 0.6875rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3);
	}
	.bento-doc :global(.bento-doc__code pre) {
		margin: 0;
		border-radius: var(--bento-radius);
		padding: 1rem;
	}
</style>
