---
const nodes = [
	{
		key: 'idea',
		label: 'Idea',
		meta: 'it starts here',
		anchor: '.bento-hero',
		offset: 110,
		icon: 'M9 18h6M10 22h4M12 2a7 7 0 0 0-4 12.7c.6.5 1 1.2 1 2V18h6v-1.3c0-.8.4-1.5 1-2A7 7 0 0 0 12 2z',
	},
	{
		key: 'concept',
		label: 'Concept',
		meta: 'shape the stack',
		anchor: '.bento-shell:nth-of-type(1)',
		offset: 90,
		icon: 'M12 19l7-7 3 3-7 7-3-3zM18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5zM2 2l7.586 7.586M11 11a2 2 0 1 0 4 0 2 2 0 0 0-4 0z',
	},
	{
		key: 'features',
		label: 'Features',
		meta: 'ship the pieces',
		anchor: '.bento-shell:nth-of-type(2)',
		offset: 90,
		icon: 'M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z',
	},
	{
		key: 'workflow',
		label: 'Workflow',
		meta: 'automate it',
		anchor: '.bento-flow',
		offset: 0,
		center: true,
		icon: 'M3 3h8v8H3zM13 13h8v8h-8zM7 11v4a2 2 0 0 0 2 2h4',
	},
] as const;
---

<div class="meta-rail" data-meta-rail aria-hidden="true">
	<svg class="meta-rail__wire" data-meta-wire fill="none" aria-hidden="true">
		<path data-meta-path stroke-linecap="round"></path>
	</svg>
	{
		nodes.map((node) => (
			<button
				type="button"
				class="meta-rail__node"
				data-meta-node
				data-meta-anchor={node.anchor}
				data-meta-offset={node.offset}
				data-meta-center={
					'center' in node && node.center ? '' : undefined
				}
				tabindex="-1"
				title={node.label}>
				<span class="meta-rail__icon">
					<svg
						viewBox="0 0 24 24"
						width="15"
						height="15"
						fill="none"
						stroke="currentColor"
						stroke-width="1.75"
						stroke-linecap="round"
						stroke-linejoin="round">
						<path d={node.icon} />
					</svg>
				</span>
				<span class="meta-rail__text">
					<span class="meta-rail__label">{node.label}</span>
					<span class="meta-rail__meta">{node.meta}</span>
				</span>
			</button>
		))
	}
	<div class="meta-rail__arrow" data-meta-arrow>
		<svg
			viewBox="0 0 24 24"
			width="14"
			height="14"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round">
			<path d="M5 12h14M12 5l7 7-7 7"></path>
		</svg>
	</div>
</div>

<style>
	:global(.sl-markdown-content) {
		position: relative;
	}

	.meta-rail {
		display: none;
	}

	@media (min-width: 90rem) {
		.meta-rail {
			position: absolute;
			inset: 0;
			z-index: 5;
			display: block;
			pointer-events: none;
			opacity: 0;
			transition: opacity 500ms ease 150ms;
		}

		.meta-rail.is-ready {
			opacity: 1;
		}
	}

	.meta-rail__wire {
		position: absolute;
		overflow: visible;
	}

	.meta-rail__wire path {
		stroke: color-mix(
			in srgb,
			var(--sl-color-accent-high) 50%,
			transparent
		);
		stroke-width: 2;
		stroke-dasharray: 8 8;
		animation: meta-rail-dash 1.2s linear infinite;
	}

	@keyframes meta-rail-dash {
		to {
			stroke-dashoffset: -16;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.meta-rail__wire path {
			animation: none;
		}
	}

	.meta-rail__node {
		position: absolute;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 0.75rem;
		border: 1px solid
			color-mix(in srgb, var(--sl-color-white) 12%, transparent);
		border-radius: 0.625rem;
		background-color: var(--sl-color-black);
		box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
		cursor: pointer;
		pointer-events: auto;
		transform: translate(-50%, -50%);
		transition:
			border-color 220ms ease,
			box-shadow 220ms ease;
	}

	.meta-rail__node:hover {
		border-color: var(--sl-color-accent-high);
		box-shadow:
			0 8px 20px rgba(0, 0, 0, 0.3),
			0 0 16px
				color-mix(in srgb, var(--sl-color-accent-high) 30%, transparent);
	}

	.meta-rail__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 26px;
		height: 26px;
		border-radius: 0.5rem;
		color: var(--sl-color-gray-3);
		background-color: color-mix(
			in srgb,
			var(--sl-color-white) 6%,
			transparent
		);
		transition: color 220ms ease;
	}

	.meta-rail__node:hover .meta-rail__icon {
		color: var(--sl-color-accent-high);
	}

	.meta-rail__text {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.0625rem;
	}

	.meta-rail__label {
		font-size: 0.6875rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		line-height: 1.2;
		color: var(--sl-color-white);
	}

	.meta-rail__meta {
		font-size: 0.5625rem;
		line-height: 1.2;
		color: var(--sl-color-gray-4);
		white-space: nowrap;
	}

	.meta-rail__arrow {
		position: absolute;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 26px;
		height: 26px;
		border-radius: 9999px;
		color: var(--sl-color-accent-high);
		background-color: var(--sl-color-black);
		border: 1px solid
			color-mix(in srgb, var(--sl-color-accent-high) 45%, transparent);
		transform: translate(-50%, -50%);
	}
</style>

<script>
	import { onMount } from '@kbve/astro/utils/clientRouter';

	onMount(() => {
		const rail = document.querySelector<HTMLElement>('[data-meta-rail]');
		if (!rail) return;

		const wire = rail.querySelector<SVGSVGElement>('[data-meta-wire]');
		const path = rail.querySelector<SVGPathElement>('[data-meta-path]');
		const arrow = rail.querySelector<HTMLElement>('[data-meta-arrow]');
		const items = rail.querySelectorAll<HTMLElement>('[data-meta-node]');
		const flow = document.querySelector<HTMLElement>('.bento-flow');
		if (!wire || !path || !arrow || !items.length || !flow) return;

		const layout = () => {
			if (!rail.offsetParent) return;
			const railRect = rail.getBoundingClientRect();
			const shell = document.querySelector(
				'.bento-shell__inner, .bento-hero__shell',
			);
			if (!shell) return;
			const shellLeft =
				shell.getBoundingClientRect().left - railRect.left;
			const x = shellLeft / 2;

			const flowRect = flow.getBoundingClientRect();
			const flowY = flowRect.top - railRect.top + flowRect.height / 2;

			let firstY = Infinity;
			items.forEach((item) => {
				const target = document.querySelector(
					item.dataset.metaAnchor ?? '',
				);
				if (!target) {
					item.style.display = 'none';
					return;
				}
				const centered = item.dataset.metaCenter !== undefined;
				const y = centered
					? flowY
					: target.getBoundingClientRect().top -
						railRect.top +
						Number(item.dataset.metaOffset ?? 0);
				item.style.left = `${x}px`;
				item.style.top = `${y}px`;
				firstY = Math.min(firstY, y);
			});

			const endX = shellLeft - 20;
			const r = Math.min(28, Math.max(endX - x, 0));

			wire.style.left = `${x}px`;
			wire.style.top = `${firstY}px`;
			const w = Math.max(endX - x, 1);
			const h = Math.max(flowY - firstY, 1);
			wire.setAttribute('width', String(w));
			wire.setAttribute('height', String(h));
			wire.setAttribute('viewBox', `0 0 ${w} ${h}`);
			path.setAttribute(
				'd',
				`M 1 0 L 1 ${h - r} Q 1 ${h}, ${1 + r} ${h} L ${w} ${h}`,
			);

			arrow.style.left = `${shellLeft - 8}px`;
			arrow.style.top = `${flowY}px`;

			rail.classList.add('is-ready');
		};

		layout();
		const ro = new ResizeObserver(layout);
		ro.observe(document.body);

		const clicks: Array<() => void> = [];
		items.forEach((item) => {
			const onClick = () => {
				const target = document.querySelector(
					item.dataset.metaAnchor ?? '',
				);
				target?.scrollIntoView({ behavior: 'smooth', block: 'start' });
			};
			item.addEventListener('click', onClick);
			clicks.push(() => item.removeEventListener('click', onClick));
		});

		return () => {
			ro.disconnect();
			clicks.forEach((fn) => fn());
		};
	});
</script>
