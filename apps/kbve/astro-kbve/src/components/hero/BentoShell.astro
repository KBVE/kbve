---
interface Props {
	eyebrow?: string;
	heading?: string;
}

const { eyebrow, heading } = Astro.props;
---

<section class="bento-shell not-content">
	<div class="bento-shell__inner">
		{
			(eyebrow || heading) && (
				<header class="bento-shell__header">
					{eyebrow && <p class="bento-shell__eyebrow">{eyebrow}</p>}
					{heading && <h2 class="bento-shell__heading">{heading}</h2>}
				</header>
			)
		}
		<slot />
	</div>
</section>

<style>
	.bento-shell {
		--bento-hairline: color-mix(
			in srgb,
			var(--sl-color-white) 5%,
			transparent
		);
		--bento-hairline-strong: color-mix(
			in srgb,
			var(--sl-color-white) 10%,
			transparent
		);
		--bento-cell-bg: var(--sl-color-black);
		width: 100%;
		margin-block-start: 0 !important;
		background-color: var(--sl-color-black);
		border-bottom: 1px solid var(--bento-hairline);
	}

	.bento-shell__inner {
		margin-inline: auto;
		width: 100%;
		max-width: 80rem;
		border-inline: 1px solid var(--bento-hairline);
	}

	.bento-shell__header {
		padding: 3rem 1rem 2rem;
	}

	.bento-shell__eyebrow {
		margin-bottom: 0.5rem;
		font-size: 0.75rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3);
	}

	.bento-shell__heading {
		font-size: clamp(1.375rem, 3vw, 2rem);
		font-weight: 600;
		letter-spacing: -0.02em;
		line-height: 1.15;
		color: var(--sl-color-white);
		max-width: 36rem;
	}

	@media (min-width: 640px) {
		.bento-shell__header {
			padding-inline: 1.5rem;
		}
	}

	:global([data-bento-reveal='pending']) {
		opacity: 0;
		transform: translateY(14px);
	}

	:global([data-bento-reveal='in']) {
		opacity: 1;
		transform: translateY(0);
		transition:
			opacity 550ms ease,
			transform 550ms cubic-bezier(0.25, 1, 0.5, 1);
	}
</style>

<script>
	import { onMount } from '@kbve/astro/utils/clientRouter';

	onMount(() => {
		const sections = document.querySelectorAll<HTMLElement>(
			'.bento-shell, .bento-hero',
		);
		if (!sections.length) return;

		const reduced = window.matchMedia(
			'(prefers-reduced-motion: reduce)',
		).matches;

		if (reduced) {
			sections.forEach((s) => s.setAttribute('data-bento-reveal', 'in'));
			return;
		}

		sections.forEach((s) => s.setAttribute('data-bento-reveal', 'pending'));

		const io = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (!entry.isIntersecting) return;
					const el = entry.target as HTMLElement;
					el.setAttribute('data-bento-reveal', 'in');
					io.unobserve(el);
				});
			},
			{ threshold: 0.08, rootMargin: '0px 0px -5% 0px' },
		);

		sections.forEach((s) => io.observe(s));
		teardownOnLeave(io);

		function teardownOnLeave(observer: IntersectionObserver) {
			window.addEventListener('pagehide', () => observer.disconnect(), {
				once: true,
			});
		}
	});
</script>
