---
import StackLogos from './StackLogos.astro';

interface Props {
	titleLines?: string[];
	rotatingWord?: string;
	rotatingWords?: string[];
	description?: string;
	primaryCta?: { label: string; href: string };
	secondaryCta?: { label: string; href: string };
	trustLine?: string;
	metaLine?: string;
	wallpaper?: string;
	wallpaperCredit?: {
		title: string;
		artist?: string;
		meta?: string;
		href?: string;
	};
}

const {
	titleLines = ['KBVE is the best', 'way to build', 'games.'],
	rotatingWord = 'games',
	rotatingWords = ['games', 'apps', 'software', 'servers', 'worlds'],
	description = 'KBVE gives you an open-source studio for games, automation, and community infrastructure. All in one place.',
	primaryCta = {
		label: 'Join the Discord',
		href: 'https://kbve.com/discord/',
	},
	secondaryCta = { label: 'Browse Projects', href: '/projects/' },
	trustLine = 'Open source · Est. 2019',
	metaLine = 'Free forever · MIT licensed · Community driven',
	wallpaper = '1781099270897-ca214439f99e',
	wallpaperCredit = {
		title: 'Under the Wave off Kanagawa — The Great Wave',
		artist: 'Katsushika Hokusai (1760–1849)',
		meta: 'Edo period · Thirty-six Views of Mount Fuji · via Unsplash',
		href: 'https://unsplash.com',
	},
} = Astro.props;

const wallpaperUrl = `https://images.unsplash.com/photo-${wallpaper}?q=80&w=1600&auto=format&fit=crop`;

const dock = [
	{
		key: 'default',
		label: 'Home',
		icon: 'm3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2zM9 22V12h6v10',
	},
	{
		key: 'community',
		label: 'Members',
		icon: 'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75',
	},
	{
		key: 'opensource',
		label: 'Monorepo',
		icon: 'M16 18 22 12 16 6M8 6 2 12 8 18',
	},
	{
		key: 'servers',
		label: 'Servers',
		icon: 'M6 12h4m-2-2v4m7-3h.01M18 10h.01M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.545-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5z',
	},
	{
		key: 'uptime',
		label: 'Status',
		icon: 'M22 12h-4l-3 9L9 3l-3 9H2',
	},
];
---

<div class="bento-hero not-content">
	<div class="bento-hero__shell">
		<section class="bento-hero__section">
			<div class="bento-hero__glow" aria-hidden="true"></div>

			<div class="bento-hero__inner">
				<div class="bento-hero__grid">
					<div class="bento-hero__headline">
						<h1 class="bento-hero__title">
							{
								titleLines.map((line) => (
									<span class="bento-hero__title-line">
										{line.includes(rotatingWord) ? (
											<>
												{line.split(rotatingWord)[0]}
												<span
													class="bento-hero__slot"
													data-rotate={JSON.stringify(
														rotatingWords,
													)}>
													{rotatingWord}
												</span>
												{line.split(rotatingWord)[1]}
											</>
										) : (
											line
										)}
									</span>
								))
							}
						</h1>

						<div class="bento-hero__stack">
							<p class="bento-hero__stack-label">
								Built with our stack
							</p>
							<div class="bento-hero__stack-logos">
								<slot name="logos">
									<StackLogos />
								</slot>
							</div>
						</div>
					</div>

					<div class="bento-hero__side">
						<p class="bento-hero__description">
							<slot name="description">{description}</slot>
						</p>

						<div class="bento-hero__cta-tray">
							<a
								class="bento-hero__cta bento-hero__cta--primary"
								href={primaryCta.href}>
								{primaryCta.label}
							</a>
							<a
								class="bento-hero__cta bento-hero__cta--ghost"
								href={secondaryCta.href}>
								{secondaryCta.label}
							</a>
						</div>

						<div class="bento-hero__trust">
							<span class="bento-hero__trust-line">
								{trustLine}
							</span>
							<span class="bento-hero__meta-line">
								{metaLine}
							</span>
						</div>
					</div>
				</div>

				<div class="bento-hero__showcase">
					<div class="bento-hero__frame">
						<img
							class="bento-hero__wallpaper"
							src={wallpaperUrl}
							alt=""
							loading="lazy"
							decoding="async"
							draggable="false"
							aria-hidden="true"
						/>
						<div class="bento-hero__menubar">
							<span
								class="bento-hero__menubar-icon"
								aria-hidden="true">
								<svg
									viewBox="0 0 24 24"
									width="13"
									height="13"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round">
									<path
										d="M5 12.55a11 11 0 0 1 14.08 0M1.42 9a16 16 0 0 1 21.16 0M8.53 16.11a6 6 0 0 1 6.95 0M12 20h.01">
									</path>
								</svg>
							</span>
							<span
								class="bento-hero__menubar-icon"
								aria-hidden="true">
								<svg
									viewBox="0 0 24 24"
									width="13"
									height="13"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round">
									<path
										d="M4 21v-7M4 10V3M12 21v-9M12 8V3M20 21v-5M20 12V3M1 14h6M9 8h6M17 16h6">
									</path>
								</svg>
							</span>
							<button
								type="button"
								class="bento-hero__menubar-icon bento-hero__menubar-help"
								data-wallpaper-help
								aria-label="About this wallpaper"
								aria-expanded="false"
								title="About this wallpaper">
								<svg
									viewBox="0 0 24 24"
									width="13"
									height="13"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round">
									<path
										d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10zM9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3m.08 4h.01">
									</path>
								</svg>
							</button>
							<span class="bento-hero__clock" data-bento-clock>
								00:00 AM
							</span>
						</div>
						<div
							class="bento-hero__credit"
							data-wallpaper-credit
							hidden>
							<span class="bento-hero__credit-title">
								{wallpaperCredit.title}
							</span>
							{
								wallpaperCredit.artist && (
									<span class="bento-hero__credit-artist">
										{wallpaperCredit.artist}
									</span>
								)
							}
							{
								wallpaperCredit.meta && (
									<span class="bento-hero__credit-meta">
										{wallpaperCredit.meta}
									</span>
								)
							}
							{
								wallpaperCredit.href && (
									<a
										class="bento-hero__credit-link"
										href={wallpaperCredit.href}
										target="_blank"
										rel="noopener noreferrer">
										View source →
									</a>
								)
							}
						</div>
						<div class="bento-hero__window" data-bento-window>
							<div
								class="bento-hero__window-header"
								data-bento-drag>
								<div class="bento-hero__traffic">
									<span
										class="bento-hero__light bento-hero__light--close">
									</span>
									<span
										class="bento-hero__light bento-hero__light--min">
									</span>
									<span
										class="bento-hero__light bento-hero__light--max">
									</span>
								</div>
								<div class="bento-hero__window-title">
									<span class="bento-hero__window-name">
										KBVE
									</span>
									<span class="bento-hero__window-sep">
										/
									</span>
									<span
										class="bento-hero__window-crumb"
										data-bento-crumb>
										Preview
									</span>
								</div>
							</div>
							<div class="bento-hero__window-body">
								<slot name="showcase">
									<div class="bento-hero__placeholder">
										<span>showcase slot</span>
									</div>
								</slot>
							</div>
						</div>
						<nav
							class="bento-hero__dock"
							aria-label="Showcase pages">
							{
								dock.map((item) => (
									<button
										type="button"
										class="bento-hero__dock-item"
										data-dock-key={item.key}
										data-dock-label={item.label}
										data-active={
											item.key === 'default'
												? ''
												: undefined
										}
										title={item.label}
										aria-label={item.label}>
										<svg
											viewBox="0 0 24 24"
											width="18"
											height="18"
											fill="none"
											stroke="currentColor"
											stroke-width="1.75"
											stroke-linecap="round"
											stroke-linejoin="round"
											aria-hidden="true">
											<path d={item.icon} />
										</svg>
									</button>
								))
							}
						</nav>
					</div>
				</div>
			</div>
		</section>
	</div>
</div>

<style>
	.bento-hero {
		--bento-hairline: color-mix(
			in srgb,
			var(--sl-color-white) 5%,
			transparent
		);
		--bento-hairline-strong: color-mix(
			in srgb,
			var(--sl-color-white) 10%,
			transparent
		);
		position: relative;
		width: 100%;
		background-color: var(--sl-color-black);
		border-bottom: 1px solid var(--bento-hairline);
	}

	.bento-hero__shell {
		margin-inline: auto;
		width: 100%;
		max-width: 80rem;
		border-inline: 1px solid var(--bento-hairline);
	}

	.bento-hero__section {
		position: relative;
		overflow: hidden;
	}

	.bento-hero__glow {
		position: absolute;
		inset: 0;
		z-index: 0;
		opacity: 0.4;
		background: radial-gradient(
			circle at center top,
			var(--sl-color-accent-low) 0%,
			transparent 62%
		);
		pointer-events: none;
	}

	.bento-hero__inner {
		position: relative;
		z-index: 1;
		margin-inline: auto;
		max-width: 80rem;
		padding: 4rem 1rem 0;
	}

	.bento-hero__grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: 1.5rem;
		align-items: start;
	}

	.bento-hero__headline {
		min-width: 0;
	}

	.bento-hero__title {
		font-size: clamp(2rem, 6vw, 4.2rem);
		font-weight: 600;
		letter-spacing: -0.02em;
		line-height: 1.02;
		color: var(--sl-color-white);
		max-width: 40rem;
	}

	.bento-hero__title-line {
		display: block;
		white-space: nowrap;
	}

	.bento-hero__slot {
		display: inline-block;
		white-space: nowrap;
		color: var(--sl-color-accent-high);
		transition: width 320ms cubic-bezier(0.25, 1, 0.5, 1);
	}

	.bento-hero__slot :global(.bento-hero__char) {
		display: inline-block;
		transition:
			transform 320ms cubic-bezier(0.25, 1, 0.5, 1),
			opacity 320ms ease;
	}

	.bento-hero__slot :global(.bento-hero__char--out) {
		transform: translateY(-0.55em);
		opacity: 0;
	}

	.bento-hero__slot :global(.bento-hero__char--pre) {
		transform: translateY(0.55em);
		opacity: 0;
		transition: none;
	}

	@media (prefers-reduced-motion: reduce) {
		.bento-hero__slot :global(.bento-hero__char) {
			transition: none;
		}
	}

	.bento-hero__stack {
		margin-top: 1.5rem;
		max-width: 40rem;
	}

	.bento-hero__stack-label {
		margin-bottom: 0.75rem;
		font-size: 0.75rem;
		color: var(--sl-color-gray-3);
	}

	.bento-hero__stack-logos {
		display: flex;
		flex-wrap: nowrap;
		align-items: center;
		gap: 1.5rem;
	}

	.bento-hero__side {
		min-width: 0;
		max-width: 30rem;
	}

	.bento-hero__description {
		font-size: 0.9375rem;
		line-height: 1.5;
		color: var(--sl-color-gray-2);
	}

	.bento-hero__cta-tray {
		display: inline-flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.625rem;
		margin-top: 1.5rem;
		padding: 0.625rem;
		border-radius: 1rem;
		box-shadow: 0 0 0 1px var(--bento-hairline-strong);
		backdrop-filter: blur(12px);
	}

	.bento-hero__cta {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
		min-height: 2.5rem;
		padding: 0.5rem 1rem;
		border-radius: 0.5rem;
		font-size: 0.875rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		text-decoration: none;
		white-space: nowrap;
		transition:
			background-color 140ms ease,
			color 140ms ease;
	}

	.bento-hero__cta::after {
		content: '';
		position: absolute;
		top: -150%;
		right: 0;
		width: 2rem;
		height: 400%;
		background-color: var(--sl-color-white);
		opacity: 0.1;
		transform: translateX(3rem) rotate(12deg);
		transition: transform 1000ms ease;
		pointer-events: none;
	}

	.bento-hero__cta:hover::after {
		transform: translateX(-14rem) rotate(12deg);
	}

	@media (prefers-reduced-motion: reduce) {
		.bento-hero__cta::after {
			display: none;
		}
	}

	.bento-hero__cta--primary {
		background-color: var(--sl-color-accent);
		color: var(--sl-color-black);
		border: 1px solid var(--sl-color-accent-high);
	}

	.bento-hero__cta--primary:hover {
		background-color: var(--sl-color-accent-high);
	}

	.bento-hero__cta--ghost {
		background-color: transparent;
		color: var(--sl-color-gray-2);
		border: 1px solid var(--bento-hairline-strong);
	}

	.bento-hero__cta--ghost:hover {
		background-color: var(--sl-color-gray-6);
		color: var(--sl-color-white);
	}

	.bento-hero__trust {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		margin-top: 1.25rem;
	}

	.bento-hero__trust-line {
		font-size: 0.75rem;
		color: var(--sl-color-white);
	}

	.bento-hero__meta-line {
		font-size: 0.75rem;
		color: var(--sl-color-gray-3);
	}

	.bento-hero__showcase {
		margin-top: 2rem;
	}

	.bento-hero__frame {
		position: relative;
		isolation: isolate;
		overflow: hidden;
		padding: 1.25rem;
		padding-bottom: 4.5rem;
		background-color: var(--sl-color-black);
		border: 1px solid var(--bento-hairline);
	}

	.bento-hero__wallpaper {
		position: absolute;
		inset: 0;
		z-index: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0.9;
		pointer-events: none;
		user-select: none;
		-webkit-user-drag: none;
	}

	.bento-hero__frame::after {
		content: '';
		position: absolute;
		inset: 0;
		z-index: 1;
		background: linear-gradient(
			to bottom,
			color-mix(in srgb, var(--sl-color-black) 30%, transparent) 0%,
			color-mix(in srgb, var(--sl-color-black) 55%, transparent) 100%
		);
		pointer-events: none;
	}

	.bento-hero__menubar {
		position: absolute;
		top: 0.75rem;
		right: 0.875rem;
		z-index: 10;
		display: inline-flex;
		align-items: center;
		gap: 0.625rem;
		padding: 0.3125rem 0.625rem;
		border-radius: 9999px;
		background: color-mix(in srgb, var(--sl-color-black) 62%, transparent);
		border: 1px solid var(--bento-hairline-strong);
		backdrop-filter: blur(12px);
	}

	.bento-hero__menubar-icon {
		display: inline-flex;
		align-items: center;
		padding: 0;
		border: none;
		background: transparent;
		color: var(--sl-color-gray-2);
	}

	button.bento-hero__menubar-icon {
		cursor: pointer;
		transition: color 160ms ease;
	}

	button.bento-hero__menubar-icon:hover,
	button.bento-hero__menubar-icon:focus-visible {
		color: var(--sl-color-accent-high);
		outline: none;
	}

	.bento-hero__clock {
		font-size: 0.6875rem;
		font-weight: 600;
		font-variant-numeric: tabular-nums;
		letter-spacing: 0.02em;
		color: var(--sl-color-white);
	}

	.bento-hero__clock :global(.bento-hero__clock-digit) {
		display: inline-block;
		transition:
			transform 320ms cubic-bezier(0.25, 1, 0.5, 1),
			opacity 320ms ease;
	}

	.bento-hero__clock :global(.bento-hero__clock-digit--pre) {
		transform: translateY(-0.6em);
		opacity: 0;
		transition: none;
	}

	@media (prefers-reduced-motion: reduce) {
		.bento-hero__clock :global(.bento-hero__clock-digit) {
			transition: none;
		}
	}

	.bento-hero__credit[hidden] {
		display: none;
	}

	.bento-hero__credit {
		position: absolute;
		top: 2.875rem;
		right: 0.875rem;
		z-index: 11;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		max-width: 18rem;
		padding: 0.875rem 1rem;
		border-radius: 0.75rem;
		background: color-mix(in srgb, var(--sl-color-black) 82%, transparent);
		border: 1px solid var(--bento-hairline-strong);
		box-shadow: 0 14px 32px rgba(0, 0, 0, 0.45);
		backdrop-filter: blur(12px);
	}

	.bento-hero__credit-title {
		font-size: 0.75rem;
		font-weight: 600;
		line-height: 1.35;
		color: var(--sl-color-white);
	}

	.bento-hero__credit-artist {
		font-size: 0.6875rem;
		color: var(--sl-color-gray-2);
	}

	.bento-hero__credit-meta {
		font-size: 0.625rem;
		line-height: 1.4;
		color: var(--sl-color-gray-3);
	}

	.bento-hero__credit-link {
		margin-top: 0.25rem;
		font-size: 0.6875rem;
		font-weight: 600;
		color: var(--sl-color-accent-high);
		text-decoration: none;
	}

	.bento-hero__dock {
		position: absolute;
		bottom: 0.875rem;
		left: 50%;
		z-index: 10;
		display: inline-flex;
		align-items: flex-end;
		gap: 0.375rem;
		padding: 0.375rem 0.5rem;
		border-radius: 0.875rem;
		transform: translateX(-50%);
		background: color-mix(in srgb, var(--sl-color-black) 62%, transparent);
		border: 1px solid var(--bento-hairline-strong);
		box-shadow: 0 10px 24px rgba(0, 0, 0, 0.4);
		backdrop-filter: blur(12px);
	}

	.bento-hero__dock-item {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 34px;
		height: 34px;
		padding: 0;
		border: none;
		border-radius: 0.5rem;
		background: transparent;
		color: var(--sl-color-gray-2);
		cursor: pointer;
		transform-origin: bottom center;
		transition:
			transform 200ms cubic-bezier(0.25, 1, 0.5, 1),
			color 160ms ease,
			background-color 160ms ease;
	}

	@media (hover: hover) {
		.bento-hero__dock-item:hover,
		.bento-hero__dock-item:focus-visible {
			transform: scale(1.3) translateY(-3px);
			color: var(--sl-color-accent-high);
			outline: none;
		}
	}

	.bento-hero__dock-item:active {
		transform: scale(0.92);
	}

	.bento-hero__dock-item[data-active] {
		color: var(--sl-color-white);
		background-color: color-mix(
			in srgb,
			var(--sl-color-white) 10%,
			transparent
		);
	}

	.bento-hero__dock-item[data-active]::after {
		content: '';
		position: absolute;
		bottom: -0.3rem;
		left: 50%;
		width: 3px;
		height: 3px;
		border-radius: 9999px;
		transform: translateX(-50%);
		background-color: var(--sl-color-accent-high);
	}

	@media (max-width: 1023.98px) {
		.bento-hero__dock {
			bottom: 0.625rem;
			left: 0.75rem;
			right: 0.75rem;
			justify-content: space-around;
			gap: 0;
			padding: 0.5rem 0.625rem;
			border-radius: 1.375rem;
			transform: none;
		}

		.bento-hero__dock-item {
			width: 42px;
			height: 42px;
			border-radius: 0.75rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.bento-hero__dock-item,
		.bento-hero__dock-item:hover {
			transform: none;
			transition:
				color 160ms ease,
				background-color 160ms ease;
		}
	}

	.bento-hero__window {
		position: relative;
		z-index: 2;
		display: flex;
		flex-direction: column;
		height: 620px;
		overflow: hidden;
		border-radius: 10px;
		outline: 1px solid var(--bento-hairline-strong);
		outline-offset: -1px;
		background: linear-gradient(
			var(--sl-color-gray-6) 0%,
			var(--sl-color-black) 100%
		);
		box-shadow: var(--sl-shadow-lg);
	}

	.bento-hero__window-header {
		display: flex;
		flex-shrink: 0;
		align-items: center;
		gap: 0.5rem;
		min-height: 2.5rem;
		padding: 0.25rem 0.625rem;
		background-color: var(--sl-color-gray-6);
		border-bottom: 1px solid var(--bento-hairline);
	}

	.bento-hero__traffic {
		display: flex;
		align-items: center;
		gap: 0.375rem;
		padding-right: 0.25rem;
	}

	.bento-hero__light {
		width: 0.75rem;
		height: 0.75rem;
		border-radius: 9999px;
		opacity: 0.5;
	}

	.bento-hero__light--close {
		background-color: #ff5f57;
	}

	.bento-hero__light--min {
		background-color: #febc2e;
	}

	.bento-hero__light--max {
