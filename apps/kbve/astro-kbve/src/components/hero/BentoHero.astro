</style>

<script>
	import { onMount } from '@kbve/astro/utils/clientRouter';

	const STAGGER_MS = 24;
	const SWAP_MS = 340;
	const HOLD_MS = 2600;

	const renderChars = (slot: HTMLElement, word: string, pre: boolean) => {
		slot.textContent = '';
		for (let i = 0; i < word.length; i++) {
			const span = document.createElement('span');
			span.className = pre
				? 'bento-hero__char bento-hero__char--pre'
				: 'bento-hero__char';
			span.style.transitionDelay = `${i * STAGGER_MS}ms`;
			span.textContent = word[i];
			slot.appendChild(span);
		}
	};

	const setupWindow = (teardowns: Array<() => void>) => {
		const win = document.querySelector<HTMLElement>('[data-bento-window]');
		if (!win) return;

		const handle = win.querySelector<HTMLElement>('[data-bento-drag]');
		const crumb = win.querySelector<HTMLElement>('[data-bento-crumb]');
		const frame = win.parentElement;

		if (handle && frame) {
			let startX = 0;
			let startY = 0;
			let baseX = 0;
			let baseY = 0;
			let x = 0;
			let y = 0;
			let dragging = false;

			const onMove = (e: PointerEvent) => {
				if (!dragging) return;
				const pad = 12;
				const maxX = frame.clientWidth - win.offsetWidth + pad;
				const maxY = frame.clientHeight - win.offsetHeight + pad;
				x = Math.min(
					Math.max(baseX + e.clientX - startX, -pad - win.offsetLeft),
					Math.max(maxX, 0),
				);
				y = Math.min(
					Math.max(baseY + e.clientY - startY, -pad - win.offsetTop),
					Math.max(maxY, 0),
				);
				win.style.transform = `translate(${x}px, ${y}px)`;
			};

			const onUp = () => {
				dragging = false;
				handle.style.cursor = 'grab';
			};

			const onDown = (e: PointerEvent) => {
				if ((e.target as HTMLElement).closest('button')) return;
				dragging = true;
				startX = e.clientX;
				startY = e.clientY;
				baseX = x;
				baseY = y;
				handle.style.cursor = 'grabbing';
				e.preventDefault();
			};

			handle.style.cursor = 'grab';
			handle.style.touchAction = 'none';
			handle.addEventListener('pointerdown', onDown);
			window.addEventListener('pointermove', onMove);
			window.addEventListener('pointerup', onUp);
			teardowns.push(() => {
				handle.removeEventListener('pointerdown', onDown);
				window.removeEventListener('pointermove', onMove);
				window.removeEventListener('pointerup', onUp);
			});
		}

		const dockItems =
			document.querySelectorAll<HTMLButtonElement>('[data-dock-key]');

		dockItems.forEach((item) => {
			const onClick = () => {
				window.dispatchEvent(
					new CustomEvent('bento:showcase', {
						detail: {
							key: item.dataset.dockKey,
							label:
								item.dataset.dockKey === 'default'
									? 'Preview'
									: item.dataset.dockLabel,
						},
					}),
				);
			};
			item.addEventListener('click', onClick);
			teardowns.push(() => item.removeEventListener('click', onClick));
		});

		const onShowcase = (e: Event) => {
			const { key, label } = (e as CustomEvent).detail ?? {};
			if (!key) return;
			const panels = document.querySelectorAll<HTMLElement>(
				'[data-showcase-panel]',
			);
			let matched = false;
			panels.forEach((p) => {
				const active = p.dataset.showcasePanel === key;
				p.toggleAttribute('data-active', active);
				if (active) matched = true;
			});
			if (!matched) {
				panels.forEach((p) =>
					p.toggleAttribute(
						'data-active',
						p.dataset.showcasePanel === 'default',
					),
				);
			}
			dockItems.forEach((item) =>
				item.toggleAttribute(
					'data-active',
					item.dataset.dockKey === (matched ? key : 'default'),
				),
			);
			if (crumb) crumb.textContent = matched ? (label ?? key) : 'Preview';
		};

		window.addEventListener('bento:showcase', onShowcase);
		teardowns.push(() =>
			window.removeEventListener('bento:showcase', onShowcase),
		);

		const clock = document.querySelector<HTMLElement>('[data-bento-clock]');
		if (clock) {
			let current = '';
			const timeNow = () =>
				new Date().toLocaleTimeString('en-US', {
					hour: '2-digit',
					minute: '2-digit',
					hour12: true,
				});

			const spinTo = (next: string) => {
				if (next === current) return;
				current = next;
				clock.textContent = '';
				for (let i = 0; i < next.length; i++) {
					const span = document.createElement('span');
					span.className =
						'bento-hero__clock-digit bento-hero__clock-digit--pre';
					span.style.transitionDelay = `${i * 40}ms`;
					span.textContent = next[i] === ' ' ? ' ' : next[i];
					clock.appendChild(span);
				}
				requestAnimationFrame(() =>
					requestAnimationFrame(() => {
						clock
							.querySelectorAll('.bento-hero__clock-digit--pre')
							.forEach((el) =>
								el.classList.remove(
									'bento-hero__clock-digit--pre',
								),
							);
					}),
				);
			};

			spinTo(timeNow());
			const id = setInterval(() => spinTo(timeNow()), 15_000);
			teardowns.push(() => clearInterval(id));
		}

		const helpBtn = document.querySelector<HTMLButtonElement>(
			'[data-wallpaper-help]',
		);
		const credit = document.querySelector<HTMLElement>(
			'[data-wallpaper-credit]',
		);
		if (helpBtn && credit) {
			const setOpen = (open: boolean) => {
				credit.hidden = !open;
				helpBtn.setAttribute('aria-expanded', String(open));
			};
			const onToggle = (e: MouseEvent) => {
				e.stopPropagation();
				setOpen(credit.hidden);
			};
			const onOutside = (e: MouseEvent) => {
				if (credit.hidden) return;
				const t = e.target as HTMLElement;
				if (!credit.contains(t) && !helpBtn.contains(t)) setOpen(false);
			};
			const onEsc = (e: KeyboardEvent) => {
				if (e.key === 'Escape') setOpen(false);
			};
			helpBtn.addEventListener('click', onToggle);
			document.addEventListener('click', onOutside);
			document.addEventListener('keydown', onEsc);
			teardowns.push(() => {
				helpBtn.removeEventListener('click', onToggle);
				document.removeEventListener('click', onOutside);
				document.removeEventListener('keydown', onEsc);
			});
		}
	};

	onMount(() => {
		const reduced = window.matchMedia(
			'(prefers-reduced-motion: reduce)',
		).matches;
		const timers: ReturnType<typeof setInterval | typeof setTimeout>[] = [];
		const teardowns: Array<() => void> = [];

		setupWindow(teardowns);

		document
			.querySelectorAll<HTMLElement>('.bento-hero__slot[data-rotate]')
			.forEach((slot) => {
				let words: string[] = [];
				try {
					words = JSON.parse(slot.dataset.rotate ?? '[]');
				} catch {
					return;
				}
				if (words.length < 2) return;

				let index = 0;
				renderChars(slot, words[0], false);

				timers.push(
					setInterval(() => {
						index = (index + 1) % words.length;
						const next = words[index];
						if (reduced) {
							slot.textContent = next;
							return;
						}
						slot.querySelectorAll('.bento-hero__char').forEach(
							(el) => el.classList.add('bento-hero__char--out'),
						);
						timers.push(
							setTimeout(() => {
								const prevWidth = slot.offsetWidth;
								renderChars(slot, next, true);
								slot.style.width = 'auto';
								const nextWidth = slot.offsetWidth;
								slot.style.width = `${prevWidth}px`;
								void slot.offsetWidth;
								slot.style.width = `${nextWidth}px`;
								requestAnimationFrame(() =>
									requestAnimationFrame(() => {
										slot.querySelectorAll(
											'.bento-hero__char--pre',
										).forEach((el) =>
											el.classList.remove(
												'bento-hero__char--pre',
											),
										);
									}),
								);
							}, SWAP_MS),
						);
					}, HOLD_MS),
				);
			});

		return () => {
			timers.forEach((t) => clearInterval(t as number));
			teardowns.forEach((fn) => fn());
		};
	});
</script>
