		display: flex;
		align-items: center;
		justify-content: center;
		height: 100%;
		font-size: 0.8125rem;
		color: var(--sl-color-gray-4);
		background-image: repeating-linear-gradient(
			45deg,
			transparent,
			transparent 24px,
			var(--bento-hairline) 24px,
			var(--bento-hairline) 25px
		);
	}

	@media (min-width: 640px) {
		.bento-hero__inner {
			padding-inline: 1.5rem;
