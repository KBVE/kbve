---
import BentoShell from './BentoShell.astro';

interface Cell {
	title: string;
	body?: string;
	stat?: string;
	statLabel?: string;
	href?: string;
	span?: 'wide' | 'tall' | 'normal';
}

interface Props {
	eyebrow?: string;
	heading?: string;
	cells?: Cell[];
}

const {
	eyebrow = 'The KBVE stack',
	heading = 'Everything the studio runs on, in one place.',
	cells = [
		{
			title: 'Community',
			body: 'Developers, gamers, and creators across Discord, Twitch, and GitHub.',
			stat: '500+',
			statLabel: 'members',
			href: '/discord/',
			span: 'wide',
		},
		{
			title: 'Open Source',
			body: 'Monorepo with apps, packages, and game servers.',
			stat: '100+',
			statLabel: 'repos',
			href: '/projects/',
		},
		{
			title: 'Game Servers',
			body: 'Live multiplayer worlds on Agones + Kubernetes.',
			stat: '3',
			statLabel: 'live',
			href: '/arcade/',
		},
		{
			title: 'Always On',
			body: 'Dev streams, CI pipelines, and cluster telemetry around the clock.',
			stat: '24/7',
			statLabel: 'uptime',
			href: '/service/',
			span: 'wide',
		},
	],
} = Astro.props;
---

<BentoShell {eyebrow} {heading}>
	<div class="bento-board__grid">
		{
			cells.map((cell) => {
				const Tag = cell.href ? 'a' : 'div';
				return (
					<Tag
						class:list={[
							'bento-board__cell',
							cell.span === 'wide' && 'bento-board__cell--wide',
							cell.span === 'tall' && 'bento-board__cell--tall',
						]}
						href={cell.href}>
						<div
							class="bento-board__cell-glow"
							aria-hidden="true"
						/>
						{cell.stat && (
							<div class="bento-board__stat">
								<span class="bento-board__stat-num">
									{cell.stat}
								</span>
								{cell.statLabel && (
									<span class="bento-board__stat-label">
										{cell.statLabel}
									</span>
								)}
							</div>
						)}
						<h3 class="bento-board__cell-title">{cell.title}</h3>
						{cell.body && (
							<p class="bento-board__cell-body">{cell.body}</p>
						)}
					</Tag>
				);
			})
		}
	</div>
</BentoShell>

<style>
	.bento-board__grid {
		display: grid;
		grid-template-columns: repeat(1, minmax(0, 1fr));
		gap: 1px;
		background-color: var(--bento-hairline);
		border-top: 1px solid var(--bento-hairline);
	}

	.bento-board__cell {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
		overflow: hidden;
		min-height: 11rem;
		padding: 1.5rem;
		background-color: var(--bento-cell-bg);
		text-decoration: none;
	}

	.bento-board__cell-glow {
		position: absolute;
		inset: 0;
		opacity: 0;
		background: radial-gradient(
			circle at top left,
			var(--sl-color-accent-low) 0%,
			transparent 55%
		);
		transition: opacity 300ms ease;
		pointer-events: none;
	}

	a.bento-board__cell:hover .bento-board__cell-glow,
	a.bento-board__cell:focus-visible .bento-board__cell-glow {
		opacity: 0.5;
	}

	a.bento-board__cell:focus-visible {
		outline: none;
		box-shadow: inset 0 0 0 2px var(--sl-color-accent-low);
	}

	.bento-board__stat {
		display: flex;
		align-items: baseline;
		gap: 0.375rem;
		margin-bottom: auto;
		padding-bottom: 1.25rem;
	}

	.bento-board__stat-num {
		font-size: clamp(1.75rem, 3.5vw, 2.5rem);
		font-weight: 650;
		letter-spacing: -0.03em;
		line-height: 1;
		color: var(--sl-color-white);
	}

	.bento-board__stat-label {
		font-size: 0.75rem;
		color: var(--sl-color-gray-3);
	}

	.bento-board__cell-title {
		position: relative;
		font-size: 0.9375rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		color: var(--sl-color-white);
	}

	.bento-board__cell-body {
		position: relative;
		font-size: 0.8125rem;
		line-height: 1.5;
		color: var(--sl-color-gray-3);
		max-width: 28rem;
	}

	@media (min-width: 640px) {
		.bento-board__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1024px) {
		.bento-board__grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}

		.bento-board__cell--wide {
			grid-column: span 2;
		}

		.bento-board__cell--tall {
			grid-row: span 2;
		}
	}
</style>
