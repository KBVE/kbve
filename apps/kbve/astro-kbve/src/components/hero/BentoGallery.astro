---
import BentoShell from './BentoShell.astro';

interface GalleryItem {
	title: string;
	caption?: string;
	src?: string;
	alt?: string;
	href?: string;
	span?: 'wide' | 'tall' | 'normal';
}

interface Props {
	eyebrow?: string;
	heading?: string;
	items?: GalleryItem[];
}

const {
	eyebrow = 'From the studio',
	heading = 'Worlds, tools, and experiments we ship.',
	items = [
		{
			title: 'Rent Earth',
			caption: 'Unreal Engine multiplayer world',
			src: '/assets/images/gameplay/rentearth.webp',
			alt: 'Rent Earth gameplay screenshot',
			href: '/project/unreal-rentearth/',
			span: 'wide',
		},
		{
			title: 'CryptoThrone',
			caption: 'Isometric browser ARPG',
			href: '/project/cryptothrone/',
		},
		{
			title: 'Rareicon',
			caption: 'Unity DOTS bullet-hell roguelite',
			href: '/project/rareicon/',
		},
		{
			title: 'The Arcade',
			caption: 'Play everything in the browser',
			href: '/arcade/',
			span: 'wide',
		},
	],
} = Astro.props;

const unitsLg = items.reduce((n, i) => n + (i.span === 'wide' ? 2 : 1), 0);
const fillLg = (3 - (unitsLg % 3)) % 3;
const fillMd = (2 - (items.length % 2)) % 2;
---

<BentoShell {eyebrow} {heading}>
	<div class="bento-gallery">
		{
			items.map((item) => {
				const Tag = item.href ? 'a' : 'div';
				return (
					<Tag
						class:list={[
							'bento-gallery__tile',
							item.span === 'wide' && 'bento-gallery__tile--wide',
							item.span === 'tall' && 'bento-gallery__tile--tall',
						]}
						href={item.href}>
						{item.src ? (
							<img
								class="bento-gallery__img"
								src={item.src}
								alt={item.alt ?? item.title}
								loading="lazy"
								decoding="async"
							/>
						) : (
							<div
								class="bento-gallery__placeholder"
								aria-hidden="true"
							/>
						)}
						<div class="bento-gallery__scrim" aria-hidden="true" />
						<div class="bento-gallery__caption">
							<span class="bento-gallery__title">
								{item.title}
							</span>
							{item.caption && (
								<span class="bento-gallery__sub">
									{item.caption}
								</span>
							)}
						</div>
					</Tag>
				);
			})
		}
		{
			Array.from({ length: fillLg }).map(() => (
				<div
					class="bento-gallery__tile bento-gallery__tile--filler bento-gallery__tile--filler-lg"
					aria-hidden="true">
					<div class="bento-gallery__placeholder" />
					<span class="bento-gallery__filler-label">
						More in the works
					</span>
				</div>
			))
		}
		{
			Array.from({ length: fillMd }).map(() => (
				<div
					class="bento-gallery__tile bento-gallery__tile--filler bento-gallery__tile--filler-md"
					aria-hidden="true">
					<div class="bento-gallery__placeholder" />
					<span class="bento-gallery__filler-label">
						More in the works
					</span>
				</div>
			))
		}
	</div>
</BentoShell>

<style>
	.bento-gallery {
		display: grid;
		grid-template-columns: repeat(1, minmax(0, 1fr));
		grid-auto-flow: dense;
		grid-auto-rows: clamp(200px, 26vw, 300px);
		gap: 1px;
		background-color: var(--bento-hairline);
		border-top: 1px solid var(--bento-hairline);
	}

	.bento-gallery__tile--filler {
		display: none;
		align-items: center;
		justify-content: center;
	}

	.bento-gallery__filler-label {
		position: relative;
		font-size: 0.75rem;
		letter-spacing: 0.04em;
		color: var(--sl-color-gray-4);
	}

	@media (min-width: 640px) and (max-width: 1023.98px) {
		.bento-gallery__tile--filler-md {
			display: flex;
		}
	}

	@media (min-width: 1024px) {
		.bento-gallery__tile--filler-lg {
			display: flex;
		}
	}

	.bento-gallery__tile {
		position: relative;
		display: block;
		overflow: hidden;
		height: 100%;
		background-color: var(--bento-cell-bg);
		text-decoration: none;
	}

	.bento-gallery__img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		transform: scale(1);
		transition:
			transform 600ms cubic-bezier(0.25, 1, 0.5, 1),
			opacity 300ms ease;
		opacity: 0.85;
	}

	a.bento-gallery__tile:hover .bento-gallery__img,
	a.bento-gallery__tile:focus-visible .bento-gallery__img {
		transform: scale(1.04);
		opacity: 1;
	}

	.bento-gallery__placeholder {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(
				circle at 20% 15%,
				var(--sl-color-accent-low) 0%,
				transparent 45%
			),
			repeating-linear-gradient(
				45deg,
				transparent,
				transparent 24px,
				var(--bento-hairline) 24px,
				var(--bento-hairline) 25px
			);
		opacity: 0.6;
		transition: opacity 300ms ease;
	}

	a.bento-gallery__tile:hover .bento-gallery__placeholder,
	a.bento-gallery__tile:focus-visible .bento-gallery__placeholder {
		opacity: 1;
	}

	.bento-gallery__scrim {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			to top,
			color-mix(in srgb, var(--sl-color-black) 85%, transparent) 0%,
			transparent 45%
		);
		pointer-events: none;
	}

	.bento-gallery__caption {
		position: absolute;
		inset-inline: 0;
		bottom: 0;
		display: flex;
		flex-direction: column;
		gap: 0.125rem;
		padding: 1rem 1.25rem;
	}

	.bento-gallery__title {
		font-size: 0.9375rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		color: var(--sl-color-white);
		text-shadow:
			0 1px 2px rgba(0, 0, 0, 0.6),
			0 2px 8px rgba(0, 0, 0, 0.45);
	}

	.bento-gallery__sub {
		font-size: 0.75rem;
		line-height: 1.4;
		color: var(--sl-color-gray-2);
		text-shadow:
			0 1px 2px rgba(0, 0, 0, 0.6),
			0 2px 6px rgba(0, 0, 0, 0.4);
	}

	a.bento-gallery__tile:focus-visible {
		outline: none;
		box-shadow: inset 0 0 0 2px var(--sl-color-accent-low);
	}

	@media (min-width: 640px) {
		.bento-gallery {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1024px) {
		.bento-gallery {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}

		.bento-gallery__tile--wide {
			grid-column: span 2;
		}

		.bento-gallery__tile--tall {
			grid-row: span 2;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.bento-gallery__img {
			transition: opacity 1ms linear;
		}

		a.bento-gallery__tile:hover .bento-gallery__img {
			transform: none;
		}
	}
</style>
