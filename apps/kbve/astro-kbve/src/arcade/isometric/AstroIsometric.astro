---

---

<div class="not-content w-full h-full">
	<div
		id="isometric-game-container"
		class="rounded-lg overflow-hidden border-2 border-gray-700 shadow-xl relative bg-[#1a1a26]"
		style="width: 100%; aspect-ratio: 16/9;">
		<canvas
			id="bevy-canvas"
			style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 0;">
		</canvas>
		<div
			id="root"
			style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; pointer-events: none;">
		</div>
	</div>
	<link rel="stylesheet" href="/isometric/assets/index.css" />
	<script type="module" src="/isometric/assets/index.js"></script>
</div>

<style>
	#isometric-game-container {
		container-type: inline-size;
	}

	@container (max-width: 600px) {
		#isometric-game-container {
			aspect-ratio: 4/3;
		}
	}
</style>
