---
import ReactTowerDefenseApp from './ReactTowerDefenseApp';
import TdHud from './TdHud';
---

<div class="not-content w-full h-full">
	<div
		id="towerdefense-game-container"
		class="rounded-lg overflow-hidden border-2 border-gray-700 shadow-xl focus:outline-none relative bg-[#0d1117]"
		style="width: 100%; aspect-ratio: 16/9;"
		tabindex="0">
		<div id="towerdefense-game-inner" class="w-full h-full">
			<ReactTowerDefenseApp client:only="react" />
		</div>
		<div class="td-hud-mount">
			<TdHud client:only="react" />
		</div>
	</div>
	<p class="text-xs text-gray-400 mt-2 text-center">
		Pick a build (<kbd>1</kbd>–<kbd>9</kbd>, <kbd>0</kbd>), click an empty
		tile to place. Click any existing tower to open its upgrade panel
		(Radar, Attack, Speed, Armor). Generators feed the global grid;
		batteries store surplus. Repair stations dispatch drones to fix damaged
		buildings. Brutes (purple) stop to chew nearby builds — runners and
		scouts speed past. Artillery hits anywhere on the map but fires slowly.
		Press <kbd>N</kbd>
		for a fresh map · <kbd>R</kbd> after game over.
	</p>
</div>

<style>
	#towerdefense-game-container {
		container-type: inline-size;
		touch-action: none;
		-webkit-user-select: none;
		user-select: none;
	}
	@container (max-width: 600px) {
		#towerdefense-game-container {
			aspect-ratio: 4/3;
		}
	}

	.td-hud-mount {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 5;
		color: #f7fafc;
		font-family:
			ui-sans-serif,
			system-ui,
			-apple-system,
			'Segoe UI',
			sans-serif;
	}

	.td-hud-root {
		position: absolute;
		inset: 0;
	}

	.td-hud-bar {
		position: absolute;
		top: 8px;
		left: 8px;
		right: 8px;
		display: flex;
		justify-content: space-between;
		align-items: stretch;
		gap: 10px;
		padding: 8px 12px;
		background: linear-gradient(
			180deg,
			rgba(17, 24, 39, 0.94) 0%,
			rgba(13, 17, 23, 0.92) 100%
		);
		border: 1px solid rgba(251, 211, 141, 0.22);
		border-radius: 10px;
		box-shadow:
			0 6px 24px rgba(0, 0, 0, 0.45),
			0 1px 0 rgba(255, 255, 255, 0.04) inset;
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		pointer-events: auto;
	}

	.td-hud-left {
		display: flex;
		gap: 8px;
		flex-wrap: wrap;
		align-items: stretch;
	}

	.td-hud-right {
		display: flex;
		align-items: stretch;
	}

	.td-hud-stat {
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: 6px 12px;
		min-width: 78px;
		border-radius: 7px;
		background: linear-gradient(
			180deg,
			rgba(31, 41, 55, 0.6) 0%,
			rgba(17, 24, 39, 0.55) 100%
		);
		border: 1px solid rgba(74, 85, 104, 0.45);
		border-left: 3px solid var(--td-accent, #fbd38d);
		box-shadow:
			0 0 0 1px rgba(0, 0, 0, 0.35),
			0 0 12px -2px
				color-mix(in srgb, var(--td-accent, #fbd38d) 18%, transparent);
		transition: border-color 120ms ease;
	}

	.td-hud-stat-wide {
		min-width: 110px;
	}

	.td-hud-stat-label {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		font-size: 10px;
		font-weight: 600;
		color: #cbd5e0;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		line-height: 1;
	}

	.td-hud-stat-icon {
		color: var(--td-accent, #fbd38d);
		font-size: 11px;
		line-height: 1;
		opacity: 0.95;
		text-shadow: 0 0 6px
			color-mix(in srgb, var(--td-accent, #fbd38d) 50%, transparent);
	}

	.td-hud-stat-value {
		font-family:
			ui-monospace, SFMono-Regular, Menlo, 'JetBrains Mono', monospace;
		font-size: 22px;
		font-weight: 800;
		line-height: 1;
		margin-top: 3px;
		color: var(--td-accent, #f7fafc);
		text-shadow:
			0 0 10px
				color-mix(in srgb, var(--td-accent, #fbd38d) 35%, transparent),
			0 1px 0 rgba(0, 0, 0, 0.6);
		letter-spacing: -0.02em;
	}

	.td-hud-stat-bar {
		margin-top: 5px;
		height: 4px;
		border-radius: 2px;
		background: rgba(255, 255, 255, 0.06);
		overflow: hidden;
	}

	.td-hud-stat-bar-fill {
		height: 100%;
		background: var(--td-accent, #fbd38d);
		box-shadow: 0 0 8px var(--td-accent, #fbd38d);
		transition:
			width 200ms ease,
			background 120ms ease;
	}

	.td-hud-timer-slot {
		display: flex;
		align-items: stretch;
		gap: 8px;
	}

	.td-hud-skip-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0 14px;
		min-width: 80px;
		font-family: inherit;
		font-size: 13px;
		font-weight: 700;
		letter-spacing: 0.04em;
		color: #1a202c;
		background: linear-gradient(180deg, #fbd38d 0%, #f6ad55 100%);
		border: none;
		border-radius: 7px;
		cursor: pointer;
		box-shadow:
			0 0 0 1px rgba(0, 0, 0, 0.3),
			0 4px 12px rgba(251, 211, 141, 0.35),
			0 0 0 1px rgba(255, 255, 255, 0.18) inset;
		transition:
			transform 90ms ease,
			box-shadow 120ms ease;
		pointer-events: auto;
	}

	.td-hud-skip-btn:hover {
		transform: translateY(-1px);
		box-shadow:
			0 0 0 1px rgba(0, 0, 0, 0.3),
			0 6px 18px rgba(251, 211, 141, 0.55),
			0 0 0 1px rgba(255, 255, 255, 0.25) inset;
	}

	.td-hud-skip-btn:active {
		transform: translateY(0);
	}

	.td-hud-overlay {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		background: radial-gradient(
			ellipse at center,
			rgba(0, 0, 0, 0.55) 0%,
			rgba(0, 0, 0, 0.85) 100%
		);
		backdrop-filter: blur(6px);
		-webkit-backdrop-filter: blur(6px);
		pointer-events: auto;
		z-index: 10;
	}

	.td-hud-overlay-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 14px;
		padding: 32px 48px 28px;
		background: linear-gradient(
			180deg,
			rgba(17, 24, 39, 0.96) 0%,
			rgba(10, 12, 18, 0.96) 100%
		);
		border: 1px solid var(--td-accent, #fbd38d);
		border-radius: 16px;
		box-shadow:
			0 24px 60px rgba(0, 0, 0, 0.6),
			0 0 60px -10px var(--td-accent, #fbd38d),
			0 1px 0 rgba(255, 255, 255, 0.06) inset;
		min-width: 320px;
	}

	.td-hud-overlay-eyebrow {
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.24em;
		text-transform: uppercase;
		color: #a0aec0;
	}

	.td-hud-overlay-text {
		font-family:
			ui-monospace, SFMono-Regular, Menlo, 'JetBrains Mono', monospace;
		font-size: 48px;
		font-weight: 800;
		letter-spacing: -0.02em;
		line-height: 1;
		color: var(--td-accent, #f7fafc);
		text-shadow:
			0 0 24px
				color-mix(in srgb, var(--td-accent, #fbd38d) 55%, transparent),
			0 2px 0 rgba(0, 0, 0, 0.6);
	}

	.td-hud-overlay-sub {
		font-size: 13px;
		color: #cbd5e0;
		margin-bottom: 4px;
	}

	.td-hud-restart-btn {
		padding: 12px 36px;
		font-family: inherit;
		font-size: 16px;
		font-weight: 700;
		letter-spacing: 0.06em;
		color: #1a202c;
		background: linear-gradient(180deg, #fbd38d 0%, #ed8936 100%);
		border: none;
		border-radius: 8px;
		cursor: pointer;
		box-shadow:
			0 0 0 1px rgba(0, 0, 0, 0.4),
			0 8px 20px rgba(251, 211, 141, 0.45),
			0 0 0 1px rgba(255, 255, 255, 0.22) inset;
		transition:
			transform 90ms ease,
			box-shadow 120ms ease;
	}

	.td-hud-restart-btn:hover {
		transform: translateY(-1px);
		box-shadow:
			0 0 0 1px rgba(0, 0, 0, 0.4),
			0 10px 28px rgba(251, 211, 141, 0.6),
			0 0 0 1px rgba(255, 255, 255, 0.28) inset;
	}

	.td-hud-restart-btn:active {
		transform: translateY(0);
	}

	.td-hud-overlay-hint {
		font-size: 11px;
		color: #718096;
		letter-spacing: 0.06em;
	}
</style>
