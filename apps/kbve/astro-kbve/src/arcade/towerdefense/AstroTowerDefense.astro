---
import ReactTowerDefenseApp from './ReactTowerDefenseApp';
import TdHud from './TdHud';
---

<div class="not-content w-full h-full">
	<div
		id="towerdefense-game-container"
		class="rounded-lg overflow-hidden border-2 border-gray-700 shadow-xl focus:outline-none relative bg-[#0d1117]"
		style="width: 100%; aspect-ratio: 16/9;"
		tabindex="0">
		<div id="towerdefense-game-inner" class="w-full h-full">
			<ReactTowerDefenseApp client:only="react" />
		</div>
		<div class="td-hud-mount">
			<TdHud client:only="react" />
		</div>
	</div>
	<p class="text-xs text-gray-400 mt-2 text-center">
		Pick a build (<kbd>1</kbd>–<kbd>9</kbd>, <kbd>0</kbd>), click an empty
		tile to place. Click any existing tower to open its upgrade panel
		(Radar, Attack, Speed, Armor). Generators feed the global grid;
		batteries store surplus. Repair stations dispatch drones to fix damaged
		buildings. Brutes (purple) stop to chew nearby builds — runners and
		scouts speed past. Artillery hits anywhere on the map but fires slowly.
		Press <kbd>N</kbd>
		for a fresh map · <kbd>R</kbd> after game over.
	</p>
</div>

<style is:global>
	#towerdefense-game-container {
		container-type: inline-size;
		touch-action: none;
		-webkit-user-select: none;
		user-select: none;
	}
	@container (max-width: 600px) {
		#towerdefense-game-container {
			aspect-ratio: 4/3;
		}
	}

	.td-hud-mount {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 5;
		color: #e2e8f0;
		font-family:
			ui-sans-serif,
			system-ui,
			-apple-system,
			'Segoe UI',
			sans-serif;
		font-feature-settings: 'tnum' 1;
	}

	.td-root {
		position: absolute;
		inset: 0;
	}

	.td-bar {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		display: flex;
		align-items: center;
		gap: 12px;
		height: 36px;
		padding: 0 14px;
		overflow: hidden;
		flex-wrap: nowrap;
		background: rgba(11, 14, 20, 0.72);
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
		backdrop-filter: blur(10px) saturate(140%);
		-webkit-backdrop-filter: blur(10px) saturate(140%);
		pointer-events: auto;
	}

	.td-group {
		display: flex;
		align-items: center;
		gap: 8px;
	}

	.td-group-buffs:empty {
		display: none;
	}

	.td-divider {
		width: 1px;
		height: 16px;
		background: rgba(255, 255, 255, 0.1);
		flex: 0 0 auto;
	}

	.td-spacer {
		flex: 1;
	}

	.td-chip {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		padding: 0;
		color: #e2e8f0;
		line-height: 1;
		white-space: nowrap;
	}

	.td-chip-svg {
		flex: 0 0 auto;
		color: #94a3b8;
	}

	.td-chip-label {
		font-size: 10px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #94a3b8;
	}

	.td-chip-value {
		font-variant-numeric: tabular-nums;
		font-size: 14px;
		font-weight: 700;
		letter-spacing: -0.01em;
	}

	.td-chip-gold .td-chip-svg,
	.td-chip-gold .td-chip-value {
		color: #fbd38d;
	}

	.td-chip-danger .td-chip-svg,
	.td-chip-danger .td-chip-value {
		color: #fc8181;
	}

	.td-chip-good .td-chip-svg,
	.td-chip-good .td-chip-value {
		color: #9ae6b4;
	}

	.td-chip-battery .td-chip-svg,
	.td-chip-battery .td-chip-value {
		color: #f6e05e;
	}

	.td-timer {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		color: #e2e8f0;
		line-height: 1;
	}

	.td-speed {
		display: inline-flex;
		align-items: center;
		gap: 3px;
		padding: 2px;
		border-radius: 6px;
		background: rgba(255, 255, 255, 0.04);
	}

	.td-speed-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 26px;
		padding: 3px 7px;
		font-family: inherit;
		font-size: 11px;
		font-weight: 700;
		color: #94a3b8;
		background: transparent;
		border: none;
		border-radius: 4px;
		cursor: pointer;
		transition:
			background 100ms ease,
			color 100ms ease;
		pointer-events: auto;
	}

	.td-speed-btn:hover {
		color: #e2e8f0;
	}

	.td-speed-btn-active {
		color: #0b0e14;
		background: #fbd38d;
	}

	.td-speed-btn-active:hover {
		color: #0b0e14;
	}

	.td-skip {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		margin-left: 4px;
		padding: 3px 10px;
		font-family: inherit;
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #0b0e14;
		background: #fbd38d;
		border: none;
		border-radius: 999px;
		cursor: pointer;
		transition:
			background 120ms ease,
			transform 90ms ease;
		pointer-events: auto;
	}

	.td-skip:hover {
		background: #f6ad55;
	}

	.td-skip:active {
		transform: scale(0.97);
	}

	.td-skip-arrow {
		font-size: 12px;
	}

	.td-over {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(8, 10, 14, 0.7);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		pointer-events: auto;
		z-index: 10;
	}

	.td-over-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 10px;
		padding: 36px 56px 28px;
		background: rgba(15, 19, 26, 0.95);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-top: 2px solid var(--td-accent, #fbd38d);
		border-radius: 14px;
		box-shadow:
			0 30px 80px rgba(0, 0, 0, 0.55),
			0 1px 0 rgba(255, 255, 255, 0.04) inset;
		min-width: 320px;
	}

	.td-over-eyebrow {
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.28em;
		text-transform: uppercase;
		color: #94a3b8;
	}

	.td-over-title {
		font-size: 44px;
		font-weight: 800;
		letter-spacing: 0.04em;
		line-height: 1;
		color: var(--td-accent, #e2e8f0);
		margin-top: 2px;
	}

	.td-over-sub {
		font-size: 13px;
		color: #cbd5e0;
		margin-bottom: 6px;
	}

	.td-over-record {
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 0.06em;
		color: #fbd38d;
		text-transform: uppercase;
		margin-bottom: 6px;
	}

	.td-over-record-dim {
		font-size: 11px;
		color: #64748b;
		letter-spacing: 0.06em;
		margin-bottom: 6px;
	}

	.td-over-restart {
		padding: 10px 30px;
		font-family: inherit;
		font-size: 14px;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #0b0e14;
		background: var(--td-accent, #fbd38d);
		border: none;
		border-radius: 999px;
		cursor: pointer;
		transition:
			filter 120ms ease,
			transform 90ms ease;
	}

	.td-over-restart:hover {
		filter: brightness(1.08);
	}

	.td-over-restart:active {
		transform: scale(0.97);
	}

	.td-over-hint {
		font-size: 11px;
		color: #64748b;
		letter-spacing: 0.06em;
	}

	.td-cards {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 12px;
		overflow: auto;
		background: radial-gradient(
			ellipse at center,
			rgba(8, 10, 14, 0.55) 0%,
			rgba(8, 10, 14, 0.85) 100%
		);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		pointer-events: auto;
		z-index: 9;
		animation: td-cards-in 220ms ease-out;
	}

	@keyframes td-cards-in {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}

	.td-cards-panel {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: clamp(8px, 1.5vh, 16px);
		padding: clamp(12px, 2.5vh, 24px) clamp(14px, 3vw, 32px)
			clamp(10px, 2.2vh, 22px);
		background: rgba(15, 19, 26, 0.96);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-top: 2px solid #fbd38d;
		border-radius: 16px;
		box-shadow: 0 30px 80px rgba(0, 0, 0, 0.55);
		width: min(560px, 96%);
		max-height: 100%;
		overflow: auto;
	}

	.td-cards-eyebrow {
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.28em;
		text-transform: uppercase;
		color: #94a3b8;
	}

	.td-cards-title {
		font-size: clamp(16px, 2.6vh, 24px);
		font-weight: 800;
		letter-spacing: -0.01em;
		color: #f7fafc;
		margin-top: -8px;
	}

	.td-cards-row {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: clamp(8px, 1.4vw, 14px);
		width: 100%;
	}

	.td-card {
		flex: 1 1 140px;
		min-width: 0;
		max-width: 200px;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: clamp(6px, 1.2vh, 10px);
		padding: clamp(12px, 2vh, 20px) clamp(10px, 1.5vw, 14px)
			clamp(10px, 1.8vh, 18px);
		background: linear-gradient(
			180deg,
			rgba(31, 41, 55, 0.85) 0%,
			rgba(15, 23, 42, 0.95) 100%
		);
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-top: 3px solid var(--card-accent, #fbd38d);
		border-radius: 12px;
		color: #e2e8f0;
		font-family: inherit;
		cursor: pointer;
		transition:
			transform 120ms ease,
			border-color 120ms ease,
			box-shadow 140ms ease,
			background 140ms ease;
		box-shadow:
			0 8px 24px rgba(0, 0, 0, 0.35),
			0 1px 0 rgba(255, 255, 255, 0.04) inset;
	}

	.td-card:hover {
		transform: translateY(-3px);
		border-color: rgba(255, 255, 255, 0.18);
		box-shadow:
			0 14px 30px rgba(0, 0, 0, 0.5),
			0 0 0 1px var(--card-accent, #fbd38d) inset,
			0 0 28px -8px var(--card-accent, #fbd38d);
	}

	.td-card:active {
		transform: translateY(-1px);
	}

	.td-card-mark {
		width: clamp(28px, 4.5vh, 42px);
		height: clamp(28px, 4.5vh, 42px);
		border-radius: 50%;
		background:
			radial-gradient(
				circle at 30% 30%,
				rgba(255, 255, 255, 0.4) 0%,
				transparent 60%
			),
			var(--card-accent, #fbd38d);
		box-shadow:
			0 0 24px -4px var(--card-accent, #fbd38d),
			0 2px 6px rgba(0, 0, 0, 0.45);
	}

	.td-card-name {
		font-size: 15px;
		font-weight: 700;
		letter-spacing: 0.02em;
		color: #f7fafc;
		text-align: center;
	}

	.td-card-desc {
		font-size: 11px;
		font-weight: 500;
		line-height: 1.4;
		color: #cbd5e0;
		text-align: center;
		max-width: 18ch;
	}

	.td-cards-skip {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		margin-top: 2px;
		padding: 6px 14px;
		font-family: inherit;
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: #94a3b8;
		background: transparent;
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: 999px;
		cursor: pointer;
		transition:
			color 120ms ease,
			border-color 120ms ease;
	}

	.td-cards-skip:hover {
		color: #e2e8f0;
		border-color: rgba(255, 255, 255, 0.28);
	}

	.td-inv-btn {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 4px 10px;
		height: 26px;
		background: rgba(15, 19, 26, 0.85);
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: 999px;
		font-family: inherit;
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.14em;
		color: #cbd5e0;
		cursor: pointer;
		pointer-events: auto;
		transition:
			color 120ms ease,
			border-color 120ms ease,
			background 120ms ease;
	}

	.td-inv-btn:hover {
		color: #f7fafc;
		border-color: rgba(251, 211, 141, 0.55);
	}

	.td-inv-btn-open {
		background: rgba(251, 211, 141, 0.18);
		border-color: rgba(251, 211, 141, 0.7);
		color: #fbd38d;
	}

	.td-inv-btn-count {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 18px;
		padding: 0 4px;
		height: 16px;
		font-size: 10px;
		font-weight: 800;
		letter-spacing: 0;
		color: #0f1620;
		background: #fbd38d;
		border-radius: 999px;
	}

	.td-inv {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 12px;
		background: rgba(8, 10, 14, 0.55);
		backdrop-filter: blur(4px);
		-webkit-backdrop-filter: blur(4px);
		pointer-events: auto;
		z-index: 8;
		animation: td-cards-in 180ms ease-out;
	}

	.td-inv-panel {
		display: flex;
		flex-direction: column;
		gap: 12px;
		padding: 16px 18px;
		width: min(440px, 92%);
		max-height: 80%;
		overflow: auto;
		background: rgba(15, 19, 26, 0.96);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-top: 2px solid #fbd38d;
		border-radius: 14px;
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.55);
	}

	.td-inv-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
	}

	.td-inv-title {
		font-size: 14px;
		font-weight: 800;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: #f7fafc;
	}

	.td-inv-close {
		width: 24px;
		height: 24px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		background: transparent;
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: 999px;
		color: #a0aec0;
		font-family: inherit;
		cursor: pointer;
	}

	.td-inv-close:hover {
		color: #f7fafc;
		border-color: rgba(255, 255, 255, 0.28);
	}

	.td-inv-empty {
		padding: 18px 8px;
		text-align: center;
		font-size: 11px;
		color: #94a3b8;
	}

	.td-inv-list {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.td-inv-item {
		display: flex;
		align-items: center;
		gap: 12px;
		padding: 10px 12px;
		background: linear-gradient(
			180deg,
			rgba(31, 41, 55, 0.85) 0%,
			rgba(15, 23, 42, 0.95) 100%
		);
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-left: 3px solid var(--card-accent, #fbd38d);
		border-radius: 10px;
		color: #e2e8f0;
		font-family: inherit;
		text-align: left;
		cursor: pointer;
		transition:
			border-color 120ms ease,
			transform 120ms ease,
			background 140ms ease;
	}

	.td-inv-item:hover {
		border-color: rgba(255, 255, 255, 0.2);
		transform: translateX(2px);
	}

	.td-inv-item-mark {
		width: 24px;
		height: 24px;
		border-radius: 50%;
		flex: 0 0 auto;
		background:
			radial-gradient(
				circle at 30% 30%,
				rgba(255, 255, 255, 0.4) 0%,
				transparent 60%
			),
			var(--card-accent, #fbd38d);
		box-shadow: 0 0 14px -3px var(--card-accent, #fbd38d);
	}

	.td-inv-item-body {
		flex: 1 1 auto;
		display: flex;
		flex-direction: column;
		gap: 2px;
		min-width: 0;
	}

	.td-inv-item-name {
		font-size: 12px;
		font-weight: 700;
		color: #f7fafc;
	}

	.td-inv-item-desc {
		font-size: 10px;
		color: #cbd5e0;
		line-height: 1.4;
	}

	.td-inv-item-charges {
		flex: 0 0 auto;
		font-size: 11px;
		font-weight: 700;
		color: #fbd38d;
	}

	.td-target-banner {
		position: absolute;
		top: 44px;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		align-items: center;
		gap: 10px;
		padding: 6px 10px 6px 14px;
		background: rgba(183, 148, 244, 0.18);
		border: 1px solid rgba(183, 148, 244, 0.7);
		border-radius: 999px;
		color: #f7fafc;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.06em;
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.45);
		pointer-events: auto;
		z-index: 6;
		animation: td-cards-in 180ms ease-out;
	}

	.td-target-banner-label {
		color: #d6bcfa;
		text-transform: uppercase;
		letter-spacing: 0.16em;
	}

	.td-target-banner-hint {
		color: #cbd5e0;
		font-weight: 500;
		letter-spacing: 0.04em;
	}

	.td-target-banner-close {
		width: 22px;
		height: 22px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		background: transparent;
		border: 1px solid rgba(255, 255, 255, 0.18);
		border-radius: 999px;
		color: #cbd5e0;
		font-family: inherit;
		cursor: pointer;
	}

	.td-target-banner-close:hover {
		color: #f7fafc;
		border-color: rgba(255, 255, 255, 0.35);
	}

	.td-tooltip {
		position: absolute;
		min-width: 180px;
		padding: 8px 10px;
		background: rgba(8, 10, 14, 0.94);
		border: 1px solid rgba(255, 255, 255, 0.18);
		border-left: 3px solid #fc8181;
		border-radius: 8px;
		font-family: ui-monospace, monospace;
		font-size: 10px;
		color: #e2e8f0;
		pointer-events: none;
		z-index: 12;
		box-shadow: 0 10px 28px rgba(0, 0, 0, 0.55);
	}

	.td-tooltip-head {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 8px;
		margin-bottom: 4px;
	}

	.td-tooltip-name {
		font-size: 11px;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: #fc8181;
	}

	.td-tooltip-eid {
		font-size: 9px;
		color: #94a3b8;
	}

	.td-tooltip-row {
		display: flex;
		justify-content: space-between;
		gap: 12px;
		padding: 1px 0;
	}

	.td-tooltip-row span:first-child {
		color: #94a3b8;
	}

	.td-tooltip-status {
		margin-top: 6px;
		text-align: center;
		font-size: 10px;
		font-weight: 800;
		letter-spacing: 0.18em;
		padding: 3px 0;
		border-radius: 4px;
	}

	.td-tooltip-status-active {
		background: rgba(72, 187, 120, 0.18);
		color: #68d391;
	}

	.td-tooltip-status-immobile {
		background: rgba(246, 173, 85, 0.18);
		color: #f6ad55;
	}

	.td-tooltip-status-dead {
		background: rgba(252, 129, 129, 0.2);
		color: #fc8181;
	}

	.td-palette {
		position: absolute;
		left: 8px;
