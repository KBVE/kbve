---
import ReactSolitaireApp from './ReactSolitaireApp';
---

<div class="not-content solitaire-stage">
	<div
		class="solitaire-frame rounded-lg overflow-hidden border-2 border-gray-700 shadow-xl focus:outline-none relative bg-[#0a4d2e]"
		tabindex="0">
		<ReactSolitaireApp client:only="react" />
	</div>
	<p class="text-xs text-gray-400 mt-2 text-center">
		Drag cards to move. Click stock to draw. Double-click a card to send it
		to a foundation. Press <kbd>N</kbd> for a new game · <kbd>Z</kbd> to undo.
	</p>
</div>

<style>
	/* Stage breaks out of Starlight's narrow content column to claim the
	   full splash content width (capped). The 6/5 frame stays centered. */
	.solitaire-stage {
		width: 100%;
		max-width: 1400px;
		margin-inline: auto;
	}
	.solitaire-frame {
		width: 100%;
		aspect-ratio: 6 / 5;
	}
</style>
