---
import ReactSolitaireApp from './ReactSolitaireApp';
---

<div class="not-content solitaire-stage" data-solitaire-stage>
	<div class="solitaire-toolbar">
		<button
			type="button"
			class="solitaire-btn"
			data-solitaire-theater
			aria-pressed="false"
			title="Theater mode — widen the table">
			<span class="solitaire-btn-icon" aria-hidden="true">▭</span>
			<span class="solitaire-btn-label">Theater</span>
		</button>
		<button
			type="button"
			class="solitaire-btn"
			data-solitaire-fullscreen
			aria-pressed="false"
			title="Toggle fullscreen">
			<span class="solitaire-btn-icon" aria-hidden="true">⛶</span>
			<span class="solitaire-btn-label">Fullscreen</span>
		</button>
	</div>
	<div
		class="solitaire-frame rounded-lg overflow-hidden border-2 border-gray-700 shadow-xl focus:outline-none relative bg-[#0a4d2e]"
		tabindex="0">
		<ReactSolitaireApp client:only="react" />
	</div>
	<div
		class="solitaire-rotate-hint rounded-lg border-2 border-gray-700 shadow-xl"
		aria-hidden="true">
		<div class="solitaire-rotate-icon" aria-hidden="true">⟳</div>
		<p class="solitaire-rotate-title">Rotate your phone</p>
		<p class="solitaire-rotate-body">
			This card table is laid out for landscape. Turn your device sideways
			to play.
		</p>
	</div>
	<p class="text-xs text-gray-400 mt-2 text-center">
		Drag cards to move. Tap a card to auto-send it to a foundation
		(double-click on desktop). Tap stock to draw. Press <kbd>N</kbd> for a new
		game · <kbd>Z</kbd> to undo.
	</p>
</div>

<style>
	.solitaire-stage {
		width: 100%;
		margin-inline: auto;
	}
	.solitaire-frame {
		width: 100%;
		/* Matches BASE_WIDTH/BASE_HEIGHT in config.ts (1320×900 with
		   sidebar). Update both together. */
		aspect-ratio: 22 / 15;
		/* Stop the browser from intercepting drag/scroll/zoom while a
		   pointer is interacting with the canvas. */
		touch-action: none;
		-webkit-user-select: none;
		user-select: none;
	}
	.solitaire-rotate-hint {
		display: none;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 12px;
		padding: 32px;
		text-align: center;
		aspect-ratio: 22 / 15;
		background: radial-gradient(circle at 50% 40%, #0f6b3f 0%, #062a18 80%);
		color: #fde68a;
	}
	.solitaire-rotate-icon {
		font-size: 56px;
		line-height: 1;
		animation: solitaire-rotate-spin 2.4s ease-in-out infinite;
	}
	.solitaire-rotate-title {
		font-size: 18px;
		font-weight: 700;
		margin: 0;
	}
	.solitaire-rotate-body {
		font-size: 13px;
		color: #d1d5db;
		max-width: 36ch;
		margin: 0;
	}
	@keyframes solitaire-rotate-spin {
		0% {
			transform: rotate(0deg);
		}
		50% {
			transform: rotate(90deg);
		}
		100% {
			transform: rotate(0deg);
		}
	}
	/* Portrait phone: hide the canvas, show the rotate hint. */
	@media (orientation: portrait) and (max-width: 768px) {
		.solitaire-frame {
			display: none;
		}
		.solitaire-toolbar {
			display: none;
		}
		.solitaire-rotate-hint {
			display: flex;
		}
	}
	.solitaire-toolbar {
		display: flex;
		gap: 8px;
		justify-content: flex-end;
		margin-bottom: 8px;
	}
	.solitaire-btn {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 6px 12px;
		font-size: 12px;
		font-weight: 500;
		color: #e5e7eb;
		background: rgba(15, 23, 42, 0.7);
		border: 1px solid rgba(179, 139, 62, 0.4);
		border-radius: 6px;
		cursor: pointer;
		transition:
			background 120ms ease,
			border-color 120ms ease;
	}
	.solitaire-btn:hover {
		background: rgba(15, 23, 42, 0.9);
		border-color: rgba(179, 139, 62, 0.8);
	}
	.solitaire-btn[aria-pressed='true'] {
		background: rgba(179, 139, 62, 0.25);
		border-color: rgba(251, 191, 36, 0.8);
		color: #fde68a;
	}
	.solitaire-btn-icon {
		font-size: 14px;
		line-height: 1;
	}

	/* Theater mode: pin the stage over the viewport with a dimmed backdrop
	   and scale the frame to fit BOTH dimensions. No window resize needed
	   to play at the largest legible size; toggling theater off restores
	   the inline layout. Esc / button click leaves the mode. */
	.solitaire-stage.is-theater {
		position: fixed;
		inset: 0;
		max-width: none;
		width: 100vw;
		height: 100vh;
		margin: 0;
		padding: 16px;
		z-index: 50;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 8px;
		background: rgba(6, 42, 24, 0.95);
		box-sizing: border-box;
	}
	.solitaire-stage.is-theater .solitaire-toolbar {
		margin-bottom: 0;
	}
	.solitaire-stage.is-theater .solitaire-frame {
		/* Pick the smaller of viewport width or viewport-height-derived
		   width (so the 22:15 aspect ratio always fits without scroll). */
		width: min(100%, calc((100vh - 110px) * 22 / 15));
		max-width: 100%;
		height: auto;
	}

	/* Fullscreen: native browser fullscreen on the stage element. */
	.solitaire-stage:fullscreen {
		width: 100vw;
		height: 100vh;
		max-width: none;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		background: #062a18;
		padding: 16px;
	}
	.solitaire-stage:fullscreen .solitaire-frame {
		width: min(100%, calc((100vh - 120px) * 22 / 15));
		max-width: 100%;
		aspect-ratio: 22 / 15;
	}
</style>

<script>
	const stage = document.querySelector<HTMLElement>('[data-solitaire-stage]');
	const theaterBtn = document.querySelector<HTMLButtonElement>(
		'[data-solitaire-theater]',
	);
	const fsBtn = document.querySelector<HTMLButtonElement>(
		'[data-solitaire-fullscreen]',
	);

	if (stage && theaterBtn) {
		const setTheater = (on: boolean) => {
			stage.classList.toggle('is-theater', on);
			theaterBtn.setAttribute('aria-pressed', String(on));
			window.dispatchEvent(new Event('resize'));
		};
		theaterBtn.addEventListener('click', () => {
			setTheater(!stage.classList.contains('is-theater'));
		});
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && stage.classList.contains('is-theater')) {
				setTheater(false);
			}
		});
	}

	if (stage && fsBtn) {
		const updateFsLabel = () => {
			const active = document.fullscreenElement === stage;
			fsBtn.setAttribute('aria-pressed', String(active));
		};
		fsBtn.addEventListener('click', async () => {
			if (document.fullscreenElement) {
				await document.exitFullscreen();
			} else {
				await stage.requestFullscreen();
			}
		});
		document.addEventListener('fullscreenchange', updateFsLabel);
	}
</script>
