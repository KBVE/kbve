---
import '../styles/global.css';
import Nav from '../components/site/Nav.astro';
import Footer from '../components/site/Footer.astro';

interface Props {
	title?: string;
	description?: string;
	canonical?: string;
	image?: string;
	type?: 'website' | 'article';
	keywords?: string[];
	noindex?: boolean;
	jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const SITE_NAME = 'KBVE';
const DEFAULT_IMAGE = 'https://kbve.com/assets/images/brand/letter_logo.png';

const {
	title = 'KBVE',
	description = 'Open-source games, tools, and cloud infrastructure.',
	canonical,
	image = DEFAULT_IMAGE,
	type = 'website',
	keywords,
	noindex = false,
	jsonLd,
} = Astro.props;

const siteOrigin = Astro.site ?? new URL('https://kbve.com');
const origin = siteOrigin.origin;
const canonicalURL = new URL(
	canonical ?? Astro.url.pathname,
	siteOrigin,
).toString();
const imageURL = new URL(image, siteOrigin).toString();

const baseLd = `{"@context":"https://schema.org","@graph":[{"@type":"Organization","@id":"${origin}/#organization","name":"${SITE_NAME}","url":"${origin}","logo":"${DEFAULT_IMAGE}","sameAs":["https://github.com/kbve/kbve","https://kbve.com/discord/"]},{"@type":"WebSite","@id":"${origin}/#website","name":"${SITE_NAME}","url":"${origin}","publisher":{"@id":"${origin}/#organization"}}]}`;

const pageLd = jsonLd
	? JSON.stringify(
			Array.isArray(jsonLd)
				? jsonLd
				: { '@context': 'https://schema.org', ...jsonLd },
		)
	: null;
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<meta name="description" content={description} />
		{
			keywords && keywords.length > 0 && (
				<meta name="keywords" content={keywords.join(', ')} />
			)
		}
		<link rel="canonical" href={canonicalURL} />
		<meta
			name="robots"
			content={noindex ? 'noindex, nofollow' : 'index, follow'}
		/>

		<meta property="og:type" content={type} />
		<meta property="og:site_name" content={SITE_NAME} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:image" content={imageURL} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageURL} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Lora:ital,wght@0,400;0,500;0,600;1,400&display=swap"
		/>

		<script type="application/ld+json" set:html={baseLd} />
		{pageLd && <script type="application/ld+json" set:html={pageLd} />}

		<slot name="head" />
	</head>
	<body>
		<Nav />
		<main data-site-main>
			<slot />
		</main>
		<Footer />
	</body>
</html>
