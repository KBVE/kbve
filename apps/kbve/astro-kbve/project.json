{
	"name": "astro-kbve",
	"$schema": "../../../node_modules/nx/schemas/project-schema.json",
	"projectType": "application",
	"sourceRoot": "apps/kbve/astro-kbve/src",
	"tags": [],
	"targets": {
		"proto": {
			"executor": "nx:run-commands",
			"inputs": ["{workspaceRoot}/packages/data/proto/kbve/*.proto"],
			"outputs": ["{projectRoot}/src/generated/proto"],
			"options": {
				"command": "buf generate packages/data/proto --template apps/kbve/astro-kbve/buf.gen.yaml",
				"cwd": "{workspaceRoot}"
			},
			"cache": true
		},
		"dev": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "apps/kbve/astro-kbve",
				"commands": [
					"rm -rf .astro node_modules/.vite node_modules/.astro ../../../node_modules/.vite",
					"nx exec -- astro sync",
					"UV_THREADPOOL_SIZE=4 NODE_OPTIONS=\"--max-old-space-size=8192\" nx exec -- astro dev"
				],
				"parallel": false
			}
		},
		"build": {
			"dependsOn": ["proto"],
			"executor": "nx:run-commands",
			"outputs": ["{workspaceRoot}/dist/apps/astro-kbve"],
			"options": {
				"cwd": "apps/kbve/astro-kbve",
				"commands": [
					"UV_THREADPOOL_SIZE=4 NODE_OPTIONS=\"--max-old-space-size=8192\" nx exec -- astro build"
				],
				"parallel": false
			},
			"cache": true
		},
		"build:osrs": {
			"dependsOn": ["proto"],
			"executor": "nx:run-commands",
			"options": {
				"cwd": "apps/kbve/astro-kbve",
				"commands": [
					"node scripts/generate-osrs-items.mjs",
					"nx exec -- astro sync",
					"UV_THREADPOOL_SIZE=4 NODE_OPTIONS=\"--max-old-space-size=8192\" nx exec -- astro build"
				],
				"parallel": false
			}
		},
		"preview": {
			"dependsOn": [
				{
					"target": "build",
					"projects": "self"
				}
			],
			"executor": "nx:run-commands",
			"options": {
				"cwd": "apps/kbve/astro-kbve",
				"commands": ["nx exec -- astro preview"],
				"parallel": false
			}
		},
		"check": {
			"dependsOn": ["proto"],
			"executor": "nx:run-commands",
			"options": {
				"cwd": "apps/kbve/astro-kbve",
				"commands": ["nx exec -- astro check"],
				"parallel": false
			},
			"cache": true
		},
		"test": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "apps/kbve/astro-kbve",
				"command": "vitest run --config vitest.config.ts"
			},
			"cache": true
		},
		"test:unit": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "apps/kbve/astro-kbve",
				"command": "vitest run --config vitest.unit-jsdom.config.ts"
			},
			"cache": true
		},
		"e2e": {
			"executor": "nx:run-commands",
			"dependsOn": ["build"],
			"options": {
				"cwd": "apps/kbve/astro-kbve",
				"commands": [
					"pnpm exec playwright test --config=playwright.config.ts"
				],
				"parallel": false
			},
			"configurations": {
				"ci": {
					"commands": [
						"pnpm exec playwright test --config=playwright.config.ts --reporter=line"
					]
				}
			}
		},
		"sync": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "apps/kbve/astro-kbve",
				"commands": ["nx exec -- astro sync"],
				"parallel": false
			}
		},
		"proto:lint": {
			"executor": "nx:run-commands",
			"options": {
				"command": "buf lint packages/data/proto",
				"cwd": "{workspaceRoot}"
			}
		},
		"proto:clean": {
			"executor": "nx:run-commands",
			"options": {
				"command": "rm -rf apps/kbve/astro-kbve/src/generated/proto && mkdir -p apps/kbve/astro-kbve/src/generated/proto",
				"cwd": "{workspaceRoot}"
			}
		},
		"sync:ci-manifest": {
			"executor": "nx:run-commands",
			"options": {
				"command": "node -e \"const fs=require('fs');const src='dist/apps/astro-kbve/api/ci-registry.json';const dst='.github/ci-dispatch-manifest.json';if(!fs.existsSync(src)){console.error('Build output not found — run astro-kbve:build first');process.exit(1);}const data=JSON.parse(fs.readFileSync(src,'utf8'));const{index,...manifest}=data;fs.writeFileSync(dst,JSON.stringify(manifest,null,'\\t')+'\\n');console.log('Wrote',dst,'—',manifest.summary.total,'tracked items');\"",
				"cwd": "{workspaceRoot}"
			}
		},
		"gen:ci-manifest": {
			"executor": "nx:run-commands",
			"inputs": [
				"{projectRoot}/src/content/docs/project/*.mdx",
				"{projectRoot}/src/data/ci/manifest-builder.ts",
				"{projectRoot}/src/data/ci/project-schema.ts",
				"{projectRoot}/src/data/schema/ICiProjectSchema.ts",
				"{projectRoot}/scripts/gen-ci-manifest.mts",
				"{workspaceRoot}/packages/data/codegen/generated/ci_registry-schema.ts"
			],
			"outputs": ["{workspaceRoot}/.github/ci-dispatch-manifest.json"],
			"options": {
				"cwd": "apps/kbve/astro-kbve",
				"command": "npx tsx scripts/gen-ci-manifest.mts"
			},
			"cache": true
		},
		"gen:ci-manifest:check": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "apps/kbve/astro-kbve",
				"command": "npx tsx scripts/gen-ci-manifest.mts --check"
			}
		},
		"sync:unreal": {
			"executor": "nx:run-commands",
			"options": {
				"command": "node apps/kbve/astro-kbve/scripts/sync-unreal-uplugin.mjs",
				"cwd": "{workspaceRoot}"
			}
		},
		"sync:unreal:check": {
			"executor": "nx:run-commands",
			"options": {
				"command": "node apps/kbve/astro-kbve/scripts/sync-unreal-uplugin.mjs --check",
				"cwd": "{workspaceRoot}"
			}
		},
		"gen:dungeon": {
			"executor": "nx:run-commands",
			"inputs": ["{workspaceRoot}/packages/data/codegen/gen_dungeon.py"],
			"outputs": [
				"{workspaceRoot}/packages/data/codegen/generated/tilemaps/crypt_depths.tilemap.json"
			],
			"options": {
				"command": "python3 packages/data/codegen/gen_dungeon.py",
				"cwd": "{workspaceRoot}"
			},
			"cache": true
		},
		"sync:tilemaps": {
			"executor": "nx:run-commands",
			"inputs": [
				"{workspaceRoot}/packages/data/codegen/gen-tilemaps.mjs",
				"{workspaceRoot}/packages/data/codegen/maps/*.json"
			],
			"outputs": [
				"{workspaceRoot}/apps/cryptothrone/astro-cryptothrone/public/assets/map/cloud_city.tilemap.json",
				"{workspaceRoot}/apps/agones/cryptothrone/server/assets/cloud_city.tilemap.json"
			],
			"options": {
				"command": "node packages/data/codegen/gen-tilemaps.mjs",
				"cwd": "{workspaceRoot}"
			},
			"cache": true
		},
		"sync:tiles": {
			"executor": "nx:run-commands",
			"inputs": [
				"{workspaceRoot}/packages/data/codegen/gen-tile-slices.mjs",
				"{workspaceRoot}/packages/data/codegen/tiles/tiles.manifest.json",
				"{workspaceRoot}/apps/cryptothrone/astro-cryptothrone/public/assets/map/cloud_tileset.png"
			],
			"outputs": [
				"{projectRoot}/public/assets/tiledb",
				"{projectRoot}/src/content/docs/tiledb"
			],
			"options": {
				"command": "node packages/data/codegen/gen-tile-slices.mjs",
				"cwd": "{workspaceRoot}"
			},
			"cache": true
		},
		"sync:tiledb": {
			"executor": "nx:run-commands",
			"inputs": [
				"{workspaceRoot}/packages/data/codegen/gen-tiledb-data.mjs",
				"{projectRoot}/src/content/docs/tiledb/*.mdx"
			],
			"outputs": [
				"{workspaceRoot}/packages/data/codegen/generated/tiledb-data.json"
			],
			"options": {
				"command": "node packages/data/codegen/gen-tiledb-data.mjs",
				"cwd": "{workspaceRoot}"
			},
			"cache": true
		},
		"sync:palettes": {
			"executor": "nx:run-commands",
			"inputs": [
				"{workspaceRoot}/packages/data/codegen/gen-palette-atlas.mjs",
				"{workspaceRoot}/packages/data/codegen/palettes/*.json",
				"{workspaceRoot}/packages/data/codegen/generated/tiledb-data.json",
				"{projectRoot}/public/assets/tiledb"
			],
			"outputs": [
				"{workspaceRoot}/apps/cryptothrone/astro-cryptothrone/public/assets/map/palettes",
				"{workspaceRoot}/apps/cryptothrone/astro-cryptothrone/src/components/game/data/palettes"
			],
			"options": {
				"command": "node packages/data/codegen/gen-palette-atlas.mjs",
				"cwd": "{workspaceRoot}"
			},
			"cache": true
		},
		"sync:mapdb": {
			"executor": "nx:run-commands",
			"inputs": [
				"{projectRoot}/src/content/docs/mapdb/*.mdx",
				"{workspaceRoot}/packages/data/codegen/gen-mapdb-data.mjs",
				"{workspaceRoot}/packages/data/codegen/descriptors/mapdb.binpb"
			],
			"outputs": [
				"{workspaceRoot}/packages/data/codegen/generated/mapdb-data.json",
				"{workspaceRoot}/packages/data/codegen/generated/mapdb-data.binpb",
				"{workspaceRoot}/apps/rareicon/unity-rareicon/Assets/StreamingAssets/mapdb.json",
				"{workspaceRoot}/apps/rareicon/unity-rareicon/Assets/StreamingAssets/mapdb.binpb",
				"{workspaceRoot}/apps/discordsh/discordsh-bot/data/mapdb.json"
			],
			"options": {
				"command": "node packages/data/codegen/gen-mapdb-data.mjs",
				"cwd": "{workspaceRoot}"
			},
			"cache": true
		},
		"sync:mapdb-zod": {
			"executor": "nx:run-commands",
			"dependsOn": ["devops:build"],
			"inputs": [
				"{workspaceRoot}/packages/data/proto/map/mapdb.proto",
				"{workspaceRoot}/packages/data/proto/kbve/common.proto",
				"{workspaceRoot}/packages/data/codegen/mapdb-zod-config.json",
				"{workspaceRoot}/packages/data/codegen/gen-mapdb-zod.mjs"
			],
			"outputs": [
				"{workspaceRoot}/packages/data/codegen/descriptors/mapdb.binpb",
				"{workspaceRoot}/packages/data/codegen/generated/mapdb-schema.ts"
			],
			"options": {
				"commands": [
					"protoc --include_imports --descriptor_set_out=packages/data/codegen/descriptors/mapdb.binpb --proto_path=packages/data/proto map/mapdb.proto",
					"npx tsx packages/data/codegen/gen-mapdb-zod.mjs"
				],
				"parallel": false,
				"cwd": "{workspaceRoot}"
			},
			"cache": true
		},
		"sync:jobboard-taxonomy": {
			"executor": "nx:run-commands",
			"inputs": [
				"{projectRoot}/src/content/docs/project/jobboard.mdx",
				"{workspaceRoot}/packages/data/codegen/gen-jobboard-taxonomy.mjs"
			],
			"outputs": [
				"{workspaceRoot}/packages/data/codegen/generated/jobboard-taxonomy.json",
				"{workspaceRoot}/packages/data/codegen/generated/jobboard-taxonomy-seed.sql",
				"{workspaceRoot}/apps/jobboard/web/src/api/taxonomy.generated.json",
				"{workspaceRoot}/apps/jobboard/docker/seed.sql"
			],
			"options": {
				"command": "node packages/data/codegen/gen-jobboard-taxonomy.mjs",
				"cwd": "{workspaceRoot}"
			},
			"cache": true
		},
		"sync:itemdb": {
			"executor": "nx:run-commands",
			"dependsOn": ["sync:itemdb-uecpp"],
			"inputs": [
				"{projectRoot}/src/content/docs/itemdb/*.mdx",
				"{workspaceRoot}/packages/data/codegen/gen-itemdb-data.mjs",
				"{workspaceRoot}/packages/data/codegen/descriptors/itemdb.binpb"
			],
			"outputs": [
				"{workspaceRoot}/packages/data/codegen/generated/itemdb-data.json",
				"{workspaceRoot}/packages/data/codegen/generated/itemdb-data.binpb",
				"{workspaceRoot}/packages/data/codegen/generated/itemdb.json",
				"{workspaceRoot}/apps/rareicon/unity-rareicon/Assets/StreamingAssets/itemdb.json",
				"{workspaceRoot}/apps/rareicon/unity-rareicon/Assets/StreamingAssets/itemdb.binpb"
			],
			"options": {
				"command": "node packages/data/codegen/gen-itemdb-data.mjs",
				"cwd": "{workspaceRoot}"
			},
			"cache": true
		},
		"sync:itemdb-uecpp": {
			"executor": "nx:run-commands",
			"inputs": [
				"{workspaceRoot}/packages/data/codegen/gen-itemdb-uecpp.mjs",
				"{workspaceRoot}/packages/data/codegen/descriptors/itemdb.binpb"
			],
			"outputs": [
				"{workspaceRoot}/packages/unreal/KBVEItemDB/Source/KBVEItemDB/Public/Generated/KBVEItemDBProtoTypes.h",
				"{workspaceRoot}/packages/unreal/KBVEItemDB/Source/KBVEItemDB/Public/Generated/KBVEItemDBProtoParse.h"
			],
			"options": {
				"command": "node packages/data/codegen/gen-itemdb-uecpp.mjs",
				"cwd": "{workspaceRoot}"
			},
			"cache": true
		},
		"sync:npcdb-uecpp": {
			"executor": "nx:run-commands",
			"inputs": [
				"{workspaceRoot}/packages/data/codegen/gen-npcdb-uecpp.mjs",
				"{workspaceRoot}/packages/data/codegen/descriptors/npcdb.binpb"
			],
			"outputs": [
				"{workspaceRoot}/packages/unreal/KBVENPCDB/Source/KBVENPCDB/Public/Generated/KBVENPCDBProtoTypes.h",
				"{workspaceRoot}/packages/unreal/KBVENPCDB/Source/KBVENPCDB/Public/Generated/KBVENPCDBProtoParse.h"
			],
			"options": {
				"command": "node packages/data/codegen/gen-npcdb-uecpp.mjs",
				"cwd": "{workspaceRoot}"
			},
			"cache": true
		},
		"sync:questdb": {
			"executor": "nx:run-commands",
			"inputs": [
				"{projectRoot}/src/content/docs/questdb/*.mdx",
				"{workspaceRoot}/packages/data/codegen/gen-questdb-data.mjs",
				"{workspaceRoot}/packages/data/codegen/descriptors/questdb.binpb"
			],
			"outputs": [
				"{workspaceRoot}/packages/data/codegen/generated/questdb-data.json",
				"{workspaceRoot}/packages/data/codegen/generated/questdb-data.binpb",
				"{workspaceRoot}/apps/rareicon/unity-rareicon/Assets/StreamingAssets/questdb.json",
				"{workspaceRoot}/apps/rareicon/unity-rareicon/Assets/StreamingAssets/questdb.binpb"
			],
			"options": {
				"command": "node packages/data/codegen/gen-questdb-data.mjs",
				"cwd": "{workspaceRoot}"
			},
			"cache": true
		},
		"sync:questdb-uecpp": {
			"executor": "nx:run-commands",
			"inputs": [
				"{workspaceRoot}/packages/data/codegen/gen-questdb-uecpp.mjs",
				"{workspaceRoot}/packages/data/codegen/descriptors/questdb.binpb"
			],
			"outputs": [
				"{workspaceRoot}/packages/unreal/KBVEQuestDB/Source/KBVEQuestDB/Public/Generated/KBVEQuestDBProtoTypes.h",
				"{workspaceRoot}/packages/unreal/KBVEQuestDB/Source/KBVEQuestDB/Public/Generated/KBVEQuestDBProtoParse.h"
			],
			"options": {
				"command": "node packages/data/codegen/gen-questdb-uecpp.mjs",
				"cwd": "{workspaceRoot}"
			},
			"cache": true
		},
		"sync:npcdb": {
			"executor": "nx:run-commands",
			"inputs": [
				"{projectRoot}/src/content/docs/npcdb/*.mdx",
				"{workspaceRoot}/packages/data/codegen/gen-npcdb-data.mjs",
				"{workspaceRoot}/packages/data/codegen/descriptors/npcdb.binpb"
			],
			"outputs": [
				"{workspaceRoot}/packages/data/codegen/generated/npcdb-data.json",
				"{workspaceRoot}/packages/data/codegen/generated/npcdb-data.binpb",
				"{workspaceRoot}/apps/rareicon/unity-rareicon/Assets/StreamingAssets/npcdb.json",
				"{workspaceRoot}/apps/rareicon/unity-rareicon/Assets/StreamingAssets/npcdb.binpb"
			],
			"options": {
				"command": "node packages/data/codegen/gen-npcdb-data.mjs",
				"cwd": "{workspaceRoot}"
			},
			"cache": true
		},
		"sync:spelldb": {
			"executor": "nx:run-commands",
			"dependsOn": ["sync:spelldb-uecpp"],
			"inputs": [
				"{projectRoot}/src/content/docs/spelldb/*.mdx",
				"{workspaceRoot}/packages/data/codegen/gen-spelldb-data.mjs",
				"{workspaceRoot}/packages/data/codegen/descriptors/spelldb.binpb"
			],
			"outputs": [
				"{workspaceRoot}/packages/data/codegen/generated/spelldb-data.json",
				"{workspaceRoot}/packages/data/codegen/generated/spelldb-data.binpb"
			],
			"options": {
				"command": "node packages/data/codegen/gen-spelldb-data.mjs",
				"cwd": "{workspaceRoot}"
			},
			"cache": true
		},
		"sync:spelldb-uecpp": {
			"executor": "nx:run-commands",
			"inputs": [
				"{workspaceRoot}/packages/data/codegen/gen-spelldb-uecpp.mjs",
				"{workspaceRoot}/packages/data/codegen/descriptors/spelldb.binpb"
			],
			"outputs": [
				"{workspaceRoot}/packages/unreal/KBVESpellDB/Source/KBVESpellDB/Public/Generated/KBVESpellDBProtoTypes.h",
				"{workspaceRoot}/packages/unreal/KBVESpellDB/Source/KBVESpellDB/Public/Generated/KBVESpellDBProtoParse.h"
			],
			"options": {
				"command": "node packages/data/codegen/gen-spelldb-uecpp.mjs",
				"cwd": "{workspaceRoot}"
			},
			"cache": true
		},
		"sync:itemdb-atlas": {
			"executor": "nx:run-commands",
			"inputs": [
				"{projectRoot}/src/content/docs/itemdb/*.mdx",
				"{projectRoot}/public/assets/items/**/*.png",
				"{workspaceRoot}/packages/data/codegen/gen-itemdb-atlas.mjs"
			],
			"outputs": [
				"{workspaceRoot}/apps/rareicon/unity-rareicon/Assets/StreamingAssets/itemdb-atlas.png",
				"{workspaceRoot}/apps/rareicon/unity-rareicon/Assets/_RareIcon/Scripts/ECS/DB/Items/Data/ItemSpriteAtlas.Generated.cs",
				"{workspaceRoot}/apps/cryptothrone/astro-cryptothrone/public/assets/items/itemdb-atlas.png",
				"{workspaceRoot}/apps/cryptothrone/astro-cryptothrone/src/components/game/data/itemAtlas.generated.ts"
			],
			"options": {
				"command": "node packages/data/codegen/gen-itemdb-atlas.mjs",
				"cwd": "{workspaceRoot}"
			},
			"cache": true
		},
		"sync:hextile-atlas": {
			"executor": "nx:run-commands",
			"inputs": [
				"{workspaceRoot}/apps/rareicon/unity-rareicon/Assets/_RareIcon/Textures/Environment/**/*.png",
				"{workspaceRoot}/packages/data/codegen/gen-hextile-atlas.mjs"
			],
			"outputs": [
				"{workspaceRoot}/apps/rareicon/unity-rareicon/Assets/StreamingAssets/hextile-atlas.png",
				"{workspaceRoot}/apps/rareicon/unity-rareicon/Assets/_RareIcon/Scripts/ECS/Hex/HexTileAtlas.Generated.cs"
			],
			"options": {
				"command": "node packages/data/codegen/gen-hextile-atlas.mjs",
				"cwd": "{workspaceRoot}"
			},
			"cache": true
		},
		"solitaire:snapshot-npcdb": {
			"dependsOn": ["build"],
			"executor": "nx:run-commands",
			"inputs": [
				"{workspaceRoot}/dist/apps/astro-kbve/api/npcdb.json",
				"{projectRoot}/scripts/snapshot-solitaire-npcdb.mjs"
			],
			"outputs": [
				"{projectRoot}/standalone/solitaire/npcdb-snapshot.json"
			],
			"options": {
				"command": "node apps/kbve/astro-kbve/scripts/snapshot-solitaire-npcdb.mjs",
				"cwd": "{workspaceRoot}"
			},
			"cache": true
		},
		"solitaire:standalone": {
			"dependsOn": ["solitaire:snapshot-npcdb"],
			"executor": "nx:run-commands",
			"inputs": [
				"{projectRoot}/standalone/solitaire/**/*",
				"{projectRoot}/src/arcade/solitaire/**/*",
				"{workspaceRoot}/packages/npm/laser/src/**/*"
			],
			"outputs": [
				"{workspaceRoot}/apps/kbve/astro-kbve/dist/solitaire-standalone"
			],
			"options": {
				"cwd": "apps/kbve/astro-kbve",
				"commands": [
					"nx exec -- vite build --config standalone/solitaire/vite.config.ts"
				],
				"parallel": false
			},
			"cache": true
		},
		"solitaire:standalone:zip": {
			"dependsOn": ["solitaire:standalone"],
			"executor": "nx:run-commands",
			"inputs": [
				"{workspaceRoot}/apps/kbve/astro-kbve/dist/solitaire-standalone/index.html"
			],
			"outputs": [
				"{workspaceRoot}/apps/kbve/astro-kbve/dist/solitaire-standalone.zip"
			],
			"options": {
				"command": "cd apps/kbve/astro-kbve/dist/solitaire-standalone && zip -r ../solitaire-standalone.zip ./",
				"cwd": "{workspaceRoot}"
			}
		}
	}
}
