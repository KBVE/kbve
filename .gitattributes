apps/rentearth/unreal-rentearth/**/*.png    filter=lfs diff=lfs merge=lfs -text
apps/rentearth/unreal-rentearth/**/*.jpg    filter=lfs diff=lfs merge=lfs -text
apps/rentearth/unreal-rentearth/**/*.jpeg   filter=lfs diff=lfs merge=lfs -text
apps/rentearth/unreal-rentearth/**/*.tga    filter=lfs diff=lfs merge=lfs -text
