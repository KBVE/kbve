# Plugin / native binaries
apps/rentearth/unreal-rentearth/**/Plugins/**/*.dylib filter=lfs diff=lfs merge=lfs -text
apps/rentearth/unreal-rentearth/**/Plugins/**/*.dll   filter=lfs diff=lfs merge=lfs -text
