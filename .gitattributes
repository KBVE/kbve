# Audio
apps/rentearth/unreal-rentearth/**/*.wav    filter=lfs diff=lfs merge=lfs -text
apps/rentearth/unreal-rentearth/**/*.mp3    filter=lfs diff=lfs merge=lfs -text
apps/rentearth/unreal-rentearth/**/*.ogg    filter=lfs diff=lfs merge=lfs -text
