{
	"name": "rn",
	"$schema": "../../../node_modules/nx/schemas/project-schema.json",
	"sourceRoot": "packages/npm/rn/src",
	"projectType": "library",
	"tags": ["scope:mobile", "type:lib"],
	"targets": {
		"lint": {
			"executor": "@nx/eslint:lint"
		},
		"typecheck": {
			"executor": "nx:run-commands",
			"options": {
				"command": "tsc --noEmit -p packages/npm/rn/tsconfig.lib.json"
			}
		},
		"test": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "packages/npm/rn",
				"command": "vitest run"
			}
		}
	}
}
