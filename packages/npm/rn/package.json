{
	"name": "@kbve/rn",
	"version": "0.0.1",
	"description": "React Native shared layer for KBVE mobile apps — agent-control protocol types, hooks, and UI primitives.",
	"keywords": [
		"react-native",
		"expo",
		"kbve",
		"agent"
	],
	"homepage": "https://kbve.com/application/javascript/",
	"bugs": {
		"url": "https://github.com/KBVE/kbve/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/KBVE/kbve.git"
	},
	"author": "KBVE <hello@kbve.com>",
	"license": "MIT",
	"type": "module",
	"main": "./src/index.ts",
	"module": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		}
	},
	"files": [
		"src/",
		"*.md",
		"LICENSE"
	],
	"dependencies": {
		"@hcaptcha/react-hcaptcha": "^2.0.2",
		"@hcaptcha/react-native-hcaptcha": "^4.0.0",
		"@kbve/core": "0.0.1",
		"@react-native-async-storage/async-storage": "2.2.0",
		"@supabase/supabase-js": "^2.95.3",
		"expo-auth-session": "~56.0.14",
		"expo-linking": "~56.0.14",
		"expo-web-browser": "~56.0.5",
		"react-native-url-polyfill": "^3.0.0",
		"react-native-webview": "13.16.1"
	},
	"peerDependencies": {
		"react": ">=18",
		"react-native": ">=0.74"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": false
		},
		"react-native": {
			"optional": false
		}
	},
	"publishConfig": {
		"access": "public"
	}
}
