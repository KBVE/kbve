{
	"name": "@kbve/fx",
	"version": "0.0.1",
	"description": "Portable TypeGPU effect library for KBVE — platform-agnostic WGSL effects, a createEffect authoring helper, and a registry. Consumed by the React Native app (react-native-webgpu) and the web (browser WebGPU); only the canvas host differs.",
	"keywords": [
		"kbve",
		"webgpu",
		"typegpu",
		"wgsl",
		"effects"
	],
	"homepage": "https://kbve.com/application/javascript/",
	"bugs": {
		"url": "https://github.com/KBVE/kbve/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/KBVE/kbve.git"
	},
	"author": "KBVE <hello@kbve.com>",
	"license": "MIT",
	"type": "module",
	"main": "./src/index.ts",
	"module": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		}
	},
	"files": [
		"src/",
		"*.md",
		"LICENSE"
	],
	"dependencies": {
		"typegpu": "0.11.8"
	},
	"devDependencies": {
		"@webgpu/types": "^0.1.60"
	},
	"publishConfig": {
		"access": "public"
	}
}
