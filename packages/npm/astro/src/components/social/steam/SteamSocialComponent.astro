---
interface SteamGame {
	title: string;
	appId: string | number;
	copy: string;
}

interface Props {
	curatorId?: string | number;
	curatorLabel?: string;
	games?: SteamGame[];
	class?: string;
}

const {
	curatorId = '45016681',
	curatorLabel = 'Visit KBVE Steam Curator',
	games = [],
	class: className = '',
} = Astro.props;

const curatorUrl = `https://store.steampowered.com/curator/${curatorId}`;
const urlFor = (appId: SteamGame['appId'], slug: string) =>
	`https://store.steampowered.com/app/${appId}/${slug.replace(/\s+/g, '_')}/`;
---

<div class:list={['mx-auto my-6 grid w-full max-w-5xl gap-5', className]}>
	<a
		class="inline-flex w-fit items-center gap-2 rounded-xl border border-sky-400 bg-[#1b2838] px-5 py-3 font-semibold text-white shadow-lg shadow-sky-500/25 transition-transform duration-150 hover:-translate-y-px focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky-300"
		href={curatorUrl}
		target="_blank"
		rel="noopener noreferrer">
		<span class="text-lg leading-none" aria-hidden="true">▶</span>
		<span>{curatorLabel}</span>
	</a>

	{
		games.length > 0 && (
			<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
				{games.map((g) => (
					<a
						class="group grid gap-2 rounded-xl border border-gray-200 bg-white p-5 text-gray-900 no-underline transition hover:-translate-y-0.5 hover:border-sky-400 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-100"
						href={urlFor(g.appId, g.title)}
						target="_blank"
						rel="noopener noreferrer">
						<span class="text-lg font-semibold">{g.title}</span>
						<span class="text-sm leading-relaxed text-gray-600 dark:text-gray-400">
							{g.copy}
						</span>
						<span class="mt-1 text-sm font-semibold text-sky-500 group-hover:text-sky-400">
							Wishlist on Steam →
						</span>
					</a>
				))}
			</div>
		)
	}
</div>
