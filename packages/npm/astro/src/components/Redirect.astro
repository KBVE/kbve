---
interface Props {
	/** Target URL to redirect to */
	url: string;
	/** Delay in seconds before redirect (default: 0) */
	delay?: number;
	/** Message shown while redirecting */
	message?: string;
	/** Page title during redirect */
	title?: string;
}

const {
	url,
	delay = 0,
	message = 'Redirecting…',
	title = 'Redirecting…',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta http-equiv="refresh" content={`${delay};url=${url}`} />
		<link rel="canonical" href={url} />
		<title>{title}</title>
		<style>
			body {
				margin: 0;
				padding: 0;
				font-family:
					system-ui,
					-apple-system,
					sans-serif;
				display: flex;
				align-items: center;
				justify-content: center;
				min-height: 100vh;
				background: var(--sl-color-bg, #0f172a);
				color: var(--sl-color-text, #e2e8f0);
			}
			.redirect-container {
				text-align: center;
			}
			.redirect-message {
				font-size: 1.125rem;
				margin-bottom: 0.5rem;
			}
			.redirect-link {
				font-size: 0.875rem;
				opacity: 0.7;
			}
			.redirect-link a {
				color: var(--sl-color-accent, #8b5cf6);
			}
		</style>
	</head>
	<body>
		<div class="redirect-container">
			<div class="redirect-message">{message}</div>
			<div class="redirect-link">
				<a href={url}>Click here if not redirected</a>
			</div>
			<slot />
		</div>

		<script define:vars={{ url, delay }}>
			setTimeout(() => {
				window.location.href = url;
			}, delay * 1000);
		</script>
	</body>
</html>
