---
interface Props {
	heading?: string;
	image?: string;
	overlay?: string;
}

const {
	heading,
	image,
	overlay = 'linear-gradient(180deg, rgba(0, 0, 0, 0.55) 50%, rgba(0, 0, 0, 0.15) 100%)',
} = Astro.props;

const bg = image ? `${overlay}, url(${image})` : overlay;
---

<section class="obs__section" data-obs-section>
	<div class="obs__outer">
		<div class="obs__inner">
			<div
				class="obs__bg"
				data-obs-image={image}
				data-obs-overlay={overlay}
				style={`background-image: ${bg};`}>
				{heading && <h2 class="obs__heading">{heading}</h2>}
				<div class="obs__content">
					<slot />
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.obs__section {
		position: absolute;
		inset: 0;
		visibility: hidden;
		pointer-events: none;
		z-index: 0;
		contain: layout paint;
		will-change: transform;
	}

	.obs__section[data-obs-active='true'] {
		pointer-events: auto;
	}

	.obs__outer,
	.obs__inner {
		width: 100%;
		height: 100%;
		overflow-y: hidden;
		will-change: transform;
		transform: translateZ(0);
	}

	.obs__bg {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 1.5rem;
		padding: 2rem;
		background-size: cover;
		background-position: center;
		color: #fff;
		text-align: center;
		will-change: transform;
		transform: translateZ(0);
		backface-visibility: hidden;
	}

	.obs__heading {
		font-size: clamp(1.75rem, 6vw, 6rem);
		font-weight: 600;
		line-height: 1.2;
		margin: 0;
		z-index: 2;
		will-change: transform, opacity;
	}

	.obs__content {
		z-index: 2;
		max-width: 72rem;
		width: 100%;
	}
</style>
