---
interface Props {
	prev?: string;
	next?: string;
	prevLabel?: string;
	nextLabel?: string;
	threshold?: number;
}

const {
	prev,
	next,
	prevLabel = 'Previous',
	nextLabel = 'Next',
	threshold = 220,
} = Astro.props;
---

<div
	class="ring"
	data-ring-root
	data-ring-prev={prev ?? ''}
	data-ring-next={next ?? ''}
	data-ring-threshold={String(threshold)}>
	{
		next && (
			<div class="ring__hint ring__hint--bottom" data-ring-hint="next">
				<span class="ring__label">{nextLabel}</span>
				<span class="ring__bar">
					<span class="ring__bar-fill" data-ring-fill="next" />
				</span>
				<svg
					viewBox="0 0 24 24"
					width="18"
					height="18"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true">
					<polyline points="6 9 12 15 18 9" />
				</svg>
			</div>
		)
	}
	{
		prev && (
			<div class="ring__hint ring__hint--top" data-ring-hint="prev">
				<svg
					viewBox="0 0 24 24"
					width="18"
					height="18"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true">
					<polyline points="18 15 12 9 6 15" />
				</svg>
				<span class="ring__bar">
					<span class="ring__bar-fill" data-ring-fill="prev" />
				</span>
				<span class="ring__label">{prevLabel}</span>
			</div>
		)
	}
</div>

<script>
	import {
		ringNavigate,
		isRingNavLocked,
		consumeRingNavDir,
	} from './_ringNav';

	const init = () => {
		// Disable browser scroll restoration so back-nav lands at our bottom.
		if ('scrollRestoration' in history) {
			history.scrollRestoration = 'manual';
		}

		const arrivalDir = consumeRingNavDir();
		if (arrivalDir === 'back') {
			document.documentElement.dataset.navDir = 'back';
			requestAnimationFrame(() => {
				window.scrollTo({
					top: document.documentElement.scrollHeight,
					behavior: 'instant' as ScrollBehavior,
				});
			});
		} else if (arrivalDir === 'forward') {
			document.documentElement.dataset.navDir = 'forward';
			window.scrollTo({ top: 0, behavior: 'instant' as ScrollBehavior });
		}

		document
			.querySelectorAll<HTMLElement>('[data-ring-root]')
			.forEach((root) => {
				if (root.dataset.ringInit === 'true') return;
				root.dataset.ringInit = 'true';

				const prev = root.dataset.ringPrev || '';
				const next = root.dataset.ringNext || '';
				const threshold = Number(root.dataset.ringThreshold) || 220;

				const fillNext = root.querySelector<HTMLElement>(
					'[data-ring-fill="next"]',
				);
				const fillPrev = root.querySelector<HTMLElement>(
					'[data-ring-fill="prev"]',
				);
				const hintNext = root.querySelector<HTMLElement>(
					'[data-ring-hint="next"]',
				);
				const hintPrev = root.querySelector<HTMLElement>(
					'[data-ring-hint="prev"]',
				);

				let accum = 0;
				let lastDir = 0;
				let lastTouchY: number | null = null;
				let pulseTimer = 0;

				const atTop = () => window.scrollY <= 1;
				const atBottom = () => {
					const doc = document.documentElement;
					return (
						window.scrollY + window.innerHeight >=
						doc.scrollHeight - 1
					);
				};

				const setProgress = (which: 'next' | 'prev', frac: number) => {
					const el = which === 'next' ? fillNext : fillPrev;
					const hint = which === 'next' ? hintNext : hintPrev;
					if (el) el.style.width = `${Math.min(100, frac * 100)}%`;
					if (hint) {
						if (frac > 0.05) hint.dataset.ringActive = 'true';
						else delete hint.dataset.ringActive;
					}
				};

				const reset = () => {
					accum = 0;
					setProgress('next', 0);
					setProgress('prev', 0);
				};

				const tryNav = () => {
					if (accum >= threshold && next && atBottom()) {
						reset();
						ringNavigate(next, 'forward');
					} else if (accum <= -threshold && prev && atTop()) {
						reset();
						ringNavigate(prev, 'back');
					}
				};

				const accumulate = (delta: number) => {
					if (isRingNavLocked()) return;
					const sameDir = Math.sign(delta) === Math.sign(lastDir);
					if (!sameDir && lastDir !== 0) accum = 0;
					lastDir = Math.sign(delta) || lastDir;

					if (delta > 0 && atBottom() && next) {
						accum = Math.max(0, accum) + delta;
						setProgress('next', accum / threshold);
						setProgress('prev', 0);
					} else if (delta < 0 && atTop() && prev) {
						accum = Math.min(0, accum) + delta;
						setProgress('prev', -accum / threshold);
						setProgress('next', 0);
					} else {
						reset();
						return;
					}

					tryNav();

					window.clearTimeout(pulseTimer);
					pulseTimer = window.setTimeout(reset, 800);
				};

				const onWheel = (e: WheelEvent) => {
					accumulate(e.deltaY);
				};

				const onTouchStart = (e: TouchEvent) => {
					lastTouchY = e.touches[0]?.clientY ?? null;
				};
				const onTouchMove = (e: TouchEvent) => {
					if (lastTouchY === null) return;
					const y = e.touches[0]?.clientY;
					if (y === undefined) return;
					const delta = lastTouchY - y;
					lastTouchY = y;
					accumulate(delta);
				};
				const onTouchEnd = () => {
					lastTouchY = null;
					reset();
				};

				const onKey = (e: KeyboardEvent) => {
					if (isRingNavLocked()) return;
					if (e.key === 'PageDown' && atBottom() && next) {
						e.preventDefault();
						ringNavigate(next, 'forward');
					} else if (e.key === 'PageUp' && atTop() && prev) {
						e.preventDefault();
						ringNavigate(prev, 'back');
					}
				};

				window.addEventListener('wheel', onWheel, { passive: true });
				window.addEventListener('touchstart', onTouchStart, {
					passive: true,
				});
				window.addEventListener('touchmove', onTouchMove, {
					passive: true,
				});
				window.addEventListener('touchend', onTouchEnd, {
					passive: true,
				});
				window.addEventListener('keydown', onKey);

				const cleanup = () => {
					window.removeEventListener('wheel', onWheel);
					window.removeEventListener('touchstart', onTouchStart);
					window.removeEventListener('touchmove', onTouchMove);
					window.removeEventListener('touchend', onTouchEnd);
					window.removeEventListener('keydown', onKey);
					window.clearTimeout(pulseTimer);
				};
				window.addEventListener('pagehide', cleanup, { once: true });
			});
	};

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', init, { once: true });
	} else {
		init();
	}
</script>

<style>
	.ring {
		position: fixed;
		inset: 0;
		pointer-events: none;
		z-index: 50;
	}

	.ring__hint {
		position: fixed;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		align-items: center;
		gap: 0.6rem;
		padding: 0.55rem 1rem;
		background: rgba(0, 0, 0, 0.55);
		color: #fff;
		border: 1px solid rgba(255, 255, 255, 0.18);
		border-radius: 9999px;
		backdrop-filter: blur(10px);
		font-size: 0.7rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		opacity: 0;
		transition:
			opacity 220ms ease,
			transform 280ms ease;
		pointer-events: none;
	}

	.ring__hint--bottom {
		bottom: 1.25rem;
		transform: translateX(-50%) translateY(8px);
	}
	.ring__hint--top {
		top: 1.25rem;
		transform: translateX(-50%) translateY(-8px);
	}

	.ring__hint[data-ring-active='true'] {
		opacity: 1;
		transform: translateX(-50%) translateY(0);
	}

	.ring__bar {
		display: inline-block;
		width: 3rem;
		height: 3px;
		background: rgba(255, 255, 255, 0.22);
		border-radius: 9999px;
		overflow: hidden;
	}

	.ring__bar-fill {
		display: block;
		width: 0;
		height: 100%;
		background: var(--sl-color-text-accent, #c9a56a);
		transition: width 80ms ease-out;
	}

	@media (max-width: 640px) {
		.ring__hint {
			font-size: 0.6rem;
			padding: 0.45rem 0.8rem;
		}
		.ring__bar {
			width: 2rem;
		}
	}
</style>
