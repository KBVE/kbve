---
import { parseYouTubeId, buildYouTubeBgEmbed } from './_video';

interface Props {
	duration?: number;
	foreground?: string;
	background?: string;
	backgroundColor?: string;
	video?: string;
	alt?: string;
	heroScale?: number;
	heroDepth?: number;
	heroTranslateY?: number;
	heroBackgroundScale?: number;
	heroPerspective?: string;
}

const {
	duration = 1.25,
	foreground,
	background,
	backgroundColor,
	video,
	alt = '',
	heroScale = 2,
	heroDepth = 350,
	heroTranslateY = 0,
	heroBackgroundScale = 1.1,
	heroPerspective = '500px',
} = Astro.props;

const heroVideoId = video ? parseYouTubeId(video) : null;
const heroEmbedSrc = heroVideoId ? buildYouTubeBgEmbed(heroVideoId) : null;

const heroBgStyle = [
	background && !heroEmbedSrc ? `background-image: url(${background});` : '',
	backgroundColor
		? `background-color: ${backgroundColor};`
		: !background && !heroEmbedSrc
			? 'background-color: var(--sl-color-bg, #121312);'
			: '',
]
	.filter(Boolean)
	.join(' ');
---

<div class="obs not-content" data-obs-root data-obs-duration={String(duration)}>
	{
		foreground && (
			<div
				class="obs__hero"
				data-obs-hero
				data-obs-hero-scale={String(heroScale)}
				data-obs-hero-depth={String(heroDepth)}
				data-obs-hero-translate-y={String(heroTranslateY)}
				data-obs-hero-bg-scale={String(heroBackgroundScale)}
				style={`--obs-hero-perspective: ${heroPerspective};`}>
				<div class="obs__hero-content">
					<section
						class="obs__hero-bg"
						aria-hidden="true"
						style={heroBgStyle}>
						{heroEmbedSrc && (
							<iframe
								class="obs__hero-video"
								src={heroEmbedSrc}
								title="Hero background video"
								loading="lazy"
								allow="autoplay; encrypted-media; picture-in-picture"
								aria-hidden="true"
							/>
						)}
					</section>
				</div>
				<div class="obs__hero-image">
					<img src={foreground} alt={alt} />
				</div>
			</div>
		)
	}
	<div class="obs__pager">
		<slot />
	</div>
	<nav class="obs__nav" aria-label="Section navigation">
		<button
			type="button"
			class="obs__nav-btn"
			data-obs-nav="up"
			aria-label="Previous section">
			<svg
				viewBox="0 0 24 24"
				width="20"
				height="20"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true">
				<polyline points="18 15 12 9 6 15"></polyline>
			</svg>
		</button>
		<button
			type="button"
			class="obs__nav-btn"
			data-obs-nav="down"
			aria-label="Next section">
			<svg
				viewBox="0 0 24 24"
				width="20"
				height="20"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true">
				<polyline points="6 9 12 15 18 9"></polyline>
			</svg>
		</button>
	</nav>
</div>

<script>
	import { gsap } from 'gsap';
	import { Observer } from 'gsap/Observer';
	import { ytPlay, ytPause } from './_video';

	gsap.registerPlugin(Observer);

	const upgradeUnsplashUrl = (url: string): string => {
		if (!url.includes('images.unsplash.com')) return url;
		try {
			const u = new URL(url);
			const target = Math.round(
				window.innerWidth * (window.devicePixelRatio || 1),
			);
			u.searchParams.set('w', String(target));
			if (!u.searchParams.has('auto'))
				u.searchParams.set('auto', 'format');
			if (!u.searchParams.has('fit')) u.searchParams.set('fit', 'crop');
			return u.toString();
		} catch {
			return url;
		}
	};

	const init = () => {
		document
			.querySelectorAll<HTMLElement>('[data-obs-root]')
			.forEach((root) => {
				if (root.dataset.obsInit === 'true') return;
				root.dataset.obsInit = 'true';

				const duration = Number(root.dataset.obsDuration) || 1.25;

				const sections = Array.from(
					root.querySelectorAll<HTMLElement>('.obs__section'),
				);
				const outerWrappers = gsap.utils.toArray<HTMLElement>(
					root.querySelectorAll('.obs__outer'),
				);
				const innerWrappers = gsap.utils.toArray<HTMLElement>(
					root.querySelectorAll('.obs__inner'),
				);
				const images = gsap.utils.toArray<HTMLElement>(
					root.querySelectorAll('.obs__bg'),
				);
				const headings = gsap.utils.toArray<HTMLElement>(
					root.querySelectorAll('.obs__heading'),
				);

				if (sections.length === 0) return;

				const preloaded: HTMLImageElement[] = [];
				images.forEach((bg) => {
					const raw = bg.dataset.obsImage;
					if (!raw) return;
					const resolved = upgradeUnsplashUrl(raw);
					if (resolved !== raw) {
						bg.style.backgroundImage = `url(${resolved})`;
					}
					const preload = new Image();
					preload.decoding = 'async';
					preload.src = resolved;
					if (typeof preload.decode === 'function') {
						preload.decode().catch(() => {});
					}
					preloaded.push(preload);
				});
				(root as any)._obsPreload = preloaded;

				const headingChars: HTMLElement[][] = headings.map(
					(heading) => {
						const text = heading.textContent ?? '';
						heading.textContent = '';
						const chars: HTMLElement[] = [];
						for (const ch of Array.from(text)) {
							const span = document.createElement('span');
							span.textContent = ch === ' ' ? '\u00A0' : ch;
							span.style.display = 'inline-block';
							span.style.willChange = 'transform, opacity';
							heading.appendChild(span);
							chars.push(span);
						}
						return chars;
					},
				);

				gsap.set(outerWrappers, { yPercent: 100 });
				gsap.set(innerWrappers, { yPercent: -100 });
				headingChars.forEach((chars) =>
					gsap.set(chars, { autoAlpha: 0 }),
				);

				let currentIndex = -1;
				let animating = false;
				const wrap = gsap.utils.wrap(0, sections.length);

				const heroEl =
					root.querySelector<HTMLElement>('[data-obs-hero]');
				const heroVideo =
					root.querySelector<HTMLIFrameElement>('.obs__hero-video');
				const sectionVideos: (HTMLIFrameElement | null)[] =
					sections.map((s) =>
						s.querySelector<HTMLIFrameElement>('.obs__bg-video'),
					);
				const hasAnyVideo = !!heroVideo || sectionVideos.some((v) => v);
				let heroActive = !!heroEl;

				const getActiveVideo = (): HTMLIFrameElement | null => {
					if (heroActive && heroVideo) return heroVideo;
					if (!heroActive && currentIndex >= 0)
						return sectionVideos[currentIndex] ?? null;
					return null;
				};

				const syncVideos = () => {
					if (!hasAnyVideo) return;
					const active = getActiveVideo();
					if (heroVideo && heroVideo !== active) ytPause(heroVideo);
					sectionVideos.forEach((v) => {
						if (v && v !== active) ytPause(v);
					});
					if (active && !document.hidden) ytPlay(active);
				};

				const setPagerActive = (active: boolean) => {
					root.dataset.obsPagerActive = String(active);
				};
				setPagerActive(!heroEl);

				const navButtons =
					root.querySelectorAll<HTMLButtonElement>('[data-obs-nav]');
				navButtons.forEach((btn) => {
					btn.addEventListener('click', () => {
						if (animating) return;
						const dir = btn.dataset.obsNav === 'up' ? -1 : 1;
						if (heroActive) {
							if (dir === 1) transitionFromHero();
							return;
						}
						gotoSection(currentIndex + dir, dir);
					});
				});

				const gotoSection = (rawIndex: number, direction: number) => {
					const index = wrap(rawIndex);
					animating = true;
					const dFactor = direction === -1 ? -1 : 1;
					const tl = gsap.timeline({
						defaults: {
							duration,
							ease: 'power1.inOut',
							force3D: true,
						},
						onComplete: () => {
							animating = false;
						},
					});

					if (currentIndex >= 0) {
						gsap.set(sections[currentIndex], { zIndex: 0 });
						sections[currentIndex].removeAttribute(
							'data-obs-active',
						);
						tl.to(images[currentIndex], {
							yPercent: -15 * dFactor,
						}).set(sections[currentIndex], { autoAlpha: 0 });
					}

					gsap.set(sections[index], { autoAlpha: 1, zIndex: 1 });
					sections[index].setAttribute('data-obs-active', 'true');
					tl.fromTo(
						[outerWrappers[index], innerWrappers[index]],
						{
							yPercent: (i: number) =>
								i ? -100 * dFactor : 100 * dFactor,
						},
						{ yPercent: 0 },
						0,
					)
						.fromTo(
							images[index],
							{ yPercent: 15 * dFactor },
							{ yPercent: 0 },
							0,
						)
						.fromTo(
							headingChars[index],
							{
								autoAlpha: 0,
								yPercent: 150 * dFactor,
							},
							{
								autoAlpha: 1,
								yPercent: 0,
								duration: duration * 0.75,
								ease: 'power2',
								stagger: { each: 0.02, from: 'random' },
							},
							0.2,
						);

					currentIndex = index;
					syncVideos();
				};

				const transitionFromHero = () => {
					if (!heroEl || !heroActive) return;
					animating = true;

					const heroImgEl = heroEl.querySelector<HTMLImageElement>(
						'.obs__hero-image img',
					);
					const heroBgEl =
						heroEl.querySelector<HTMLElement>('.obs__hero-bg');
					const hScale = Number(heroEl.dataset.obsHeroScale) || 2;
					const hDepth = Number(heroEl.dataset.obsHeroDepth) || 350;
					const hBgScale =
						Number(heroEl.dataset.obsHeroBgScale) || 1.1;
					const index = 0;

					gsap.set(sections[index], { autoAlpha: 1, zIndex: 1 });
					sections[index].setAttribute('data-obs-active', 'true');

					const tl = gsap.timeline({
						defaults: {
							duration,
							ease: 'power1.inOut',
							force3D: true,
						},
						onComplete: () => {
							animating = false;
							heroActive = false;
							setPagerActive(true);
							if (heroEl) heroEl.style.visibility = 'hidden';
							syncVideos();
						},
					});

					if (heroImgEl) {
						tl.to(
							heroImgEl,
							{
								scale: hScale,
								z: hDepth,
								autoAlpha: 0,
								ease: 'power1.in',
							},
							0,
						);
					}
					if (heroBgEl) {
						tl.to(
							heroBgEl,
							{
								scale: hBgScale,
								autoAlpha: 0,
								ease: 'power1.in',
							},
							0,
						);
					}

					tl.fromTo(
						[outerWrappers[index], innerWrappers[index]],
						{ yPercent: (i: number) => (i ? -100 : 100) },
						{ yPercent: 0 },
						0,
					)
						.fromTo(
							images[index],
							{ yPercent: 15 },
							{ yPercent: 0 },
							0,
						)
						.fromTo(
							headingChars[index],
							{ autoAlpha: 0, yPercent: 150 },
							{
								autoAlpha: 1,
								yPercent: 0,
								duration: duration * 0.75,
								ease: 'power2',
								stagger: { each: 0.02, from: 'random' },
							},
							0.2,
						);

					currentIndex = index;
				};

				if (heroEl) {
					syncVideos();
				} else {
					gotoSection(0, 1);
				}

				if (hasAnyVideo) {
					const watchdog = window.setInterval(() => {
						if (document.hidden) return;
						const active = getActiveVideo();
						if (active) ytPlay(active);
					}, 5000);

					const onVisibility = () => {
						if (document.hidden) {
							if (heroVideo) ytPause(heroVideo);
							sectionVideos.forEach((v) => v && ytPause(v));
						} else {
							syncVideos();
						}
					};
					document.addEventListener('visibilitychange', onVisibility);

					const cleanup = () => {
						clearInterval(watchdog);
						document.removeEventListener(
							'visibilitychange',
							onVisibility,
						);
					};
					document.addEventListener('astro:before-swap', cleanup, {
						once: true,
					});
					window.addEventListener('pagehide', cleanup, {
						once: true,
					});
				}

				Observer.create({
					target: window,
					type: 'wheel,touch,pointer',
					wheelSpeed: -1,
					onDown: () => {
						if (animating) return;
						if (heroActive) return;
						gotoSection(currentIndex - 1, -1);
					},
					onUp: () => {
						if (animating) return;
						if (heroActive) {
							transitionFromHero();
						} else {
							gotoSection(currentIndex + 1, 1);
						}
					},
					tolerance: 10,
					preventDefault: true,
				});
			});
	};

	init();
	document.addEventListener('astro:after-swap', init);
</script>

<style>
	.obs {
		position: relative;
		width: 100%;
		height: 100vh;
		overflow: hidden;
	}

	.obs__pager {
		position: absolute;
		inset: 0;
		overflow: hidden;
		z-index: 1;
	}

	.obs__hero {
		position: absolute;
		inset: 0;
		z-index: 3;
	}

	.obs__hero-content {
		position: relative;
		width: 100%;
		overflow-x: hidden;
		z-index: 1;
	}

	.obs__hero-bg {
		position: relative;
		width: 100%;
		height: 100vh;
		background-position: center center;
		background-repeat: no-repeat;
		background-size: cover;
		overflow: hidden;
		will-change: transform;
		transform: translateZ(0);
	}

	.obs__hero-video {
		position: absolute;
		top: 50%;
		left: 50%;
		width: 120%;
		height: 120%;
		min-width: 120vw;
		min-height: 120vh;
		transform: translate(-50%, -50%);
		border: 0;
		pointer-events: none;
		z-index: 0;
	}

	.obs__hero-image {
		width: 100%;
		height: 100vh;
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		z-index: 2;
		perspective: var(--obs-hero-perspective);
		overflow: hidden;
	}

	.obs__hero-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center center;
		will-change: transform;
	}

	.obs__nav {
		position: fixed;
		top: 50%;
		right: 1.25rem;
		transform: translateY(-50%);
		display: flex;
		flex-direction: column;
		gap: 0.625rem;
		z-index: 40;
		opacity: 0;
		pointer-events: none;
		transition:
			opacity 260ms ease,
			transform 260ms ease;
	}

	.obs[data-obs-pager-active='true'] .obs__nav {
		opacity: 1;
		pointer-events: auto;
	}

	.obs__nav-btn {
		width: 2.75rem;
		height: 2.75rem;
		border-radius: 9999px;
		display: grid;
		place-items: center;
		background: rgba(0, 0, 0, 0.45);
		color: #fff;
		border: 1px solid rgba(255, 255, 255, 0.2);
		backdrop-filter: blur(8px);
		cursor: pointer;
		transition:
			background 180ms ease,
			transform 180ms ease,
			border-color 180ms ease;
	}

	.obs__nav-btn:hover {
		background: rgba(0, 0, 0, 0.7);
		border-color: rgba(255, 255, 255, 0.55);
		transform: scale(1.05);
	}

	.obs__nav-btn:active {
		transform: scale(0.95);
	}

	.obs__nav-btn:focus-visible {
		outline: 2px solid var(--sl-color-text-accent, #c9a56a);
		outline-offset: 2px;
	}
</style>
