---
interface Props {
	duration?: number;
	threshold?: number;
	foreground?: string;
	background?: string;
	backgroundColor?: string;
	alt?: string;
	heroEnd?: string;
	heroScale?: number;
	heroDepth?: number;
	heroTranslateY?: number;
	heroBackgroundScale?: number;
	heroPerspective?: string;
}

const {
	duration = 1.25,
	threshold = 0.85,
	foreground,
	background,
	backgroundColor,
	alt = '',
	heroEnd = '+=150%',
	heroScale = 2,
	heroDepth = 350,
	heroTranslateY = 0,
	heroBackgroundScale = 1.1,
	heroPerspective = '500px',
} = Astro.props;

const heroBgStyle = [
	background ? `background-image: url(${background});` : '',
	backgroundColor
		? `background-color: ${backgroundColor};`
		: !background
			? 'background-color: var(--sl-color-bg, #121312);'
			: '',
]
	.filter(Boolean)
	.join(' ');
---

<div
	class="obs not-content"
	data-obs-root
	data-obs-duration={String(duration)}
	data-obs-threshold={String(threshold)}>
	{
		foreground && (
			<div
				class="obs__hero"
				data-obs-hero
				data-obs-hero-end={heroEnd}
				data-obs-hero-scale={String(heroScale)}
				data-obs-hero-depth={String(heroDepth)}
				data-obs-hero-translate-y={String(heroTranslateY)}
				data-obs-hero-bg-scale={String(heroBackgroundScale)}
				style={`--obs-hero-perspective: ${heroPerspective};`}>
				<div class="obs__hero-content">
					<section
						class="obs__hero-bg"
						aria-hidden="true"
						style={heroBgStyle}
					/>
				</div>
				<div class="obs__hero-image">
					<img src={foreground} alt={alt} />
				</div>
			</div>
		)
	}
	<div class="obs__pager">
		<slot />
	</div>
</div>

<script>
	import { gsap } from 'gsap';
	import { Observer } from 'gsap/Observer';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	gsap.registerPlugin(Observer, ScrollTrigger);

	const upgradeUnsplashUrl = (url: string): string => {
		if (!url.includes('images.unsplash.com')) return url;
		try {
			const u = new URL(url);
			const target = Math.round(
				window.innerWidth * (window.devicePixelRatio || 1),
			);
			u.searchParams.set('w', String(target));
			if (!u.searchParams.has('auto'))
				u.searchParams.set('auto', 'format');
			if (!u.searchParams.has('fit')) u.searchParams.set('fit', 'crop');
			return u.toString();
		} catch {
			return url;
		}
	};

	const init = () => {
		document
			.querySelectorAll<HTMLElement>('[data-obs-root]')
			.forEach((root) => {
				if (root.dataset.obsInit === 'true') return;
				root.dataset.obsInit = 'true';

				const duration = Number(root.dataset.obsDuration) || 1.25;
				const threshold = Number(root.dataset.obsThreshold) || 0.85;

				const sections = Array.from(
					root.querySelectorAll<HTMLElement>('.obs__section'),
				);
				const outerWrappers = gsap.utils.toArray<HTMLElement>(
					root.querySelectorAll('.obs__outer'),
				);
				const innerWrappers = gsap.utils.toArray<HTMLElement>(
					root.querySelectorAll('.obs__inner'),
				);
				const images = gsap.utils.toArray<HTMLElement>(
					root.querySelectorAll('.obs__bg'),
				);
				const headings = gsap.utils.toArray<HTMLElement>(
					root.querySelectorAll('.obs__heading'),
				);

				if (sections.length === 0) return;

				const preloaded: HTMLImageElement[] = [];
				images.forEach((bg) => {
					const raw = bg.dataset.obsImage;
					if (!raw) return;
					const overlay = bg.dataset.obsOverlay || '';
					const resolved = upgradeUnsplashUrl(raw);
					if (resolved !== raw) {
						bg.style.backgroundImage = overlay
							? `${overlay}, url(${resolved})`
							: `url(${resolved})`;
					}
					const preload = new Image();
					preload.decoding = 'async';
					preload.src = resolved;
					if (typeof preload.decode === 'function') {
						preload.decode().catch(() => {});
					}
					preloaded.push(preload);
				});
				(root as any)._obsPreload = preloaded;

				const headingChars: HTMLElement[][] = headings.map(
					(heading) => {
						const text = heading.textContent ?? '';
						heading.textContent = '';
						const chars: HTMLElement[] = [];
						for (const ch of Array.from(text)) {
							const span = document.createElement('span');
							span.textContent = ch === ' ' ? '\u00A0' : ch;
							span.style.display = 'inline-block';
							span.style.willChange = 'transform, opacity';
							heading.appendChild(span);
							chars.push(span);
						}
						return chars;
					},
				);

				gsap.set(outerWrappers, { yPercent: 100 });
				gsap.set(innerWrappers, { yPercent: -100 });
				headingChars.forEach((chars) =>
					gsap.set(chars, { autoAlpha: 0 }),
				);

				let currentIndex = -1;
				let animating = false;
				const wrap = gsap.utils.wrap(0, sections.length);

				const gotoSection = (rawIndex: number, direction: number) => {
					const index = wrap(rawIndex);
					animating = true;
					const dFactor = direction === -1 ? -1 : 1;
					const tl = gsap.timeline({
						defaults: {
							duration,
							ease: 'power1.inOut',
							force3D: true,
						},
						onComplete: () => {
							animating = false;
						},
					});

					if (currentIndex >= 0) {
						gsap.set(sections[currentIndex], { zIndex: 0 });
						sections[currentIndex].removeAttribute(
							'data-obs-active',
						);
						tl.to(images[currentIndex], {
							yPercent: -15 * dFactor,
						}).set(sections[currentIndex], { autoAlpha: 0 });
					}

					gsap.set(sections[index], { autoAlpha: 1, zIndex: 1 });
					sections[index].setAttribute('data-obs-active', 'true');
					tl.fromTo(
						[outerWrappers[index], innerWrappers[index]],
						{
							yPercent: (i: number) =>
								i ? -100 * dFactor : 100 * dFactor,
						},
						{ yPercent: 0 },
						0,
					)
						.fromTo(
							images[index],
							{ yPercent: 15 * dFactor },
							{ yPercent: 0 },
							0,
						)
						.fromTo(
							headingChars[index],
							{
								autoAlpha: 0,
								yPercent: 150 * dFactor,
							},
							{
								autoAlpha: 1,
								yPercent: 0,
								duration: duration * 0.75,
								ease: 'power2',
								stagger: { each: 0.02, from: 'random' },
							},
							0.2,
						);

					currentIndex = index;
				};

				gotoSection(0, 1);

				const observer = Observer.create({
					target: window,
					type: 'wheel,touch,pointer',
					wheelSpeed: -1,
					onDown: () =>
						!animating && gotoSection(currentIndex - 1, -1),
					onUp: () => !animating && gotoSection(currentIndex + 1, 1),
					tolerance: 10,
					preventDefault: true,
				});

				observer.disable();

				const hero = root.querySelector<HTMLElement>('[data-obs-hero]');
				if (hero) {
					const heroImg = hero.querySelector<HTMLElement>(
						'.obs__hero-image img',
					);
					const heroBg =
						hero.querySelector<HTMLElement>('.obs__hero-bg');
					const end = hero.dataset.obsHeroEnd || '+=150%';
					const hScale = Number(hero.dataset.obsHeroScale) || 2;
					const hDepth = Number(hero.dataset.obsHeroDepth) || 350;
					const hTransY = Number(hero.dataset.obsHeroTranslateY) || 0;
					const hBgScale = Number(hero.dataset.obsHeroBgScale) || 1.1;

					if (heroImg && heroBg) {
						const getNavHeight = () => {
							const nav = document.querySelector<HTMLElement>(
								'header.header, header[data-header], .header',
							);
							return nav?.offsetHeight ?? 56;
						};

						gsap.timeline({
							scrollTrigger: {
								trigger: hero,
								start: () => `top top+=${getNavHeight()}`,
								end,
								pin: true,
								pinSpacing: true,
								scrub: true,
								invalidateOnRefresh: true,
								onLeave: () => observer.enable(),
								onEnterBack: () => observer.disable(),
							},
						})
							.to(heroImg, {
								scale: hScale,
								z: hDepth,
								y: hTransY,
								transformOrigin: 'center center',
								ease: 'power1.inOut',
							})
							.to(
								heroBg,
								{
									scale: hBgScale,
									transformOrigin: 'center center',
									ease: 'power1.inOut',
								},
								'<',
							);
					}
				} else {
					const io = new IntersectionObserver(
						(entries) => {
							entries.forEach((entry) => {
								if (entry.isIntersecting) {
									observer.enable();
								} else {
									observer.disable();
								}
							});
						},
						{ threshold },
					);
					io.observe(root);
				}
			});
	};

	init();
	document.addEventListener('astro:after-swap', init);
</script>

<style>
	.obs {
		position: relative;
		width: 100%;
	}

	.obs__pager {
		position: relative;
		width: 100%;
		height: 100vh;
		overflow: hidden;
	}

	.obs__hero {
		position: relative;
		width: 100%;
		z-index: 1;
	}

	.obs__hero-content {
		position: relative;
		width: 100%;
		overflow-x: hidden;
		z-index: 1;
	}

	.obs__hero-bg {
		width: 100%;
		height: 100vh;
		background-position: center center;
		background-repeat: no-repeat;
		background-size: cover;
		will-change: transform;
		transform: translateZ(0);
	}

	.obs__hero-image {
		width: 100%;
		height: 100vh;
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		z-index: 2;
		perspective: var(--obs-hero-perspective);
		overflow: hidden;
	}

	.obs__hero-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center center;
		will-change: transform;
	}
</style>
