---
interface Props {
	title: string;
	description: string;
	href: string;
	accent?: string;
	icon?: 'rocket' | 'puzzle' | 'github' | 'controller' | 'spark' | 'compass';
}

const {
	title,
	description,
	href,
	accent = 'var(--sl-color-text-accent, #c9a56a)',
	icon = 'spark',
} = Astro.props;
---

<a
	class="rsc"
	href={href}
	style={`--rsc-accent: ${accent};`}
	data-astro-prefetch>
	<span class="rsc__glow" aria-hidden="true"></span>
	<span class="rsc__icon" aria-hidden="true">
		{
			icon === 'rocket' && (
				<svg
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round">
					<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z" />
					<path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z" />
					<path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0" />
					<path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5" />
				</svg>
			)
		}
		{
			icon === 'puzzle' && (
				<svg
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round">
					<path d="M19.439 7.85c-.049.322.059.648.289.878l1.568 1.568c.47.47.706 1.087.706 1.704s-.235 1.233-.706 1.704l-1.611 1.611a.98.98 0 0 1-.837.276c-.47-.07-.802-.48-.872-.95-.248-1.65-2.097-2.643-3.572-1.829-1.474.815-1.474 2.954 0 3.769 1.475.814 3.324-.18 3.572-1.829.07-.47.402-.88.872-.95a.98.98 0 0 1 .837.276l1.611 1.611c.47.47.706 1.087.706 1.704s-.235 1.233-.706 1.704l-1.568 1.568c-.23.23-.556.338-.878.289-1.65-.248-2.643-2.097-1.829-3.572.815-1.474 2.954-1.474 3.769 0 .814 1.475-.18 3.324-1.829 3.572z" />
				</svg>
			)
		}
		{
			icon === 'github' && (
				<svg viewBox="0 0 24 24" fill="currentColor">
					<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
				</svg>
			)
		}
		{
			icon === 'controller' && (
				<svg
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round">
					<line x1="6" y1="11" x2="10" y2="11" />
					<line x1="8" y1="9" x2="8" y2="13" />
					<line x1="15" y1="12" x2="15.01" y2="12" />
					<line x1="18" y1="10" x2="18.01" y2="10" />
					<path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.545-.604-6.584-.685-7.258A4 4 0 0 0 17.32 5z" />
				</svg>
			)
		}
		{
			icon === 'compass' && (
				<svg
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round">
					<circle cx="12" cy="12" r="10" />
					<polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76" />
				</svg>
			)
		}
		{
			icon === 'spark' && (
				<svg
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round">
					<path d="M12 2v4" />
					<path d="M12 18v4" />
					<path d="M4.93 4.93l2.83 2.83" />
					<path d="M16.24 16.24l2.83 2.83" />
					<path d="M2 12h4" />
					<path d="M18 12h4" />
					<path d="M4.93 19.07l2.83-2.83" />
					<path d="M16.24 7.76l2.83-2.83" />
					<circle cx="12" cy="12" r="3" />
				</svg>
			)
		}
	</span>
	<span class="rsc__body">
		<span class="rsc__title">{title}</span>
		<span class="rsc__desc">{description}</span>
	</span>
	<span class="rsc__arrow" aria-hidden="true">
		<svg
			viewBox="0 0 24 24"
			width="18"
			height="18"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round">
			<line x1="5" y1="12" x2="19" y2="12"></line>
			<polyline points="12 5 19 12 12 19"></polyline>
		</svg>
	</span>
</a>

<style>
	.rsc {
		--rsc-accent: var(--sl-color-text-accent, #c9a56a);
		position: relative;
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 1rem;
		padding: 1.25rem 1.4rem;
		border-radius: 16px;
		border: 1px solid var(--sl-color-gray-5, #262626);
		background: linear-gradient(
			145deg,
			rgba(255, 255, 255, 0.03) 0%,
			rgba(255, 255, 255, 0.01) 60%,
			color-mix(in oklab, var(--rsc-accent) 12%, transparent) 100%
		);
		color: inherit;
		text-decoration: none;
		overflow: hidden;
		isolation: isolate;
		transition:
			transform 220ms ease,
			border-color 220ms ease,
			box-shadow 240ms ease;
	}

	.rsc:hover,
	.rsc:focus-visible {
		transform: translateY(-3px);
		border-color: color-mix(in oklab, var(--rsc-accent) 60%, transparent);
		box-shadow:
			0 12px 32px rgba(0, 0, 0, 0.45),
			0 0 0 1px color-mix(in oklab, var(--rsc-accent) 35%, transparent);
		outline: none;
	}

	.rsc__glow {
		position: absolute;
		inset: -50%;
		z-index: 0;
		background: radial-gradient(
			circle at 20% 0%,
			color-mix(in oklab, var(--rsc-accent) 30%, transparent) 0%,
			transparent 55%
		);
		opacity: 0;
		transition: opacity 280ms ease;
		pointer-events: none;
	}
	.rsc:hover .rsc__glow,
	.rsc:focus-visible .rsc__glow {
		opacity: 1;
	}

	.rsc__icon {
		position: relative;
		z-index: 1;
		display: grid;
		place-items: center;
		width: 2.75rem;
		height: 2.75rem;
		border-radius: 12px;
		background: color-mix(in oklab, var(--rsc-accent) 15%, transparent);
		color: var(--rsc-accent);
		flex-shrink: 0;
	}
	.rsc__icon svg {
		width: 1.4rem;
		height: 1.4rem;
	}

	.rsc__body {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		min-width: 0;
	}

	.rsc__title {
		font-size: 1rem;
		font-weight: 700;
		color: var(--sl-color-white, #fff);
		letter-spacing: 0.01em;
	}

	.rsc__desc {
		font-size: 0.85rem;
		line-height: 1.4;
		color: var(--sl-color-gray-2, #c2c2c2);
	}

	.rsc__arrow {
		position: relative;
		z-index: 1;
		display: grid;
		place-items: center;
		color: var(--rsc-accent);
		opacity: 0.65;
		transform: translateX(-4px);
		transition:
			transform 220ms ease,
			opacity 220ms ease;
		flex-shrink: 0;
	}
	.rsc:hover .rsc__arrow,
	.rsc:focus-visible .rsc__arrow {
		transform: translateX(0);
		opacity: 1;
	}

	@media (max-width: 480px) {
		.rsc {
			padding: 1rem;
			gap: 0.85rem;
		}
		.rsc__title {
			font-size: 0.95rem;
		}
		.rsc__desc {
			font-size: 0.8rem;
		}
	}
</style>
