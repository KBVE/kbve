{
	"name": "chisel-ubuntu-axum",
	"$schema": "../../../node_modules/nx/schemas/project-schema.json",
	"projectType": "library",
	"sourceRoot": "packages/docker/chisel-ubuntu-axum",
	"targets": {
		"container": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"npx nx run chisel-ubuntu-axum:containerx-runtime",
					"npx nx run chisel-ubuntu-axum:containerx-builder"
				],
				"parallel": false
			},
			"configurations": {
				"local": {},
				"production": {}
			}
		},
		"containerx-runtime": {
			"executor": "@nx-tools/nx-container:build",
			"options": {
				"engine": "docker",
				"context": "packages/docker/chisel-ubuntu-axum",
				"file": "packages/docker/chisel-ubuntu-axum/Dockerfile",
				"target": "runtime",
				"platforms": ["linux/amd64"],
				"load": true,
				"push": false,
				"tags": ["ghcr.io/kbve/chisel-ubuntu-axum:24.04"]
			},
			"configurations": {
				"local": {
					"tags": ["ghcr.io/kbve/chisel-ubuntu-axum:24.04"]
				},
				"production": {
					"tags": [
						"ghcr.io/kbve/chisel-ubuntu-axum:24.04",
						"ghcr.io/kbve/chisel-ubuntu-axum:latest"
					],
					"push": true,
					"metadata": {
						"images": ["ghcr.io/kbve/chisel-ubuntu-axum"]
					},
					"cache-from": [
						"type=registry,ref=ghcr.io/kbve/chisel-ubuntu-axum:buildcache-runtime"
					],
					"cache-to": [
						"type=registry,ref=ghcr.io/kbve/chisel-ubuntu-axum:buildcache-runtime,mode=max"
					]
				}
			}
		},
		"containerx-builder": {
			"executor": "@nx-tools/nx-container:build",
			"options": {
				"engine": "docker",
				"context": "packages/docker/chisel-ubuntu-axum",
				"file": "packages/docker/chisel-ubuntu-axum/Dockerfile",
				"target": "builder",
				"platforms": ["linux/amd64"],
				"load": true,
				"push": false,
				"tags": ["ghcr.io/kbve/chisel-ubuntu-axum:24.04-builder"]
			},
			"configurations": {
				"local": {
					"tags": ["ghcr.io/kbve/chisel-ubuntu-axum:24.04-builder"]
				},
				"production": {
					"tags": [
						"ghcr.io/kbve/chisel-ubuntu-axum:24.04-builder",
						"ghcr.io/kbve/chisel-ubuntu-axum:builder"
					],
					"push": true,
					"metadata": {
						"images": ["ghcr.io/kbve/chisel-ubuntu-axum"]
					},
					"cache-from": [
						"type=registry,ref=ghcr.io/kbve/chisel-ubuntu-axum:buildcache-builder"
					],
					"cache-to": [
						"type=registry,ref=ghcr.io/kbve/chisel-ubuntu-axum:buildcache-builder,mode=max"
					]
				}
			}
		},
		"test": {
			"executor": "nx:run-commands",
			"dependsOn": ["container"],
			"options": {
				"commands": [
					"echo '=== Runtime image tests ==='",
					"docker run --rm ghcr.io/kbve/chisel-ubuntu-axum:24.04 /usr/bin/env true",
					"docker run --rm ghcr.io/kbve/chisel-ubuntu-axum:24.04 ls /usr/lib/x86_64-linux-gnu/libjemalloc.so.2",
					"docker run --rm ghcr.io/kbve/chisel-ubuntu-axum:24.04 ls /usr/lib/x86_64-linux-gnu/libpq.so.5",
					"echo '=== Builder image tests ==='",
					"docker run --rm ghcr.io/kbve/chisel-ubuntu-axum:24.04-builder cargo --version",
					"docker run --rm ghcr.io/kbve/chisel-ubuntu-axum:24.04-builder cargo chef --version",
					"docker run --rm ghcr.io/kbve/chisel-ubuntu-axum:24.04-builder node --version",
					"docker run --rm ghcr.io/kbve/chisel-ubuntu-axum:24.04-builder pnpm --version",
					"docker run --rm ghcr.io/kbve/chisel-ubuntu-axum:24.04-builder protoc --version",
					"docker run --rm ghcr.io/kbve/chisel-ubuntu-axum:24.04-builder pkg-config --libs libpq",
					"echo '=== All chisel base image tests passed ==='",
					"echo 'Runtime: jemalloc + libpq + CA certs OK'",
					"echo 'Builder: rust + cargo-chef + node + pnpm + protobuf OK'"
				],
				"parallel": false
			}
		}
	},
	"tags": ["docker", "base-image", "chisel"]
}
