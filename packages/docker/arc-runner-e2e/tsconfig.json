{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"types": ["node", "vitest/globals"],
		"noUncheckedSideEffectImports": false,
		"ignoreDeprecations": "6.0"
	},
	"include": ["e2e/**/*.ts", "vitest.config.ts"]
}
