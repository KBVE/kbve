{
	"name": "data-sql",
	"$schema": "../../../node_modules/nx/schemas/project-schema.json",
	"projectType": "library",
	"sourceRoot": "packages/data/sql",
	"tags": ["scope:data", "type:sql"],
	"targets": {
		"kilobase-up": {
			"executor": "nx:run-commands",
			"options": {
				"command": "docker compose -f kilobase-docker-compose.yml up -d",
				"cwd": "{projectRoot}/dbmate"
			}
		},
		"kilobase-down": {
			"executor": "nx:run-commands",
			"options": {
				"command": "docker compose -f kilobase-docker-compose.yml down",
				"cwd": "{projectRoot}/dbmate"
			}
		},
		"kilobase-reset": {
			"executor": "nx:run-commands",
			"options": {
				"command": "docker compose -f kilobase-docker-compose.yml down -v && docker compose -f kilobase-docker-compose.yml up -d",
				"cwd": "{projectRoot}/dbmate"
			}
		},
		"migrate-up": {
			"executor": "nx:run-commands",
			"options": {
				"command": "dbmate --no-dump-schema --migrations-dir migrations up",
				"cwd": "{projectRoot}/dbmate"
			}
		},
		"migrate-status": {
			"executor": "nx:run-commands",
			"options": {
				"command": "dbmate --no-dump-schema --migrations-dir migrations status",
				"cwd": "{projectRoot}/dbmate"
			}
		},
		"test-migration": {
			"executor": "nx:run-commands",
			"options": {
				"command": "./test-migration.sh",
				"cwd": "{projectRoot}/dbmate"
			}
		},
		"smoke-kilobase": {
			"executor": "nx:run-commands",
			"options": {
				"command": "./smoke.sh kilobase",
				"cwd": "{projectRoot}/dbmate"
			}
		},
		"smoke-kilobase-keep": {
			"executor": "nx:run-commands",
			"options": {
				"command": "./smoke.sh kilobase --keep",
				"cwd": "{projectRoot}/dbmate"
			}
		},
		"smoke-kilobase-rollback": {
			"executor": "nx:run-commands",
			"options": {
				"command": "./smoke.sh kilobase --rollback",
				"cwd": "{projectRoot}/dbmate"
			}
		},
		"smoke": {
			"executor": "nx:run-commands",
			"options": {
				"command": "./smoke.sh kilobase --rollback",
				"cwd": "{projectRoot}/dbmate"
			}
		},
		"smoke-seed": {
			"executor": "nx:run-commands",
			"options": {
				"command": "./seed-smoke.sh",
				"cwd": "{projectRoot}/dbmate"
			}
		},
		"smoke-seed-keep": {
			"executor": "nx:run-commands",
			"options": {
				"command": "./seed-smoke.sh --keep",
				"cwd": "{projectRoot}/dbmate"
			}
		}
	}
}
