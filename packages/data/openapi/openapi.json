						"type": "string",
						"description": "Certificate type: \"trusted\" (CA-signed, no hash pinning) or \"self-signed\"\n(must use serverCertificateHashes with cert_digest). Empty if WT disabled."
					},
					"server_url": {
						"type": "string",
						"description": "The WebSocket URL the client should connect to."
					},
					"server_wt_url": {
						"type": "string",
						"description": "The WebTransport (HTTPS/QUIC) URL. Empty if WT is not available."
					},
					"token": {
						"type": "string",
						"description": "Base64-encoded ConnectToken (2048 bytes decoded)."
					}
				}
