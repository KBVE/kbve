	"preamble": [
		"export const OSRSHeadTagSchema = z.object({\n\ttag: z.enum(['meta', 'link', 'script', 'style', 'title', 'base', 'noscript', 'template']),\n\tattrs: z.record(z.union([z.string(), z.boolean()])).optional(),\n\tcontent: z.string().optional(),\n});\n\nexport type OSRSHeadTag = z.infer<typeof OSRSHeadTagSchema>;",
		"export const OSRSCombatStyles = [\n\t'stab',\n\t'slash',\n\t'crush',\n\t'magic',\n\t'ranged',\n\t'defensive',\n\t'controlled',\n\t'accurate',\n\t'aggressive',\n\t'rapid',\n\t'longrange',\n] as const;\n\nexport type OSRSCombatStyle = (typeof OSRSCombatStyles)[number];\n\nexport const OSRSCombatStyleSchema = z.enum(OSRSCombatStyles);"
	],

	"postamble": [
		{
			"name": "OSRSDropTableSchema",
			"code": "export const OSRSDropTableSchema = z.union([\n\tz.object({\n\t\tsources: z.array(OSRSDropSourceSchema).optional(),\n\t\tprimary_source: z.string().optional(),\n\t\tbest_drop_rate: z.string().optional(),\n\t}),\n\tz.array(OSRSDropSourceSchema),\n]);\n\nexport type OSRSDropTable = z.infer<typeof OSRSDropTableSchema>;"
		}
	],

	"typeGuards": [
		{
			"name": "hasEquipment",
			"inputType": "OSRSExtended",
			"returnType": "item is OSRSExtended & { equipment: OSRSEquipment }",
			"isTypePredicate": true,
			"body": "return item.equipment !== undefined;"
		},
		{
			"name": "isWeapon",
			"inputType": "OSRSExtended",
			"returnType": "boolean",
			"isTypePredicate": false,
			"body": "return item.equipment?.slot === 'weapon' || item.equipment?.slot === '2h';"
		},
		{
			"name": "hasSpecialAttack",
			"inputType": "OSRSExtended",
			"returnType": "item is OSRSExtended & { special_attack: OSRSSpecialAttack }",
			"isTypePredicate": true,
			"body": "return item.special_attack !== undefined;"
		},
		{
			"name": "hasSetBonus",
			"inputType": "OSRSExtended",
			"returnType": "item is OSRSExtended & { set_bonus: OSRSSetBonus }",
			"isTypePredicate": true,
			"body": "return item.set_bonus !== undefined;"
		},
		{
			"name": "isPotion",
			"inputType": "OSRSExtended",
			"returnType": "item is OSRSExtended & { potion: OSRSPotion }",
			"isTypePredicate": true,
			"body": "return item.potion !== undefined;"
		},
		{
			"name": "isFood",
			"inputType": "OSRSExtended",
			"returnType": "item is OSRSExtended & { food: OSRSFood }",
			"isTypePredicate": true,
			"body": "return item.food !== undefined;"
		},
		{
			"name": "hasCooking",
			"inputType": "OSRSExtended",
			"returnType": "item is OSRSExtended & { cooking: OSRSCooking }",
			"isTypePredicate": true,
			"body": "return item.cooking !== undefined;"
		},
		{
			"name": "hasDropSources",
			"inputType": "OSRSExtended",
			"returnType": "item is OSRSExtended & { drop_table: OSRSDropTable }",
			"isTypePredicate": true,
			"body": "if (item.drop_table === undefined) return false;\nif (Array.isArray(item.drop_table)) {\n\treturn item.drop_table.length > 0;\n}\nreturn (item.drop_table.sources?.length ?? 0) > 0;"
		},
		{
			"name": "hasShopSources",
			"inputType": "OSRSExtended",
			"returnType": "boolean",
			"isTypePredicate": false,
			"body": "return (item.shops?.length ?? 0) > 0;"
		},
		{
			"name": "hasRecipes",
			"inputType": "OSRSExtended",
			"returnType": "boolean",
			"isTypePredicate": false,
			"body": "return (item.recipes?.length ?? 0) > 0;"
		},
		{
			"name": "isTreasureTrailItem",
			"inputType": "OSRSExtended",
			"returnType": "item is OSRSExtended & { treasure_trail: OSRSTreasureTrail }",
			"isTypePredicate": true,
			"body": "return item.treasure_trail !== undefined;"
		},
		{
			"name": "hasMeta",
			"inputType": "OSRSExtended",
			"returnType": "item is OSRSExtended & { meta: OSRSMeta }",
			"isTypePredicate": true,
			"body": "return item.meta !== undefined;"
		},
		{
			"name": "hasProperties",
			"inputType": "OSRSExtended",
			"returnType": "item is OSRSExtended & { properties: OSRSItemProperties }",
			"isTypePredicate": true,
			"body": "return item.properties !== undefined;"
		},
		{
			"name": "isTradeable",
			"inputType": "OSRSExtended",
			"returnType": "boolean",
			"isTypePredicate": false,
			"body": "return (\n\titem.properties?.tradeable === true ||\n\titem.properties?.tradeable_ge === true\n);"
		},
		{
			"name": "isQuestItem",
			"inputType": "OSRSExtended",
			"returnType": "boolean",
			"isTypePredicate": false,
			"body": "return item.properties?.quest_item === true;"
		},
		{
			"name": "hasRelatedItems",
			"inputType": "OSRSExtended",
			"returnType": "boolean",
			"isTypePredicate": false,
			"body": "return (item.related_items?.length ?? 0) > 0;"
		}
	],

	"helpers": [
		{
			"name": "generateMetaDescription",
			"code": "export function generateMetaDescription(item: OSRSExtended): string {\n\tconst parts: string[] = [item.name];\n\n\tif (item.members) {\n\t\tparts.push('(P2P)');\n\t}\n\n\tif (hasEquipment(item) && item.equipment.slot) {\n\t\tparts.push(`- ${item.equipment.slot} slot equipment`);\n\t} else if (isPotion(item)) {\n\t\tparts.push('- potion');\n\t} else if (isFood(item)) {\n\t\tparts.push(`- heals ${item.food.heals ?? '?'} HP`);\n\t}\n\n\tparts.push(`in Old School RuneScape. ${item.examine}`);\n\n\tconst description = parts.join(' ');\n\treturn description.length > 160\n\t\t? description.substring(0, 157) + '...'\n\t\t: description;\n}"
		}
	]
}
