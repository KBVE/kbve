		"kbve.osrs.OSRSEquipment.weapon_type": "z.string().nullable().optional()",
		"kbve.osrs.OSRSDropSource.rarity": "z.string().nullable().optional()",
		"kbve.osrs.OSRSShopSource.shop_name": "z.string()",
		"kbve.osrs.OSRSShopSource.price": "z.union([z.number(), z.string()]).optional()",
		"kbve.osrs.OSRSShopSource.stock": "z.union([z.number(), z.string()]).optional()",
		"kbve.osrs.OSRSSkillingSource.skill": "z.string().transform((s) => s.toLowerCase())",
		"kbve.osrs.OSRSSkillingSource.level": "z.number().min(1).max(99)",
		"kbve.osrs.OSRSTreasureTrail.tier": "z.enum(['beginner', 'easy', 'medium', 'hard', 'elite', 'master'])",
		"kbve.osrs.OSRSTreasureTrail.reward_tiers": "z.array(z.enum(['beginner', 'easy', 'medium', 'hard', 'elite', 'master'])).optional()",
		"kbve.osrs.OSRSRelatedItem.relationship": "z.enum(['variant', 'upgrade', 'downgrade', 'component', 'product', 'set_piece', 'alternative']).optional()",
		"kbve.osrs.OSRSRecipeMaterial.quantity": "z.number().default(1)",
		"kbve.osrs.OSRSRecipeMaterial.consumed": "z.boolean().default(true)",
		"kbve.osrs.OSRSCookingBurnRate.level": "z.number().nullable().optional()",
		"kbve.osrs.OSRSEffect.stat": "z.string().transform((s) => s.toLowerCase()).nullable().optional()",
		"kbve.osrs.OSRSConsumable.heals": "z.number().nullable().optional()",
		"kbve.osrs.OSRSConsumable.doses": "z.number().min(0).max(4).nullable().optional()",
