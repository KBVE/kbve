{
	"name": "uniti",
	"$schema": "../../../../node_modules/nx/schemas/project-schema.json",
	"projectType": "library",
	"sourceRoot": "packages/rust/bevy/uniti/src",
	"tags": ["ffi", "cdylib"],
	"targets": {
		"build": {
			"executor": "nx:run-commands",
			"options": {
				"commands": ["cargo build -p uniti --release"],
				"cwd": "packages/rust/bevy/uniti"
			}
		},
		"build:macos": {
			"executor": "nx:run-commands",
			"options": {
				"parallel": false,
				"commands": [
					"cargo build -p uniti --release",
					"mkdir -p ../../../../apps/rareicon/unity-rareicon/Assets/Plugins/macOS",
					"cp ../../../../dist/target/release/libuniti.dylib ../../../../apps/rareicon/unity-rareicon/Assets/Plugins/macOS/libuniti.dylib",
					"xattr -cr ../../../../apps/rareicon/unity-rareicon/Assets/Plugins/macOS/libuniti.dylib",
					"codesign --force --deep --sign - ../../../../apps/rareicon/unity-rareicon/Assets/Plugins/macOS/libuniti.dylib"
				],
				"cwd": "packages/rust/bevy/uniti"
			}
		},
		"build:windows": {
			"executor": "nx:run-commands",
			"options": {
				"parallel": false,
				"commands": [
					"cargo xwin build -p uniti --release --target x86_64-pc-windows-msvc",
					"mkdir -p ../../../../apps/rareicon/unity-rareicon/Assets/Plugins/Windows/x86_64",
					"cp ../../../../dist/target/x86_64-pc-windows-msvc/release/uniti.dll ../../../../apps/rareicon/unity-rareicon/Assets/Plugins/Windows/x86_64/uniti.dll"
				],
				"cwd": "packages/rust/bevy/uniti"
			}
		},
		"build:linux": {
			"executor": "nx:run-commands",
			"options": {
				"parallel": false,
				"commands": [
					"cross build -p uniti --release --target x86_64-unknown-linux-gnu",
					"mkdir -p ../../../../apps/rareicon/unity-rareicon/Assets/Plugins/Linux/x86_64",
					"cp ../../../../dist/target/x86_64-unknown-linux-gnu/release/libuniti.so ../../../../apps/rareicon/unity-rareicon/Assets/Plugins/Linux/x86_64/libuniti.so"
				],
				"cwd": "packages/rust/bevy/uniti"
			}
		},
		"build:ios": {
			"executor": "nx:run-commands",
			"options": {
				"parallel": false,
				"commands": [
					"rustup target add aarch64-apple-ios aarch64-apple-ios-sim",
					"cargo build -p uniti --release --target aarch64-apple-ios",
					"cargo build -p uniti --release --target aarch64-apple-ios-sim",
					"rm -rf ../../../../apps/rareicon/unity-rareicon/Assets/Plugins/iOS/uniti.xcframework",
					"mkdir -p ../../../../apps/rareicon/unity-rareicon/Assets/Plugins/iOS",
					"xcodebuild -create-xcframework -library ../../../../dist/target/aarch64-apple-ios/release/libuniti.a -library ../../../../dist/target/aarch64-apple-ios-sim/release/libuniti.a -output ../../../../apps/rareicon/unity-rareicon/Assets/Plugins/iOS/uniti.xcframework"
				],
				"cwd": "packages/rust/bevy/uniti"
			}
		},
		"build:android": {
			"executor": "nx:run-commands",
			"options": {
				"parallel": false,
				"commands": [
					"rustup target add aarch64-linux-android armv7-linux-androideabi i686-linux-android x86_64-linux-android",
					"cargo ndk --version > /dev/null 2>&1 || cargo install cargo-ndk --locked",
					"cargo ndk -t arm64-v8a -t armeabi-v7a -t x86 -t x86_64 -o ../../../../apps/rareicon/unity-rareicon/Assets/Plugins/Android/libs build -p uniti --release"
				],
				"cwd": "packages/rust/bevy/uniti"
			}
		},
		"build:all": {
			"executor": "nx:run-commands",
			"dependsOn": ["verify"],
			"options": {
				"parallel": false,
				"commands": [
					"npx nx run uniti:build:macos",
					"npx nx run uniti:build:windows",
					"npx nx run uniti:build:linux",
					"npx nx run uniti:build:ios",
					"npx nx run uniti:build:android"
				]
			}
		},
		"verify": {
			"executor": "nx:run-commands",
			"options": {
				"parallel": false,
				"commands": [
					"cargo fmt -p uniti -- --check",
					"cargo clippy -p uniti --all-targets -- -D warnings",
					"cargo test -p uniti --no-fail-fast"
				],
				"cwd": "packages/rust/bevy/uniti"
			}
		},
		"bench": {
			"executor": "nx:run-commands",
			"options": {
				"commands": ["cargo bench -p uniti"],
				"cwd": "packages/rust/bevy/uniti"
			}
		},
		"build:desktop": {
			"executor": "nx:run-commands",
			"options": {
				"parallel": false,
				"commands": [
					"npx nx run uniti:build:macos",
					"npx nx run uniti:build:windows",
					"npx nx run uniti:build:linux"
				]
			}
		},
		"build:mobile": {
			"executor": "nx:run-commands",
			"options": {
				"parallel": false,
				"commands": [
					"npx nx run uniti:build:ios",
					"npx nx run uniti:build:android"
				]
			}
		},
		"test": {
			"executor": "nx:run-commands",
			"options": {
				"commands": ["cargo test -p uniti"],
				"cwd": "packages/rust/bevy/uniti"
			}
		},
		"lint": {
			"executor": "nx:run-commands",
			"options": {
				"commands": ["cargo clippy -p uniti -- -D warnings"],
				"cwd": "packages/rust/bevy/uniti"
			}
		}
	}
}
