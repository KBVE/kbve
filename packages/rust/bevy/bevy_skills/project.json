{
	"name": "bevy_skills",
	"$schema": "../../../../node_modules/nx/schemas/project-schema.json",
	"projectType": "library",
	"sourceRoot": "packages/rust/bevy/bevy_skills/src",
	"tags": [],
	"targets": {
		"build": {
			"executor": "nx:run-commands",
			"options": {
				"commands": ["cargo build -p bevy_skills"],
				"cwd": "packages/rust/bevy/bevy_skills"
			}
		},
		"test": {
			"executor": "nx:run-commands",
			"options": {
				"commands": ["cargo test -p bevy_skills"],
				"cwd": "packages/rust/bevy/bevy_skills"
			}
		},
		"lint": {
			"executor": "nx:run-commands",
			"options": {
				"commands": ["cargo clippy -p bevy_skills -- -D warnings"],
				"cwd": "packages/rust/bevy/bevy_skills"
			}
		},
		"check-wasm": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"cargo +nightly check -p bevy_skills --target wasm32-unknown-unknown"
				],
				"cwd": "packages/rust/bevy/bevy_skills"
			}
		},
		"check-desktop": {
			"executor": "nx:run-commands",
			"options": {
				"commands": ["cargo check -p bevy_skills"],
				"cwd": "packages/rust/bevy/bevy_skills"
			}
		},
		"e2e": {
			"executor": "nx:run-commands",
			"options": {
				"parallel": false,
				"commands": [
					"nx run bevy_skills:test",
					"nx run bevy_skills:check-wasm",
					"nx run bevy_skills:check-desktop"
				]
			}
		},
		"dry": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"cargo publish -p bevy_skills --dry-run --allow-dirty"
				],
				"parallel": false
			}
		}
	}
}
