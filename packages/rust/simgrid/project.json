{
	"name": "simgrid",
	"$schema": "../../../node_modules/nx/schemas/project-schema.json",
	"projectType": "library",
	"sourceRoot": "packages/rust/simgrid/src",
	"tags": ["rust", "bevy", "game-server"],
	"targets": {
		"build": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cargo build -p simgrid"
			},
			"outputs": ["{workspaceRoot}/dist/target/debug/libsimgrid.rlib"]
		},
		"test": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cargo test -p simgrid"
			}
		},
		"lint": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cargo clippy -p simgrid --all-targets -- -D warnings"
			}
		}
	}
}
