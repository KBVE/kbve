	"lint-staged": {
		"*.{ts,tsx,js,jsx}": [
			"eslint --fix --no-error-on-unmatched-pattern",
			"prettier --write"
		],
		"*.astro": [
			"prettier --write --plugin=prettier-plugin-astro"
		],
		"*.{json,md,yml,yaml,css,scss}": [
			"prettier --write"
		],
		"*.rs": [
			"rustfmt"
		],
		"*.py": [
			"autopep8 --in-place",
			"flake8 --max-line-length 120"
		],
		"apps/kbve/edge/functions/**/*.ts": [
			"./scripts/deno-fmt.sh"
		]
	},
