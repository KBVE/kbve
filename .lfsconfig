; Git LFS endpoint override.
;
; The kbve monorepo lives on GitHub; large binary assets are stored on
; the self-hosted Forgejo instance at forgejo.kbve.com. Each game's
; binaries live in their own LFS-only repo under the KBVE org:
;   KBVE/chuck      → Unreal artifact repo
;   KBVE/rareicon   → Unity artifact repo (configured below)
;
; Pointer files land in this repo (small text); blobs land on Forgejo.
; Devs touching apps/rareicon/**/Plugins/** need Forgejo credentials
; cached in their git credential helper. Devs working elsewhere in the
; monorepo never invoke the LFS smudge filter and can ignore Forgejo
; entirely (clone with GIT_LFS_SKIP_SMUDGE=1 to skip the auth round-trip
; if `git lfs` isn't installed locally).
[lfs]
    url = https://forgejo.kbve.com/KBVE/rareicon.git/info/lfs
